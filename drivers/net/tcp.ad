# drivers/net/tcp.ad
#
# Minimal TCP/IPv4 stack — both active-open (client) and passive-open
# (server). Implements just enough of RFC 793 / 9293 to complete a
# three-way handshake either direction, exchange a few segments, and
# tear down cleanly via FIN. With LISTEN/SYN_RCVD wired (M16.124) an
# in-kernel sshd-shaped server can accept inbound connections; the
# active-open path remains the one apt/HTTP rides on.
#
# Active-open state machine (client):
#
#   CLOSED --tcp_connect()--> SYN_SENT
#       --recv SYN-ACK / send ACK--> ESTABLISHED
#       --tcp_send()/tcp_recv() while data flows--
#       --tcp_close() / send FIN--> FIN_WAIT_1
#       --recv ACK--> FIN_WAIT_2
#       --recv FIN / send ACK--> TIME_WAIT --(skip 2*MSL)--> CLOSED
#
# Passive-open state machine (server, M16.124):
#
#   CLOSED --tcp_listen()--> LISTEN
#       --recv SYN / alloc new TCB + send SYN-ACK--> SYN_RCVD (new slot)
#       --recv ACK--> ESTABLISHED (new slot)
#       --tcp_accept() returns the ESTABLISHED slot--
#   LISTEN slot stays in LISTEN — keeps accepting further SYNs until
#   tcp_close()'d.
#
# Connection table: static 8-entry TCB array. With a single listener
# slot allocated, the remaining 7 slots are available for accepted
# connections — the practical cap until per-listener accept queues land.
# Active-open ephemeral source ports ROTATE over the IANA dynamic
# range 49152..65535 via a monotonic counter (_tcp_ephemeral_next) —
# every tcp_connect gets the next port, wrapping at the top. This is
# the standard TCP behavior and the fix for the back-to-back-connect
# wedge: when consecutive short-lived connections reuse the same low
# slot, a fixed slot-derived source port would present an IDENTICAL
# 4-tuple to the peer (and to SLIRP) before the previous connection
# fully drained — SLIRP / strict TCP treat that as a duplicate and
# wedge the 3rd/4th rapid handshake. Rotating the source port gives
# each connection a distinct 4-tuple, which also sidesteps any
# TIME_WAIT-style "just-closed 4-tuple can't be reused yet" concern
# — exactly why real stacks rotate. Passive-open still uses the
# listener's bound port for the local port across all accepted slots.
# M16.109 added per-segment retransmission (RFC 6298 RTO + exponential
# backoff, capped at 5 retries). Still no congestion control beyond
# cwnd=1 segment, no SACK, no timestamps, no window scaling.
#
# Checksum uses the IPv4 pseudo-header (src_ip, dst_ip, 0, proto=6,
# tcp_length) prepended to the TCP header + payload — same 1's
# complement algorithm as UDP/ICMP (ip_csum16 in ip.ad), just fed a
# concatenation. We build the pseudo-header into a tiny scratch
# buffer right before the segment in tcp_tx_buf so a single
# ip_csum16 call covers both.
#
# State of `rcv_nxt`: we track "next expected sequence number from
# the peer" so the ACK we send back ack's everything received so
# far. We DO NOT buffer out-of-order segments — SLIRP delivers in
# order, and if a real peer ever reorders we just drop the OoO
# segment. That's a correctness regression for the real internet
# but fine for the SLIRP-bounded smoke test.

from kernel.printk.printk import printk0, printk1, printk2
from drivers.net.ip import ip_send, ip_csum16, IPPROTO_TCP, ip_our_ip_b, ip_have_our_ip
from drivers.net.virtio_net import virtio_net_poll
from drivers.net.eth import eth_tx, eth_get_mac
from drivers.net.arp import arp_lookup
from arch.x86.kernel.time import get_jiffies, pit_monotonic_us
# kernel_cond_resched: the wedge-class fix. Every `while get_jiffies()
# < deadline:` loop in this file runs from userland-syscall context with
# EFLAGS.IF cleared (IA32_FMASK = 0x0200); without an IRQ-window inside
# the loop body, the LAPIC timer never fires, `jiffies` stays frozen,
# and the deadline never elapses. kernel_cond_resched briefly enables
# interrupts (sti + hlt + cli) so the LAPIC timer can tick and any
# STATE_READY peer can be scheduled in. See kernel/sched/core.ad for the
# full rationale.
from kernel.sched.core import kernel_cond_resched
# Event-driven rx wait: a reader blocked on a slot's rx ring sleeps on
# that slot's WaitQueue and is woken DIRECTLY by the virtio-net rx IRQ
# (which drains the ring into the slot and calls wq_wake_all). The
# bounded-timeout commit is the TCG safety net: if MSI-X rx IRQs are not
# delivered (emulation), the sleep still wakes itself ~every tick to
# re-pump virtio_net_poll() and re-check, degrading to today's poll with
# no wedge. See kernel/sched/core.ad for the WaitQueue contract.
from kernel.sched.core import WaitQueue, wq_init, wq_wake_all
from kernel.sched.core import wq_wait_prepare, wq_wait_cancel
from kernel.sched.core import wq_wait_commit_timeout, WQ_EINTR, WQ_TIMEOUT


# TCP control-block states (RFC 793). Numbered to match the order
# stock Linux uses in include/net/tcp_states.h so a future debugger
# can share the enum.
TCP_CLOSED:      uint32 = 0
TCP_LISTEN:      uint32 = 1
TCP_SYN_SENT:    uint32 = 2
TCP_SYN_RECV:    uint32 = 3
TCP_ESTABLISHED: uint32 = 4
TCP_FIN_WAIT_1:  uint32 = 5
TCP_FIN_WAIT_2:  uint32 = 6
TCP_CLOSE_WAIT:  uint32 = 7
TCP_CLOSING:     uint32 = 8
TCP_LAST_ACK:    uint32 = 9
TCP_TIME_WAIT:   uint32 = 10

# tcp_connect() failure codes. Pre-U-socket this function returned a
# flat -1 for every failure; the userland connect(2) bridge in
# linux_abi/u_syscalls.ad needs to distinguish the cases so it can
# hand back a faithful errno (-ECONNREFUSED vs -ETIMEDOUT vs
# -ENETUNREACH). All four are negative, so existing in-kernel callers
# that only test `slot < 0` (http.ad / tls.ad / init/main.ad smokes)
# are unaffected.
TCP_ERR_NOSLOT:  int32 = -1    # connection table full / SYN send failed
TCP_ERR_ARP:     int32 = -2    # on-link ARP never resolved (net unreachable)
TCP_ERR_REFUSED: int32 = -3    # peer sent RST in response to our SYN
TCP_ERR_TIMEOUT: int32 = -4    # SYN-ACK never arrived before the deadline


# Flag bits in TcpHdr.flags (low byte of the data_off/flags word).
TCP_FIN: uint8 = 0x01
TCP_SYN: uint8 = 0x02
TCP_RST: uint8 = 0x04
TCP_PSH: uint8 = 0x08
TCP_ACK: uint8 = 0x10
TCP_URG: uint8 = 0x20


# 20-byte fixed TCP header (no options). data_off packs the header
# length in 32-bit words (high 4 bits) and 4 reserved bits.
class TcpHdr:
    src:      uint16    # 0:  source port      (big-endian on wire)
    dst:      uint16    # 2:  dest port        (big-endian on wire)
    seq:      uint32    # 4:  sequence number
    ack:      uint32    # 8:  ack number
    data_off: uint8     # 12: header length<<4 | reserved
    flags:    uint8     # 13: TCP_FIN .. TCP_URG
    window:   uint16    # 14: receive window
    checksum: uint16    # 16
    urg_ptr:  uint16    # 18


# Sizes / limits.
TCP_HDR_LEN:        uint64 = 20
TCP_MSS:            uint64 = 536       # conservative default per RFC 879
# Per-slot inbound ring capacity. V5.3 (M16.x): bumped from 1500 →
# 16384 so multiple back-to-back inbound segments (TLS handshake
# bursts that fragment a server's Certificate flight across two or
# three TCP segments are the load-bearing case) can accumulate in
# the same poll cycle without the second segment clobbering the
# first. 16384 is also the TLS 1.3 record max plaintext, so a
# single record always fits even if it shards across N TCP
# segments. See `tcp_slot_rx_head` / `tcp_slot_rx_tail` below.
TCP_RX_BUF:         uint64 = 262144    # 256 KiB circular RX ring / slot
TCP_TX_BUF:         uint64 = 1500
TCP_PSEUDO_LEN:     uint64 = 12        # src4 + dst4 + zero + proto + length(2)

# Receive window we advertise BEFORE a slot has a live ring (SYN /
# SYN-ACK, where rx_count is 0). Once ESTABLISHED, every segment
# advertises the actual free ring space via _tcp_adv_window — see the
# RX-ring banner. Capped at 0xFFFF: classic TCP has no window scaling
# so the largest advertisable window is 65535 bytes; the 256 KiB ring
# is drained fast enough that a 64 KiB peer-side flight is plenty.
TCP_DEFAULT_WIN:    uint16 = 0xFFFF
TCP_WIN_MAX:        uint64 = 65535     # no window scaling -> 16-bit cap


# Connection table. Parallel-array layout to keep the per-slot
# scalar accesses simple (and to dodge any 2-D Array codegen
# surprises). 8 slots fits 256 bytes of state — comfortably static.
TCP_NUM_SLOTS:      uint64 = 8
# IANA dynamic / ephemeral port range (RFC 6335 §6). Active-open
# source ports rotate monotonically across [TCP_EPHEMERAL_LO,
# TCP_EPHEMERAL_HI] inclusive, wrapping at the top. 16384 distinct
# ports — a multi-package `apt install` cycles through a handful
# of back-to-back connections per boot and never revisits a port,
# so no two in-flight connections to the same server ever collide.
TCP_EPHEMERAL_LO:   uint16 = 49152
TCP_EPHEMERAL_HI:   uint16 = 65535

# Monotonic ephemeral-port cursor. Lazy-seeded on the first
# tcp_connect (see _tcp_ephemeral_next) from the ISN generator so
# two boots don't start on the same port; thereafter it advances
# by one per active-open and wraps back to TCP_EPHEMERAL_LO once it
# passes TCP_EPHEMERAL_HI. Top-level (BSS) — keeps it out of any
# call frame, same dodge the slot tables and tcp_isn_state use.
tcp_ephemeral_cur:  uint16 = 0
tcp_ephemeral_init: uint8  = 0

tcp_slot_state:    Array[8, uint32]      # TCP_CLOSED..TCP_TIME_WAIT
# Concurrent-accept guard: 1 once tcp_accept has handed this slot back
# to a caller, 0 otherwise. tcp_accept scans for an ESTABLISHED slot on
# the listener's port and returns the FIRST match; without this flag a
# second tcp_accept call (the httpd master accepting its next peer)
# would re-return a slot already owned by an earlier worker — every
# concurrent connection past the first would alias the same TCB. The
# flag is cleared when a slot is (re)allocated for a fresh SYN and when
# a slot resets to CLOSED, so a recycled TCB starts un-accepted.
tcp_slot_accepted: Array[8, uint32]      # 1 = already returned by tcp_accept
tcp_slot_local_p:  Array[8, uint16]      # local port (host order)
tcp_slot_remote_p: Array[8, uint16]      # remote port (host order)
# Remote IPv4 stored as flat 32-byte array, slot*4 + byte (network
# order) — same flat-1D dodge dns.ad uses for its result table.
tcp_slot_remote_ip: Array[32, uint8]
tcp_slot_snd_nxt:   Array[8, uint32]     # next byte we will send
tcp_slot_snd_una:   Array[8, uint32]     # oldest unacknowledged byte
tcp_slot_rcv_nxt:   Array[8, uint32]     # next byte we expect from peer
tcp_slot_last_act:  Array[8, uint64]     # jiffies of last RX/TX

# Per-slot inbound RX ring. V5.3 (M16.x): replaces the M16.102
# single-segment overwrite buffer (1500 bytes / slot, blown away on
# every inbound segment) with a grow-and-append queue. tcp_rx
# appends each in-order segment's payload at [tail], advances tail.
# The RX ring is a TRUE CIRCULAR buffer: `head` (consumer) and `tail`
# (producer) both advance modulo TCP_RX_BUF, and a separate `count`
# tracks how many bytes are currently buffered (head==tail is then
# unambiguous — empty when count==0, full when count==TCP_RX_BUF).
#
# Why circular, not the old linear "compact only on full drain":
# fetching a real Debian `Release` (~150 KiB) or `Packages.gz` off a
# live mirror streams far more than one ring's worth of data, and the
# consumer (the TLS record stitcher) drains a record at a time. A
# linear buffer wastes all the space below `head` until a complete
# drain, so `tail` hit TCP_RX_BUF and segments were DROPPED mid-
# transfer even though the ring was half-empty. A circular ring reuses
# the freed front immediately.
#
# Flow control: every ACK/segment we emit advertises a receive window
# equal to the ACTUAL free ring space (_tcp_adv_window). When the
# consumer lags and the ring fills, the advertised window shrinks
# toward 0 and the peer's TCP stops sending — no drop, no retransmit
# storm. As tcp_recv drains, it emits a window-update ACK so the peer
# reopens. A segment that still does not fit (peer ignored a zero
# window) is dropped without advancing rcv_nxt, exactly as before — a
# correctness backstop, no longer the normal path.
#
# 256 KiB / slot comfortably holds a whole real-world index response
# in flight. Layout: flat 1-D array of slot*TCP_RX_BUF + offset (the
# nested-Array-codegen dodge every other table here uses).
tcp_slot_rx_data:   Array[2097152, uint8] # 8 slots * 262144 bytes
tcp_slot_rx_head:   Array[8, uint64]      # consumer position (drain)
tcp_slot_rx_tail:   Array[8, uint64]      # producer position (append)
tcp_slot_rx_count:  Array[8, uint64]      # bytes currently buffered

# Per-slot rx/event wait queue. A task blocked in tcp_recv (waiting for
# data), tcp_connect (waiting for SYN-ACK), tcp_send (waiting for the
# ACK) or tcp_accept (waiting for a child) sleeps on the WaitQueue of the
# relevant slot. The rx IRQ path (virtio_net_poll -> tcp_rx) calls
# wq_wake_all on this queue whenever it makes a slot's wait-condition
# true: data deposited, state advanced to ESTABLISHED, a child accepted,
# a FIN/RST seen. Woken directly from IRQ context (wq_wake_all is IRQ-
# safe: rq_lock only, never schedule()). For listeners, the LISTEN slot's
# own queue is the accept queue (children enqueue + wake the parent).
tcp_slot_rx_wq:     Array[8, WaitQueue]

# Per-slot flag: did we observe a FIN from the peer? Latched the
# first time we see it; cleared on tcp_close completion.
tcp_slot_saw_fin:   Array[8, uint8]


# --- Retransmission state (M16.108, RFC 6298) ---
#
# Each slot tracks the most-recent segment we sent that needs an ACK
# back (SYN, FIN, or data — pure ACKs don't get retransmitted). The
# polling loops in tcp_connect / tcp_send / tcp_recv call
# _tcp_check_retrans on every iteration to fire a retransmit when
# `(get_jiffies() - last_send_jiffies) > rto_jiffies` and we still
# don't have the ACK.
#
# RTT estimation follows RFC 6298 with integer math. Initial RTO is
# 100 jiffies (= 1 s @ HZ=100). After the first RTT sample lands,
# RTO collapses to `srtt + 4 * rttvar` clamped to a 10-jiffy floor
# (100 ms — anything smaller is below SLIRP's turn-around jitter).
# Exponential backoff doubles RTO on every retransmit (§5.5). After
# 5 retries we give up and signal the caller via -1.
TCP_RTO_INITIAL: uint64 = 100               # 100 jiffies = 1 s
TCP_RTO_MIN:     uint64 = 10                # floor 100 ms
TCP_MAX_RETRIES: uint64 = 5

tcp_slot_last_send:  Array[8, uint64]       # jiffies of last (re)tx
tcp_slot_rto:        Array[8, uint64]       # current RTO in jiffies
tcp_slot_retries:    Array[8, uint64]       # retransmits for current seg
tcp_slot_srtt:       Array[8, uint64]       # smoothed RTT (jiffies)
tcp_slot_rttvar:     Array[8, uint64]       # RTT variance (jiffies)
tcp_slot_have_rtt:   Array[8, uint8]        # 0 until first RTT sample
tcp_slot_unacked:    Array[8, uint8]        # 1 if pending seg awaits ACK
tcp_slot_pend_flags: Array[8, uint8]        # flags of pending segment
tcp_slot_pend_seq:   Array[8, uint32]       # seq for retransmit
tcp_slot_pend_len:   Array[8, uint64]       # payload length
# Per-slot pending-payload snapshot. One MSS per slot — caller writes
# the segment into this scratch buffer in _tcp_build_and_send and the
# retransmit path re-reads it from here.
tcp_slot_pend_data:  Array[4288, uint8]     # 8 * TCP_MSS (= 8 * 536)


# --- Congestion control (#166, RFC 5681 Reno/NewReno) ---
#
# Per-slot cwnd / ssthresh in BYTES (mirrors Linux's snd_cwnd*mss). On
# connect/accept cwnd starts at IW = 1 SMSS-ish (we use TCP_MSS bytes,
# the classic IW=1 conservative open) and ssthresh starts effectively
# infinite (TCP_SSTHRESH_INIT). Each ACK that advances snd_una runs
# _tcp_cc_on_ack:
#   * slow start  (cwnd <  ssthresh): cwnd += SMSS  per good ACK
#                                     (exponential — doubles per RTT)
#   * cong avoid  (cwnd >= ssthresh): cwnd += SMSS*SMSS/cwnd per ACK
#                                     (additive — ~+1 SMSS per RTT, AI)
# Three duplicate ACKs (RFC 5681 §3.2 fast retransmit) run
# _tcp_cc_on_dupack: ssthresh = max(FlightSize/2, 2*SMSS), then fast
# retransmit the missing segment and enter fast recovery with
# cwnd = ssthresh + 3*SMSS (the "inflate by the 3 dup-ACK'd segments"
# of NewReno). A fresh (non-dup) ACK during recovery deflates cwnd
# back to ssthresh and exits recovery (MD complete).
TCP_SMSS:           uint64 = 536             # sender MSS (== TCP_MSS)
TCP_IW:             uint64 = 536             # initial window = 1 SMSS
TCP_SSTHRESH_INIT:  uint64 = 0xFFFFFFFF      # "infinite" until first loss
TCP_DUPACK_THRESH:  uint64 = 3               # fast-retransmit trigger

tcp_slot_cwnd:      Array[8, uint64]         # congestion window (bytes)
tcp_slot_ssthresh:  Array[8, uint64]         # slow-start threshold (bytes)
tcp_slot_dupacks:   Array[8, uint64]         # consecutive duplicate ACKs
tcp_slot_in_recov:  Array[8, uint8]          # 1 == in fast recovery
tcp_slot_recov_pt:  Array[8, uint32]         # recovery point (snd_nxt at loss)
tcp_slot_last_ack:  Array[8, uint32]         # last ack# seen (dup detection)


# --- Window scaling (#166, RFC 7323 §2) ---
#
# Both sides advertise a Window Scale (WScale) option ONLY in the SYN /
# SYN-ACK. snd_wscale = the shift the PEER advertised (applied to the
# window we read off their segments to compute their real receive
# window). rcv_wscale = the shift WE advertise (applied by the peer to
# our 16-bit window field to recover the true window). We advertise
# TCP_RCV_WSCALE so a single 16-bit field can express up to
# 65535 << TCP_RCV_WSCALE bytes — well past the 64 KiB classic cap.
# wscale_ok latches to 1 once the SYN exchange negotiated it (BOTH
# sides must send the option, RFC 7323 §2.2); if the peer omitted it we
# fall back to no scaling on this connection (both shifts 0).
TCP_RCV_WSCALE:     uint8 = 7                # we shift our window by 7 (×128)
TCP_OPT_END:        uint8 = 0                # End-of-options
TCP_OPT_NOP:        uint8 = 1                # No-op (padding)
TCP_OPT_MSS:        uint8 = 2               # Maximum segment size
TCP_OPT_WSCALE:     uint8 = 3               # Window scale
TCP_OPT_SACK_PERM:  uint8 = 4               # SACK-permitted
TCP_OPT_SACK:       uint8 = 5               # SACK blocks

tcp_slot_snd_wscale: Array[8, uint8]        # shift applied to peer's window
tcp_slot_rcv_wscale: Array[8, uint8]        # shift we advertise (TCP_RCV_WSCALE)
tcp_slot_wscale_ok:  Array[8, uint8]        # 1 == both sides negotiated WScale
tcp_slot_snd_wnd:    Array[8, uint64]       # peer's advertised window (scaled bytes)


# --- SACK (#166, RFC 2018) ---
#
# sack_ok latches when both SYNs carried SACK-permitted. The receiver
# keeps up to TCP_SACK_BLOCKS out-of-order blocks it has buffered above
# rcv_nxt (each [left,right) in absolute sequence space); it emits them
# as a SACK option on the ACKs it sends while a hole persists. The
# sender, on receiving a SACK option, marks the ACKed-via-SACK ranges
# and retransmits ONLY the genuinely-missing segment below the highest
# SACK block (the hole the cumulative ACK still points at).
TCP_SACK_BLOCKS:    uint64 = 4              # max blocks we track / emit

tcp_slot_sack_ok:    Array[8, uint8]        # 1 == SACK negotiated
tcp_slot_sack_n:     Array[8, uint64]       # number of valid recv-side blocks
# Receiver-side out-of-order block table. Flat parallel arrays, slot*4 +
# block index. left = first absolute seq of the block, right = one past
# the last (so block length == right - left). Blocks are kept sorted /
# coalesced by _tcp_sack_add so the most recent OoO arrival is block 0
# (RFC 2018 §4 ordering).
tcp_slot_sack_left:  Array[32, uint32]      # 8 slots * 4 blocks
tcp_slot_sack_right: Array[32, uint32]


# --- Multi-listener accept queue (#166) ---
#
# Each LISTEN slot owns a small FIFO ring of child slot indices that
# have completed the three-way handshake (reached ESTABLISHED) and are
# waiting to be handed out by tcp_accept — a real listen(2) backlog.
# tcp_rx enqueues a child the instant it transitions a SYN_RCVD slot to
# ESTABLISHED; tcp_accept dequeues the head. This decouples "how many
# inbound connections can be pending" from "first match in the table"
# so N concurrent connections to one listener are accepted in arrival
# order, not whatever the linear scan happened to hit first.
TCP_ACCEPT_BACKLOG: uint64 = 8              # queued-but-unaccepted children / listener

tcp_slot_acc_head:   Array[8, uint64]       # FIFO consumer cursor
tcp_slot_acc_tail:   Array[8, uint64]       # FIFO producer cursor
tcp_slot_acc_count:  Array[8, uint64]       # children currently queued
# Flat ring of child slot indices: listener*TCP_ACCEPT_BACKLOG + pos.
tcp_slot_acc_ring:   Array[64, uint32]      # 8 listeners * 8 backlog
# Back-pointer: for an accepted/handshaking child, which listener slot
# it belongs to (so tcp_rx can enqueue it on the right listener). 0xFF
# == not a passive child.
tcp_slot_parent:     Array[8, uint8]


# Counters bumped by tcp_rx / tcp_tx. Mirrors a couple of fields in
# /proc/net/snmp Tcp:; we'll grow the list when the rest of the
# stack lands.
tcp_in_segs:    uint64 = 0
tcp_out_segs:   uint64 = 0
tcp_in_data:    uint64 = 0
tcp_out_data:   uint64 = 0
tcp_resets_in:  uint64 = 0
tcp_resets_out: uint64 = 0


# Initial-sequence-number generator. xorshift64 seeded from
# get_jiffies() the first time we issue a SYN. Real Linux uses an
# MD4/SipHash-based per-flow ISN to defend against blind injection;
# we don't have a threat model that requires that, so a single
# global xorshift state is fine.
tcp_isn_state: uint64 = 0
tcp_isn_init:  uint8  = 0


# Scratch buffer for outbound TCP. Laid out as:
#   [0..TCP_PSEUDO_LEN)            pseudo-header (csum input only)
#   [TCP_PSEUDO_LEN..+TCP_HDR_LEN) TCP header
#   [...+payload_len)              payload
# ip_send is handed the pointer AFTER the pseudo-header.
tcp_tx_buf: Array[2048, uint8]

# Scratch buffer for the one-shot ARP REQUEST we send before the
# first connect to a not-yet-cached on-link host. Same shape as
# dns.ad's _dns_build_arp_request_for_server (14 ETH + 28 ARP +
# 22 pad = 64 bytes). When a connect targets a guestfwd address
# like 10.0.2.100, that host has its own MAC distinct from the
# gateway (10.0.2.2) and the DNS server (10.0.2.3), so we have to
# ARP for it before ip_send can find a destination MAC.
tcp_arp_buf: Array[64, uint8]


def _tcp_build_arp_request(b0: uint8, b1: uint8,
                           b2: uint8, b3: uint8) -> int32:
    # Construct a 42-byte (padded to 60) Ethernet+ARP REQUEST asking
    # "who-has b0.b1.b2.b3 tell our_ip" and hand it to eth_tx.
    # Returns 0 on send success, -1 if our IP or MAC isn't ready.
    our_mac: Ptr[uint8] = eth_get_mac()
    if our_mac == cast[Ptr[uint8]](0):
        return -1
    if ip_have_our_ip() == 0:
        return -1
    i: uint64 = 0
    while i < 64:
        tcp_arp_buf[i] = 0
        i = i + 1
    # Ethernet header: dst=broadcast, src=our MAC, type=0x0806.
    j: uint64 = 0
    while j < 6:
        tcp_arp_buf[j] = 0xFF
        tcp_arp_buf[6 + j] = our_mac[j]
        j = j + 1
    tcp_arp_buf[12] = 0x08
    tcp_arp_buf[13] = 0x06
    # ARP body @ offset 14.
    tcp_arp_buf[14] = 0x00
    tcp_arp_buf[15] = 0x01            # htype Ethernet
    tcp_arp_buf[16] = 0x08
    tcp_arp_buf[17] = 0x00            # ptype IPv4
    tcp_arp_buf[18] = 6               # hlen
    tcp_arp_buf[19] = 4               # plen
    tcp_arp_buf[20] = 0x00
    tcp_arp_buf[21] = 0x01            # opcode REQUEST
    # sha = our MAC
    k: uint64 = 0
    while k < 6:
        tcp_arp_buf[22 + k] = our_mac[k]
        k = k + 1
    # spa = our IP
    tcp_arp_buf[28] = ip_our_ip_b(0)
    tcp_arp_buf[29] = ip_our_ip_b(1)
    tcp_arp_buf[30] = ip_our_ip_b(2)
    tcp_arp_buf[31] = ip_our_ip_b(3)
    # tha already zero (target hardware addr filled in by responder).
    # tpa = the IP we're asking about.
    tcp_arp_buf[38] = b0
    tcp_arp_buf[39] = b1
    tcp_arp_buf[40] = b2
    tcp_arp_buf[41] = b3
    printk1("[tcp] ARP request -> 10.0.2.%d\n", cast[uint64](b3))
    buf_ptr: Ptr[uint8] = cast[Ptr[uint8]](&tcp_arp_buf[0])
    return eth_tx(buf_ptr, 60)


def _tcp_prime_arp(b0: uint8, b1: uint8, b2: uint8, b3: uint8) -> int32:
    # If `b0.b1.b2.b3` is already in the ARP cache, we're done.
    # Otherwise emit one ARP REQUEST and poll the RX ring for up to
    # ~100 ms until the reply lands in the cache. Returns 0 on cache
    # hit when we exit, -1 on timeout. Mirrors dns._dns_prime_arp.
    target: Array[4, uint8]
    target[0] = b0
    target[1] = b1
    target[2] = b2
    target[3] = b3
    addr_ptr: Ptr[uint8] = cast[Ptr[uint8]](&target[0])
    if arp_lookup(addr_ptr) != cast[Ptr[uint8]](0):
        return 0
    _tcp_build_arp_request(b0, b1, b2, b3)
    start: uint64 = get_jiffies()
    deadline: uint64 = start + 10                 # 10 jiffies == 100 ms
    while get_jiffies() < deadline:
        virtio_net_poll()
        if arp_lookup(addr_ptr) != cast[Ptr[uint8]](0):
            return 0
        # Preempt-class wedge-fix: with IF=0 here, the LAPIC timer
        # can't bump jiffies — without this the loop would never see
        # `get_jiffies() >= deadline`. kernel_cond_resched briefly sti+
        # hlt+cli so the timer fires (and any STATE_READY peer runs).
        kernel_cond_resched()
    return -1


def _tcp_isn_next() -> uint32:
    # xorshift64 step. Lazy-seed on first call using get_jiffies()
    # mixed with a constant so a boot that never sees IRQs (mostly
    # impossible — time_init is called early) still produces a
    # non-zero state.
    if tcp_isn_init == 0:
        seed: uint64 = get_jiffies() ^ 0x9E3779B97F4A7C15
        if seed == 0:
            seed = 0xDEADBEEFCAFEBABE
        tcp_isn_state = seed
        tcp_isn_init = 1
    x: uint64 = tcp_isn_state
    x = x ^ (x << 13)
    x = x ^ (x >> 7)
    x = x ^ (x << 17)
    tcp_isn_state = x
    return cast[uint32](x & 0xFFFFFFFF)


def _tcp_ephemeral_next() -> uint16:
    # Hand out the next active-open source port, rotating
    # monotonically across the IANA dynamic range
    # [TCP_EPHEMERAL_LO, TCP_EPHEMERAL_HI] and wrapping at the top.
    #
    # This is the fix for the back-to-back-connect wedge: every
    # tcp_connect gets a DIFFERENT source port, so two consecutive
    # connections to the same server present distinct 4-tuples even
    # when the slot allocator reuses the same low slot. SLIRP (and
    # strict TCP) no longer see what looks like a duplicate
    # connection, and there is no just-closed-4-tuple reuse window.
    #
    # Lazy-seed the cursor on first use from the ISN generator so
    # the starting port varies boot to boot — harmless for
    # correctness (any port in range works) but avoids two boots
    # racing on the same first port against a long-lived SLIRP.
    if tcp_ephemeral_init == 0:
        span: uint32 = cast[uint32](TCP_EPHEMERAL_HI) \
                       - cast[uint32](TCP_EPHEMERAL_LO) + 1
        seed: uint32 = _tcp_isn_next() % span
        tcp_ephemeral_cur = TCP_EPHEMERAL_LO + cast[uint16](seed)
        tcp_ephemeral_init = 1
    port: uint16 = tcp_ephemeral_cur
    # Advance the cursor for the next caller, wrapping at HI.
    if tcp_ephemeral_cur >= TCP_EPHEMERAL_HI:
        tcp_ephemeral_cur = TCP_EPHEMERAL_LO
    else:
        tcp_ephemeral_cur = tcp_ephemeral_cur + 1
    return port


def _tcp_alloc_slot() -> int32:
    # Find a free TCB. Returns slot index 0..7 or -1 if all slots
    # are in use (no eviction — tcp_connect callers must close
    # their connections to free slots).
    #
    # First pass: a truly CLOSED slot. Second pass: a TIME_WAIT slot —
    # we don't enforce the 2*MSL quiet period (see the state-machine
    # comment at the top of the file: "TIME_WAIT --(skip 2*MSL)-->
    # CLOSED"), and with only 8 TCBs a concurrent server (httpd's
    # per-connection workers) would otherwise wedge once a handful of
    # short-lived connections piled up in TIME_WAIT. Reclaiming a
    # TIME_WAIT slot for a fresh connection is the pragmatic Plan-9-ish
    # choice here; the new SYN_RECV init fully reinitialises the TCB.
    i: uint64 = 0
    while i < TCP_NUM_SLOTS:
        if tcp_slot_state[i] == TCP_CLOSED:
            return cast[int32](i)
        i = i + 1
    i = 0
    while i < TCP_NUM_SLOTS:
        if tcp_slot_state[i] == TCP_TIME_WAIT:
            return cast[int32](i)
        i = i + 1
    return -1


def _tcp_find_slot(remote_b0: uint8, remote_b1: uint8,
                   remote_b2: uint8, remote_b3: uint8,
                   remote_port: uint16,
                   local_port: uint16) -> int32:
    # Match incoming segment against the connection table by
    # (remote_ip, remote_port, local_port). Returns slot index or
    # -1 on miss. LISTEN-state slots are intentionally NOT matched
    # here — they're a wildcard on (remote_ip, remote_port) and need
    # a separate lookup (_tcp_find_listener) that the SYN-arrival
    # path in tcp_rx falls back to on a miss.
    i: uint64 = 0
    while i < TCP_NUM_SLOTS:
        if tcp_slot_state[i] != TCP_CLOSED:
            if tcp_slot_state[i] != TCP_LISTEN:
                if tcp_slot_remote_p[i] == remote_port:
                    if tcp_slot_local_p[i] == local_port:
                        base: uint64 = i * 4
                        if tcp_slot_remote_ip[base + 0] == remote_b0:
                            if tcp_slot_remote_ip[base + 1] == remote_b1:
                                if tcp_slot_remote_ip[base + 2] == remote_b2:
                                    if tcp_slot_remote_ip[base + 3] == remote_b3:
                                        return cast[int32](i)
        i = i + 1
    return -1


def _tcp_find_listener(local_port: uint16) -> int32:
    # Search the TCB table for a LISTEN slot bound to `local_port`.
    # Wildcards on remote (a LISTEN slot accepts SYNs from any
    # remote_ip / remote_port). Returns slot index or -1 on miss.
    # Called from tcp_rx after a _tcp_find_slot miss when the
    # incoming segment might be a passive-open SYN.
    i: uint64 = 0
    while i < TCP_NUM_SLOTS:
        if tcp_slot_state[i] == TCP_LISTEN:
            if tcp_slot_local_p[i] == local_port:
                return cast[int32](i)
        i = i + 1
    return -1


def _tcp_update_rto(slot: uint64, rtt: uint64):
    # RFC 6298 §2 RTT estimator with integer arithmetic.
    #   First sample : SRTT = R; RTTVAR = R / 2.
    #   Subsequent   : RTTVAR = (3*RTTVAR + |SRTT - R|) / 4
    #                  SRTT   = (7*SRTT + R) / 8
    # Then RTO = max(SRTT + 4*RTTVAR, TCP_RTO_MIN). No upper bound
    # (the backoff path in _tcp_check_retrans can grow RTO, but
    # successful samples reset to the smoothed value).
    if tcp_slot_have_rtt[slot] == 0:
        tcp_slot_srtt[slot] = rtt
        tcp_slot_rttvar[slot] = rtt / 2
        tcp_slot_have_rtt[slot] = 1
    else:
        srtt: uint64 = tcp_slot_srtt[slot]
        rttvar: uint64 = tcp_slot_rttvar[slot]
        diff: uint64 = 0
        if srtt >= rtt:
            diff = srtt - rtt
        else:
            diff = rtt - srtt
        rttvar = (3 * rttvar + diff) / 4
        srtt = (7 * srtt + rtt) / 8
        tcp_slot_srtt[slot] = srtt
        tcp_slot_rttvar[slot] = rttvar
    rto: uint64 = tcp_slot_srtt[slot] + 4 * tcp_slot_rttvar[slot]
    if rto < TCP_RTO_MIN:
        rto = TCP_RTO_MIN
    tcp_slot_rto[slot] = rto


def _tcp_arm_retrans(slot: uint64, flags: uint8,
                     seq: uint32, payload: Ptr[uint8],
                     payload_len: uint64):
    # Snapshot the in-flight segment so the polling-loop retransmit
    # path can rebuild it without help from the original caller.
    # Pure ACKs (no SYN/FIN/data) are NOT armed — they don't need
    # retransmission; a lost ACK is recovered by the peer's own RTO.
    is_syn: uint8 = flags & TCP_SYN
    is_fin: uint8 = flags & TCP_FIN
    needs_ack: uint8 = 0
    if is_syn != 0:
        needs_ack = 1
    if is_fin != 0:
        needs_ack = 1
    if payload_len > 0:
        needs_ack = 1
    if needs_ack == 0:
        return
    tcp_slot_unacked[slot] = 1
    tcp_slot_pend_flags[slot] = flags
    tcp_slot_pend_seq[slot] = seq
    tcp_slot_pend_len[slot] = payload_len
    tcp_slot_last_send[slot] = get_jiffies()
    if payload_len > 0:
        base: uint64 = slot * TCP_MSS
        i: uint64 = 0
        cap: uint64 = payload_len
        if cap > TCP_MSS:
            cap = TCP_MSS
        while i < cap:
            tcp_slot_pend_data[base + i] = payload[i]
            i = i + 1


def _tcp_clear_pending(slot: uint64, acked_seq: uint32):
    # Called from tcp_rx when an ACK advances snd_una past the
    # pending segment's seq+len. Measures RTT (only on first send —
    # Karn's algorithm: don't sample on a retransmitted segment) and
    # clears the per-slot retransmission state.
    if tcp_slot_unacked[slot] == 0:
        return
    pend_seq: uint32 = tcp_slot_pend_seq[slot]
    pend_len: uint64 = tcp_slot_pend_len[slot]
    pend_flags: uint8 = tcp_slot_pend_flags[slot]
    seq_consumed: uint32 = pend_seq + cast[uint32](pend_len)
    if (pend_flags & TCP_SYN) != 0:
        seq_consumed = seq_consumed + 1
    if (pend_flags & TCP_FIN) != 0:
        seq_consumed = seq_consumed + 1
    # Did this ACK cover our pending segment?
    if acked_seq < seq_consumed:
        return
    # Karn: only sample RTT when retries == 0 (the segment wasn't
    # retransmitted). Otherwise we can't tell which copy the ACK is
    # for and an erroneous sample would skew SRTT badly.
    if tcp_slot_retries[slot] == 0:
        rtt: uint64 = get_jiffies() - tcp_slot_last_send[slot]
        if rtt == 0:
            rtt = 1
        _tcp_update_rto(slot, rtt)
    tcp_slot_unacked[slot] = 0
    tcp_slot_retries[slot] = 0
    tcp_slot_pend_len[slot] = 0
    tcp_slot_pend_flags[slot] = 0


def _tcp_retransmit(slot: uint64) -> int32:
    # Rebuild and resend the pending segment using the snapshotted
    # flags / seq / payload. Bumps tcp_slot_retries; the caller (the
    # polling loop) bumps RTO via exponential backoff. Returns 0 on
    # successful tx, -1 on send failure.
    flags: uint8 = tcp_slot_pend_flags[slot]
    seq: uint32 = tcp_slot_pend_seq[slot]
    payload_len: uint64 = tcp_slot_pend_len[slot]
    # Temporarily roll snd_nxt back to the pending segment's seq so
    # _tcp_build_and_send stamps the wire-correct sequence number;
    # restore after the call.
    saved_snd_nxt: uint32 = tcp_slot_snd_nxt[slot]
    tcp_slot_snd_nxt[slot] = seq
    rc: int32 = 0
    if payload_len > 0:
        base: uint64 = slot * TCP_MSS
        pl_ptr: Ptr[uint8] = cast[Ptr[uint8]](&tcp_slot_pend_data[base])
        rc = _tcp_send_segment(slot, flags, pl_ptr, payload_len, 1)
    else:
        rc = _tcp_send_segment(slot, flags, cast[Ptr[uint8]](0), 0, 1)
    tcp_slot_snd_nxt[slot] = saved_snd_nxt
    return rc


def _tcp_check_retrans(slot: uint64) -> int32:
    # Polling-loop helper. Returns:
    #   0   nothing to do (no pending segment, or RTO not yet expired)
    #   1   retransmit fired this iteration
    #  -1   exceeded TCP_MAX_RETRIES — caller should give up
    if tcp_slot_unacked[slot] == 0:
        return 0
    now: uint64 = get_jiffies()
    elapsed: uint64 = now - tcp_slot_last_send[slot]
    rto: uint64 = tcp_slot_rto[slot]
    if elapsed < rto:
        return 0
    if tcp_slot_retries[slot] >= TCP_MAX_RETRIES:
        # Convert jiffies to ms for the log line (HZ=100 -> *10).
        rto_ms: uint64 = rto * 10
        printk2("[tcp] connect timeout after %d retries (rto=%dms)\n",
                tcp_slot_retries[slot], rto_ms)
        return -1
    tcp_slot_retries[slot] = tcp_slot_retries[slot] + 1
    # Exponential backoff (RFC 6298 §5.5).
    tcp_slot_rto[slot] = rto * 2
    rto_ms: uint64 = rto * 10
    printk2("[tcp] retrans #%d rto=%dms\n",
            tcp_slot_retries[slot], rto_ms)
    _tcp_retransmit(slot)
    # last_send refreshed by _tcp_send_segment via the same code
    # path the original tx used. Stash now for safety.
    tcp_slot_last_send[slot] = get_jiffies()
    return 1


# _tcp_adv_window: the receive window to advertise on the next segment
# this slot sends — the actual free space in its circular RX ring,
# capped at TCP_WIN_MAX (classic TCP has no window scaling, so a window
# wider than 65535 cannot be expressed on the wire). When the consumer
# lags and the ring fills this returns 0, which tells the peer's TCP to
# stop sending until a later tcp_recv drains the ring and emits a
# window-update ACK.

def _tcp_adv_window(slot: uint64) -> uint16:
    used: uint64 = tcp_slot_rx_count[slot]
    free: uint64 = 0
    if used < TCP_RX_BUF:
        free = TCP_RX_BUF - used
    if free > TCP_WIN_MAX:
        free = TCP_WIN_MAX
    return cast[uint16](free)


# --- Congestion control helpers (#166) --------------------------------

def _tcp_cc_init(slot: uint64):
    # Reset a slot's congestion-control state for a fresh connection.
    # IW=1 SMSS conservative open (RFC 5681 §3.1); ssthresh "infinite".
    tcp_slot_cwnd[slot] = TCP_IW
    tcp_slot_ssthresh[slot] = TCP_SSTHRESH_INIT
    tcp_slot_dupacks[slot] = 0
    tcp_slot_in_recov[slot] = 0
    tcp_slot_recov_pt[slot] = 0
    tcp_slot_last_ack[slot] = 0


def _tcp_cc_on_ack(slot: uint64, acked_bytes: uint64):
    # A fresh cumulative ACK advanced snd_una by `acked_bytes`. Grow the
    # window per RFC 5681:
    #   slow start (cwnd < ssthresh): cwnd += min(acked, SMSS) — doubles
    #                                  the window every RTT.
    #   congestion avoidance        : cwnd += SMSS*SMSS/cwnd  — roughly
    #                                  +1 SMSS per RTT (additive increase).
    # If we were in fast recovery, a fresh ACK that reaches the recovery
    # point completes the loss episode: deflate cwnd to ssthresh and
    # exit recovery (NewReno).
    if tcp_slot_in_recov[slot] != 0:
        # Fresh ACK during recovery — recovery ends, deflate to ssthresh.
        tcp_slot_cwnd[slot] = tcp_slot_ssthresh[slot]
        tcp_slot_in_recov[slot] = 0
        tcp_slot_dupacks[slot] = 0
        return
    cwnd: uint64 = tcp_slot_cwnd[slot]
    ssthresh: uint64 = tcp_slot_ssthresh[slot]
    if cwnd < ssthresh:
        inc: uint64 = acked_bytes
        if inc > TCP_SMSS:
            inc = TCP_SMSS
        tcp_slot_cwnd[slot] = cwnd + inc
    else:
        inc2: uint64 = (TCP_SMSS * TCP_SMSS) / cwnd
        if inc2 == 0:
            inc2 = 1
        tcp_slot_cwnd[slot] = cwnd + inc2


def _tcp_cc_enter_loss(slot: uint64):
    # RFC 5681 §3.2 step 2: ssthresh = max(FlightSize/2, 2*SMSS).
    # FlightSize = snd_nxt - snd_una (bytes in flight). Called by the
    # fast-retransmit (3 dup-ACK) path and shared by the RTO path.
    flight: uint64 = 0
    snd_nxt: uint32 = tcp_slot_snd_nxt[slot]
    snd_una: uint32 = tcp_slot_snd_una[slot]
    if snd_nxt > snd_una:
        flight = cast[uint64](snd_nxt - snd_una)
    half: uint64 = flight / 2
    floor: uint64 = 2 * TCP_SMSS
    if half < floor:
        half = floor
    tcp_slot_ssthresh[slot] = half


def _tcp_cc_on_dupack(slot: uint64) -> int32:
    # Count a duplicate ACK. On the THIRD one, drop ssthresh, enter fast
    # recovery, and signal the caller to fast-retransmit. cwnd is set to
    # ssthresh + 3*SMSS (inflated by the three segments that left the
    # network — the dup ACKs prove they arrived). Returns 1 iff this dup
    # ACK is the one that triggers the fast retransmit, else 0.
    tcp_slot_dupacks[slot] = tcp_slot_dupacks[slot] + 1
    if tcp_slot_in_recov[slot] != 0:
        # Already recovering — each further dup ACK inflates cwnd by
        # one SMSS (RFC 5681 §3.2 step 4) so new data can be clocked out.
        tcp_slot_cwnd[slot] = tcp_slot_cwnd[slot] + TCP_SMSS
        return 0
    if tcp_slot_dupacks[slot] == TCP_DUPACK_THRESH:
        _tcp_cc_enter_loss(slot)
        tcp_slot_in_recov[slot] = 1
        tcp_slot_recov_pt[slot] = tcp_slot_snd_nxt[slot]
        tcp_slot_cwnd[slot] = tcp_slot_ssthresh[slot] + 3 * TCP_SMSS
        return 1
    return 0


# --- Window-scaling helper (#166) -------------------------------------

def _tcp_adv_window_scaled(slot: uint64) -> uint16:
    # Free RX-ring space expressed as a SCALED 16-bit window field. When
    # WScale was negotiated (rcv_wscale > 0) we right-shift the true free
    # space by our advertised shift so the on-wire 16-bit value, once the
    # peer left-shifts it by the same amount, recovers the true (possibly
    # >64 KiB) window. Without negotiation this degrades to the classic
    # _tcp_adv_window (cap 65535).
    used: uint64 = tcp_slot_rx_count[slot]
    free: uint64 = 0
    if used < TCP_RX_BUF:
        free = TCP_RX_BUF - used
    sh: uint8 = 0
    if tcp_slot_wscale_ok[slot] != 0:
        sh = tcp_slot_rcv_wscale[slot]
    scaled: uint64 = free >> sh
    if scaled > TCP_WIN_MAX:
        scaled = TCP_WIN_MAX
    return cast[uint16](scaled)


def _tcp_effective_window(slot: uint64) -> uint64:
    # The peer's TRUE receive window in bytes: the 16-bit value off their
    # last segment left-shifted by snd_wscale (the shift THEY advertised).
    # Stored in tcp_slot_snd_wnd by tcp_rx; this just reads it back.
    return tcp_slot_snd_wnd[slot]


# --- SACK receiver-side block bookkeeping (#166, RFC 2018) ------------

def _tcp_sack_reset(slot: uint64):
    tcp_slot_sack_n[slot] = 0


def _tcp_sack_add(slot: uint64, left: uint32, right: uint32):
    # Record an out-of-order block [left,right) the receiver has buffered
    # above rcv_nxt. Coalesces with an adjacent/overlapping existing
    # block, then moves the (new-or-grown) block to the front (block 0) —
    # RFC 2018 §4 wants the most recently received block reported first.
    # Keeps at most TCP_SACK_BLOCKS; oldest fall off the end.
    if right <= left:
        return
    sb: uint64 = slot * TCP_SACK_BLOCKS
    n: uint64 = tcp_slot_sack_n[slot]
    # Try to coalesce with an existing block.
    i: uint64 = 0
    merged: int32 = -1
    while i < n:
        bl: uint32 = tcp_slot_sack_left[sb + i]
        br: uint32 = tcp_slot_sack_right[sb + i]
        # Overlap or exact adjacency in either direction.
        if left <= br:
            if right >= bl:
                nl: uint32 = bl
                if left < nl:
                    nl = left
                nr: uint32 = br
                if right > nr:
                    nr = right
                tcp_slot_sack_left[sb + i] = nl
                tcp_slot_sack_right[sb + i] = nr
                left = nl
                right = nr
                merged = cast[int32](i)
                i = n                            # break
        if merged < 0:
            i = i + 1
        else:
            i = n
    if merged < 0:
        # New block. Append (or evict the oldest if full) then it gets
        # rotated to the front below.
        if n < TCP_SACK_BLOCKS:
            tcp_slot_sack_left[sb + n] = left
            tcp_slot_sack_right[sb + n] = right
            n = n + 1
            tcp_slot_sack_n[slot] = n
            merged = cast[int32](n - 1)
        else:
            # Overwrite the last (oldest) block.
            tcp_slot_sack_left[sb + (n - 1)] = left
            tcp_slot_sack_right[sb + (n - 1)] = right
            merged = cast[int32](n - 1)
    # Rotate the merged/new block to the front (block 0).
    mi: uint64 = cast[uint64](merged)
    if mi != 0:
        ml: uint32 = tcp_slot_sack_left[sb + mi]
        mr: uint32 = tcp_slot_sack_right[sb + mi]
        k: uint64 = mi
        while k > 0:
            tcp_slot_sack_left[sb + k] = tcp_slot_sack_left[sb + k - 1]
            tcp_slot_sack_right[sb + k] = tcp_slot_sack_right[sb + k - 1]
            k = k - 1
        tcp_slot_sack_left[sb + 0] = ml
        tcp_slot_sack_right[sb + 0] = mr


def _tcp_sack_drop_below(slot: uint64, rcv_nxt: uint32):
    # The cumulative ACK advanced (rcv_nxt grew, the hole filled). Drop /
    # trim any recorded block now fully or partially below rcv_nxt — it is
    # no longer "out of order above the cumulative point".
    sb: uint64 = slot * TCP_SACK_BLOCKS
    n: uint64 = tcp_slot_sack_n[slot]
    w: uint64 = 0
    i: uint64 = 0
    while i < n:
        bl: uint32 = tcp_slot_sack_left[sb + i]
        br: uint32 = tcp_slot_sack_right[sb + i]
        if br > rcv_nxt:
            keep_l: uint32 = bl
            if keep_l < rcv_nxt:
                keep_l = rcv_nxt
            tcp_slot_sack_left[sb + w] = keep_l
            tcp_slot_sack_right[sb + w] = br
            w = w + 1
        i = i + 1
    tcp_slot_sack_n[slot] = w


def _tcp_sack_covers(slot: uint64, seq: uint32, end: uint32) -> int32:
    # Sender-side: did an incoming SACK block fully cover [seq,end)? Used
    # by the retransmit chooser to skip segments the peer already has.
    sb: uint64 = slot * TCP_SACK_BLOCKS
    n: uint64 = tcp_slot_sack_n[slot]
    i: uint64 = 0
    while i < n:
        if tcp_slot_sack_left[sb + i] <= seq:
            if tcp_slot_sack_right[sb + i] >= end:
                return 1
        i = i + 1
    return 0


def _tcp_build_and_send(slot: uint64, flags: uint8,
                        payload: Ptr[uint8],
                        payload_len: uint64) -> int32:
    # Public-shaped wrapper: build, transmit, and arm retransmission
    # state. is_retrans=0 here means "first send — record this seq
    # in the pending slot and start the RTO clock".
    return _tcp_send_segment(slot, flags, payload, payload_len, 0)


def _tcp_send_segment(slot: uint64, flags: uint8,
                      payload: Ptr[uint8],
                      payload_len: uint64,
                      is_retrans: uint64) -> int32:
    # Build the pseudo-header + TCP header + payload, compute the
    # checksum, and hand the segment to ip_send. The pseudo-header
    # is laid down at tcp_tx_buf[0..12); the segment proper starts
    # at tcp_tx_buf[12]. ip_send only sees the segment pointer.
    # Decide TCP options for this segment up front so we know the header
    # length before laying down the pseudo-header / TCP header.
    #   SYN segments carry MSS + WScale + SACK-permitted (the negotiation
    #     happens only in the SYN exchange, RFC 7323/2018).
    #   A pure ACK while we hold out-of-order receiver blocks carries a
    #     SACK option listing those blocks (RFC 2018 §3).
    # opt_len is a multiple of 4 (padded with NOP/EOL); 0 when no options.
    is_syn_seg: uint8 = flags & TCP_SYN
    opt_len: uint64 = 0
    sack_blocks_out: uint64 = 0
    if is_syn_seg != 0:
        # MSS(4) + WScale(3) + SACK-perm(2) + 3 NOP pad = 12 bytes.
        opt_len = 12
    else:
        # Emit SACK blocks only on a pure-ACK-bearing data-light segment
        # when SACK is negotiated and we have out-of-order blocks.
        if tcp_slot_sack_ok[slot] != 0:
            if payload_len == 0:
                nblk: uint64 = tcp_slot_sack_n[slot]
                if nblk > 0:
                    if nblk > 4:
                        nblk = 4
                    sack_blocks_out = nblk
                    # 2 NOP + 1 kind + 1 len + 8*nblk
                    opt_len = 4 + 8 * nblk

    if payload_len + TCP_HDR_LEN + opt_len + TCP_PSEUDO_LEN > 2048:
        printk1("[tcp] segment too big (%d bytes payload)\n", payload_len)
        return -1
    if ip_have_our_ip() == 0:
        printk0("[tcp] no local IP configured\n")
        return -1

    local_port:  uint16 = tcp_slot_local_p[slot]
    remote_port: uint16 = tcp_slot_remote_p[slot]
    snd_nxt:     uint32 = tcp_slot_snd_nxt[slot]
    rcv_nxt:     uint32 = tcp_slot_rcv_nxt[slot]
    base:        uint64 = slot * 4
    r0: uint8 = tcp_slot_remote_ip[base + 0]
    r1: uint8 = tcp_slot_remote_ip[base + 1]
    r2: uint8 = tcp_slot_remote_ip[base + 2]
    r3: uint8 = tcp_slot_remote_ip[base + 3]

    # --- Pseudo-header @ tcp_tx_buf[0..12) ---
    tcp_tx_buf[0] = ip_our_ip_b(0)
    tcp_tx_buf[1] = ip_our_ip_b(1)
    tcp_tx_buf[2] = ip_our_ip_b(2)
    tcp_tx_buf[3] = ip_our_ip_b(3)
    tcp_tx_buf[4] = r0
    tcp_tx_buf[5] = r1
    tcp_tx_buf[6] = r2
    tcp_tx_buf[7] = r3
    tcp_tx_buf[8] = 0                 # reserved zero byte
    tcp_tx_buf[9] = IPPROTO_TCP       # 6
    hdr_total: uint64 = TCP_HDR_LEN + opt_len
    seg_len: uint16 = cast[uint16](hdr_total + payload_len)
    tcp_tx_buf[10] = cast[uint8]((cast[uint32](seg_len) >> 8) & 0xFF)
    tcp_tx_buf[11] = cast[uint8](cast[uint32](seg_len) & 0xFF)

    # --- TCP header @ tcp_tx_buf[12..) ---
    h: uint64 = 12
    tcp_tx_buf[h + 0] = cast[uint8]((cast[uint32](local_port) >> 8) & 0xFF)
    tcp_tx_buf[h + 1] = cast[uint8](cast[uint32](local_port) & 0xFF)
    tcp_tx_buf[h + 2] = cast[uint8]((cast[uint32](remote_port) >> 8) & 0xFF)
    tcp_tx_buf[h + 3] = cast[uint8](cast[uint32](remote_port) & 0xFF)
    tcp_tx_buf[h + 4] = cast[uint8]((snd_nxt >> 24) & 0xFF)
    tcp_tx_buf[h + 5] = cast[uint8]((snd_nxt >> 16) & 0xFF)
    tcp_tx_buf[h + 6] = cast[uint8]((snd_nxt >> 8) & 0xFF)
    tcp_tx_buf[h + 7] = cast[uint8](snd_nxt & 0xFF)
    tcp_tx_buf[h + 8] = cast[uint8]((rcv_nxt >> 24) & 0xFF)
    tcp_tx_buf[h + 9] = cast[uint8]((rcv_nxt >> 16) & 0xFF)
    tcp_tx_buf[h + 10] = cast[uint8]((rcv_nxt >> 8) & 0xFF)
    tcp_tx_buf[h + 11] = cast[uint8](rcv_nxt & 0xFF)
    # data_off = header length in 32-bit words << 4.
    hdr_words_out: uint8 = cast[uint8](hdr_total / 4)
    tcp_tx_buf[h + 12] = hdr_words_out << 4
    tcp_tx_buf[h + 13] = flags
    # Advertise the actual free RX-ring space (SCALED when WScale was
    # negotiated) so the peer's TCP flow control throttles to our drain
    # rate — and so a >64 KiB window can be expressed (see WScale banner).
    adv_win: uint16 = _tcp_adv_window_scaled(slot)
    tcp_tx_buf[h + 14] = cast[uint8]((cast[uint32](adv_win) >> 8) & 0xFF)
    tcp_tx_buf[h + 15] = cast[uint8](cast[uint32](adv_win) & 0xFF)
    tcp_tx_buf[h + 16] = 0              # checksum: zeroed before computation
    tcp_tx_buf[h + 17] = 0             # (filled in by ip_csum16 below)
    tcp_tx_buf[h + 18] = 0              # urg_ptr
    tcp_tx_buf[h + 19] = 0

    # --- TCP options @ tcp_tx_buf[h+20 ..) ---
    if opt_len > 0:
        o: uint64 = h + TCP_HDR_LEN
        if is_syn_seg != 0:
            # MSS (kind 2, len 4): 536 = 0x0218.
            tcp_tx_buf[o + 0] = TCP_OPT_MSS
            tcp_tx_buf[o + 1] = 4
            tcp_tx_buf[o + 2] = cast[uint8]((TCP_MSS >> 8) & 0xFF)
            tcp_tx_buf[o + 3] = cast[uint8](TCP_MSS & 0xFF)
            # WScale (kind 3, len 3): shift = TCP_RCV_WSCALE.
            tcp_tx_buf[o + 4] = TCP_OPT_WSCALE
            tcp_tx_buf[o + 5] = 3
            tcp_tx_buf[o + 6] = TCP_RCV_WSCALE
            # SACK-permitted (kind 4, len 2).
            tcp_tx_buf[o + 7] = TCP_OPT_SACK_PERM
            tcp_tx_buf[o + 8] = 2
            # 3 NOP padding to align to 4-byte boundary (12 total).
            tcp_tx_buf[o + 9] = TCP_OPT_NOP
            tcp_tx_buf[o + 10] = TCP_OPT_NOP
            tcp_tx_buf[o + 11] = TCP_OPT_NOP
        else:
            # SACK blocks (RFC 2018 §3): 2 NOP align + kind 5 + len +
            # 8 bytes per block (left, right big-endian).
            tcp_tx_buf[o + 0] = TCP_OPT_NOP
            tcp_tx_buf[o + 1] = TCP_OPT_NOP
            tcp_tx_buf[o + 2] = TCP_OPT_SACK
            tcp_tx_buf[o + 3] = cast[uint8](2 + 8 * sack_blocks_out)
            sb_out: uint64 = slot * TCP_SACK_BLOCKS
            bi: uint64 = 0
            while bi < sack_blocks_out:
                bo: uint64 = o + 4 + 8 * bi
                bl: uint32 = tcp_slot_sack_left[sb_out + bi]
                br: uint32 = tcp_slot_sack_right[sb_out + bi]
                tcp_tx_buf[bo + 0] = cast[uint8]((bl >> 24) & 0xFF)
                tcp_tx_buf[bo + 1] = cast[uint8]((bl >> 16) & 0xFF)
                tcp_tx_buf[bo + 2] = cast[uint8]((bl >> 8) & 0xFF)
                tcp_tx_buf[bo + 3] = cast[uint8](bl & 0xFF)
                tcp_tx_buf[bo + 4] = cast[uint8]((br >> 24) & 0xFF)
                tcp_tx_buf[bo + 5] = cast[uint8]((br >> 16) & 0xFF)
                tcp_tx_buf[bo + 6] = cast[uint8]((br >> 8) & 0xFF)
                tcp_tx_buf[bo + 7] = cast[uint8](br & 0xFF)
                bi = bi + 1

    # --- Payload @ tcp_tx_buf[h + hdr_total ..) ---
    if payload_len > 0:
        i: uint64 = 0
        while i < payload_len:
            tcp_tx_buf[h + hdr_total + i] = payload[i]
            i = i + 1

    # --- Checksum: covers pseudo-header + TCP header + options + payload ---
    csum_buf: Ptr[uint8] = cast[Ptr[uint8]](&tcp_tx_buf[0])
    csum_len: uint64 = TCP_PSEUDO_LEN + hdr_total + payload_len
    csum: uint16 = ip_csum16(csum_buf, csum_len)
    tcp_tx_buf[h + 16] = cast[uint8]((cast[uint32](csum) >> 8) & 0xFF)
    tcp_tx_buf[h + 17] = cast[uint8](cast[uint32](csum) & 0xFF)

    # Hand the segment (NOT the pseudo-header) to ip_send.
    seg_ptr: Ptr[uint8] = cast[Ptr[uint8]](&tcp_tx_buf[12])
    seg_total: uint64 = hdr_total + payload_len
    tcp_out_segs = tcp_out_segs + 1
    if payload_len > 0:
        tcp_out_data = tcp_out_data + payload_len
    if (flags & TCP_RST) != 0:
        tcp_resets_out = tcp_resets_out + 1
    tcp_slot_last_act[slot] = get_jiffies()
    rc: int32 = ip_send(r0, r1, r2, r3, IPPROTO_TCP, seg_ptr, seg_total)
    # First-send-only: snapshot the segment for retransmission. We
    # use snd_nxt as the seq because that's what we just wrote into
    # the header. Pure ACKs (no SYN/FIN/no payload) skip arming
    # inside _tcp_arm_retrans.
    if is_retrans == 0:
        if rc == 0:
            _tcp_arm_retrans(slot, flags, snd_nxt, payload, payload_len)
    else:
        # Retransmit path — refresh the timer; retries already bumped
        # by _tcp_check_retrans.
        tcp_slot_last_send[slot] = get_jiffies()
    return rc


# Scratch for parsed incoming SACK blocks (sender side). Filled by
# _tcp_parse_options; consumed by the ESTABLISHED ACK path which uses
# them to retransmit only the genuinely-missing segment. Flat: 2*N
# entries (left,right) — top-level BSS (no function-local arrays).
tcp_rx_sack_n:     uint64 = 0
tcp_rx_sack_left:  Array[8, uint32]
tcp_rx_sack_right: Array[8, uint32]


def _tcp_parse_options(payload: Ptr[uint8], hdr_bytes: uint64,
                       want_mss: Ptr[uint16],
                       want_wscale: Ptr[uint8],
                       saw_wscale: Ptr[uint8],
                       saw_sack_perm: Ptr[uint8]):
    # Walk the TCP options region [20, hdr_bytes) of an incoming segment.
    # MSS / WScale / SACK-permitted are reported via out-params (only
    # meaningful on a SYN). Any SACK blocks (kind 5) are decoded into the
    # tcp_rx_sack_* scratch table for the sender-side retransmit chooser.
    want_mss[0] = 0
    want_wscale[0] = 0
    saw_wscale[0] = 0
    saw_sack_perm[0] = 0
    tcp_rx_sack_n = 0
    p: uint64 = 20
    while p < hdr_bytes:
        kind: uint8 = payload[p]
        if kind == TCP_OPT_END:
            p = hdr_bytes                                # end of options
        elif kind == TCP_OPT_NOP:
            p = p + 1
        else:
            if p + 1 >= hdr_bytes:
                p = hdr_bytes
            else:
                olen: uint64 = cast[uint64](payload[p + 1])
                if olen < 2:
                    p = hdr_bytes                        # malformed; stop
                elif p + olen > hdr_bytes:
                    p = hdr_bytes                        # truncated; stop
                else:
                    if kind == TCP_OPT_MSS:
                        if olen == 4:
                            m: uint16 = (cast[uint16](payload[p + 2]) << 8) \
                                | cast[uint16](payload[p + 3])
                            want_mss[0] = m
                    elif kind == TCP_OPT_WSCALE:
                        if olen == 3:
                            want_wscale[0] = payload[p + 2]
                            saw_wscale[0] = 1
                    elif kind == TCP_OPT_SACK_PERM:
                        saw_sack_perm[0] = 1
                    elif kind == TCP_OPT_SACK:
                        # 8 bytes per block.
                        nb: uint64 = (olen - 2) / 8
                        if nb > 8:
                            nb = 8
                        bi: uint64 = 0
                        while bi < nb:
                            bo: uint64 = p + 2 + 8 * bi
                            bl: uint32 = (cast[uint32](payload[bo + 0]) << 24) \
                                | (cast[uint32](payload[bo + 1]) << 16) \
                                | (cast[uint32](payload[bo + 2]) << 8) \
                                | cast[uint32](payload[bo + 3])
                            br: uint32 = (cast[uint32](payload[bo + 4]) << 24) \
                                | (cast[uint32](payload[bo + 5]) << 16) \
                                | (cast[uint32](payload[bo + 6]) << 8) \
                                | cast[uint32](payload[bo + 7])
                            tcp_rx_sack_left[bi] = bl
                            tcp_rx_sack_right[bi] = br
                            bi = bi + 1
                        tcp_rx_sack_n = nb
                    p = p + olen


def tcp_rx(payload: Ptr[uint8], length: uint64,
           src_b0: uint8, src_b1: uint8,
           src_b2: uint8, src_b3: uint8):
    # Parse the incoming TCP segment, look up the matching TCB by
    # (remote_ip, remote_port, local_port), and run the state
    # machine. Caller is ip_rx in ip.ad (proto=6 path).
    tcp_in_segs = tcp_in_segs + 1
    if length < TCP_HDR_LEN:
        printk0("[tcp] runt segment\n")
        return
    # Pull the on-wire fields. Multi-byte values are big-endian on
    # the wire; we byte-swap inline so the rest of the function
    # works in host order.
    sp_hi: uint16 = cast[uint16](payload[0]) << 8
    sp_lo: uint16 = cast[uint16](payload[1])
    src_port: uint16 = sp_hi | sp_lo
    dp_hi: uint16 = cast[uint16](payload[2]) << 8
    dp_lo: uint16 = cast[uint16](payload[3])
    dst_port: uint16 = dp_hi | dp_lo
    seq32: uint32 = (cast[uint32](payload[4]) << 24) | (cast[uint32](payload[5]) << 16) \
        | (cast[uint32](payload[6]) << 8) | cast[uint32](payload[7])
    ack32: uint32 = (cast[uint32](payload[8]) << 24) | (cast[uint32](payload[9]) << 16) \
        | (cast[uint32](payload[10]) << 8) | cast[uint32](payload[11])
    data_off: uint8 = payload[12]
    flags:    uint8 = payload[13]
    win_raw: uint16 = (cast[uint16](payload[14]) << 8) | cast[uint16](payload[15])
    hdr_words: uint64 = cast[uint64]((data_off >> 4) & 0x0F)
    hdr_bytes: uint64 = hdr_words * 4
    if hdr_bytes < TCP_HDR_LEN:
        printk0("[tcp] bogus data_off\n")
        return
    if length < hdr_bytes:
        printk0("[tcp] header truncated\n")
        return

    # Parse TCP options once. MSS / WScale / SACK-permitted matter only
    # on a SYN; any SACK blocks land in the tcp_rx_sack_* scratch table.
    opt_mss:        uint16 = 0
    opt_wscale:     uint8 = 0
    opt_saw_wscale: uint8 = 0
    opt_saw_sackp:  uint8 = 0
    if hdr_bytes > TCP_HDR_LEN:
        _tcp_parse_options(payload, hdr_bytes,
                           &opt_mss, &opt_wscale,
                           &opt_saw_wscale, &opt_saw_sackp)
    else:
        tcp_rx_sack_n = 0

    slot_signed: int32 = _tcp_find_slot(src_b0, src_b1, src_b2, src_b3,
                                        src_port, dst_port)
    if slot_signed < 0:
        # No exact 4-tuple match. If this is a SYN aimed at a port
        # we're listening on (M16.124 passive-open path), allocate a
        # fresh TCB in SYN_RCVD and send the SYN-ACK. Otherwise drop
        # with a diagnostic. Sending a RST would be technically
        # correct (RFC 793 §3.4) but generates noise during smoke
        # tests and confuses port-scanner-style probes.
        if (flags & TCP_SYN) != 0:
            listener_signed: int32 = _tcp_find_listener(dst_port)
            if listener_signed >= 0:
                new_signed: int32 = _tcp_alloc_slot()
                if new_signed < 0:
                    printk1("[tcp] LISTEN port=%d but TCB table full\n",
                            cast[uint64](dst_port))
                    return
                new_slot: uint64 = cast[uint64](new_signed)
                isn_srv: uint32 = _tcp_isn_next()
                # Populate the new TCB. seq32 is the peer's ISN; the
                # SYN consumes one sequence number so rcv_nxt is
                # peer_seq + 1. Our snd_nxt starts at ISN; the SYN-ACK
                # we send carries seq=ISN and bumps snd_nxt to ISN+1
                # afterwards (mirrors the active-open SYN dance).
                tcp_slot_state[new_slot] = TCP_SYN_RECV
                tcp_slot_accepted[new_slot] = 0    # fresh peer, not yet accepted
                tcp_slot_local_p[new_slot] = dst_port
                tcp_slot_remote_p[new_slot] = src_port
                nb: uint64 = new_slot * 4
                tcp_slot_remote_ip[nb + 0] = src_b0
                tcp_slot_remote_ip[nb + 1] = src_b1
                tcp_slot_remote_ip[nb + 2] = src_b2
                tcp_slot_remote_ip[nb + 3] = src_b3
                tcp_slot_snd_nxt[new_slot] = isn_srv
                tcp_slot_snd_una[new_slot] = isn_srv
                tcp_slot_rcv_nxt[new_slot] = seq32 + 1
                tcp_slot_rx_head[new_slot] = 0
                tcp_slot_rx_tail[new_slot] = 0
                tcp_slot_rx_count[new_slot] = 0
                tcp_slot_saw_fin[new_slot] = 0
                tcp_slot_last_act[new_slot] = get_jiffies()
                # Reset retransmission state for the new slot.
                tcp_slot_unacked[new_slot] = 0
                tcp_slot_retries[new_slot] = 0
                tcp_slot_rto[new_slot] = TCP_RTO_INITIAL
                tcp_slot_have_rtt[new_slot] = 0
                tcp_slot_srtt[new_slot] = 0
                tcp_slot_rttvar[new_slot] = 0
                tcp_slot_pend_flags[new_slot] = 0
                tcp_slot_pend_len[new_slot] = 0
                tcp_slot_pend_seq[new_slot] = 0
                # Congestion control + option negotiation for the child.
                _tcp_cc_init(new_slot)
                _tcp_sack_reset(new_slot)
                # WScale: mirror the peer's offer. We advertise our own
                # shift in the SYN-ACK; the negotiation succeeds only if
                # the peer offered one too (RFC 7323 §2.2).
                tcp_slot_rcv_wscale[new_slot] = TCP_RCV_WSCALE
                if opt_saw_wscale != 0:
                    tcp_slot_snd_wscale[new_slot] = opt_wscale
                    tcp_slot_wscale_ok[new_slot] = 1
                else:
                    tcp_slot_snd_wscale[new_slot] = 0
                    tcp_slot_wscale_ok[new_slot] = 0
                # SACK: enabled only if the peer offered SACK-permitted.
                if opt_saw_sackp != 0:
                    tcp_slot_sack_ok[new_slot] = 1
                else:
                    tcp_slot_sack_ok[new_slot] = 0
                # Peer's initial window (unscaled until ESTABLISHED).
                tcp_slot_snd_wnd[new_slot] = cast[uint64](win_raw)
                tcp_slot_parent[new_slot] = cast[uint8](listener_signed)
                printk2("[tcp] SYN -> listen port=%d new slot=%d\n",
                        cast[uint64](dst_port), new_slot)
                # Emit SYN-ACK. seq=isn_srv (snd_nxt), ack=rcv_nxt
                # (peer's seq+1). _tcp_send_segment reads both from
                # the slot, so we just set them up above and call.
                rc_sa: int32 = _tcp_build_and_send(new_slot,
                                                  TCP_SYN | TCP_ACK,
                                                  cast[Ptr[uint8]](0), 0)
                # SYN consumes one byte of sequence space on the wire;
                # advance snd_nxt past it so the expected client ACK
                # is ISN+1.
                tcp_slot_snd_nxt[new_slot] = isn_srv + 1
                if rc_sa == 0:
                    printk2("[tcp] SYN-ACK -> %d.%d.",
                            cast[uint64](src_b0), cast[uint64](src_b1))
                    printk2("%d.%d slot=", cast[uint64](src_b2),
                            cast[uint64](src_b3))
                    printk1("%d\n", new_slot)
                else:
                    printk0("[tcp] SYN-ACK send failed\n")
                return
        printk2("[tcp] no TCB for src_port=%d dst_port=%d\n",
                cast[uint64](src_port), cast[uint64](dst_port))
        return
    slot: uint64 = cast[uint64](slot_signed)
    tcp_slot_last_act[slot] = get_jiffies()

    # If the peer sent RST, blow the TCB away regardless of state.
    if (flags & TCP_RST) != 0:
        tcp_resets_in = tcp_resets_in + 1
        printk1("[tcp] RST on slot=%d -> CLOSED\n", slot)
        tcp_slot_state[slot] = TCP_CLOSED
        # Wake any waiter (connect / recv / send) so it observes the
        # CLOSED state and returns the appropriate error promptly.
        wq_wake_all(&tcp_slot_rx_wq[slot])
        return

    payload_off: uint64 = hdr_bytes
    seg_payload_len: uint64 = length - hdr_bytes
    seg_payload: Ptr[uint8] = cast[Ptr[uint8]](
        cast[uint64](payload) + payload_off)

    state: uint32 = tcp_slot_state[slot]

    # SYN_RCVD: we sent SYN-ACK after a LISTEN match; expect the
    # peer's bare ACK acknowledging our ISN+1 to finish the
    # passive-open three-way handshake. M16.124 path. If the ACK
    # also carries data we hand it to the ESTABLISHED block by
    # falling through after the transition.
    if state == TCP_SYN_RECV:
        if (flags & TCP_ACK) != 0:
            expected_ack_sr: uint32 = tcp_slot_snd_nxt[slot]
            # The peer's final ACK acks our SYN (ISN+1). Normally
            # snd_nxt has already been advanced to ISN+1 by the caller
            # that emitted the SYN-ACK. But over LOOPBACK the whole
            # handshake runs synchronously and re-entrantly: the
            # client's final ACK is delivered (recursively) from inside
            # the very _tcp_build_and_send() that emitted our SYN-ACK,
            # BEFORE the caller's post-send `snd_nxt = ISN+1` line has
            # executed — so snd_nxt is still ISN here. Accept either
            # ISN+1 (already-bumped, normal wire path) or ISN+1 when
            # snd_nxt still reads ISN (loopback re-entrant path).
            if ack32 == expected_ack_sr or ack32 == expected_ack_sr + 1:
                tcp_slot_snd_una[slot] = ack32
                _tcp_clear_pending(slot, ack32)
                tcp_slot_state[slot] = TCP_ESTABLISHED
                # Enqueue on the parent listener's accept backlog so
                # tcp_accept hands children out in arrival order even
                # when several connect concurrently.
                _tcp_accept_enqueue(slot)
                # Wake the tcp_accept waiter blocked on the LISTEN slot:
                # a child connection is now ready to be handed out. The
                # waiter sleeps on the parent listener's own queue.
                parent_b: uint8 = tcp_slot_parent[slot]
                if parent_b != 0xFF:
                    wq_wake_all(&tcp_slot_rx_wq[cast[uint64](parent_b)])
                printk1("[tcp] accepted slot=%d -> ESTABLISHED\n", slot)
                state = TCP_ESTABLISHED
                # Fall through to the ESTABLISHED block below in case
                # this ACK carried data or a FIN tail.
            else:
                printk2("[tcp] SYN_RCVD bad ack=%x exp=%x\n",
                        cast[uint64](ack32),
                        cast[uint64](expected_ack_sr))
                return
        else:
            # No ACK bit set — drop. Spec also allows a duplicate SYN
            # to retrigger the SYN-ACK; we just rely on the peer's
            # own retransmission to resend.
            return

    # SYN_SENT: expect SYN+ACK acknowledging our ISN+1. On match we
    # bump rcv_nxt past the peer's SYN, set snd_una = ack, and
    # transition to ESTABLISHED. The caller's polling loop in
    # tcp_connect emits the final ACK after we return.
    if state == TCP_SYN_SENT:
        if (flags & TCP_SYN) != 0:
            if (flags & TCP_ACK) != 0:
                # The peer's ACK should equal our snd_nxt (= ISN+1).
                # Mirror of the SYN_RCVD loopback fix above: over
                # LOOPBACK the handshake runs synchronously and
                # re-entrantly — the peer's SYN-ACK is delivered
                # (recursively) from inside the very
                # _tcp_build_and_send() that emitted OUR SYN, BEFORE
                # tcp_connect's post-send `snd_nxt = ISN+1` line has
                # executed. So snd_nxt may still read ISN here. Accept
                # either ISN+1 (normal already-bumped wire path) or the
                # received ISN+1 when snd_nxt still reads ISN (loopback
                # re-entrant path).
                expected_ack: uint32 = tcp_slot_snd_nxt[slot]
                if ack32 != expected_ack and ack32 != expected_ack + 1:
                    printk2("[tcp] SYN-ACK bad ack=%x exp=%x\n",
                            cast[uint64](ack32),
                            cast[uint64](expected_ack))
                    return
                tcp_slot_snd_una[slot] = ack32
                # Finalize option negotiation from the SYN-ACK. WScale /
                # SACK succeed only if the peer echoed the option (both
                # sides must offer it).
                if opt_saw_wscale != 0:
                    tcp_slot_snd_wscale[slot] = opt_wscale
                    tcp_slot_wscale_ok[slot] = 1
                else:
                    tcp_slot_snd_wscale[slot] = 0
                    tcp_slot_wscale_ok[slot] = 0
                if opt_saw_sackp != 0:
                    tcp_slot_sack_ok[slot] = 1
                else:
                    tcp_slot_sack_ok[slot] = 0
                # Peer's window (now scaled once negotiation is known).
                if tcp_slot_wscale_ok[slot] != 0:
                    tcp_slot_snd_wnd[slot] = cast[uint64](win_raw) \
                        << tcp_slot_snd_wscale[slot]
                else:
                    tcp_slot_snd_wnd[slot] = cast[uint64](win_raw)
                # Normalize snd_nxt to ISN+1 (= ack32, the peer's ack
                # of our SYN's phantom byte) NOW. On the normal wire
                # path tcp_connect has already done this; on the
                # loopback re-entrant path snd_nxt still reads ISN and
                # the caller's bump runs only AFTER we return — too
                # late for the final ACK we are about to stamp. Forcing
                # it here guarantees the third-leg ACK carries seq=ISN+1
                # so the peer's rcv_nxt lands correctly.
                tcp_slot_snd_nxt[slot] = ack32
                # RTT sample + clear pending-SYN retransmission state.
                _tcp_clear_pending(slot, ack32)
                # rcv_nxt = peer's ISN + 1 (the SYN consumes one
                # sequence number even though it carries no data).
                tcp_slot_rcv_nxt[slot] = seq32 + 1
                # Emit the third leg of the handshake: pure ACK.
                _tcp_build_and_send(slot, TCP_ACK,
                                    cast[Ptr[uint8]](0), 0)
                tcp_slot_state[slot] = TCP_ESTABLISHED
                # Wake the tcp_connect waiter blocked on this slot — the
                # active-open handshake just completed.
                wq_wake_all(&tcp_slot_rx_wq[slot])
                printk1("[tcp] slot=%d -> ESTABLISHED\n", slot)
                return
        # Anything else in SYN_SENT is a protocol error; drop.
        return

    # ESTABLISHED: handle data + FIN. Out-of-order segments (seq32 ahead
    # of rcv_nxt) are no longer silently dropped: when SACK is negotiated
    # we record the block and emit a SACK option so the peer retransmits
    # only the hole (RFC 2018).
    if state == TCP_ESTABLISHED:
        # Track the peer's advertised window (scaled).
        if tcp_slot_wscale_ok[slot] != 0:
            tcp_slot_snd_wnd[slot] = cast[uint64](win_raw) \
                << tcp_slot_snd_wscale[slot]
        else:
            tcp_slot_snd_wnd[slot] = cast[uint64](win_raw)
        if seg_payload_len > 0:
            if seq32 != tcp_slot_rcv_nxt[slot]:
                # Out-of-order arrival. If it sits ABOVE rcv_nxt and SACK
                # is on, record the block and immediately emit a duplicate
                # ACK carrying the SACK option so the sender learns which
                # range we already hold (and which segment is the hole).
                if seq32 > tcp_slot_rcv_nxt[slot]:
                    if tcp_slot_sack_ok[slot] != 0:
                        seg_end: uint32 = seq32 + cast[uint32](seg_payload_len)
                        _tcp_sack_add(slot, seq32, seg_end)
                        printk2("[tcp] slot=%d OoO seg seq=%d -> SACK\n",
                                slot, cast[uint64](seq32))
                        _tcp_build_and_send(slot, TCP_ACK,
                                            cast[Ptr[uint8]](0), 0)
            elif seq32 == tcp_slot_rcv_nxt[slot]:
                # Append the payload into the slot's CIRCULAR RX ring.
                # `tail` is the producer cursor (mod TCP_RX_BUF); the
                # bytes wrap around the end of the slot's window. If the
                # ring genuinely has no room (peer ignored our shrunken
                # advertised window) we DROP the segment and DO NOT
                # advance rcv_nxt — the peer's TCP retransmit resends
                # after RTO. With per-segment free-space window
                # advertisement (_tcp_adv_window) this drop path is now
                # a backstop, not the normal flow.
                free: uint64 = 0
                if tcp_slot_rx_count[slot] < TCP_RX_BUF:
                    free = TCP_RX_BUF - tcp_slot_rx_count[slot]
                if seg_payload_len > free:
                    printk2(
                        "[tcp] slot=%d rx ring full (count=%d), drop seg\n",
                        slot, tcp_slot_rx_count[slot])
                    # No ACK — peer will retransmit when its RTO fires.
                    # Don't advance rcv_nxt or rx_count.
                else:
                    rx_base: uint64 = slot * TCP_RX_BUF
                    tail: uint64 = tcp_slot_rx_tail[slot]
                    i: uint64 = 0
                    while i < seg_payload_len:
                        tcp_slot_rx_data[rx_base + tail] = seg_payload[i]
                        tail = tail + 1
                        if tail >= TCP_RX_BUF:
                            tail = 0
                        i = i + 1
                    tcp_slot_rx_tail[slot] = tail
                    tcp_slot_rx_count[slot] = tcp_slot_rx_count[slot] \
                        + seg_payload_len
                    # Event-driven wake: data just landed in this slot's
                    # ring. Wake any tcp_recv blocked on it (IRQ context
                    # safe). On the fast path this is the rx IRQ → an
                    # instant reader wake with no poll latency.
                    wq_wake_all(&tcp_slot_rx_wq[slot])
                    tcp_slot_rcv_nxt[slot] = seq32 + cast[uint32](seg_payload_len)
                    tcp_in_data = tcp_in_data + seg_payload_len
                    # This in-order arrival may have closed (part of) a
                    # previously-recorded hole — drop SACK blocks now at or
                    # below the new cumulative point.
                    if tcp_slot_sack_ok[slot] != 0:
                        _tcp_sack_drop_below(slot, tcp_slot_rcv_nxt[slot])
                    # Send an ACK back so the peer knows we got the data
                    # (and can release its retransmit buffer).
                    _tcp_build_and_send(slot, TCP_ACK,
                                        cast[Ptr[uint8]](0), 0)
                    printk2("[tcp] slot=%d rx %d bytes\n",
                            slot, seg_payload_len)
        if (flags & TCP_FIN) != 0:
            # Peer half-closed. Advance rcv_nxt past the FIN's
            # phantom byte and remember we saw it so tcp_close can
            # finish the four-way termination.
            tcp_slot_rcv_nxt[slot] = tcp_slot_rcv_nxt[slot] + 1
            tcp_slot_saw_fin[slot] = 1
            # Wake a blocked reader so it observes EOF (saw_fin + empty
            # ring -> tcp_recv returns 0) without waiting for a poll tick.
            wq_wake_all(&tcp_slot_rx_wq[slot])
            printk1("[tcp] FIN on established slot=%d\n", slot)
            # ACK the FIN. We stay ESTABLISHED-like (Linux would go
            # CLOSE_WAIT here) until the local side calls tcp_close.
            _tcp_build_and_send(slot, TCP_ACK,
                                cast[Ptr[uint8]](0), 0)
        if (flags & TCP_ACK) != 0:
            prev_una: uint32 = tcp_slot_snd_una[slot]
            if ack32 > prev_una:
                # Fresh ACK: advance snd_una, grow the congestion window,
                # and clear the duplicate-ACK counter.
                acked: uint64 = cast[uint64](ack32 - prev_una)
                tcp_slot_snd_una[slot] = ack32
                _tcp_cc_on_ack(slot, acked)
                tcp_slot_dupacks[slot] = 0
                # RTT sample + clear retransmission for the data segment.
                _tcp_clear_pending(slot, ack32)
                # Wake a tcp_send waiter blocked for this ACK so it can
                # confirm delivery without a poll tick of latency.
                wq_wake_all(&tcp_slot_rx_wq[slot])
            else:
                # Duplicate / stale ACK. A pure ACK (no data, no window
                # change) that repeats the highest ack# and we still have
                # data in flight is a true RFC 5681 duplicate ACK. Record
                # any SACK blocks it carries (the receiver telling us what
                # it already holds), then run the fast-retransmit machine.
                if ack32 == prev_una:
                    if tcp_slot_unacked[slot] != 0:
                        # Stash incoming SACK blocks into the slot table so
                        # _tcp_sack_covers can consult them.
                        if tcp_slot_sack_ok[slot] != 0:
                            if tcp_rx_sack_n > 0:
                                _tcp_sack_reset(slot)
                                si2: uint64 = 0
                                while si2 < tcp_rx_sack_n:
                                    _tcp_sack_add(slot,
                                                  tcp_rx_sack_left[si2],
                                                  tcp_rx_sack_right[si2])
                                    si2 = si2 + 1
                        do_rtx: int32 = _tcp_cc_on_dupack(slot)
                        if do_rtx == 1:
                            # Fast retransmit: resend ONLY the missing
                            # segment — the one the cumulative ACK still
                            # points at. If a SACK block already covers
                            # it (shouldn't, but be safe) skip the resend.
                            pseq: uint32 = tcp_slot_pend_seq[slot]
                            plen: uint64 = tcp_slot_pend_len[slot]
                            pend2: uint32 = pseq + cast[uint32](plen)
                            covered: int32 = _tcp_sack_covers(slot, pseq, pend2)
                            new_ssthresh: uint64 = tcp_slot_ssthresh[slot]
                            new_cwnd: uint64 = tcp_slot_cwnd[slot]
                            printk2(
                                "[tcp] fast-retransmit slot=%d ssthresh=%d\n",
                                slot, new_ssthresh)
                            printk1("[tcp] fast-recovery cwnd=%d\n", new_cwnd)
                            if covered == 0:
                                _tcp_retransmit(slot)
                            else:
                                printk1(
                                    "[tcp] slot=%d hole already SACKed\n",
                                    slot)
        return

    # FIN_WAIT_1: we sent FIN; expect ACK (-> FIN_WAIT_2) and/or
    # FIN (-> TIME_WAIT). If both arrive in the same segment (common)
    # we collapse straight through TIME_WAIT -> CLOSED.
    if state == TCP_FIN_WAIT_1:
        if (flags & TCP_ACK) != 0:
            if ack32 >= tcp_slot_snd_nxt[slot]:
                tcp_slot_snd_una[slot] = ack32
                _tcp_clear_pending(slot, ack32)
                tcp_slot_state[slot] = TCP_FIN_WAIT_2
                printk1("[tcp] slot=%d -> FIN_WAIT_2\n", slot)
        if (flags & TCP_FIN) != 0:
            # Peer's FIN. ACK it and move to TIME_WAIT (or CLOSING
            # if we haven't seen the ACK of our FIN yet).
            tcp_slot_rcv_nxt[slot] = seq32 + 1
            _tcp_build_and_send(slot, TCP_ACK,
                                cast[Ptr[uint8]](0), 0)
            if tcp_slot_state[slot] == TCP_FIN_WAIT_2:
                tcp_slot_state[slot] = TCP_TIME_WAIT
                printk1("[tcp] slot=%d -> TIME_WAIT\n", slot)
            else:
                tcp_slot_state[slot] = TCP_CLOSING
                printk1("[tcp] slot=%d -> CLOSING\n", slot)
            tcp_slot_saw_fin[slot] = 1
        return

    if state == TCP_FIN_WAIT_2:
        if (flags & TCP_FIN) != 0:
            tcp_slot_rcv_nxt[slot] = seq32 + 1
            _tcp_build_and_send(slot, TCP_ACK,
                                cast[Ptr[uint8]](0), 0)
            tcp_slot_state[slot] = TCP_TIME_WAIT
            tcp_slot_saw_fin[slot] = 1
            printk1("[tcp] slot=%d -> TIME_WAIT\n", slot)
        return

    if state == TCP_CLOSING:
        if (flags & TCP_ACK) != 0:
            if ack32 >= tcp_slot_snd_nxt[slot]:
                _tcp_clear_pending(slot, ack32)
                tcp_slot_state[slot] = TCP_TIME_WAIT
                printk1("[tcp] slot=%d -> TIME_WAIT\n", slot)
        return

    if state == TCP_LAST_ACK:
        if (flags & TCP_ACK) != 0:
            if ack32 >= tcp_slot_snd_nxt[slot]:
                _tcp_clear_pending(slot, ack32)
                tcp_slot_state[slot] = TCP_CLOSED
                printk1("[tcp] slot=%d -> CLOSED (last-ack)\n", slot)
        return

    # TIME_WAIT / CLOSED: ignore (or RST if it's not a stale dup).
    return


def tcp_connect(remote_b0: uint8, remote_b1: uint8,
                remote_b2: uint8, remote_b3: uint8,
                remote_port: uint16,
                timeout_jiffies: uint64) -> int32:
    # Active-open. Allocate a TCB, pick an ISN, send SYN, poll until
    # the SYN-ACK arrives (or the deadline elapses), send the final
    # ACK, transition to ESTABLISHED. Returns slot index on success,
    # -1 on timeout / no free slot / send failure.
    slot_signed: int32 = _tcp_alloc_slot()
    if slot_signed < 0:
        printk0("[tcp] no free slot for connect\n")
        return TCP_ERR_NOSLOT
    slot: uint64 = cast[uint64](slot_signed)
    # On-link destinations (same /24 as our IP) need their own ARP
    # entry before ip_send can find a destination MAC; off-link
    # ones are routed via the gateway whose MAC was cached during
    # M16.88's ARP probe. We use the same /24 heuristic as
    # ip._ip_in_subnet — good enough for SLIRP and any other
    # /24-shaped layout we encounter pre-DHCP-classful-routing.
    if ip_have_our_ip() == 1:
        if ip_our_ip_b(0) == remote_b0:
            if ip_our_ip_b(1) == remote_b1:
                if ip_our_ip_b(2) == remote_b2:
                    if _tcp_prime_arp(remote_b0, remote_b1,
                                      remote_b2, remote_b3) != 0:
                        printk0("[tcp] ARP for target timed out\n")
                        return TCP_ERR_ARP
    isn: uint32 = _tcp_isn_next()
    # Rotate the ephemeral source port — see _tcp_ephemeral_next.
    # Back-to-back connects to the same server now present distinct
    # 4-tuples even when _tcp_alloc_slot keeps handing back slot 0.
    local_port: uint16 = _tcp_ephemeral_next()

    tcp_slot_state[slot] = TCP_SYN_SENT
    tcp_slot_local_p[slot] = local_port
    tcp_slot_remote_p[slot] = remote_port
    base: uint64 = slot * 4
    tcp_slot_remote_ip[base + 0] = remote_b0
    tcp_slot_remote_ip[base + 1] = remote_b1
    tcp_slot_remote_ip[base + 2] = remote_b2
    tcp_slot_remote_ip[base + 3] = remote_b3
    # snd_nxt advances past the SYN's phantom byte immediately so
    # the expected SYN-ACK ack value is ISN+1.
    tcp_slot_snd_nxt[slot] = isn + 1
    tcp_slot_snd_una[slot] = isn
    tcp_slot_rcv_nxt[slot] = 0
    tcp_slot_rx_head[slot] = 0
    tcp_slot_rx_tail[slot] = 0
    tcp_slot_rx_count[slot] = 0
    tcp_slot_saw_fin[slot] = 0
    tcp_slot_last_act[slot] = get_jiffies()
    # Fresh per-slot retransmission state. A slot just returned to
    # the pool by tcp_close can carry stale RTO / RTT / pending-
    # segment fields; wipe ALL of them here so nothing leaks into
    # the new connection on this slot. The first SYN we send gets
    # armed by _tcp_send_segment; if no SYN-ACK comes back the
    # connect-side polling loop fires _tcp_check_retrans.
    tcp_slot_unacked[slot] = 0
    tcp_slot_retries[slot] = 0
    tcp_slot_rto[slot] = TCP_RTO_INITIAL
    tcp_slot_have_rtt[slot] = 0
    tcp_slot_srtt[slot] = 0
    tcp_slot_rttvar[slot] = 0
    tcp_slot_last_send[slot] = 0
    tcp_slot_pend_flags[slot] = 0
    tcp_slot_pend_len[slot] = 0
    tcp_slot_pend_seq[slot] = 0
    # Fresh congestion control / option-negotiation state. wscale_ok and
    # sack_ok start 0 and latch only if the SYN-ACK echoes the options.
    # We DO advertise our own WScale + SACK-permitted in the SYN below
    # (the SYN-segment option builder in _tcp_send_segment is
    # unconditional on SYN), so the negotiation is symmetric.
    _tcp_cc_init(slot)
    _tcp_sack_reset(slot)
    tcp_slot_snd_wscale[slot] = 0
    tcp_slot_rcv_wscale[slot] = TCP_RCV_WSCALE
    tcp_slot_wscale_ok[slot] = 0
    tcp_slot_sack_ok[slot] = 0
    tcp_slot_snd_wnd[slot] = TCP_DEFAULT_WIN
    tcp_slot_parent[slot] = 0xFF
    # The SYN segment we transmit needs seq=ISN. We temporarily set
    # snd_nxt back to ISN for the build, then restore +1.
    tcp_slot_snd_nxt[slot] = isn
    printk2("[tcp] slot=%d connect -> port=%d\n",
            slot, cast[uint64](remote_port))
    rc: int32 = _tcp_build_and_send(slot, TCP_SYN,
                                    cast[Ptr[uint8]](0), 0)
    tcp_slot_snd_nxt[slot] = isn + 1
    if rc != 0:
        printk0("[tcp] SYN send failed\n")
        tcp_slot_state[slot] = TCP_CLOSED
        return TCP_ERR_NOSLOT

    # Poll until ESTABLISHED or timeout. tcp_rx flips the state.
    # On each iteration also nudge _tcp_check_retrans so the SYN
    # gets retransmitted when its RTO expires — RFC 6298 §5 path.
    start: uint64 = get_jiffies()
    deadline: uint64 = start + timeout_jiffies
    while get_jiffies() < deadline:
        virtio_net_poll()
        if tcp_slot_state[slot] == TCP_ESTABLISHED:
            return cast[int32](slot)
        if tcp_slot_state[slot] == TCP_CLOSED:
            # Got a RST while waiting for SYN-ACK.
            printk0("[tcp] connect refused\n")
            return TCP_ERR_REFUSED
        rtx: int32 = _tcp_check_retrans(slot)
        if rtx < 0:
            # Exceeded TCP_MAX_RETRIES — give up early. No SYN-ACK
            # ever came back, so this is a timeout, not a refusal.
            tcp_slot_state[slot] = TCP_CLOSED
            return TCP_ERR_TIMEOUT
        # Event-driven SYN-ACK wait. tcp_rx wakes us the instant the
        # state flips to ESTABLISHED (or CLOSED on RST). The bounded
        # ~1-tick commit is BOTH the TCG fallback (re-poll if no rx IRQ)
        # AND what keeps _tcp_check_retrans's RTO ticking: each timeout
        # loop re-fires the retransmit check, so SYN retransmit-on-RTO
        # still works exactly as before. jiffies advances during the
        # sti;hlt in wq_wait_commit_timeout, so the deadline still elapses.
        wq_wait_prepare(&tcp_slot_rx_wq[slot])
        if tcp_slot_state[slot] == TCP_ESTABLISHED \
                or tcp_slot_state[slot] == TCP_CLOSED:
            wq_wait_cancel(&tcp_slot_rx_wq[slot])
        else:
            wrc: int32 = wq_wait_commit_timeout(&tcp_slot_rx_wq[slot], 1)
            if wrc == WQ_EINTR:
                tcp_slot_state[slot] = TCP_CLOSED
                return TCP_ERR_TIMEOUT
    printk1("[tcp] connect timeout on slot=%d\n", slot)
    tcp_slot_state[slot] = TCP_CLOSED
    return TCP_ERR_TIMEOUT


def tcp_send(slot_signed: int32, buf: Ptr[uint8],
             length: uint64) -> int64:
    # Send a single data segment from the slot's snd_nxt. Bumps
    # snd_nxt by `length` immediately (segment counted as in-flight)
    # and polls for the ACK up to ~1 second. Returns the number of
    # bytes accepted by the peer (== length on success) or -1.
    if slot_signed < 0:
        return -1
    slot: uint64 = cast[uint64](slot_signed)
    if slot >= TCP_NUM_SLOTS:
        return -1
    if tcp_slot_state[slot] != TCP_ESTABLISHED:
        printk1("[tcp] send on non-established slot=%d\n", slot)
        return -1
    if length == 0:
        return 0
    if length > TCP_MSS:
        # Truncate — single-segment-at-a-time API. Caller can loop.
        length = TCP_MSS
    target_ack: uint32 = tcp_slot_snd_nxt[slot] + cast[uint32](length)
    rc: int32 = _tcp_build_and_send(slot, TCP_ACK | TCP_PSH,
                                    buf, length)
    if rc != 0:
        return -1
    tcp_slot_snd_nxt[slot] = target_ack
    # Poll for the ACK. SLIRP turns segments around in well under
    # 10 ms; on real wires _tcp_check_retrans fires the RFC 6298
    # retransmit when the per-slot RTO expires. Deadline runs long
    # enough to cover the full exponential backoff cap of 5 retries
    # (1+2+4+8+16+32 = 63 RTOs ≈ 63 s in the worst case); 1200
    # jiffies = 12 s is a compromise that catches the first 4..5
    # backoff bounces without dragging the smoke test under SLIRP.
    start: uint64 = get_jiffies()
    deadline: uint64 = start + 1200
    while get_jiffies() < deadline:
        virtio_net_poll()
        if tcp_slot_snd_una[slot] >= target_ack:
            return cast[int64](length)
        if tcp_slot_state[slot] == TCP_CLOSED:
            return -1
        rtx: int32 = _tcp_check_retrans(slot)
        if rtx < 0:
            # Exceeded TCP_MAX_RETRIES — peer has gone dark.
            return -1
        # Event-driven ACK wait. tcp_rx wakes us when a fresh ACK
        # advances snd_una. Bounded ~1-tick commit re-fires
        # _tcp_check_retrans (RFC 6298 backoff intact) and serves as the
        # TCG re-poll fallback.
        wq_wait_prepare(&tcp_slot_rx_wq[slot])
        if tcp_slot_snd_una[slot] >= target_ack \
                or tcp_slot_state[slot] == TCP_CLOSED:
            wq_wait_cancel(&tcp_slot_rx_wq[slot])
        else:
            wrc: int32 = wq_wait_commit_timeout(&tcp_slot_rx_wq[slot], 1)
            if wrc == WQ_EINTR:
                return -1
    # Even with retransmit we couldn't get an ACK. Return -1 so the
    # caller can distinguish a lost segment from a clean send.
    printk1("[tcp] send ACK timeout slot=%d\n", slot)
    return -1


def tcp_recv(slot_signed: int32, buf: Ptr[uint8],
             max_len: uint64, timeout_jiffies: uint64) -> int64:
    # Block (well, poll) until the slot's rx ring has bytes, then copy
    # up to `max_len` from [head..tail) into `buf` and advance head.
    # If the read drains the ring (head == tail) both pointers reset
    # to 0 so the next append starts from offset zero. Returns bytes
    # copied, 0 on EOF (peer FIN'd with no pending data), or -1 on
    # error. V5.3: ring-backed, so accumulated multi-segment data
    # (think: TLS handshake split across two TCP segments) survives a
    # virtio_net_poll cycle without overwrite.
    if slot_signed < 0:
        return -1
    slot: uint64 = cast[uint64](slot_signed)
    if slot >= TCP_NUM_SLOTS:
        return -1
    state: uint32 = tcp_slot_state[slot]
    if state != TCP_ESTABLISHED:
        if tcp_slot_rx_count[slot] == 0:
            return -1
    # Bound the poll by a REAL WALL-CLOCK deadline read off the free-
    # running PIT counter (pit_monotonic_us). tcp_recv runs from
    # userland-syscall context (read(2) on a socket fd) with CPU
    # interrupts IF-masked, so the LAPIC timer never ticks and `jiffies`
    # is frozen for the whole call — a `while get_jiffies() < deadline`
    # loop degenerates into `while True`. A pre-fix attempt used a fixed
    # ITERATION COUNT instead, but that is CPU-speed-dependent and far
    # too short for real-internet RTT: against a live CDN the 500k-iter
    # budget elapsed in a few ms — well before the mirror's response
    # crossed the wire — so apt's HTTPS read returned a spurious EOF.
    # The 8254 PIT channel-0 counter keeps running regardless of IF, so
    # pit_monotonic_us() gives us a true microsecond clock here. The
    # caller's `timeout_jiffies` is the intended wait in jiffies
    # (HZ=100 -> 10 ms each); convert to a microsecond budget.
    budget_us: uint64 = timeout_jiffies * 10000
    if budget_us == 0:
        budget_us = 5000000                       # 5 s default
    start_us: uint64 = pit_monotonic_us()
    while True:
        # Pump the rx ring once. On the fast path the IRQ has already
        # deposited (and woken us); this re-check covers an IF=0 window
        # and the very first pass. The two-phase wq wait below closes the
        # lost-wakeup race: we re-check rx_count AFTER linking onto the
        # queue, so a deposit-and-wake landing between the check and the
        # sleep cannot be missed.
        virtio_net_poll()
        avail: uint64 = tcp_slot_rx_count[slot]
        if avail > 0:
            n: uint64 = avail
            if n > max_len:
                n = max_len
            # Copy from the CIRCULAR ring starting at `head`, wrapping
            # at the slot's window boundary.
            rx_base: uint64 = slot * TCP_RX_BUF
            head: uint64 = tcp_slot_rx_head[slot]
            i: uint64 = 0
            while i < n:
                buf[i] = tcp_slot_rx_data[rx_base + head]
                head = head + 1
                if head >= TCP_RX_BUF:
                    head = 0
                i = i + 1
            tcp_slot_rx_head[slot] = head
            was_full: int32 = 0
            if avail >= TCP_RX_BUF:
                was_full = 1
            tcp_slot_rx_count[slot] = avail - n
            # Window-update ACK: draining the ring just enlarged the
            # free space we can advertise. If the ring had been full
            # (advertised window 0), the peer is parked waiting for a
            # window update — send an ACK now so it resumes. (When the
            # ring was not full the peer is still sending and our
            # per-segment ACKs already carry the fresh window, so this
            # extra ACK is only needed on the full -> not-full edge.)
            if was_full != 0 and tcp_slot_state[slot] == TCP_ESTABLISHED:
                _tcp_build_and_send(slot, TCP_ACK,
                                    cast[Ptr[uint8]](0), 0)
            return cast[int64](n)
        if tcp_slot_saw_fin[slot] != 0:
            if tcp_slot_rx_count[slot] == 0:
                return 0
        if tcp_slot_state[slot] == TCP_CLOSED:
            return -1
        # If a previous tcp_send still has an unacked segment in
        # flight when the user dropped into tcp_recv, fire the RTO
        # path from here too — otherwise a server that ACKs only
        # after responding would starve our retransmit.
        rtx: int32 = _tcp_check_retrans(slot)
        if rtx < 0:
            return -1
        # Wall-clock deadline check off the free-running PIT counter.
        if pit_monotonic_us() - start_us >= budget_us:
            return 0                      # treat timeout-with-no-data as 0
        # Event-driven block: sleep on the slot's rx wait queue instead
        # of spin-polling. The rx IRQ (virtio_net_poll -> tcp_rx deposit)
        # calls wq_wake_all(&tcp_slot_rx_wq[slot]) the instant data lands,
        # so a working IRQ gives us a zero-latency wake (fast path). The
        # two-phase prepare/recheck closes the lost-wakeup window: after
        # we link onto the queue we RE-CHECK the ring; a deposit racing in
        # between the top-of-loop check and the sleep is caught here.
        #
        # TCG fallback (option a): wq_wait_commit_timeout sleeps at most
        # ~1 tick; if no rx IRQ ever fires (emulated MSI-X drops), the
        # 100 Hz timer wakes us via WQ_TIMEOUT and we loop back to
        # virtio_net_poll() — degrading to today's poll, never wedging.
        wq_wait_prepare(&tcp_slot_rx_wq[slot])
        # Re-check the wake conditions now that we are queued. If any is
        # already true, cancel the wait and loop to handle it at the top.
        if tcp_slot_rx_count[slot] > 0 \
                or tcp_slot_saw_fin[slot] != 0 \
                or tcp_slot_state[slot] == TCP_CLOSED:
            wq_wait_cancel(&tcp_slot_rx_wq[slot])
        else:
            wrc: int32 = wq_wait_commit_timeout(&tcp_slot_rx_wq[slot], 1)
            if wrc == WQ_EINTR:
                # Interrupted by a signal — abort the blocking read.
                return -1


def tcp_slot_at_eof(slot_signed: int32) -> int32:
    # Returns 1 iff the slot has truly reached end-of-stream: the peer
    # sent a FIN and the rx ring is fully drained, OR the slot is
    # CLOSED. Returns 0 for a live ESTABLISHED slot that simply has no
    # data buffered this instant. Used by vfs_read's FD_SOCKET arm to
    # tell a real EOF apart from a poll that found the ring momentarily
    # empty — without this a non-blocking read of 0 bytes would be
    # mis-latched as a permanent socket close.
    if slot_signed < 0:
        return 1
    slot: uint64 = cast[uint64](slot_signed)
    if slot >= TCP_NUM_SLOTS:
        return 1
    if tcp_slot_state[slot] == TCP_CLOSED:
        return 1
    if tcp_slot_saw_fin[slot] != 0:
        if tcp_slot_rx_count[slot] == 0:
            return 1
    return 0


def tcp_recv_nb(slot_signed: int32, buf: Ptr[uint8],
                max_len: uint64) -> int64:
    # Non-blocking receive. Pumps virtio_net_poll() once so freshly
    # arrived segments land in the ring, then copies whatever is
    # buffered. Returns >0 bytes copied, 0 if the slot is still live
    # but has nothing buffered ("would block"), or -1 on a true EOF
    # (peer FIN + drained ring) or a CLOSED slot. This is the building
    # block behind SYS_READ_NB for socket fds — an event-loop daemon
    # can poll the socket without the 5 s blocking budget tcp_recv
    # imposes.
    if slot_signed < 0:
        return -1
    slot: uint64 = cast[uint64](slot_signed)
    if slot >= TCP_NUM_SLOTS:
        return -1
    virtio_net_poll()
    avail: uint64 = tcp_slot_rx_count[slot]
    if avail > 0:
        n: uint64 = avail
        if n > max_len:
            n = max_len
        rx_base: uint64 = slot * TCP_RX_BUF
        head: uint64 = tcp_slot_rx_head[slot]
        i: uint64 = 0
        while i < n:
            buf[i] = tcp_slot_rx_data[rx_base + head]
            head = head + 1
            if head >= TCP_RX_BUF:
                head = 0
            i = i + 1
        tcp_slot_rx_head[slot] = head
        was_full: int32 = 0
        if avail >= TCP_RX_BUF:
            was_full = 1
        tcp_slot_rx_count[slot] = avail - n
        if was_full != 0 and tcp_slot_state[slot] == TCP_ESTABLISHED:
            _tcp_build_and_send(slot, TCP_ACK, cast[Ptr[uint8]](0), 0)
        return cast[int64](n)
    if tcp_slot_saw_fin[slot] != 0:
        return -1
    if tcp_slot_state[slot] == TCP_CLOSED:
        return -1
    return 0


def tcp_recv_pending(slot_signed: int32) -> int32:
    # Non-destructive readiness probe for poll(2) / epoll(7). Pumps
    # virtio_net once so freshly arrived segments land, then reports
    # WITHOUT consuming any bytes:
    #   1  — data buffered, or peer FIN / CLOSED (a read would return
    #        bytes-or-EOF immediately; level-triggered epoll treats both
    #        as "readable")
    #   0  — slot live but empty ("would block")
    # The Layer-2 epoll/poll shim (linux_abi/u_epoll.ad via fs/vfs.ad)
    # needs this because tcp_recv_nb is destructive — epoll_wait must be
    # able to re-report a still-readable fd on every wait without
    # draining the socket.
    if slot_signed < 0:
        return 1
    slot: uint64 = cast[uint64](slot_signed)
    if slot >= TCP_NUM_SLOTS:
        return 1
    virtio_net_poll()
    if tcp_slot_rx_count[slot] > 0:
        return 1
    if tcp_slot_saw_fin[slot] != 0:
        return 1
    if tcp_slot_state[slot] == TCP_CLOSED:
        return 1
    return 0


def tcp_close(slot_signed: int32) -> int32:
    # Active close: send FIN, wait for peer's ACK + FIN, send the
    # final ACK, return to CLOSED. Slot becomes reusable.
    if slot_signed < 0:
        return -1
    slot: uint64 = cast[uint64](slot_signed)
    if slot >= TCP_NUM_SLOTS:
        return -1
    state: uint32 = tcp_slot_state[slot]
    if state == TCP_CLOSED:
        return 0
    # If the peer already FIN'd us (CLOSE_WAIT-shape from the rx
    # path), we send FIN then move LAST_ACK -> CLOSED on the next
    # ACK. Otherwise standard FIN_WAIT_1 path.
    saw_fin: uint8 = tcp_slot_saw_fin[slot]
    # Emit FIN. seq = current snd_nxt; the FIN consumes one byte of
    # sequence space, so snd_nxt bumps by 1 immediately.
    rc: int32 = _tcp_build_and_send(slot, TCP_ACK | TCP_FIN,
                                    cast[Ptr[uint8]](0), 0)
    if rc != 0:
        printk0("[tcp] FIN send failed\n")
        # Force CLOSED locally — we can't reach the peer anyway.
        tcp_slot_state[slot] = TCP_CLOSED
        return -1
    tcp_slot_snd_nxt[slot] = tcp_slot_snd_nxt[slot] + 1
    if saw_fin != 0:
        tcp_slot_state[slot] = TCP_LAST_ACK
    else:
        tcp_slot_state[slot] = TCP_FIN_WAIT_1
    # Poll until CLOSED or TIME_WAIT (treat TIME_WAIT as CLOSED for
    # the slot-free purpose — we don't honor the 2*MSL quiet period
    # because tcp_connect rotates the ephemeral source port on every
    # active-open: the next connection on this slot uses a fresh
    # port, so its 4-tuple can't collide with this just-closed one
    # and there's no straggling-segment window the slot must absorb).
    #
    # FIN_WAIT_2 timeout (RFC 793 §3.5 / RFC 7414 §2.17): if the
    # peer ACKs our FIN but never sends its own FIN (common with
    # half-open servers that block instead of closing — e.g. a
    # Python server that just `recv` and never `close()`), we'd
    # otherwise wait forever for a FIN that isn't coming. Bound the
    # wait at ~5 s. On expiry we go DIRECTLY to CLOSED (not
    # TIME_WAIT) because the peer never sent FIN; there's no
    # straggling-FIN window to absorb. Slot is reusable immediately.
    #
    # Why iteration-count, not get_jiffies():  the existing
    # marker-gated smokes (and tcp_close from the boot-time
    # net_smoke_test) run BEFORE any code path enables CPU
    # interrupts via sti — local_irq_enable is only ever invoked
    # from yield_to_others / the linux_abi exec stub, both
    # post-sched_init. The LAPIC timer is *programmed* by
    # lapic_calibrate_and_setup_timer but its interrupt is
    # IF-blocked at the CPU, so jiffies never tick during synchronous
    # in-kernel smokes. A `while get_jiffies() < deadline` loop in
    # that phase becomes effectively `while True` if no inbound
    # packet flips the state — which is exactly the FIN_WAIT_2
    # half-open shape. The free-running 8254 PIT counter keeps
    # advancing regardless of EFLAGS.IF, so pit_monotonic_us() gives a
    # real microsecond clock here (a fixed iteration count would be
    # CPU-speed-dependent — the same flaw the tcp_recv path hit). Bound
    # the close wait at ~5 s of real wall-clock time.
    close_budget_us: uint64 = 5000000             # 5 s
    close_start_us: uint64 = pit_monotonic_us()
    while True:
        virtio_net_poll()
        s: uint32 = tcp_slot_state[slot]
        if s == TCP_CLOSED:
            tcp_slot_state[slot] = TCP_CLOSED
            printk1("[tcp] closed slot=%d\n", slot)
            return 0
        if s == TCP_TIME_WAIT:
            tcp_slot_state[slot] = TCP_CLOSED
            printk1("[tcp] closed slot=%d\n", slot)
            return 0
        rtx: int32 = _tcp_check_retrans(slot)
        if rtx < 0:
            # Peer dropped off the wire — slot is dead.
            tcp_slot_state[slot] = TCP_CLOSED
            return 0
        if pit_monotonic_us() - close_start_us >= close_budget_us:
            break                                 # fall through to timeout
    # Timed out. Distinguish FIN_WAIT_2 (peer ACK'd our FIN, never
    # sent theirs — half-open) from FIN_WAIT_1 (peer never ACK'd
    # our FIN — totally unresponsive) so the diagnostic is precise.
    # Either way we force CLOSED so the slot is reusable.
    final_state: uint32 = tcp_slot_state[slot]
    if final_state == TCP_FIN_WAIT_2:
        printk1("[tcp] FIN_WAIT_2 timeout slot=%d\n", slot)
    else:
        printk1("[tcp] close timeout on slot=%d (forcing CLOSED)\n", slot)
    tcp_slot_state[slot] = TCP_CLOSED
    return 0


def tcp_listen(local_port: uint16) -> int32:
    # Passive open. Allocate a TCB, mark it LISTEN, bind it to
    # `local_port`. Returns the listener slot index, or -1 if no
    # slot was free (all 8 already used by active connections or
    # other listeners). The listener slot is a wildcard on
    # (remote_ip, remote_port); incoming SYNs at local_port spawn
    # new TCBs in SYN_RCVD via tcp_rx.
    #
    # Sizing caveat: with TCP_NUM_SLOTS=8, one listener + 7
    # connections is the practical cap. A real socket layer would
    # decouple the accept queue from the active-connection table;
    # that's deferred until Phase F's /net/tcp/clone shape.
    slot_signed: int32 = _tcp_alloc_slot()
    if slot_signed < 0:
        printk1("[tcp] listen port=%d: no free slot\n",
                cast[uint64](local_port))
        return -1
    slot: uint64 = cast[uint64](slot_signed)
    tcp_slot_state[slot] = TCP_LISTEN
    tcp_slot_local_p[slot] = local_port
    tcp_slot_remote_p[slot] = 0
    base: uint64 = slot * 4
    tcp_slot_remote_ip[base + 0] = 0
    tcp_slot_remote_ip[base + 1] = 0
    tcp_slot_remote_ip[base + 2] = 0
    tcp_slot_remote_ip[base + 3] = 0
    tcp_slot_snd_nxt[slot] = 0
    tcp_slot_snd_una[slot] = 0
    tcp_slot_rcv_nxt[slot] = 0
    tcp_slot_rx_head[slot] = 0
    tcp_slot_rx_tail[slot] = 0
    tcp_slot_rx_count[slot] = 0
    tcp_slot_saw_fin[slot] = 0
    tcp_slot_unacked[slot] = 0
    tcp_slot_retries[slot] = 0
    tcp_slot_pend_flags[slot] = 0
    tcp_slot_pend_len[slot] = 0
    tcp_slot_pend_seq[slot] = 0
    # Fresh accept backlog for this listener.
    tcp_slot_acc_head[slot] = 0
    tcp_slot_acc_tail[slot] = 0
    tcp_slot_acc_count[slot] = 0
    tcp_slot_parent[slot] = 0xFF
    printk1("[tcp] listening on port=%d\n", cast[uint64](local_port))
    return cast[int32](slot)


def _tcp_accept_enqueue(child: uint64):
    # Append a just-ESTABLISHED passive child onto its parent listener's
    # accept-backlog FIFO. The parent is the LISTEN slot whose local_port
    # matches the child's; tcp_slot_parent was stamped at SYN time. If the
    # backlog ring is full the child is dropped from the queue (it stays
    # ESTABLISHED and tcp_accept's fallback table scan can still find it),
    # mirroring a Linux listen-overflow. Idempotent: a child already on the
    # ring (re-entered ESTABLISHED via a duplicate ACK) is not re-queued.
    par: uint8 = tcp_slot_parent[child]
    if par == 0xFF:
        return
    lslot: uint64 = cast[uint64](par)
    if lslot >= TCP_NUM_SLOTS:
        return
    if tcp_slot_state[lslot] != TCP_LISTEN:
        return
    if tcp_slot_acc_count[lslot] >= TCP_ACCEPT_BACKLOG:
        printk1("[tcp] accept backlog full on listener=%d\n", lslot)
        return
    # Dedup: already queued?
    rb: uint64 = lslot * TCP_ACCEPT_BACKLOG
    cnt: uint64 = tcp_slot_acc_count[lslot]
    hh: uint64 = tcp_slot_acc_head[lslot]
    j: uint64 = 0
    while j < cnt:
        pos: uint64 = hh + j
        if pos >= TCP_ACCEPT_BACKLOG:
            pos = pos - TCP_ACCEPT_BACKLOG
        if tcp_slot_acc_ring[rb + pos] == cast[uint32](child):
            return                                  # already queued
        j = j + 1
    tail: uint64 = tcp_slot_acc_tail[lslot]
    tcp_slot_acc_ring[rb + tail] = cast[uint32](child)
    tail = tail + 1
    if tail >= TCP_ACCEPT_BACKLOG:
        tail = 0
    tcp_slot_acc_tail[lslot] = tail
    tcp_slot_acc_count[lslot] = cnt + 1
    printk2("[tcp] enqueue child=%d on listener=%d backlog\n",
            child, lslot)


def _tcp_accept_dequeue(lslot: uint64) -> int32:
    # Pop the head child off the listener's accept FIFO, skipping any
    # that are no longer ESTABLISHED (closed before accept) or already
    # accepted. Returns the child slot or -1 when the queue is empty.
    rb: uint64 = lslot * TCP_ACCEPT_BACKLOG
    while tcp_slot_acc_count[lslot] > 0:
        head: uint64 = tcp_slot_acc_head[lslot]
        child: uint32 = tcp_slot_acc_ring[rb + head]
        head = head + 1
        if head >= TCP_ACCEPT_BACKLOG:
            head = 0
        tcp_slot_acc_head[lslot] = head
        tcp_slot_acc_count[lslot] = tcp_slot_acc_count[lslot] - 1
        c: uint64 = cast[uint64](child)
        if c < TCP_NUM_SLOTS:
            if tcp_slot_state[c] == TCP_ESTABLISHED:
                if tcp_slot_accepted[c] == 0:
                    return cast[int32](child)
    return -1


def _tcp_accept_ready(lslot: uint64, listen_port: uint16) -> uint64:
    # Non-destructive predicate: is there a child ready for tcp_accept to
    # hand out on this listener? Mirrors tcp_accept's two lookup paths
    # (backlog FIFO + table-scan fallback) but consumes nothing. Used to
    # re-check the accept wait-condition after wq_wait_prepare so a child
    # that reached ESTABLISHED between the top-of-loop scan and our sleep
    # is not missed (the lost-wakeup close).
    rb: uint64 = lslot * TCP_ACCEPT_BACKLOG
    cnt: uint64 = tcp_slot_acc_count[lslot]
    hh: uint64 = tcp_slot_acc_head[lslot]
    j: uint64 = 0
    while j < cnt:
        pos: uint64 = hh + j
        if pos >= TCP_ACCEPT_BACKLOG:
            pos = pos - TCP_ACCEPT_BACKLOG
        c: uint64 = cast[uint64](tcp_slot_acc_ring[rb + pos])
        if c < TCP_NUM_SLOTS:
            if tcp_slot_state[c] == TCP_ESTABLISHED:
                if tcp_slot_accepted[c] == 0:
                    return 1
        j = j + 1
    i: uint64 = 0
    while i < TCP_NUM_SLOTS:
        if i != lslot:
            if tcp_slot_state[i] == TCP_ESTABLISHED:
                if tcp_slot_local_p[i] == listen_port:
                    if tcp_slot_accepted[i] == 0:
                        return 1
        i = i + 1
    return 0


def tcp_accept(listener_slot: int32, timeout_jiffies: uint64) -> int32:
    # Block (well, poll) until a connection completes the three-way
    # handshake on the same local_port as `listener_slot` and
    # transitions to ESTABLISHED. Returns the *new* slot index, or
    # -1 on timeout / bad listener.
    #
    # Primary path: pop the listener's accept-backlog FIFO, which tcp_rx
    # fills in arrival order as each child reaches ESTABLISHED — so N
    # concurrent inbound connections are accepted oldest-first, one per
    # tcp_accept call (a real listen(2) backlog). Fallback: if the FIFO
    # is momentarily empty but a matching ESTABLISHED child exists that
    # was never enqueued (backlog overflow), the linear table scan still
    # finds it so no connection is permanently lost.
    if listener_slot < 0:
        return -1
    lslot: uint64 = cast[uint64](listener_slot)
    if lslot >= TCP_NUM_SLOTS:
        return -1
    if tcp_slot_state[lslot] != TCP_LISTEN:
        return -1
    listen_port: uint16 = tcp_slot_local_p[lslot]
    start: uint64 = get_jiffies()
    deadline: uint64 = start + timeout_jiffies
    while get_jiffies() < deadline:
        virtio_net_poll()
        # 1) Backlog FIFO — arrival-ordered.
        q: int32 = _tcp_accept_dequeue(lslot)
        if q >= 0:
            tcp_slot_accepted[cast[uint64](q)] = 1
            printk1("[tcp] accept returning slot=%d\n", cast[uint64](q))
            return q
        # 2) Fallback table scan (backlog-overflow safety net).
        i: uint64 = 0
        while i < TCP_NUM_SLOTS:
            if i != lslot:
                if tcp_slot_state[i] == TCP_ESTABLISHED:
                    if tcp_slot_local_p[i] == listen_port:
                        if tcp_slot_accepted[i] == 0:
                            tcp_slot_accepted[i] = 1
                            printk1("[tcp] accept returning slot=%d\n", i)
                            return cast[int32](i)
            i = i + 1
        # Event-driven accept wait. A child reaching ESTABLISHED enqueues
        # on this listener's backlog and wakes tcp_slot_rx_wq[lslot] (see
        # the SYN_RECV->ESTABLISHED transition in tcp_rx). We sleep on the
        # listener's own queue. The bounded ~1-tick commit is the TCG
        # fallback (re-poll if no rx IRQ) and the very thing that keeps
        # hamsh (PID 1) scheduled: each timeout opens the IRQ window and,
        # crucially, the sleeper is OFF the runqueue (STATE_WAIT) between
        # ticks so peers run freely — strictly better than the old spin.
        wq_wait_prepare(&tcp_slot_rx_wq[lslot])
        if _tcp_accept_ready(lslot, listen_port) != 0:
            wq_wait_cancel(&tcp_slot_rx_wq[lslot])
        else:
            wrc: int32 = wq_wait_commit_timeout(&tcp_slot_rx_wq[lslot], 1)
            if wrc == WQ_EINTR:
                printk1("[tcp] accept interrupted on listener slot=%d\n",
                        lslot)
                return -1
    printk1("[tcp] accept timeout on listener slot=%d\n", lslot)
    return -1


def tcp_listen_close(listener_slot: int32) -> int32:
    # Tear down a passive (LISTEN) TCB. Unlike tcp_close this sends no
    # FIN — a listener has no peer, so there's nothing to FIN. We just
    # reset the slot to CLOSED so _tcp_alloc_slot can hand it out
    # again. Connections already spawned off the listener (their own
    # TCBs in ESTABLISHED) are untouched — close those via tcp_close.
    # Returns 0 on success, -1 for a bad slot.
    if listener_slot < 0:
        return -1
    slot: uint64 = cast[uint64](listener_slot)
    if slot >= TCP_NUM_SLOTS:
        return -1
    tcp_slot_state[slot] = TCP_CLOSED
    tcp_slot_local_p[slot] = 0
    tcp_slot_remote_p[slot] = 0
    printk1("[tcp] listener slot=%d closed\n", slot)
    return 0


def tcp_listen_smoke_test():
    # M16.124 passive-open smoke test. Listens on port 80 with a
    # short timeout so the boot path keeps moving regardless of
    # whether QEMU has a hostfwd back-channel mapped or not.
    #
    # Expected wire activity when run under scripts/test_net_tcp_listen.sh
    # (which boots QEMU with `-netdev user,hostfwd=tcp::5555-:80`):
    #
    #     [tcp] listening on port=80
    #     [tcp] SYN -> listen port=80 new slot=N
    #     [tcp] SYN-ACK -> <host>.x.y.z slot=N
    #     [tcp] accepted slot=N -> ESTABLISHED   (if client's final ACK arrives)
    #     [tcp] accept returning slot=N
    #
    # Without hostfwd we still emit the listening marker; the test
    # script grades that as half-credit (LISTEN reached but no client
    # to drive SYN-ACK).
    printk0("[tcp] listen smoke test starting\n")
    lslot: int32 = tcp_listen(80)
    if lslot < 0:
        printk0("[tcp] listen failed (TCB table full?)\n")
        return
    # Poll for up to 300 jiffies (3 s @ HZ=100). Plenty for the
    # test script's `nc localhost 5555` to round-trip through SLIRP's
    # hostfwd. With no client we time out cleanly and the listener
    # slot stays in LISTEN — the test script doesn't require accept
    # success, only the LISTEN + SYN-ACK markers.
    conn: int32 = tcp_accept(lslot, 300)
    if conn >= 0:
        printk1("[tcp] accepted connection slot=%d\n",
                cast[uint64](conn))
        # Read whatever the peer sent us (best effort; nc probably
        # already closed by the time we polled). 100 jiffies = 1 s.
        rxbuf: Array[64, uint8]
        rxbuf_ptr: Ptr[uint8] = cast[Ptr[uint8]](&rxbuf[0])
        nrecv: int64 = tcp_recv(conn, rxbuf_ptr, 64, 100)
        if nrecv > 0:
            printk1("[tcp] listener rx %d bytes\n",
                    cast[uint64](nrecv))
        tcp_close(conn)
    else:
        printk0("[tcp] listen smoke: no client (hostfwd unmapped?)\n")
    # Leave the listener slot in LISTEN — it's harmless and the boot
    # path doesn't reuse the slot before reboot.


# ---------------------------------------------------------------------------
# tcp_loopback_smoke_test — in-kernel single-process loopback round-trip.
#
# This test proves the TCP loopback state machine works end-to-end without
# relying on two-process scheduling. It runs entirely within ONE kernel boot
# path invocation, no SLIRP/hostfwd required:
#
#   1. tcp_listen(TEST_PORT)                 → LISTEN slot L
#   2. tcp_connect(127,0,0,1, TEST_PORT, …) → SYN is looped back synchronously
#                                              → _tcp_find_listener finds L
#                                              → SYN-ACK looped back
#                                              → final ACK looped back
#                                              → both sides ESTABLISHED
#   3. tcp_send / tcp_recv data byte each way
#   4. tcp_close both sides
#
# Expected serial output (grep in test_tcp_loopback.sh):
#   [tcp-loopback] ESTABLISHED both sides
#   [tcp-loopback] data round-trip OK
#   [tcp-loopback] PASS
#
# Any failure emits [tcp-loopback] FAIL so the test script can detect it.
#
# Port 6000 is chosen to match the problem description; it is not used by
# any other in-kernel test, so there is no LISTEN-slot clash.

TCP_LOOPBACK_PORT: uint16 = 6000
# Scratch RX buffer for the loopback test — must be top-level BSS (Adder U9
# nested-frame Array quirk), so it is placed here alongside the other
# module-level arrays.
tcp_loopback_rx: Array[16, uint8]

def tcp_loopback_smoke_test():
    printk0("[tcp-loopback] test starting (port=6000)\n")

    # Step 1 — set up the listener.
    lslot: int32 = tcp_listen(TCP_LOOPBACK_PORT)
    if lslot < 0:
        printk0("[tcp-loopback] FAIL: tcp_listen failed (TCB table full?)\n")
        return
    printk1("[tcp-loopback] listen slot=%d\n", cast[uint64](lslot))

    # Step 2 — active open to 127.0.0.1:6000.
    #
    # The SYN is delivered SYNCHRONOUSLY via the loopback shortcut in
    # ip_send → ip_rx → tcp_rx. Because interrupts are disabled during
    # a kernel-context call, the whole three-way handshake (SYN →
    # SYN-ACK → ACK) completes before tcp_connect's polling loop even
    # runs its first iteration. The timeout only matters if the
    # synchronous path fails and a retransmit is needed.
    cslot: int32 = tcp_connect(127, 0, 0, 1, TCP_LOOPBACK_PORT, 300)
    if cslot < 0:
        printk1("[tcp-loopback] FAIL: tcp_connect returned %d\n",
                cast[uint64](cast[uint32](cslot)))
        tcp_listen_close(lslot)
        return

    # Verify the client side is ESTABLISHED.
    if tcp_slot_state[cast[uint64](cslot)] != TCP_ESTABLISHED:
        printk1("[tcp-loopback] FAIL: client slot=%d not ESTABLISHED (state=%d)\n",
                cast[uint64](cslot),
                cast[uint64](tcp_slot_state[cast[uint64](cslot)]))
        tcp_close(cslot)
        tcp_listen_close(lslot)
        return

    # Find the server-side ESTABLISHED slot (the one tcp_accept would return).
    # We don't call tcp_accept (it has a timeout loop) — just scan directly.
    srv_slot: int32 = -1
    si: uint64 = 0
    while si < TCP_NUM_SLOTS:
        if cast[int32](si) != lslot:
            if cast[int32](si) != cslot:
                if tcp_slot_state[si] == TCP_ESTABLISHED:
                    if tcp_slot_local_p[si] == TCP_LOOPBACK_PORT:
                        srv_slot = cast[int32](si)
                        si = TCP_NUM_SLOTS   # break
        si = si + 1

    if srv_slot < 0:
        printk0("[tcp-loopback] FAIL: no ESTABLISHED server slot found\n")
        tcp_close(cslot)
        tcp_listen_close(lslot)
        return

    printk2("[tcp-loopback] client slot=%d server slot=%d\n",
            cast[uint64](cslot), cast[uint64](srv_slot))
    printk0("[tcp-loopback] ESTABLISHED both sides\n")

    # Step 3 — send one byte from client to server, read it back.
    tx_byte: Array[1, uint8]
    tx_byte[0] = 0x42   # 'B'
    tx_ptr: Ptr[uint8] = cast[Ptr[uint8]](&tx_byte[0])
    tx_rc: int64 = tcp_send(cslot, tx_ptr, 1)
    if tx_rc != 1:
        printk1("[tcp-loopback] FAIL: client tcp_send rc=%d\n",
                cast[uint64](cast[uint32](cast[int32](tx_rc))))
        tcp_close(cslot)
        tcp_close(srv_slot)
        tcp_listen_close(lslot)
        return

    rx_ptr: Ptr[uint8] = cast[Ptr[uint8]](&tcp_loopback_rx[0])
    rx_rc: int64 = tcp_recv(srv_slot, rx_ptr, 1, 200)
    if rx_rc != 1 or tcp_loopback_rx[0] != 0x42:
        printk2("[tcp-loopback] FAIL: server tcp_recv rc=%d byte=%d\n",
                cast[uint64](cast[uint32](cast[int32](rx_rc))),
                cast[uint64](tcp_loopback_rx[0]))
        tcp_close(cslot)
        tcp_close(srv_slot)
        tcp_listen_close(lslot)
        return

    # Send one byte from server to client.
    tx_byte[0] = 0x43   # 'C'
    tx_rc2: int64 = tcp_send(srv_slot, tx_ptr, 1)
    if tx_rc2 != 1:
        printk1("[tcp-loopback] FAIL: server tcp_send rc=%d\n",
                cast[uint64](cast[uint32](cast[int32](tx_rc2))))
        tcp_close(cslot)
        tcp_close(srv_slot)
        tcp_listen_close(lslot)
        return

    rx_rc2: int64 = tcp_recv(cslot, rx_ptr, 1, 200)
    if rx_rc2 != 1 or tcp_loopback_rx[0] != 0x43:
        printk2("[tcp-loopback] FAIL: client tcp_recv rc=%d byte=%d\n",
                cast[uint64](cast[uint32](cast[int32](rx_rc2))),
                cast[uint64](tcp_loopback_rx[0]))
        tcp_close(cslot)
        tcp_close(srv_slot)
        tcp_listen_close(lslot)
        return

    printk0("[tcp-loopback] data round-trip OK\n")

    # Step 4 — clean up.  Close server first so its FIN arrives at the client
    # synchronously via loopback while the client is still ESTABLISHED; the
    # client can then close cleanly without polling for the remote FIN.
    tcp_close(srv_slot)
    tcp_close(cslot)
    tcp_listen_close(lslot)
    printk0("[tcp-loopback] PASS\n")


# ---------------------------------------------------------------------------
# tcp_maturity_selftest — #166 data-path maturity self-test.
#
# Exercises the four new features against crafted in-kernel state so the
# assertions are fully deterministic (no SLIRP / wire timing). Prints
# UNFORGEABLE numeric markers the test script greps:
#
#   [tcp-mat] CC: 3 dup-ACKs -> fast retransmit, ssthresh halved, cwnd cut
#   [tcp-mat] WSCALE: negotiated, advertised window > 65535
#   [tcp-mat] SACK: out-of-order block emitted, incoming SACK retransmits hole
#   [tcp-mat] ACCEPT: N concurrent children accepted in order
#   [tcp-mat] PASS   (only if every sub-test passed)
#
# Any failure prints [tcp-mat] FAIL <what> and the function returns early
# without the PASS line.

# Scratch buffers for the WScale wire round-trip — top-level BSS (Adder
# nested-frame Array quirk).
tcp_mat_synbuf:  Array[64, uint8]


def _tcp_mat_clear_slot(slot: uint64):
    # Bring a slot to a clean, CLOSED-but-initialized baseline for the
    # self-test (so stale state from a prior boot path can't leak in).
    tcp_slot_state[slot] = TCP_CLOSED
    tcp_slot_local_p[slot] = 0
    tcp_slot_remote_p[slot] = 0
    tcp_slot_snd_nxt[slot] = 0
    tcp_slot_snd_una[slot] = 0
    tcp_slot_rcv_nxt[slot] = 0
    tcp_slot_unacked[slot] = 0
    tcp_slot_retries[slot] = 0
    tcp_slot_pend_flags[slot] = 0
    tcp_slot_pend_seq[slot] = 0
    tcp_slot_pend_len[slot] = 0
    tcp_slot_accepted[slot] = 0
    _tcp_cc_init(slot)
    _tcp_sack_reset(slot)
    tcp_slot_snd_wscale[slot] = 0
    tcp_slot_rcv_wscale[slot] = TCP_RCV_WSCALE
    tcp_slot_wscale_ok[slot] = 0
    tcp_slot_sack_ok[slot] = 0
    tcp_slot_snd_wnd[slot] = TCP_DEFAULT_WIN
    tcp_slot_parent[slot] = 0xFF
    tcp_slot_acc_head[slot] = 0
    tcp_slot_acc_tail[slot] = 0
    tcp_slot_acc_count[slot] = 0


def tcp_maturity_selftest():
    printk0("[tcp-mat] starting #166 TCP-maturity self-test\n")

    # ------------------------------------------------------------------
    # 1) CONGESTION CONTROL — slow start, then 3 dup-ACK fast retransmit.
    # ------------------------------------------------------------------
    s: uint64 = 0
    _tcp_mat_clear_slot(s)
    tcp_slot_state[s] = TCP_ESTABLISHED
    # Put 10 SMSS in flight: snd_una=1000, snd_nxt=1000+10*536.
    tcp_slot_snd_una[s] = 1000
    tcp_slot_snd_nxt[s] = 1000 + cast[uint32](10 * TCP_SMSS)
    tcp_slot_unacked[s] = 1
    tcp_slot_pend_seq[s] = 1000               # the in-flight (lost) segment
    tcp_slot_pend_len[s] = TCP_SMSS
    tcp_slot_pend_flags[s] = TCP_ACK | TCP_PSH
    # Slow start: cwnd starts at IW (536). One good ACK of 536 bytes
    # should double-ish it to 1072 (exponential growth).
    cwnd0: uint64 = tcp_slot_cwnd[s]
    _tcp_cc_on_ack(s, TCP_SMSS)
    cwnd1: uint64 = tcp_slot_cwnd[s]
    printk2("[tcp-mat] CC slow-start cwnd %d -> %d (one ACK)\n", cwnd0, cwnd1)
    if cwnd1 != cwnd0 + TCP_SMSS:
        printk0("[tcp-mat] FAIL CC slow-start increment\n")
        return
    # Reset in-flight accounting (the good ACK above bumped nothing real;
    # restore the loss scenario).
    tcp_slot_snd_una[s] = 1000
    tcp_slot_cwnd[s] = 10 * TCP_SMSS          # pretend window opened up
    tcp_slot_ssthresh[s] = TCP_SSTHRESH_INIT
    tcp_slot_dupacks[s] = 0
    tcp_slot_in_recov[s] = 0
    flight: uint64 = cast[uint64](tcp_slot_snd_nxt[s] - tcp_slot_snd_una[s])
    expect_ssthresh: uint64 = flight / 2      # max(FlightSize/2, 2*SMSS)
    if expect_ssthresh < 2 * TCP_SMSS:
        expect_ssthresh = 2 * TCP_SMSS
    pre_cwnd: uint64 = tcp_slot_cwnd[s]
    printk2("[tcp-mat] CC before-loss cwnd=%d flight=%d\n", pre_cwnd, flight)
    # Feed three duplicate ACKs.
    d1: int32 = _tcp_cc_on_dupack(s)
    d2: int32 = _tcp_cc_on_dupack(s)
    d3: int32 = _tcp_cc_on_dupack(s)
    fired: int32 = d1 + d2 + d3               # exactly the 3rd returns 1
    post_ssthresh: uint64 = tcp_slot_ssthresh[s]
    post_cwnd: uint64 = tcp_slot_cwnd[s]
    printk2("[tcp-mat] CC dup1=%d dup2=%d\n", cast[uint64](cast[uint32](d1)),
            cast[uint64](cast[uint32](d2)))
    printk2("[tcp-mat] CC dup3=%d fired=%d\n", cast[uint64](cast[uint32](d3)),
            cast[uint64](cast[uint32](fired)))
    printk2("[tcp-mat] CC after-loss ssthresh=%d cwnd=%d\n",
            post_ssthresh, post_cwnd)
    if fired != 1:
        printk0("[tcp-mat] FAIL CC fast-retransmit did not fire on 3rd dupACK\n")
        return
    if post_ssthresh != expect_ssthresh:
        printk2("[tcp-mat] FAIL CC ssthresh=%d expect=%d\n",
                post_ssthresh, expect_ssthresh)
        return
    # cwnd in fast recovery = ssthresh + 3*SMSS, and must be < the
    # pre-loss cwnd (the window was genuinely cut).
    if post_cwnd != post_ssthresh + 3 * TCP_SMSS:
        printk0("[tcp-mat] FAIL CC fast-recovery cwnd value\n")
        return
    if post_cwnd >= pre_cwnd:
        printk0("[tcp-mat] FAIL CC cwnd not reduced below pre-loss\n")
        return
    printk2(
        "[tcp-mat] CC: 3 dup-ACKs -> fast retransmit, ssthresh=%d cwnd=%d\n",
        post_ssthresh, post_cwnd)
    # A fresh ACK now exits recovery, deflating cwnd to ssthresh.
    tcp_slot_snd_una[s] = 1000 + cast[uint32](TCP_SMSS)
    _tcp_cc_on_ack(s, TCP_SMSS)
    if tcp_slot_cwnd[s] != post_ssthresh:
        printk1("[tcp-mat] FAIL CC recovery exit cwnd=%d\n", tcp_slot_cwnd[s])
        return
    printk1("[tcp-mat] CC recovery exit -> cwnd=ssthresh=%d\n",
            tcp_slot_cwnd[s])

    # ------------------------------------------------------------------
    # 2) WINDOW SCALING — advertised window can exceed 65535 bytes.
    # ------------------------------------------------------------------
    _tcp_mat_clear_slot(s)
    tcp_slot_state[s] = TCP_ESTABLISHED
    tcp_slot_wscale_ok[s] = 1
    tcp_slot_rcv_wscale[s] = TCP_RCV_WSCALE
    tcp_slot_rx_count[s] = 0                   # ring empty -> max free space
    # On-wire 16-bit field, scaled down by our shift.
    raw_field: uint16 = _tcp_adv_window_scaled(s)
    # Effective window the peer recovers: raw_field << rcv_wscale.
    eff_win: uint64 = cast[uint64](raw_field) << TCP_RCV_WSCALE
    printk2("[tcp-mat] WSCALE raw16=%d shift=%d\n", cast[uint64](raw_field),
            cast[uint64](TCP_RCV_WSCALE))
    printk1("[tcp-mat] WSCALE effective window=%d bytes\n", eff_win)
    if eff_win <= 65535:
        printk0("[tcp-mat] FAIL WSCALE effective window not > 65535\n")
        return
    # Also prove the SYN option emit -> parse round-trip negotiates it.
    # Build a SYN from slot s into the tx buffer, then parse the option
    # region back out. We point a parser at the emitted segment.
    tcp_slot_remote_p[s] = 6001
    tcp_slot_local_p[s] = 6002
    # Emit a SYN so the option builder lays MSS+WScale+SACK-perm.
    # (ip_send to 127.0.0.1 loops back, but we only need the bytes in
    # tcp_tx_buf; the segment proper starts at tcp_tx_buf[12].)
    tcp_slot_snd_nxt[s] = 5000
    tcp_slot_rcv_nxt[s] = 0
    nb_b0: uint8 = 0
    nb_b1: uint8 = 0
    nb_b2: uint8 = 0
    nb_b3: uint8 = 0
    # Stamp a remote IP of 0.0.0.0 so ip_send drops it (we ignore the
    # send result; only the buffered header matters).
    rbz: uint64 = s * 4
    tcp_slot_remote_ip[rbz + 0] = nb_b0
    tcp_slot_remote_ip[rbz + 1] = nb_b1
    tcp_slot_remote_ip[rbz + 2] = nb_b2
    tcp_slot_remote_ip[rbz + 3] = nb_b3
    _tcp_send_segment(s, TCP_SYN, cast[Ptr[uint8]](0), 0, 1)
    # The TCP segment is at tcp_tx_buf[12..]; header is 20 + 12 opt = 32.
    seg_ptr_m: Ptr[uint8] = cast[Ptr[uint8]](&tcp_tx_buf[12])
    p_mss:    uint16 = 0
    p_wscale: uint8 = 0
    p_sawws:  uint8 = 0
    p_sawsp:  uint8 = 0
    _tcp_parse_options(seg_ptr_m, 32, &p_mss, &p_wscale, &p_sawws, &p_sawsp)
    printk2("[tcp-mat] WSCALE round-trip mss=%d wscale=%d\n",
            cast[uint64](p_mss), cast[uint64](p_wscale))
    if p_sawws != 1 or p_wscale != TCP_RCV_WSCALE:
        printk0("[tcp-mat] FAIL WSCALE option not emitted/parsed\n")
        return
    if p_sawsp != 1:
        printk0("[tcp-mat] FAIL SACK-permitted not emitted in SYN\n")
        return
    if p_mss != cast[uint16](TCP_MSS):
        printk0("[tcp-mat] FAIL MSS option mismatch\n")
        return
    printk1("[tcp-mat] WSCALE: negotiated, advertised window=%d > 65535\n",
            eff_win)

    # ------------------------------------------------------------------
    # 3) SACK — out-of-order receipt emits blocks; incoming SACK selects
    #    only the missing segment for retransmit.
    # ------------------------------------------------------------------
    _tcp_mat_clear_slot(s)
    tcp_slot_state[s] = TCP_ESTABLISHED
    tcp_slot_sack_ok[s] = 1
    tcp_slot_rcv_nxt[s] = 2000                 # cumulative point (hole here)
    # Receiver buffers an out-of-order block [2536, 3072) (the segment
    # after the missing one). Record it.
    _tcp_sack_add(s, 2536, 3072)
    sb: uint64 = s * TCP_SACK_BLOCKS
    if tcp_slot_sack_n[s] != 1:
        printk1("[tcp-mat] FAIL SACK block count=%d\n", tcp_slot_sack_n[s])
        return
    bl0: uint32 = tcp_slot_sack_left[sb + 0]
    br0: uint32 = tcp_slot_sack_right[sb + 0]
    printk2("[tcp-mat] SACK block emitted left=%d right=%d\n",
            cast[uint64](bl0), cast[uint64](br0))
    if bl0 != 2536 or br0 != 3072:
        printk0("[tcp-mat] FAIL SACK block bounds wrong\n")
        return
    # A second OoO arrival adjacent below coalesces into one block.
    _tcp_sack_add(s, 2536, 2600)              # overlaps existing block
    if tcp_slot_sack_n[s] != 1:
        printk0("[tcp-mat] FAIL SACK overlap did not coalesce\n")
        return
    # Now the SENDER side: we have segment [2000,2536) in flight (the
    # hole) and the peer SACKed [2536,3072). _tcp_sack_covers must say
    # the hole is NOT covered (so it gets retransmitted) but the SACKed
    # range IS covered (so it is NOT retransmitted).
    hole_covered: int32 = _tcp_sack_covers(s, 2000, 2536)
    sacked_covered: int32 = _tcp_sack_covers(s, 2536, 3072)
    printk2("[tcp-mat] SACK hole_covered=%d sacked_covered=%d\n",
            cast[uint64](cast[uint32](hole_covered)),
            cast[uint64](cast[uint32](sacked_covered)))
    if hole_covered != 0:
        printk0("[tcp-mat] FAIL SACK reported the hole as already received\n")
        return
    if sacked_covered != 1:
        printk0("[tcp-mat] FAIL SACK did not recognise the SACKed range\n")
        return
    # Drive the wire parser: craft a segment carrying a SACK option for
    # [2536,3072) and confirm _tcp_parse_options decodes it.
    mi: uint64 = 0
    while mi < 64:
        tcp_mat_synbuf[mi] = 0
        mi = mi + 1
    # Minimal TCP header (20) + NOP NOP SACK(kind5,len10, one block) = 32.
    tcp_mat_synbuf[12] = 0x80                  # data_off = 8 words (32 bytes)
    tcp_mat_synbuf[20] = TCP_OPT_NOP
    tcp_mat_synbuf[21] = TCP_OPT_NOP
    tcp_mat_synbuf[22] = TCP_OPT_SACK
    tcp_mat_synbuf[23] = 10                    # 2 + 8*1
    tcp_mat_synbuf[24] = cast[uint8]((2536 >> 24) & 0xFF)
    tcp_mat_synbuf[25] = cast[uint8]((2536 >> 16) & 0xFF)
    tcp_mat_synbuf[26] = cast[uint8]((2536 >> 8) & 0xFF)
    tcp_mat_synbuf[27] = cast[uint8](2536 & 0xFF)
    tcp_mat_synbuf[28] = cast[uint8]((3072 >> 24) & 0xFF)
    tcp_mat_synbuf[29] = cast[uint8]((3072 >> 16) & 0xFF)
    tcp_mat_synbuf[30] = cast[uint8]((3072 >> 8) & 0xFF)
    tcp_mat_synbuf[31] = cast[uint8](3072 & 0xFF)
    sk_ptr: Ptr[uint8] = cast[Ptr[uint8]](&tcp_mat_synbuf[0])
    z1: uint16 = 0
    z2: uint8 = 0
    z3: uint8 = 0
    z4: uint8 = 0
    _tcp_parse_options(sk_ptr, 32, &z1, &z2, &z3, &z4)
    printk1("[tcp-mat] SACK wire-parse blocks=%d\n", tcp_rx_sack_n)
    if tcp_rx_sack_n != 1:
        printk0("[tcp-mat] FAIL SACK wire-parse block count\n")
        return
    if tcp_rx_sack_left[0] != 2536 or tcp_rx_sack_right[0] != 3072:
        printk0("[tcp-mat] FAIL SACK wire-parse bounds\n")
        return
    printk0(
        "[tcp-mat] SACK: out-of-order block emitted, incoming SACK selects hole\n")

    # ------------------------------------------------------------------
    # 4) MULTI-LISTENER ACCEPT QUEUE — N children accepted in arrival
    #    order via the backlog FIFO.
    # ------------------------------------------------------------------
    # Clear ALL slots to baseline so the listener owns a clean backlog.
    ci: uint64 = 0
    while ci < TCP_NUM_SLOTS:
        _tcp_mat_clear_slot(ci)
        ci = ci + 1
    lsl: uint64 = 0
    tcp_slot_state[lsl] = TCP_LISTEN
    tcp_slot_local_p[lsl] = 7000
    tcp_slot_acc_head[lsl] = 0
    tcp_slot_acc_tail[lsl] = 0
    tcp_slot_acc_count[lsl] = 0
    # Three children (slots 1,2,3) reach ESTABLISHED in this order and
    # enqueue onto the listener's backlog.
    nkids: uint64 = 3
    kk: uint64 = 1
    while kk <= nkids:
        tcp_slot_state[kk] = TCP_ESTABLISHED
        tcp_slot_local_p[kk] = 7000
        tcp_slot_accepted[kk] = 0
        tcp_slot_parent[kk] = cast[uint8](lsl)
        _tcp_accept_enqueue(kk)
        kk = kk + 1
    if tcp_slot_acc_count[lsl] != nkids:
        printk1("[tcp-mat] FAIL ACCEPT backlog count=%d\n",
                tcp_slot_acc_count[lsl])
        return
    # Dequeue: must come back 1,2,3 in arrival order.
    in_order: int32 = 1
    expect_child: uint32 = 1
    dq: uint64 = 0
    while dq < nkids:
        got: int32 = _tcp_accept_dequeue(lsl)
        printk2("[tcp-mat] ACCEPT dequeue #%d -> slot=%d\n",
                dq, cast[uint64](cast[uint32](got)))
        if got < 0:
            in_order = 0
            dq = nkids
        else:
            if cast[uint32](got) != expect_child:
                in_order = 0
            tcp_slot_accepted[cast[uint64](got)] = 1
            expect_child = expect_child + 1
            dq = dq + 1
    if in_order != 1:
        printk0("[tcp-mat] FAIL ACCEPT children not dequeued in order\n")
        return
    # Queue is now empty.
    if _tcp_accept_dequeue(lsl) >= 0:
        printk0("[tcp-mat] FAIL ACCEPT queue not empty after N dequeues\n")
        return
    printk1("[tcp-mat] ACCEPT: %d concurrent children accepted in order\n",
            nkids)

    # Restore all slots to CLOSED so this self-test leaves no live TCBs.
    ri: uint64 = 0
    while ri < TCP_NUM_SLOTS:
        _tcp_mat_clear_slot(ri)
        ri = ri + 1

    printk0("[tcp-mat] PASS\n")


def tcp_init():
    tcp_in_segs    = 0
    tcp_out_segs   = 0
    tcp_in_data    = 0
    tcp_out_data   = 0
    tcp_resets_in  = 0
    tcp_resets_out = 0
    tcp_isn_init   = 0
    tcp_isn_state  = 0
    tcp_ephemeral_cur  = 0
    tcp_ephemeral_init = 0
    i: uint64 = 0
    while i < TCP_NUM_SLOTS:
        tcp_slot_state[i] = TCP_CLOSED
        tcp_slot_local_p[i] = 0
        tcp_slot_remote_p[i] = 0
        tcp_slot_snd_nxt[i] = 0
        tcp_slot_snd_una[i] = 0
        tcp_slot_rcv_nxt[i] = 0
        tcp_slot_last_act[i] = 0
        tcp_slot_rx_head[i] = 0
        tcp_slot_rx_tail[i] = 0
        tcp_slot_rx_count[i] = 0
        wq_init(&tcp_slot_rx_wq[i])
        tcp_slot_saw_fin[i] = 0
        tcp_slot_last_send[i] = 0
        tcp_slot_rto[i] = TCP_RTO_INITIAL
        tcp_slot_retries[i] = 0
        tcp_slot_srtt[i] = 0
        tcp_slot_rttvar[i] = 0
        tcp_slot_have_rtt[i] = 0
        tcp_slot_unacked[i] = 0
        tcp_slot_pend_flags[i] = 0
        tcp_slot_pend_seq[i] = 0
        tcp_slot_pend_len[i] = 0
        # #166: congestion control, window scaling, SACK, accept queue.
        tcp_slot_cwnd[i] = TCP_IW
        tcp_slot_ssthresh[i] = TCP_SSTHRESH_INIT
        tcp_slot_dupacks[i] = 0
        tcp_slot_in_recov[i] = 0
        tcp_slot_recov_pt[i] = 0
        tcp_slot_last_ack[i] = 0
        tcp_slot_snd_wscale[i] = 0
        tcp_slot_rcv_wscale[i] = TCP_RCV_WSCALE
        tcp_slot_wscale_ok[i] = 0
        tcp_slot_snd_wnd[i] = TCP_DEFAULT_WIN
        tcp_slot_sack_ok[i] = 0
        tcp_slot_sack_n[i] = 0
        tcp_slot_acc_head[i] = 0
        tcp_slot_acc_tail[i] = 0
        tcp_slot_acc_count[i] = 0
        tcp_slot_parent[i] = 0xFF
        i = i + 1
    j: uint64 = 0
    while j < 32:
        tcp_slot_remote_ip[j] = 0
        tcp_slot_sack_left[j] = 0
        tcp_slot_sack_right[j] = 0
        j = j + 1
    k: uint64 = 0
    while k < 64:
        tcp_slot_acc_ring[k] = 0
        k = k + 1
    tcp_rx_sack_n = 0
    printk0("tcp: initialized (8-slot client TCB table)\n")


# --- Read-only introspection accessors (for /proc/net/tcp) ----------
#
# fs/procfs.ad renders the Linux /proc/net/tcp table from this TCB
# table. The per-slot arrays are module-private; these tiny getters let
# procfs walk them without reaching across the module boundary. Ports
# are returned in HOST order (the slot arrays store host order); the IP
# is returned packed dotted-quad-high-byte-first (network-order octets
# assembled MSB=first octet) so it matches _host_ip_u32()'s convention.

def tcp_num_slots() -> uint64:
    return TCP_NUM_SLOTS

def tcp_slot_st(i: uint64) -> uint32:
    if i >= TCP_NUM_SLOTS:
        return TCP_CLOSED
    return tcp_slot_state[i]

def tcp_slot_lport(i: uint64) -> uint16:
    if i >= TCP_NUM_SLOTS:
        return 0
    return tcp_slot_local_p[i]

def tcp_slot_rport(i: uint64) -> uint16:
    if i >= TCP_NUM_SLOTS:
        return 0
    return tcp_slot_remote_p[i]

def tcp_slot_rip(i: uint64) -> uint32:
    # Remote IPv4 as a packed uint32 with the first dotted-quad octet in
    # the high byte. Slot stores 4 network-order bytes at i*4..i*4+3.
    if i >= TCP_NUM_SLOTS:
        return 0
    base: uint64 = i * 4
    b0: uint32 = cast[uint32](tcp_slot_remote_ip[base])
    b1: uint32 = cast[uint32](tcp_slot_remote_ip[base + 1])
    b2: uint32 = cast[uint32](tcp_slot_remote_ip[base + 2])
    b3: uint32 = cast[uint32](tcp_slot_remote_ip[base + 3])
    return (b0 << 24) | (b1 << 16) | (b2 << 8) | b3

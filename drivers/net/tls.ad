    gcm_kat_pt[52] = 0xaa
    gcm_kat_pt[53] = 0x0d
    gcm_kat_pt[54] = 0xe6
    gcm_kat_pt[55] = 0x57
    gcm_kat_pt[56] = 0xba
    gcm_kat_pt[57] = 0x63
    gcm_kat_pt[58] = 0x7b
    gcm_kat_pt[59] = 0x39
    gcm_kat_aad[0] = 0xfe
    gcm_kat_aad[1] = 0xed
    gcm_kat_aad[2] = 0xfa
    gcm_kat_aad[3] = 0xce
    gcm_kat_aad[4] = 0xde
    gcm_kat_aad[5] = 0xad
    gcm_kat_aad[6] = 0xbe
    gcm_kat_aad[7] = 0xef
    gcm_kat_aad[8] = 0xfe
    gcm_kat_aad[9] = 0xed

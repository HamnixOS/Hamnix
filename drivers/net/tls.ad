    gcm_kat_pt[29] = 0x31
    gcm_kat_pt[30] = 0x8a
    gcm_kat_pt[31] = 0x72
    gcm_kat_pt[32] = 0x1c
    gcm_kat_pt[33] = 0x3c
    gcm_kat_pt[34] = 0x0c
    gcm_kat_pt[35] = 0x95
    gcm_kat_pt[36] = 0x95
    gcm_kat_pt[37] = 0x68
    gcm_kat_pt[38] = 0x09

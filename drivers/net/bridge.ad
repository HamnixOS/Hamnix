# drivers/net/bridge.ad
#
# Status: learning L2 switch with TWO real data paths wired:
#         (1) bridge_selftest() — in-memory unit test that drives the REAL
#             bridge_rx() learn+forward path through three fake capture
#             ports. Still in tree; PROVES the forwarding logic.
#         (2) bridge_vxlan_overlay_selftest() — wires the bridge into the
#             native VXLAN (RFC 7348) overlay. A bridge port is configured
#             with a VXLAN TX hook that calls vxlan_encap() on egress; an
#             in-VM loopback pump calls vxlan_decap() and re-injects the
#             recovered inner Ethernet frame at the peer-bridge port via
#             bridge_rx(). This is the first time bridge.ad is wired to
#             another driver-side data path (vxlan.ad).
# Remaining: hook bridge_rx into a real netdev table so virtio_net's RX
#         path can deliver frames into the bridge under a brctl-shape API.
#         The VXLAN overlay wiring (above) lays the groundwork: a bridge
#         port can now hand a frame to a non-trivial egress consumer.
# See docs/net_protocol_status.md for the consolidated tracker.
#
# A native learning Ethernet bridge — the software equivalent of Linux's
# brX netdev / brctl (a learning L2 switch). It joins N ports into one
# broadcast domain and forwards frames between them based on a learned
# MAC forwarding database (FDB):
#
#   * On every received frame the bridge LEARNS the (source MAC -> ingress
#     port) association into the FDB.
#   * It then looks up the frame's DESTINATION MAC in the FDB:
#       - KNOWN and on a different port  -> forward ONLY to that port
#         (unicast — the whole point of a learning switch vs. a dumb hub).
#       - UNKNOWN, or broadcast/multicast -> FLOOD to every port except the
#         ingress port.
#   * A frame is NEVER sent back out the port it arrived on.
#
# This is purely an L2 forwarding feature inside the native stack — there
# is no socket API involved. Each bridge port carries a TX hook: an
# (port_index, frame, len) callback the bridge invokes to push a frame out
# of that port. The self-test installs fake capture ports to PROVE the
# learn+flood+forward data path without any NIC.

from kernel.printk.printk import printk0, printk1, printk2, printk_set_level
from drivers.tty.serial.early_8250 import PRINTK_LEVEL_EMERG
from drivers.net.eth import ETH_HDR_LEN
from drivers.net.vxlan import (
    vxlan_init, vxlan_fdb_add, vxlan_encap, vxlan_decap,
    VXLAN_OUTER_OVERHEAD,
)


# --- Sizing constants --------------------------------------------------

# Maximum number of ports a single bridge can join (Linux's BR_MAX_PORTS
# is 1024; 8 is plenty for the native use case and the self-test).
BRIDGE_MAX_PORTS: uint64 = 8

# Fixed-size MAC forwarding database. A real bridge ages entries out; this
# table uses round-robin replacement once full, which is sufficient to keep
# the hot set resident and never overflows.
BRIDGE_FDB_MAX: uint64 = 64

# Ethernet address length.
BRIDGE_MAC_LEN: uint64 = 6

# The largest L2 frame we forward (standard Ethernet MTU 1500 + 14-byte
# header). Every frame/capture scratch buffer is sized to this so an
# oversized copy can never silently overflow into the next BSS global.
BRIDGE_MAX_FRAME: uint64 = 1514


# --- The bridge structure ----------------------------------------------
#
# A port's TX hook receives (port_index, frame_ptr, frame_len). The bridge
# itself is identity-less w.r.t. the hook; the hook closes over whatever
# device state it needs via the port index.
#
# We keep the whole bridge in module-scope globals (the runtime has no heap
# allocator wired for driver structs here, and a single software bridge is
# the common case). bridge_create() resets it; the API still threads a
# Bridge* so the shape matches a multi-instance design.

class Bridge:
    nports:  uint64                       # number of joined ports
    # Per-port TX hook function pointers. Signature:
    #   def hook(port: uint64, frame: Ptr[uint8], length: uint64)
    tx_hooks: Array[8, Fn[None, uint64, Ptr[uint8], uint64]]   # BRIDGE_MAX_PORTS
    # FDB parallel arrays (entry i is valid iff fdb_inuse[i] == 1).
    fdb_inuse: Array[64, uint8]          # BRIDGE_FDB_MAX
    fdb_mac:   Array[384, uint8]         # BRIDGE_FDB_MAX * 6 (flattened)
    fdb_port:  Array[64, uint64]         # ingress port the MAC was seen on
    fdb_next:  uint64                     # round-robin replacement cursor
    # Accounting (mirrors the per-bridge stats a real br netdev keeps).
    n_learned: uint64
    n_flooded: uint64
    n_unicast: uint64


# A single static bridge instance. bridge_create() returns its address.
g_bridge: Bridge


# --- printk helpers (force EMERG level so banners always surface) ------

def _br_emerg0(s: Ptr[char]):
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0(s)


def _br_emerg1(s: Ptr[char], a: uint64):
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk1(s, a)


def _br_emerg2(s: Ptr[char], a: uint64, b: uint64):
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk2(s, a, b)


# --- Bridge lifecycle --------------------------------------------------

def bridge_create() -> Ptr[Bridge]:
    # Reset the static bridge to an empty state and hand back its address.
    br: Ptr[Bridge] = &g_bridge
    br[0].nports = 0
    br[0].fdb_next = 0
    br[0].n_learned = 0
    br[0].n_flooded = 0
    br[0].n_unicast = 0
    i: uint64 = 0
    while i < BRIDGE_MAX_PORTS:
        br[0].tx_hooks[i] = cast[Fn[None, uint64, Ptr[uint8], uint64]](0)
        i = i + 1
    j: uint64 = 0
    while j < BRIDGE_FDB_MAX:
        br[0].fdb_inuse[j] = 0
        br[0].fdb_port[j] = 0
        j = j + 1
    k: uint64 = 0
    while k < (BRIDGE_FDB_MAX * BRIDGE_MAC_LEN):
        br[0].fdb_mac[k] = 0
        k = k + 1
    return br


def bridge_add_port(br: Ptr[Bridge],
                    tx_hook: Fn[None, uint64, Ptr[uint8], uint64]) -> int32:
    # Join a new port whose egress is driven by tx_hook. Returns the new
    # port index (>=0), or -1 if the bridge is full.
    if br[0].nports >= BRIDGE_MAX_PORTS:
        return cast[int32](0 - 1)
    p: uint64 = br[0].nports
    br[0].tx_hooks[p] = tx_hook
    br[0].nports = p + 1
    return cast[int32](p)


# --- MAC helpers -------------------------------------------------------

def _br_mac_eq(a: Ptr[uint8], b: Ptr[uint8]) -> int32:
    # 1 if the two 6-byte MACs are equal, else 0.
    i: uint64 = 0
    while i < BRIDGE_MAC_LEN:
        if a[i] != b[i]:
            return 0
        i = i + 1
    return 1


def _br_is_broadcast(mac: Ptr[uint8]) -> int32:
    # 1 if the MAC is ff:ff:ff:ff:ff:ff (L2 broadcast).
    i: uint64 = 0
    while i < BRIDGE_MAC_LEN:
        if mac[i] != 0xff:
            return 0
        i = i + 1
    return 1


def _br_is_multicast(mac: Ptr[uint8]) -> int32:
    # 1 if the I/G (group) bit of the first octet is set. Broadcast is a
    # special case of multicast; both must flood.
    if (cast[uint64](mac[0]) & 0x01) == 1:
        return 1
    return 0


# --- FDB (forwarding database) -----------------------------------------

def _br_fdb_mac_ptr(br: Ptr[Bridge], slot: uint64) -> Ptr[uint8]:
    # Address of the 6-byte MAC for FDB entry `slot` in the flat array.
    return cast[Ptr[uint8]](&br[0].fdb_mac[slot * BRIDGE_MAC_LEN])


def bridge_fdb_lookup(br: Ptr[Bridge], mac: Ptr[uint8]) -> int64:
    # Return the port a MAC was learned on, or -1 if unknown.
    i: uint64 = 0
    while i < BRIDGE_FDB_MAX:
        if br[0].fdb_inuse[i] == 1:
            entry: Ptr[uint8] = _br_fdb_mac_ptr(br, i)
            if _br_mac_eq(entry, mac) == 1:
                return cast[int64](br[0].fdb_port[i])
        i = i + 1
    return cast[int64](0 - 1)


def bridge_fdb_learn(br: Ptr[Bridge], mac: Ptr[uint8], port: uint64):
    # Insert or refresh (mac -> port). Never learns a broadcast/multicast
    # source (such a source MAC would be malformed; real bridges ignore it).
    if _br_is_multicast(mac) == 1:
        return
    # If the MAC is already present, just update its port (handles a station
    # that moved to a different port) and we're done.
    i: uint64 = 0
    while i < BRIDGE_FDB_MAX:
        if br[0].fdb_inuse[i] == 1:
            entry: Ptr[uint8] = _br_fdb_mac_ptr(br, i)
            if _br_mac_eq(entry, mac) == 1:
                br[0].fdb_port[i] = port
                return
        i = i + 1
    # Not present: find a free slot, else round-robin replace.
    slot: uint64 = BRIDGE_FDB_MAX
    j: uint64 = 0
    while j < BRIDGE_FDB_MAX:
        if br[0].fdb_inuse[j] == 0:
            slot = j
            j = BRIDGE_FDB_MAX
        else:
            j = j + 1
    if slot == BRIDGE_FDB_MAX:
        # Table full — evict the round-robin victim.
        slot = br[0].fdb_next
        br[0].fdb_next = (br[0].fdb_next + 1) % BRIDGE_FDB_MAX
    dst: Ptr[uint8] = _br_fdb_mac_ptr(br, slot)
    k: uint64 = 0
    while k < BRIDGE_MAC_LEN:
        dst[k] = mac[k]
        k = k + 1
    br[0].fdb_port[slot] = port
    br[0].fdb_inuse[slot] = 1
    br[0].n_learned = br[0].n_learned + 1


# --- Egress ------------------------------------------------------------

def _br_tx(br: Ptr[Bridge], port: uint64, frame: Ptr[uint8], length: uint64):
    # Invoke a port's TX hook. No-op if unset.
    hook: Fn[None, uint64, Ptr[uint8], uint64] = br[0].tx_hooks[port]
    if hook == cast[Fn[None, uint64, Ptr[uint8], uint64]](0):
        return
    hook(port, frame, length)


def _br_flood(br: Ptr[Bridge], ingress: uint64, frame: Ptr[uint8],
              length: uint64):
    # Send the frame out every port except the ingress port.
    p: uint64 = 0
    while p < br[0].nports:
        if p != ingress:
            _br_tx(br, p, frame, length)
        p = p + 1
    br[0].n_flooded = br[0].n_flooded + 1


# --- The forwarding decision -------------------------------------------

def bridge_rx(br: Ptr[Bridge], ingress: uint64, frame: Ptr[uint8],
              length: uint64):
    # Drive the learn + forward path for one received frame.
    #
    # Ethernet header: bytes [0..5] = dst MAC, [6..11] = src MAC.
    if length < ETH_HDR_LEN:
        return                              # runt — nothing to forward
    if ingress >= br[0].nports:
        return                              # frame from a non-port
    dst_mac: Ptr[uint8] = frame
    src_mac: Ptr[uint8] = cast[Ptr[uint8]](
        cast[uint64](frame) + BRIDGE_MAC_LEN)

    # 1) LEARN the source.
    bridge_fdb_learn(br, src_mac, ingress)

    # 2) Decide egress by destination.
    if _br_is_multicast(dst_mac) == 1:
        # Broadcast/multicast always floods (BUM traffic).
        _br_flood(br, ingress, frame, length)
        return
    dport: int64 = bridge_fdb_lookup(br, dst_mac)
    if dport < 0:
        # Unknown unicast -> flood.
        _br_flood(br, ingress, frame, length)
        return
    out: uint64 = cast[uint64](dport)
    if out == ingress:
        # Destination is on the ingress port — drop (never hairpin).
        return
    # Known unicast on a different port -> forward only there.
    _br_tx(br, out, frame, length)
    br[0].n_unicast = br[0].n_unicast + 1


# =====================================================================
# Self-test: in-memory fake ports that capture transmitted frames
# =====================================================================
#
# Three capture ports record every frame their TX hook receives. We then
# drive bridge_rx() with crafted frames and assert the forwarding pattern.

# Per-port capture: count of frames delivered + a copy of the LAST frame
# (its length + bytes). Sized to BRIDGE_MAX_FRAME so a max frame can't
# overflow into the adjacent global.
_bt_cap_count: Array[8, uint64]                 # frames captured per port
_bt_cap_len:   Array[8, uint64]                 # length of last captured
_bt_cap_buf0:  Array[1514, uint8]               # port0 last frame bytes
_bt_cap_buf1:  Array[1514, uint8]               # port1 last frame bytes
_bt_cap_buf2:  Array[1514, uint8]               # port2 last frame bytes

# Scratch frame the self-test crafts (sized to the max frame).
_bt_frame:     Array[1514, uint8]


def _bt_reset_captures():
    i: uint64 = 0
    while i < BRIDGE_MAX_PORTS:
        _bt_cap_count[i] = 0
        _bt_cap_len[i] = 0
        i = i + 1


def _bt_store(buf: Ptr[uint8], frame: Ptr[uint8], length: uint64):
    n: uint64 = length
    if n > BRIDGE_MAX_FRAME:
        n = BRIDGE_MAX_FRAME
    i: uint64 = 0
    while i < n:
        buf[i] = frame[i]
        i = i + 1


# The three capture TX hooks. Each records that a frame was delivered to
# its port and stashes a copy of the bytes.
def _bt_hook0(port: uint64, frame: Ptr[uint8], length: uint64):
    _bt_cap_count[0] = _bt_cap_count[0] + 1
    _bt_cap_len[0] = length
    _bt_store(cast[Ptr[uint8]](&_bt_cap_buf0[0]), frame, length)


def _bt_hook1(port: uint64, frame: Ptr[uint8], length: uint64):
    _bt_cap_count[1] = _bt_cap_count[1] + 1
    _bt_cap_len[1] = length
    _bt_store(cast[Ptr[uint8]](&_bt_cap_buf1[0]), frame, length)


def _bt_hook2(port: uint64, frame: Ptr[uint8], length: uint64):
    _bt_cap_count[2] = _bt_cap_count[2] + 1
    _bt_cap_len[2] = length
    _bt_store(cast[Ptr[uint8]](&_bt_cap_buf2[0]), frame, length)


def _bt_build_frame(dst: Ptr[uint8], src: Ptr[uint8], payload: uint8) -> uint64:
    # Lay an Ethernet frame: dst(6) | src(6) | ethertype(2) | payload(46).
    # Returns the total length (a min-size 60-byte L2 frame).
    i: uint64 = 0
    while i < 6:
        _bt_frame[i] = dst[i]
        _bt_frame[6 + i] = src[i]
        i = i + 1
    _bt_frame[12] = 0x08            # ethertype 0x0800 (IPv4) — arbitrary
    _bt_frame[13] = 0x00
    j: uint64 = 14
    while j < 60:
        _bt_frame[j] = payload
        j = j + 1
    return 60


# Reusable MAC scratch buffers for the self-test. Stations are unicast
# (02:00:00:00:00:xx); FF is the L2 broadcast.
_bt_mac_aa: Array[6, uint8]        # station A  02:00:00:00:00:AA
_bt_mac_bb: Array[6, uint8]        # station B  02:00:00:00:00:BB
_bt_mac_cc: Array[6, uint8]        # station C  02:00:00:00:00:CC
_bt_mac_ff: Array[6, uint8]        # FF:FF:FF:FF:FF:FF (broadcast)


def _bt_set_unicast_mac(m: Ptr[uint8], last: uint8):
    # Build a proper locally-administered UNICAST MAC 02:00:00:00:00:<last>.
    # The first octet 0x02 has the I/G (group) bit (bit0) clear, so the
    # bridge treats it as an individual address and LEARNS it — a station
    # MAC whose first octet has bit0 set would (correctly) be ignored as a
    # malformed source by the learning logic.
    m[0] = 0x02
    m[1] = 0x00
    m[2] = 0x00
    m[3] = 0x00
    m[4] = 0x00
    m[5] = last


def _bt_fill_mac(m: Ptr[uint8], v: uint8):
    i: uint64 = 0
    while i < 6:
        m[i] = v
        i = i + 1


def bridge_selftest() -> int32:
    # Returns 1 on PASS, 0 on FAIL. Drives the REAL bridge_rx() path through
    # three fake capture ports and asserts learn/flood/forward behaviour.
    _br_emerg0("[bridge] self-test start\n")
    ok: int32 = 1

    # Stations AA/BB/CC are proper locally-administered UNICAST MACs
    # (02:00:00:00:00:xx) so the bridge learns them; FF is the L2 broadcast.
    _bt_set_unicast_mac(cast[Ptr[uint8]](&_bt_mac_aa[0]), 0xAA)
    _bt_set_unicast_mac(cast[Ptr[uint8]](&_bt_mac_bb[0]), 0xBB)
    _bt_set_unicast_mac(cast[Ptr[uint8]](&_bt_mac_cc[0]), 0xCC)
    _bt_fill_mac(cast[Ptr[uint8]](&_bt_mac_ff[0]), 0xFF)

    br: Ptr[Bridge] = bridge_create()
    p0: int32 = bridge_add_port(br, _bt_hook0)
    p1: int32 = bridge_add_port(br, _bt_hook1)
    p2: int32 = bridge_add_port(br, _bt_hook2)
    if p0 != 0 or p1 != 1 or p2 != 2:
        _br_emerg0("[bridge] FAIL: add_port indices wrong\n")
        return 0
    if br[0].nports != 3:
        _br_emerg0("[bridge] FAIL: nports != 3\n")
        return 0
    _br_emerg0("[bridge] ports OK (3 ports joined)\n")

    # ----------------------------------------------------------------
    # (a) Unknown-unicast FLOOD: port0 sends src=AA dst=BB (BB unknown).
    #     Must flood to port1 + port2 but NOT port0 (ingress).
    # ----------------------------------------------------------------
    _bt_reset_captures()
    flen: uint64 = _bt_build_frame(
        cast[Ptr[uint8]](&_bt_mac_bb[0]),     # dst BB (unknown)
        cast[Ptr[uint8]](&_bt_mac_aa[0]),     # src AA
        0x11)
    bridge_rx(br, 0, cast[Ptr[uint8]](&_bt_frame[0]), flen)
    if _bt_cap_count[0] != 0:
        _br_emerg1("[bridge] FAIL: flood hit ingress port0 (cnt=%d)\n",
                   _bt_cap_count[0])
        ok = 0
    if _bt_cap_count[1] != 1 or _bt_cap_count[2] != 1:
        _br_emerg2("[bridge] FAIL: flood missed (p1=%d p2=%d)\n",
                   _bt_cap_count[1], _bt_cap_count[2])
        ok = 0
    if ok == 1:
        _br_emerg0("[bridge] flood-unknown OK\n")

    # (d-part-1) The source AA must now be learned on port0.
    aa_port: int64 = bridge_fdb_lookup(br, cast[Ptr[uint8]](&_bt_mac_aa[0]))
    if aa_port != 0:
        _br_emerg1("[bridge] FAIL: AA learned on wrong port (%d)\n",
                   cast[uint64](aa_port))
        ok = 0
    else:
        _br_emerg0("[bridge] fdb-learned AA->port0 OK\n")

    # ----------------------------------------------------------------
    # (b) Learned UNICAST: port1 sends src=BB dst=AA. AA is known on
    #     port0, so it must be delivered ONLY to port0 (not flooded).
    # ----------------------------------------------------------------
    _bt_reset_captures()
    ulen: uint64 = _bt_build_frame(
        cast[Ptr[uint8]](&_bt_mac_aa[0]),     # dst AA (known on port0)
        cast[Ptr[uint8]](&_bt_mac_bb[0]),     # src BB
        0x22)
    bridge_rx(br, 1, cast[Ptr[uint8]](&_bt_frame[0]), ulen)
    if _bt_cap_count[0] != 1:
        _br_emerg1("[bridge] FAIL: unicast not delivered to port0 (cnt=%d)\n",
                   _bt_cap_count[0])
        ok = 0
    if _bt_cap_count[1] != 0:
        _br_emerg0("[bridge] FAIL: unicast echoed to ingress port1\n")
        ok = 0
    if _bt_cap_count[2] != 0:
        _br_emerg1("[bridge] FAIL: unicast leaked to port2 (cnt=%d)\n",
                   _bt_cap_count[2])
        ok = 0
    # Verify the delivered bytes are byte-identical to what we sent.
    if _bt_cap_len[0] != ulen:
        _br_emerg2("[bridge] FAIL: unicast len %d != %d\n",
                   _bt_cap_len[0], ulen)
        ok = 0
    else:
        ci: uint64 = 0
        while ci < ulen:
            if _bt_cap_buf0[ci] != _bt_frame[ci]:
                _br_emerg1("[bridge] FAIL: unicast byte mismatch @%d\n", ci)
                ok = 0
                ci = ulen
            else:
                ci = ci + 1
    if ok == 1:
        _br_emerg0("[bridge] learned-unicast OK\n")

    # (d-part-2) BB must now be learned on port1.
    bb_port: int64 = bridge_fdb_lookup(br, cast[Ptr[uint8]](&_bt_mac_bb[0]))
    if bb_port != 1:
        _br_emerg1("[bridge] FAIL: BB learned on wrong port (%d)\n",
                   cast[uint64](bb_port))
        ok = 0
    else:
        _br_emerg0("[bridge] fdb-learned BB->port1 OK\n")

    # ----------------------------------------------------------------
    # (c) BROADCAST flood: port2 sends src=CC dst=FF:FF:FF:FF:FF:FF.
    #     Must flood to port0 + port1 (both non-ingress) but NOT port2.
    # ----------------------------------------------------------------
    _bt_reset_captures()
    blen: uint64 = _bt_build_frame(
        cast[Ptr[uint8]](&_bt_mac_ff[0]),     # dst broadcast
        cast[Ptr[uint8]](&_bt_mac_cc[0]),     # src CC
        0x33)
    bridge_rx(br, 2, cast[Ptr[uint8]](&_bt_frame[0]), blen)
    if _bt_cap_count[2] != 0:
        _br_emerg1("[bridge] FAIL: broadcast hit ingress port2 (cnt=%d)\n",
                   _bt_cap_count[2])
        ok = 0
    if _bt_cap_count[0] != 1 or _bt_cap_count[1] != 1:
        _br_emerg2("[bridge] FAIL: broadcast missed (p0=%d p1=%d)\n",
                   _bt_cap_count[0], _bt_cap_count[1])
        ok = 0
    if ok == 1:
        _br_emerg0("[bridge] broadcast-flood OK\n")

    # (d-part-3) CC must now be learned on port2; a broadcast dst must NOT
    # have been learned as a forwarding MAC.
    cc_port: int64 = bridge_fdb_lookup(br, cast[Ptr[uint8]](&_bt_mac_cc[0]))
    if cc_port != 2:
        _br_emerg1("[bridge] FAIL: CC learned on wrong port (%d)\n",
                   cast[uint64](cc_port))
        ok = 0
    ff_port: int64 = bridge_fdb_lookup(br, cast[Ptr[uint8]](&_bt_mac_ff[0]))
    if ff_port >= 0:
        _br_emerg0("[bridge] FAIL: broadcast MAC was learned into FDB\n")
        ok = 0
    if ok == 1:
        _br_emerg0("[bridge] fdb-verified OK (AA/BB/CC learned, FF not)\n")

    if ok == 1:
        _br_emerg0("[bridge] PASS\n")
        return 1
    _br_emerg0("[bridge] FAIL\n")
    return 0


# =====================================================================
# VXLAN overlay wiring + selftest
# =====================================================================
#
# The honesty audit (docs/audit_gap_vs_linux_2026-06-13.md §3) flagged
# bridge.ad and vxlan.ad as in-memory selftest-only. This block REALLY
# wires them: a bridge port's TX hook calls vxlan_encap() to produce a
# full RFC-7348 outer frame (Eth|IP|UDP:4789|VXLAN|inner) which is
# delivered to an in-VM loopback ring; the loopback pump calls
# vxlan_decap() and re-injects the recovered inner Ethernet frame into
# the bridge at the configured peer-side port via bridge_rx().
#
# Compared to the "two QEMU instances + tap-pair" plan in the brief,
# this is the option-5 in-VM loopback: one box, one bridge, two bridge
# ports — port "WEST" represents the local-LAN side, port "EAST"
# represents the far side of the tunnel after decap. The wire is a
# loopback buffer instead of UDP on a real NIC.
#
# Loopback limit (documented per the brief): we do not route the outer
# frame through ip_send/udp_send/virtio_net_tx — the loopback ring
# stands in for the outer UDP/IPv4 datagram on the wire. That keeps
# the test deterministic and host-independent. Wiring the bridge to a
# real netdev table so the outer frame goes out virtio_net_tx and the
# inbound side runs through udp_rx port-4789 demux is the next step.

# Loopback ring state: a single in-flight outer frame is enough for
# the selftest's "inject one inner frame, observe one decap" shape.
_brvx_loop_buf:   Array[2000, uint8]
_brvx_loop_len:   uint64 = 0
_brvx_loop_valid: uint8  = 0

# Per-tunnel-port config (single tunnel port for the selftest).
_brvx_vni:        uint32 = 0
_brvx_local_ip:   uint32 = 0
_brvx_remote_ip:  uint32 = 0
_brvx_local_mac:  Array[6, uint8]
_brvx_remote_mac: Array[6, uint8]
_brvx_tunnel_port_index: uint64 = 0

# Counters proving the wired path actually carried bytes.
brvx_tx_encaps_seen: uint64 = 0
brvx_rx_decaps_seen: uint64 = 0
brvx_inner_capture_count: uint64 = 0
_brvx_inner_capture_len:  uint64 = 0
_brvx_inner_capture_buf:  Array[1514, uint8]

# Decap scratch — sized for the largest inner frame, kept in BSS so
# bridge_vxlan_loopback_pump doesn't put a 1514-byte buffer on the stack.
_brvx_decap_scratch:      Array[1514, uint8]


def bridge_vxlan_port_tx(port: uint64, frame: Ptr[uint8], length: uint64):
    # Bridge port TX hook: VXLAN-encapsulate the L2 frame the bridge
    # decided to forward out this port, and park the outer frame on
    # the loopback ring. Matches the Fn[None, uint64, Ptr[uint8],
    # uint64] signature stored in Bridge.tx_hooks.
    rc: int64 = vxlan_encap(frame, length, _brvx_vni,
                            _brvx_local_ip, _brvx_remote_ip,
                            cast[Ptr[uint8]](&_brvx_local_mac[0]),
                            cast[Ptr[uint8]](&_brvx_remote_mac[0]),
                            cast[Ptr[uint8]](&_brvx_loop_buf[0]),
                            cast[uint64](2000))
    if rc < 0:
        _br_emerg1("[bridge-vxlan] FAIL: encap rc=%d\n",
                   cast[uint64](rc))
        return
    _brvx_loop_len = cast[uint64](rc)
    _brvx_loop_valid = 1
    brvx_tx_encaps_seen = brvx_tx_encaps_seen + 1


def _brvx_inner_capture_hook(port: uint64, frame: Ptr[uint8],
                              length: uint64):
    # Capture hook on the "EAST" side: record the inner frame the
    # bridge floods/forwards after decap so the test can assert
    # byte-identity vs the originally injected inner frame.
    brvx_inner_capture_count = brvx_inner_capture_count + 1
    n: uint64 = length
    if n > BRIDGE_MAX_FRAME:
        n = BRIDGE_MAX_FRAME
    _brvx_inner_capture_len = n
    i: uint64 = 0
    while i < n:
        _brvx_inner_capture_buf[i] = frame[i]
        i = i + 1


def bridge_vxlan_loopback_pump(br: Ptr[Bridge], ingress: uint64) -> int32:
    # Take whatever the encap hook parked on the loopback ring, run
    # vxlan_decap() to recover the inner Ethernet frame, and re-inject
    # it into the bridge at `ingress` (the "EAST" port). Returns the
    # number of inner frames pumped (0 if the ring was empty, 1 on
    # success, <0 on decap failure).
    if _brvx_loop_valid == 0:
        return 0
    vni_out: uint32 = 0
    inner_len: int64 = vxlan_decap(
        cast[Ptr[uint8]](&_brvx_loop_buf[0]),
        _brvx_loop_len,
        cast[Ptr[uint8]](&_brvx_decap_scratch[0]),
        cast[uint64](1514),
        cast[Ptr[uint32]](&vni_out))
    if inner_len < 0:
        _br_emerg1("[bridge-vxlan] FAIL: decap rc=%d\n",
                   cast[uint64](inner_len))
        _brvx_loop_valid = 0
        return cast[int32](-1)
    if vni_out != _brvx_vni:
        _br_emerg2("[bridge-vxlan] FAIL: decap vni=%d != %d\n",
                   cast[uint64](vni_out), cast[uint64](_brvx_vni))
        _brvx_loop_valid = 0
        return cast[int32](-2)
    brvx_rx_decaps_seen = brvx_rx_decaps_seen + 1
    _brvx_loop_valid = 0
    bridge_rx(br, ingress, cast[Ptr[uint8]](&_brvx_decap_scratch[0]),
              cast[uint64](inner_len))
    return 1


# Test-side scratch.
_brvxt_mac_w:  Array[6, uint8]    # station-W (WEST side, local LAN)
_brvxt_mac_e:  Array[6, uint8]    # station-E (EAST side, far LAN)
_brvxt_mac_ff: Array[6, uint8]    # broadcast
_brvxt_inner:  Array[1514, uint8]


def bridge_vxlan_overlay_selftest() -> int32:
    # Returns 1 on PASS, 0 on FAIL.
    #
    # Topology:
    #   bridge ports: 0=WEST capture, 1=VXLAN tunnel TX hook,
    #                 2=EAST capture
    # Flow under test:
    #   1. inject inner frame (src=W dst=E) at port 0
    #   2. bridge sees unknown-unicast dst (FDB empty) -> floods to
    #      port 1 (tunnel) AND port 2 (EAST capture)
    #   3. port 1's TX hook is bridge_vxlan_port_tx -> vxlan_encap()
    #      parks an outer VXLAN frame on the loopback ring
    #   4. bridge_vxlan_loopback_pump(br, ingress=1) does vxlan_decap()
    #      and re-injects the inner frame at port 1 (so the bridge
    #      treats the decap'd frame as having arrived from the tunnel)
    #   5. that triggers a SECOND forwarding decision: the inner
    #      frame's dst=E is still unknown so it floods to port 0
    #      (WEST capture) and port 2 (EAST capture) — but NOT back
    #      to port 1 (ingress). We assert the WEST capture sees
    #      byte-identical inner bytes.
    _br_emerg0("[bridge-vxlan] overlay self-test start\n")
    ok: int32 = 1
    vxlan_init()

    # Configure the tunnel.
    _brvx_vni = 100
    _brvx_local_ip  = (10 << 24) | (0 << 16) | (0 << 8) | 1   # 10.0.0.1
    _brvx_remote_ip = (10 << 24) | (0 << 16) | (0 << 8) | 2   # 10.0.0.2
    i: uint64 = 0
    while i < 6:
        _brvx_local_mac[i]  = 0
        _brvx_remote_mac[i] = 0
        i = i + 1
    _brvx_local_mac[0]  = 0x02
    _brvx_local_mac[5]  = 0x01
    _brvx_remote_mac[0] = 0x02
    _brvx_remote_mac[5] = 0x02

    # FDB tells vxlan_send_by_vni where 100 lives (not used by the
    # direct encap path but mirrors what a real config would do, and
    # lets future callers use send_by_vni against this same VNI).
    vxlan_fdb_add(100, _brvx_remote_ip,
                  cast[Ptr[uint8]](&_brvx_remote_mac[0]))

    # Reset overlay counters / captures.
    _brvx_loop_valid = 0
    _brvx_loop_len   = 0
    brvx_tx_encaps_seen = 0
    brvx_rx_decaps_seen = 0
    brvx_inner_capture_count = 0
    _brvx_inner_capture_len  = 0

    # Stations.
    _bt_set_unicast_mac(cast[Ptr[uint8]](&_brvxt_mac_w[0]), 0xAA)
    _bt_set_unicast_mac(cast[Ptr[uint8]](&_brvxt_mac_e[0]), 0xEE)
    _bt_fill_mac(cast[Ptr[uint8]](&_brvxt_mac_ff[0]), 0xFF)

    # Bridge with three ports: WEST capture, VXLAN tunnel, EAST capture.
    br: Ptr[Bridge] = bridge_create()
    pw: int32 = bridge_add_port(br, _bt_hook0)
    pt: int32 = bridge_add_port(br, bridge_vxlan_port_tx)
    pe: int32 = bridge_add_port(br, _brvx_inner_capture_hook)
    if pw != 0 or pt != 1 or pe != 2:
        _br_emerg0("[bridge-vxlan] FAIL: add_port indices wrong\n")
        return 0
    _brvx_tunnel_port_index = cast[uint64](pt)
    _bt_reset_captures()

    # Build the inner Ethernet frame at port-WEST.
    i = 0
    while i < 6:
        _brvxt_inner[i]     = _brvxt_mac_e[i]      # dst E
        _brvxt_inner[6 + i] = _brvxt_mac_w[i]      # src W
        i = i + 1
    _brvxt_inner[12] = 0x08
    _brvxt_inner[13] = 0x00                         # ethertype IPv4
    j: uint64 = 14
    while j < 60:
        _brvxt_inner[j] = cast[uint8]((j * 7 + 11) & 0xFF)
        j = j + 1
    inner_len: uint64 = 60

    # Step 1+2+3: inject WEST -> bridge floods unknown unicast.
    # Tunnel port's hook does vxlan_encap into the loopback ring.
    bridge_rx(br, 0, cast[Ptr[uint8]](&_brvxt_inner[0]), inner_len)

    if brvx_tx_encaps_seen != 1:
        _br_emerg1("[bridge-vxlan] FAIL: encaps_seen=%d != 1\n",
                   brvx_tx_encaps_seen)
        ok = 0
    else:
        _br_emerg0("[bridge-vxlan] PASS encap-fired-via-bridge-port\n")
    if _brvx_loop_valid != 1:
        _br_emerg0("[bridge-vxlan] FAIL: loopback ring empty after encap\n")
        ok = 0
    else:
        if _brvx_loop_len != VXLAN_OUTER_OVERHEAD + inner_len:
            _br_emerg2("[bridge-vxlan] FAIL: outer len %d != %d\n",
                       _brvx_loop_len,
                       VXLAN_OUTER_OVERHEAD + inner_len)
            ok = 0
        else:
            _br_emerg1("[bridge-vxlan] PASS outer-on-loopback-ring len=%d\n",
                       _brvx_loop_len)

    # Step 4: pump the loopback through vxlan_decap -> bridge_rx on
    # ingress=tunnel port (1). The bridge then makes a SECOND
    # forwarding decision for the recovered inner frame.
    pumped: int32 = bridge_vxlan_loopback_pump(br, 1)
    if pumped != 1:
        _br_emerg1("[bridge-vxlan] FAIL: pump rc=%d\n",
                   cast[uint64](pumped))
        ok = 0
    else:
        _br_emerg0("[bridge-vxlan] PASS decap-pumped-into-bridge\n")
    if brvx_rx_decaps_seen != 1:
        _br_emerg1("[bridge-vxlan] FAIL: decaps_seen=%d != 1\n",
                   brvx_rx_decaps_seen)
        ok = 0

    # Step 5: after the decap re-injection at ingress=1, dst E is
    # still unknown -> flood to ports 0 (WEST capture) and 2 (EAST
    # capture). _bt_cap_count[0] from the WEST hook is the truth
    # signal: the inner frame made it ALL the way through
    # bridge -> vxlan_encap -> loopback -> vxlan_decap -> bridge.
    # The original flood from step 2 ALSO hit port 2 (the EAST
    # capture got 1 hit there before pump). So:
    #   port 0 (WEST capture): expect 1 hit from the post-decap flood
    #   port 2 (EAST capture / _brvx_inner_capture_hook): expect
    #          2 hits — one from step 2's flood, one from step 5.
    if _bt_cap_count[0] != 1:
        _br_emerg1("[bridge-vxlan] FAIL: WEST capture count=%d != 1\n",
                   _bt_cap_count[0])
        ok = 0
    else:
        _br_emerg0("[bridge-vxlan] PASS west-capture-fired\n")
    if brvx_inner_capture_count != 2:
        _br_emerg1("[bridge-vxlan] FAIL: east capture count=%d != 2\n",
                   brvx_inner_capture_count)
        ok = 0
    else:
        _br_emerg0("[bridge-vxlan] PASS east-capture-fired-twice\n")

    # Byte-identity assertion: the inner frame captured at WEST
    # after the full encap/decap round-trip must be byte-identical
    # to what we originally injected.
    if _bt_cap_len[0] != inner_len:
        _br_emerg2("[bridge-vxlan] FAIL: WEST capture len %d != %d\n",
                   _bt_cap_len[0], inner_len)
        ok = 0
    else:
        identical: int32 = 1
        ci: uint64 = 0
        while ci < inner_len:
            if _bt_cap_buf0[ci] != _brvxt_inner[ci]:
                identical = 0
                ci = inner_len
            else:
                ci = ci + 1
        if identical != 1:
            _br_emerg0("[bridge-vxlan] FAIL: WEST capture bytes differ from injected inner\n")
            ok = 0
        else:
            _br_emerg0("[bridge-vxlan] PASS roundtrip-byte-identical (inner)\n")

    if ok == 1:
        _br_emerg0("[bridge-vxlan] PASS\n")
        return 1
    _br_emerg0("[bridge-vxlan] FAIL\n")
    return 0

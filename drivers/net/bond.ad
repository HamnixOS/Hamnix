# drivers/net/bond.ad
#
# Status: in-memory selftest only — NOT wired to any real NIC, /net 9P path,
#         or the kernel netdev table. bond_selftest() is the sole external
#         caller; member slaves are fake records, not real net_devices.
# TODO(net-honesty): wire to drivers/net/eth.ad netdev table (enslave real
#         NICs, route eth tx through bond_select_slave) or remove.
# See docs/net_protocol_status.md for the consolidated tracker.
#
# Native link aggregation (bonding) — the Linux `bonding` driver's two
# foundational modes:
#
#   mode 1  active-backup : exactly ONE enslaved NIC is "active" and carries
#                           all transmit traffic. The others sit hot as
#                           backups. If the active slave's link goes down, a
#                           live backup is promoted to active and tx fails
#                           over to it with no change visible to upper layers.
#
#   mode 0  balance-rr    : transmit frames are striped across all live
#                           slaves in round-robin order. A slave whose link is
#                           down is skipped, so the rr cursor only ever lands
#                           on a carrier-up member.
#
# A bond is a logical net_device that enslaves N member NICs. Each slave is a
# small record: its ifindex, 6-byte MAC, and link state (up/down). The bond
# itself tracks the current active slave (mode 1) and a round-robin cursor
# (mode 0). enslave/release mutate the member set; a link-down event triggers
# re-selection (mode 1 failover / mode 0 skip).
#
# This is the kernel-side substrate of `ip link add bond0 type bond` +
# `ip link set ethN master bond0`. No external NIC is required to exercise it:
# the self-test builds fake slaves, drives genuine slave selection, failover,
# and round-robin distribution, and asserts tx lands on the computed slave.
#
# Parallel-arrays-of-globals discipline (module-scope globals only), exactly
# like eth.ad's hand-built net_device and vlan.ad's interface table.

from kernel.printk.printk import printk0, printk1, printk2, printk_set_level
from drivers.tty.serial.early_8250 import PRINTK_LEVEL_EMERG
from drivers.net.eth import ETH_HDR_LEN


# --- Bonding modes (numbered exactly as the Linux bonding driver) ------

BOND_MODE_ROUNDROBIN: uint32 = 0     # balance-rr
BOND_MODE_ACTIVEBACKUP: uint32 = 1   # active-backup

# Link states of a slave (carrier).
BOND_LINK_DOWN: uint8 = 0
BOND_LINK_UP:   uint8 = 1

# Maximum slaves a single bond can enslave. A fixed array — a real Linux
# bond has no hard cap, but a small fixed set is enough to drive the
# selection / failover / round-robin logic genuinely.
BOND_MAX_SLAVES: uint64 = 8

# Sentinel for "no active slave" (mode 1) — the bond is carrier-down.
BOND_NO_ACTIVE: int32 = -1


# =====================================================================
# The bond device (single bond — one bond0, parallel-array slaves)
# =====================================================================
#
# A real machine adds bond0/bond1/...; the load-bearing logic is per-bond,
# so a single bond with a fixed slave table is enough to prove selection,
# failover and round-robin. Growing to N bonds is a table-of-this.

bond_mode:        uint32 = 0          # BOND_MODE_*
bond_active:      int32 = -1          # active slave index (mode 1), or -1
bond_rr_cursor:   uint64 = 0          # round-robin cursor (mode 0)
bond_nslaves:     uint64 = 0          # number of enslaved members

# Per-slave records (declaration order = BSS layout; sized to BOND_MAX_SLAVES).
bond_slave_inuse:  Array[8, uint8]    # 1 if this slot holds an enslaved NIC
bond_slave_ifidx:  Array[8, uint32]   # the member NIC's ifindex
bond_slave_link:   Array[8, uint8]    # BOND_LINK_UP / BOND_LINK_DOWN

# A slave's MAC is 6 bytes; we keep an 8*6 flat byte array so each slave's
# MAC lives at [slot*6 .. slot*6+5]. A dedicated, exactly-sized flat buffer
# (8*6=48) so no undersized array silently overflows into the next global.
BOND_MAC_LEN: uint64 = 6
bond_slave_macs:   Array[48, uint8]   # 8 slaves * 6 bytes, flat

# Transmit accounting, per slave (which slave actually carried each frame).
bond_slave_tx:     Array[8, uint64]   # tx frame count per slave

# Bond-level counters.
bond_tx_total:     uint64 = 0         # total frames submitted to bond_tx
bond_tx_nocarrier: uint64 = 0         # frames dropped: no live slave


def bond_init(mode: uint32):
    # (Re)initialize the bond in the given mode with an empty slave set.
    # Idempotent.
    bond_mode      = mode
    bond_active    = BOND_NO_ACTIVE
    bond_rr_cursor = 0
    bond_nslaves   = 0
    bond_tx_total     = 0
    bond_tx_nocarrier = 0
    i: uint64 = 0
    while i < BOND_MAX_SLAVES:
        bond_slave_inuse[i] = 0
        bond_slave_ifidx[i] = 0
        bond_slave_link[i]  = BOND_LINK_DOWN
        bond_slave_tx[i]    = 0
        i = i + 1
    m: uint64 = 0
    while m < (BOND_MAX_SLAVES * BOND_MAC_LEN):
        bond_slave_macs[m] = 0
        m = m + 1


# =====================================================================
# enslave / release
# =====================================================================

def bond_enslave(ifidx: uint32, mac6: Ptr[uint8], link: uint8) -> int32:
    # Enslave a member NIC into the bond. Returns the slave slot index on
    # success, -1 if the bond is full. The new slave's link state is `link`
    # (BOND_LINK_UP/DOWN). After adding, re-run active selection so the bond
    # carrier reflects the new member set (mode 1: if there's no active slave
    # and this one is up, it becomes active).
    slot: int32 = -1
    i: uint64 = 0
    while i < BOND_MAX_SLAVES:
        if bond_slave_inuse[i] == 0:
            slot = cast[int32](i)
            i = BOND_MAX_SLAVES
        else:
            i = i + 1
    if slot < 0:
        return -1
    s: uint64 = cast[uint64](slot)
    bond_slave_inuse[s] = 1
    bond_slave_ifidx[s] = ifidx
    bond_slave_link[s]  = link
    bond_slave_tx[s]    = 0
    j: uint64 = 0
    while j < BOND_MAC_LEN:
        bond_slave_macs[s * BOND_MAC_LEN + j] = mac6[j]
        j = j + 1
    bond_nslaves = bond_nslaves + 1
    bond_select_active()
    return slot


def bond_release(slot: uint64) -> int32:
    # Release (un-enslave) the member at `slot`. Returns 0 on success, -1 if
    # the slot is empty/out of range. If the released slave was the active
    # one (mode 1), re-select an active slave from the remaining members.
    if slot >= BOND_MAX_SLAVES:
        return -1
    if bond_slave_inuse[slot] == 0:
        return -1
    bond_slave_inuse[slot] = 0
    bond_slave_link[slot]  = BOND_LINK_DOWN
    bond_slave_ifidx[slot] = 0
    if bond_nslaves > 0:
        bond_nslaves = bond_nslaves - 1
    if bond_active == cast[int32](slot):
        bond_active = BOND_NO_ACTIVE
    bond_select_active()
    return 0


# =====================================================================
# Link events + active selection (failover)
# =====================================================================

def bond_set_link(slot: uint64, link: uint8) -> int32:
    # Carrier event for a slave: mark its link up/down. Returns 0 on success,
    # -1 if the slot is empty/out of range. A link-down on the active slave
    # (mode 1) triggers failover via re-selection; a link-up may promote a
    # newly-live slave to active if there was none.
    if slot >= BOND_MAX_SLAVES:
        return -1
    if bond_slave_inuse[slot] == 0:
        return -1
    bond_slave_link[slot] = link
    # If the active slave just went down, drop the active pointer so
    # re-selection picks a live backup.
    if bond_active == cast[int32](slot):
        if link == BOND_LINK_DOWN:
            bond_active = BOND_NO_ACTIVE
    bond_select_active()
    return 0


def bond_select_active():
    # (Re)compute the active slave (mode 1 active-backup). If the current
    # active slave is still in use and link-up, keep it (stability — a real
    # bond does not flap the active slave gratuitously). Otherwise promote the
    # first live (inuse + link-up) slave, in slot order, to active. If none is
    # live, the bond has no active slave (carrier down).
    #
    # In mode 0 (balance-rr) there is no single "active" slave; we still keep
    # bond_active pointing at the first live slave as a convenience/diagnostic,
    # but tx uses the round-robin cursor, not bond_active.
    if bond_active >= 0:
        a: uint64 = cast[uint64](bond_active)
        if a < BOND_MAX_SLAVES:
            if bond_slave_inuse[a] != 0:
                if bond_slave_link[a] == BOND_LINK_UP:
                    return
    # Current active is gone/down — find the first live slave.
    i: uint64 = 0
    while i < BOND_MAX_SLAVES:
        if bond_slave_inuse[i] != 0:
            if bond_slave_link[i] == BOND_LINK_UP:
                bond_active = cast[int32](i)
                return
        i = i + 1
    bond_active = BOND_NO_ACTIVE


def bond_active_slave() -> int32:
    # Accessor: the current active slave index (mode 1), or -1 if none.
    return bond_active


def bond_slave_is_live(slot: uint64) -> int32:
    # 1 if the slot is an enslaved, link-up member; 0 otherwise.
    if slot >= BOND_MAX_SLAVES:
        return 0
    if bond_slave_inuse[slot] == 0:
        return 0
    if bond_slave_link[slot] != BOND_LINK_UP:
        return 0
    return 1


def bond_live_count() -> uint64:
    # Number of enslaved members whose link is currently up.
    n: uint64 = 0
    i: uint64 = 0
    while i < BOND_MAX_SLAVES:
        if bond_slave_is_live(i) == 1:
            n = n + 1
        i = i + 1
    return n


# =====================================================================
# Transmit slave selection
# =====================================================================

def bond_tx_slave() -> int32:
    # Compute which slave should carry the NEXT transmit frame, WITHOUT
    # bumping any counters. Returns the slave slot index, or -1 if no slave is
    # live (carrier down).
    #
    #   mode 1 active-backup: the active slave (already guaranteed live by
    #                         bond_select_active).
    #   mode 0 balance-rr   : the next live slave in round-robin order,
    #                         starting from the cursor and skipping down slaves.
    if bond_mode == BOND_MODE_ACTIVEBACKUP:
        if bond_active < 0:
            return -1
        # Defensive: confirm the active slave is still live.
        if bond_slave_is_live(cast[uint64](bond_active)) != 1:
            return -1
        return bond_active
    # balance-rr: scan up to BOND_MAX_SLAVES slots from the cursor, returning
    # the first live one. Skips down/empty slots so the cursor only ever
    # resolves to a carrier-up member.
    if bond_live_count() == 0:
        return -1
    probes: uint64 = 0
    cur: uint64 = bond_rr_cursor
    while probes < BOND_MAX_SLAVES:
        idx: uint64 = cur % BOND_MAX_SLAVES
        if bond_slave_is_live(idx) == 1:
            return cast[int32](idx)
        cur = cur + 1
        probes = probes + 1
    return -1


def bond_tx(frame: Ptr[uint8], length: uint64) -> int32:
    # Submit an Ethernet frame to the bond. Selects the carrying slave per the
    # active mode, bumps that slave's tx counter (and the bond total), advances
    # the round-robin cursor (mode 0) past the chosen slave, and returns the
    # slave slot index that carried the frame. Returns -1 (and bumps the
    # no-carrier drop counter) if no slave is live.
    #
    # `frame`/`length` are the fully built L2 frame; we validate the minimum
    # length the way eth_tx would, but the bond's job is slave SELECTION, not
    # framing — a real bond hands the frame down to the chosen slave's NIC tx.
    bond_tx_total = bond_tx_total + 1
    if length < ETH_HDR_LEN:
        bond_tx_nocarrier = bond_tx_nocarrier + 1
        return -1
    slot: int32 = bond_tx_slave()
    if slot < 0:
        bond_tx_nocarrier = bond_tx_nocarrier + 1
        return -1
    s: uint64 = cast[uint64](slot)
    bond_slave_tx[s] = bond_slave_tx[s] + 1
    # In balance-rr, advance the cursor to JUST AFTER the slave we used so the
    # next frame starts its scan at the following slot (genuine round-robin).
    if bond_mode == BOND_MODE_ROUNDROBIN:
        bond_rr_cursor = (s + 1) % BOND_MAX_SLAVES
    return slot


def bond_slave_tx_count(slot: uint64) -> uint64:
    # Accessor: how many frames slave `slot` has carried.
    if slot >= BOND_MAX_SLAVES:
        return 0
    return bond_slave_tx[slot]


# =====================================================================
# In-kernel self-test (deterministic, no NIC required)
# =====================================================================
#
# Mirrors drivers/net/vlan.ad::vlan_selftest / gre.ad::gre_selftest. Pure
# in-memory: build fake slaves, prove active-backup tx lands on the active
# slave, fail the active slave and prove failover to a backup, then prove
# balance-rr distributes round-robin across live slaves and skips a down one.

def _bond_emerg0(s: Ptr[char]):
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0(s)


def _bond_emerg1(s: Ptr[char], a: uint64):
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk1(s, a)


def _bond_emerg2(s: Ptr[char], a: uint64, b: uint64):
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk2(s, a, b)


# Scratch frame buffer. The largest L2 frame is the 1514-byte MTU Ethernet
# frame; we size to 1600 so an undersized array can't silently overflow into
# the next module-scope global (BSS is laid out in declaration order).
BOND_T_CAP: uint64 = 1600
_bondt_frame: Array[1600, uint8]


def _bond_build_frame(seed: uint8) -> uint64:
    # Build a deterministic untagged Ethernet frame (dst aa.., src bb..,
    # ethertype 0x0800, then a few payload bytes). Returns the frame length.
    plen: uint64 = 32
    i: uint64 = 0
    while i < 6:
        _bondt_frame[i]     = 0xAA
        _bondt_frame[6 + i] = 0xBB
        i = i + 1
    _bondt_frame[12] = 0x08
    _bondt_frame[13] = 0x00
    j: uint64 = 0
    while j < plen:
        _bondt_frame[ETH_HDR_LEN + j] = cast[uint8](
            (cast[uint32](seed) + cast[uint32](j)) & 0xFF)
        j = j + 1
    return ETH_HDR_LEN + plen


def _bond_fake_mac(out6: Ptr[uint8], base: uint8):
    # Fill a 6-byte MAC 02:base:base:base:base:base (locally-administered).
    out6[0] = 0x02
    k: uint64 = 1
    while k < 6:
        out6[k] = base
        k = k + 1


# A small 6-byte scratch MAC for building slaves.
_bond_macbuf: Array[6, uint8]


def bond_selftest() -> int32:
    # Returns 1 on PASS, 0 on FAIL. Prints granular [bond] ... OK lines and a
    # final [bond] PASS / [bond] FAIL.
    _bond_emerg0("[bond] self-test start\n")
    ok: int32 = 1

    flen: uint64 = _bond_build_frame(0x42)

    # ================================================================
    # Mode 1: active-backup
    # ================================================================
    bond_init(BOND_MODE_ACTIVEBACKUP)

    # Enslave three NICs, all link-up. ifindex 10/11/12.
    _bond_fake_mac(cast[Ptr[uint8]](&_bond_macbuf[0]), 0x10)
    s0: int32 = bond_enslave(10, cast[Ptr[uint8]](&_bond_macbuf[0]), BOND_LINK_UP)
    _bond_fake_mac(cast[Ptr[uint8]](&_bond_macbuf[0]), 0x11)
    s1: int32 = bond_enslave(11, cast[Ptr[uint8]](&_bond_macbuf[0]), BOND_LINK_UP)
    _bond_fake_mac(cast[Ptr[uint8]](&_bond_macbuf[0]), 0x12)
    s2: int32 = bond_enslave(12, cast[Ptr[uint8]](&_bond_macbuf[0]), BOND_LINK_UP)
    if s0 < 0 or s1 < 0 or s2 < 0:
        _bond_emerg0("[bond] FAIL: enslave returned -1\n")
        return 0
    if bond_nslaves != 3:
        _bond_emerg1("[bond] FAIL: nslaves %d != 3\n", bond_nslaves)
        return 0
    _bond_emerg0("[bond] enslave 3 slaves (mode active-backup) OK\n")

    # The first live slave (slot 0) must be active.
    if bond_active_slave() != s0:
        _bond_emerg2("[bond] FAIL: initial active %d != %d\n",
                     cast[uint64](bond_active_slave()), cast[uint64](s0))
        ok = 0
    else:
        _bond_emerg1("[bond] active-backup initial active = slave %d OK\n",
                     cast[uint64](s0))

    # Transmit several frames — every one must land on the active slave (s0).
    t: uint64 = 0
    ab_ok: int32 = 1
    while t < 5:
        carried: int32 = bond_tx(cast[Ptr[uint8]](&_bondt_frame[0]), flen)
        if carried != s0:
            ab_ok = 0
            t = 5
        else:
            t = t + 1
    if ab_ok != 1:
        _bond_emerg0("[bond] FAIL: active-backup tx not all on active slave\n")
        ok = 0
    if bond_slave_tx_count(cast[uint64](s0)) != 5:
        _bond_emerg1("[bond] FAIL: active slave tx count %d != 5\n",
                     bond_slave_tx_count(cast[uint64](s0)))
        ok = 0
    # The backups must have carried ZERO frames.
    if bond_slave_tx_count(cast[uint64](s1)) != 0 or bond_slave_tx_count(cast[uint64](s2)) != 0:
        _bond_emerg0("[bond] FAIL: backup slaves carried tx in active-backup\n")
        ok = 0
    if ok == 1:
        _bond_emerg1("[bond] active-backup tx routes to active slave %d (5 frames) OK\n",
                     cast[uint64](s0))

    # --- Failover: mark the active slave (s0) DOWN. ---
    if bond_set_link(cast[uint64](s0), BOND_LINK_DOWN) != 0:
        _bond_emerg0("[bond] FAIL: bond_set_link(s0 down)\n")
        return 0
    # A live backup must now be active (the first live slave = s1).
    new_active: int32 = bond_active_slave()
    if new_active != s1:
        _bond_emerg2("[bond] FAIL: failover active %d != %d\n",
                     cast[uint64](new_active), cast[uint64](s1))
        ok = 0
    else:
        _bond_emerg2("[bond] failover: active slave %d down -> promoted slave %d OK\n",
                     cast[uint64](s0), cast[uint64](s1))

    # Transmit must now route to the newly-promoted slave (s1).
    fo_carried: int32 = bond_tx(cast[Ptr[uint8]](&_bondt_frame[0]), flen)
    if fo_carried != s1:
        _bond_emerg2("[bond] FAIL: post-failover tx on %d != %d\n",
                     cast[uint64](fo_carried), cast[uint64](s1))
        ok = 0
    else:
        _bond_emerg1("[bond] post-failover tx routes to promoted slave %d OK\n",
                     cast[uint64](s1))

    # --- All slaves down: bond is carrier-down, tx must fail. ---
    bond_set_link(cast[uint64](s1), BOND_LINK_DOWN)
    bond_set_link(cast[uint64](s2), BOND_LINK_DOWN)
    nc_before: uint64 = bond_tx_nocarrier
    nc_carried: int32 = bond_tx(cast[Ptr[uint8]](&_bondt_frame[0]), flen)
    if nc_carried != -1:
        _bond_emerg1("[bond] FAIL: tx with all slaves down returned %d\n",
                     cast[uint64](nc_carried))
        ok = 0
    if bond_tx_nocarrier != (nc_before + 1):
        _bond_emerg0("[bond] FAIL: no-carrier drop counter not bumped\n")
        ok = 0
    if ok == 1:
        _bond_emerg0("[bond] all-slaves-down tx drops (no carrier) OK\n")

    # ================================================================
    # Mode 0: balance-rr
    # ================================================================
    bond_init(BOND_MODE_ROUNDROBIN)

    # Enslave four NICs, all up: ifindex 20/21/22/23 -> slots 0/1/2/3.
    _bond_fake_mac(cast[Ptr[uint8]](&_bond_macbuf[0]), 0x20)
    r0: int32 = bond_enslave(20, cast[Ptr[uint8]](&_bond_macbuf[0]), BOND_LINK_UP)
    _bond_fake_mac(cast[Ptr[uint8]](&_bond_macbuf[0]), 0x21)
    r1: int32 = bond_enslave(21, cast[Ptr[uint8]](&_bond_macbuf[0]), BOND_LINK_UP)
    _bond_fake_mac(cast[Ptr[uint8]](&_bond_macbuf[0]), 0x22)
    r2: int32 = bond_enslave(22, cast[Ptr[uint8]](&_bond_macbuf[0]), BOND_LINK_UP)
    _bond_fake_mac(cast[Ptr[uint8]](&_bond_macbuf[0]), 0x23)
    r3: int32 = bond_enslave(23, cast[Ptr[uint8]](&_bond_macbuf[0]), BOND_LINK_UP)
    if r0 < 0 or r1 < 0 or r2 < 0 or r3 < 0:
        _bond_emerg0("[bond] FAIL: balance-rr enslave\n")
        return 0
    _bond_emerg0("[bond] enslave 4 slaves (mode balance-rr) OK\n")

    # Transmit 8 frames. With 4 live slaves and round-robin, the carrying
    # slave must cycle 0,1,2,3,0,1,2,3.
    rr_ok: int32 = 1
    f: uint64 = 0
    while f < 8:
        want: int32 = cast[int32](f % 4)
        got: int32 = bond_tx(cast[Ptr[uint8]](&_bondt_frame[0]), flen)
        if got != want:
            _bond_emerg2("[bond] FAIL: rr frame -> slave %d != %d\n",
                         cast[uint64](got), cast[uint64](want))
            rr_ok = 0
            f = 8
        else:
            f = f + 1
    if rr_ok != 1:
        ok = 0
    else:
        _bond_emerg0("[bond] balance-rr cycles 0,1,2,3,0,1,2,3 across live slaves OK\n")

    # Each of the 4 slaves must have carried exactly 2 of the 8 frames.
    even_ok: int32 = 1
    e: uint64 = 0
    while e < 4:
        if bond_slave_tx_count(e) != 2:
            _bond_emerg2("[bond] FAIL: rr slave %d carried %d != 2\n",
                         e, bond_slave_tx_count(e))
            even_ok = 0
            e = 4
        else:
            e = e + 1
    if even_ok != 1:
        ok = 0
    else:
        _bond_emerg0("[bond] balance-rr even distribution (2 frames each) OK\n")

    # --- Down a slave (slot 1) mid-stream; rr must SKIP it. ---
    if bond_set_link(1, BOND_LINK_DOWN) != 0:
        _bond_emerg0("[bond] FAIL: bond_set_link(rr slot1 down)\n")
        return 0
    # Reset per-slave tx counters by re-recording the baseline, then transmit
    # 6 frames. Live slaves are now {0,2,3}; the down slave (1) must NEVER
    # carry a frame. Capture baselines first.
    base0: uint64 = bond_slave_tx_count(0)
    base1: uint64 = bond_slave_tx_count(1)
    base2: uint64 = bond_slave_tx_count(2)
    base3: uint64 = bond_slave_tx_count(3)
    skip_ok: int32 = 1
    g: uint64 = 0
    while g < 6:
        gc: int32 = bond_tx(cast[Ptr[uint8]](&_bondt_frame[0]), flen)
        if gc == 1:
            _bond_emerg0("[bond] FAIL: rr tx landed on the DOWN slave 1\n")
            skip_ok = 0
            g = 6
        else:
            if bond_slave_is_live(cast[uint64](gc)) != 1:
                _bond_emerg1("[bond] FAIL: rr tx on non-live slave %d\n",
                             cast[uint64](gc))
                skip_ok = 0
                g = 6
            else:
                g = g + 1
    if skip_ok != 1:
        ok = 0
    # The down slave's count must be unchanged; the 6 frames must be spread
    # over the 3 live slaves (2 each, since rr is exact over 3 live members).
    if bond_slave_tx_count(1) != base1:
        _bond_emerg0("[bond] FAIL: down slave 1 tx count changed\n")
        ok = 0
    d0: uint64 = bond_slave_tx_count(0) - base0
    d2: uint64 = bond_slave_tx_count(2) - base2
    d3: uint64 = bond_slave_tx_count(3) - base3
    if (d0 + d2 + d3) != 6:
        _bond_emerg1("[bond] FAIL: live-slave tx delta %d != 6\n", d0 + d2 + d3)
        ok = 0
    if d0 != 2 or d2 != 2 or d3 != 2:
        _bond_emerg2("[bond] FAIL: rr-skip distribution uneven (s0=%d s2/s3)\n",
                     d0, d2 + d3)
        ok = 0
    if ok == 1:
        _bond_emerg0("[bond] balance-rr skips down slave, distributes to live {0,2,3} OK\n")

    # --- release a slave and confirm the member set shrinks. ---
    pre_n: uint64 = bond_nslaves
    if bond_release(cast[uint64](r3)) != 0:
        _bond_emerg0("[bond] FAIL: release slot r3\n")
        ok = 0
    if bond_nslaves != (pre_n - 1):
        _bond_emerg2("[bond] FAIL: nslaves after release %d != %d\n",
                     bond_nslaves, pre_n - 1)
        ok = 0
    if bond_slave_is_live(cast[uint64](r3)) != 0:
        _bond_emerg0("[bond] FAIL: released slave still live\n")
        ok = 0
    if ok == 1:
        _bond_emerg0("[bond] release member (slave set shrinks) OK\n")

    if ok == 1:
        _bond_emerg0("[bond] PASS\n")
        return 1
    _bond_emerg0("[bond] FAIL\n")
    return 0

# drivers/net/eth.ad
#
# L37+ scaffold: Ethernet (IEEE 802.3) framing + the kernel's notion
# of a "net_device". Read-only stubs — eth_rx() just logs and drops.
#
# Wiring intent (when the rest of the stack lands):
#   NIC ISR -> drains its RX ring -> hands raw frames to eth_rx().
#   eth_rx() peels the 14-byte EthHdr, looks at .proto, and dispatches:
#     ETH_P_IP   -> drivers/net/ip.ad:ip_rx
#     ETH_P_ARP  -> drivers/net/arp.ad:arp_rx
#     ETH_P_IPV6 -> (not yet)
#
# The single net_device global mirrors stock Linux's struct net_device
# at the absolute minimum: an interface name (so /proc/net/dev has
# something to print), a 6-byte MAC, and a pair of tx/rx counters that
# the NIC driver bumps. A real Linux build has ~1.5 KiB of net_device
# state (queues, ethtool ops, qdisc, ndo_* table); we'll grow into that
# once a real driver actually moves bytes.

from kernel.printk.printk import printk0, printk1


# EtherType values (host order; on the wire these are big-endian and
# eth_rx will byte-swap before comparing).
ETH_P_IP:   uint16 = 0x0800
ETH_P_ARP:  uint16 = 0x0806
ETH_P_IPV6: uint16 = 0x86DD


# Standard Ethernet II header. 14 bytes on the wire. No 802.1Q tag
# handling yet — a tagged frame would have an extra 4 bytes between
# src and proto that we'd peel off before the proto check.
class EthHdr:
    dest:  Array[6, uint8]
    src:   Array[6, uint8]
    proto: uint16


# Hand-built net_device. Same parallel-arrays-of-globals discipline as
# linux_abi/api_socket.ad, except there's only one NIC for now so we
# inline the fields rather than build a slot table.
ETH_IFNAME_LEN: uint64 = 16

nd_name:    Array[16, uint8]
nd_mac:     Array[6, uint8]
nd_mtu:     uint32 = 1500
nd_up:      uint32 = 0
nd_rx_pkts: uint64 = 0
nd_rx_drop: uint64 = 0
nd_tx_pkts: uint64 = 0


def eth_rx(frame: Ptr[uint8], length: uint64):
    # Scaffold stub. A real implementation would:
    #   1. Validate length >= 14 (header) and <= MTU + 14.
    #   2. Cast frame to Ptr[EthHdr], byte-swap .proto.
    #   3. Switch on the host-order proto and tail-call the L3 handler.
    #   4. On unknown proto, bump nd_rx_drop and return.
    # For now: log + discard.
    nd_rx_pkts = nd_rx_pkts + 1
    nd_rx_drop = nd_rx_drop + 1
    printk1("eth_rx: %d bytes\n", length)


def eth_tx(frame: Ptr[uint8], length: uint64) -> int32:
    # Placeholder transmit path. The NIC driver will replace the body
    # with a ring-doorbell sequence; for now we just count the call.
    nd_tx_pkts = nd_tx_pkts + 1
    printk1("eth_tx: %d bytes (no driver)\n", length)
    return 0


def eth_init():
    # Zero the interface name and MAC; bring the (nonexistent) link
    # down. A real init would walk PCI for a known NIC ID, install
    # the ISR, allocate RX/TX rings, then flip nd_up to 1.
    i: uint64 = 0
    while i < ETH_IFNAME_LEN:
        nd_name[i] = 0
        i = i + 1
    i = 0
    while i < 6:
        nd_mac[i] = 0
        i = i + 1
    nd_up      = 0
    nd_rx_pkts = 0
    nd_rx_drop = 0
    nd_tx_pkts = 0
    printk0("eth: scaffold initialized (no driver bound)\n")

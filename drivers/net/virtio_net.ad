# drivers/net/virtio_net.ad
#
# Bare-metal virtio-net PCI driver — mirror of drivers/net/virtio_net.c
# at minimum scope. Probes the legacy virtio-net PCI device
# (1AF4:1000), runs the standard virtio init dance, sets up the
# RX (queue 0) and TX (queue 1) virtqueues, pre-populates the RX
# ring with 8 receive buffers, reads the device MAC, and exposes a
# polling helper `virtio_net_poll()` that drains the RX used ring
# and calls `eth_rx()` for each received frame.
#
# Why a polling helper and not a real IRQ handler? The bare-metal
# kernel currently brings up the LAPIC for the timer tick but does
# NOT program the IOAPIC, so PCI INTx lines have nowhere to land.
# MSI-X would work but adds complexity ruled out of this milestone.
# Polling on demand is sufficient to prove the driver delivers
# frames — `net_smoke_test()` in init/main.ad calls
# `virtio_net_poll()` in a short busy loop after device init,
# giving QEMU SLIRP time to inject its initial ARP/DHCP broadcast.
#
# Frame shape on the wire vs. in the virtio queue:
#
#   virtio_net legacy RX buffer:
#     [ struct virtio_net_hdr (10 bytes) | ethernet frame ]
#
#   struct virtio_net_hdr (without F_MRG_RXBUF) — 10 bytes:
#       u8  flags
#       u8  gso_type
#       u16 hdr_len
#       u16 gso_size
#       u16 csum_start
#       u16 csum_offset
#
# We strip the 10-byte virtio_net_hdr before handing the raw
# Ethernet frame up to eth_rx().

from kernel.printk.printk import printk0, printk1, printk2
from drivers.pci.pci import (
    pci_find, pci_read_bar, pci_enable_io_and_master,
    pci_enable_mem_and_master,
    pci_config_read_byte, pci_bdf_bus, pci_bdf_dev, pci_bdf_fn,
    PCI_BDF_NONE, PCI_CAP_ID_MSIX,
    pci_find_capability, pci_msix_table_size, pci_msix_table_addr,
    pci_msix_program_vector, pci_msix_enable,
)
from drivers.virtio.virtio_pci import (
    virtio_reset, virtio_acknowledge, virtio_driver_ok,
    virtio_read_host_features, virtio_write_guest_features,
    virtio_notify, VIRTIO_PCI_CONFIG, VIRTIO_PCI_CONFIG_MSIX,
    VIRTIO_PCI_ISR, VIRTIO_MSI_NO_VECTOR,
    virtio_set_config_msix_vector, virtio_set_queue_msix_vector,
)
from arch.x86.kernel.apic import ioapic_redirect
from arch.x86.kernel.irq import register_irq_handler
from kernel.softirq import (
    raise_softirq, open_softirq, NET_RX_SOFTIRQ, softirq_started_get,
)
from mm.page_alloc import alloc_pages
from mm.slab import kmalloc
from drivers.net.eth import eth_rx, nd_mac, eth_register_tx_hook
# Higher-half kernel: device DMA targets must be physical addresses.
from arch.x86.mm.pgtable import virt_to_phys

extern def memset(dst: Ptr[uint8], val: int32, n: uint64) -> Ptr[uint8]


VNET_PCI_VENDOR:        uint32 = 0x1AF4
VIRTIO_NET_LEGACY:    uint32 = 0x1000

# Feature bits we care about (legacy bit positions).
VIRTIO_NET_F_MAC:        uint32 = 0x20         # bit 5  — config.mac is valid
VIRTIO_NET_F_MRG_RXBUF:  uint32 = 0x8000       # bit 15 — mergeable RX buffers
VIRTIO_NET_F_CTRL_VQ:    uint32 = 0x20000      # bit 17 — control virtqueue
VIRTIO_NET_F_MQ:         uint32 = 0x400000     # bit 22 — multiqueue + cfg pairs

# virtio-net control virtqueue: command classes / commands.
#   class VIRTIO_NET_CTRL_MQ (4), cmd VIRTIO_NET_CTRL_MQ_VQ_PAIRS_SET (0)
# The control buffer is { u8 class, u8 cmd, <cmd-data>, u8 ack }. For
# the MQ_VQ_PAIRS_SET command the data is a u16 little-endian pair count.
# The device writes VIRTIO_NET_OK (0) / VIRTIO_NET_ERR (1) into ack.
VIRTIO_NET_CTRL_MQ:               uint8 = 4
VIRTIO_NET_CTRL_MQ_VQ_PAIRS_SET:  uint8 = 0
VIRTIO_NET_OK:                    uint8 = 0
VIRTIO_NET_ERR:                   uint8 = 1

# Descriptor flags (mirror of drivers/virtio/virtio_ring.ad — duplicated
# here so this driver isn't tangled in with virtio-blk's helpers, which
# assume a 3-descriptor chain shape we don't share).
VNET_DESC_F_NEXT:    uint16 = 1
VNET_DESC_F_WRITE:   uint16 = 2

# Sizes used by the RX ring layout.
#
# Two virtio_net_hdr shapes exist. Without F_MRG_RXBUF the header is
# 10 bytes; with F_MRG_RXBUF the device appends a u16 num_buffers field
# making it 12 bytes. We pick the active length at negotiation time and
# stash it in vnet_state.hdr_len so the RX/TX paths agree.
VIRTIO_NET_HDR_LEN:       uint64 = 10        # legacy (no F_MRG_RXBUF)
VIRTIO_NET_HDR_LEN_MRG:   uint64 = 12        # F_MRG_RXBUF (adds num_buffers)
VIRTIO_NET_HDR_NUMBUF_OFF: uint64 = 10       # u16 num_buffers at byte 10
RX_BUF_BYTES:         uint64 = 1538        # 12-byte vnet hdr + 1526 slack
NR_RX_BUFS:           uint64 = 16

# Virtqueue indices in the virtio-net spec. RX/TX for the single active
# datapath are 0/1. The control virtqueue index depends on how many
# queue-pairs the device exposes: it is always 2*max_virtqueue_pairs.
# With a single negotiated pair that lands at index 2.
VQ_RX:                uint32 = 0
VQ_TX:                uint32 = 1

# Legacy virtio header offset for the device-specific config window
# (mac is at offset 0 of that window for virtio-net).
VNET_CFG_MAC_OFF:     uint32 = 0

# PCI config-space offsets used by the IRQ wiring path.
PCI_INTERRUPT_LINE:   uint32 = 0x3C
PCI_INTERRUPT_PIN:    uint32 = 0x3D

# CPU vector this driver claims for its INTx IRQ. The IDT runs vectors
# 32..47 for legacy PIC IRQs and reserves the 48..71 band for IOAPIC-
# routed PCI INTx (see arch/x86/kernel/idt.ad). 0x40 (64) is the
# first slot in that band — virtio-net is the bring-up consumer; the
# other drivers (AHCI / NVMe / e1000e / r8169) claim 0x41..0x47.
VNET_IRQ_VECTOR:      uint32 = 0x40

# MSI-X CPU vectors. When the device advertises the MSI-X capability
# we route each interrupt source to its own LAPIC vector — one per
# virtqueue plus one for config-change — which is the prerequisite
# for per-queue scaling. The IDT IRQ band runs through 0x71, so the
# 0x49..0x4B slots are free (0x48 is r8169-gigabit MSI).
#   0x49  RX queue (virtqueue 0)
#   0x4A  TX queue (virtqueue 1)
#   0x4B  config-change
# The MSI-X table-entry indices are 0/1/2 in the same order.
VNET_MSIX_VEC_RX:     uint32 = 0x49
VNET_MSIX_VEC_TX:     uint32 = 0x4A
VNET_MSIX_VEC_CFG:    uint32 = 0x4B
VNET_MSIX_ENTRY_RX:   uint32 = 0
VNET_MSIX_ENTRY_TX:   uint32 = 1
VNET_MSIX_ENTRY_CFG:  uint32 = 2

# LAPIC ID to route the IRQ to. Always the BSP (id 0) for now — once
# we have IRQ affinity / SMP IRQ steering, this becomes per-IRQ
# policy.
VNET_LAPIC_ID:        uint32 = 0


# Per-virtqueue runtime state. Mirrors virtio_ring's VirtQueue but
# stays local to this driver — we want a separate descriptor free-list
# discipline (single-descriptor chains for RX, single-descriptor TX
# chains too in future) without sharing the 3-buf chain assumption.
class VNetVQ:
    qsize:           uint16
    used_idx_seen:   uint16
    pad0:            uint16
    pad1:            uint16
    desc_addr:       uint64       # qsize * 16 bytes
    avail_addr:      uint64       # 6 + qsize * 2 bytes
    used_addr:       uint64       # 6 + qsize * 8 bytes
    page_addr:       uint64       # base of the contiguous queue allocation


class VirtioNet:
    iobase:          uint32
    irq_pin:         uint32                # IOAPIC pin we redirected (INTx)
    cfg_base:        uint32                # device-config window: 0x14 INTx, 0x18 MSI-X
    msix_enabled:    uint32                # 1 once MSI-X is the interrupt path
    msix_table:      uint64                # mapped MSI-X table base (MSI-X path)
    rx:              VNetVQ
    tx:              VNetVQ
    ctrl:            VNetVQ                # control virtqueue (F_CTRL_VQ)
    rx_buf_addrs:    Array[16, uint64]   # NR_RX_BUFS slots
    mac:             Array[6, uint8]
    rx_packets:      uint64
    irq_count:       uint64                # IRQs handled by virtio_net_irq_handler
    # --- modern-feature negotiation state ---
    mrg_rxbuf:       uint32                # 1 when F_MRG_RXBUF negotiated
    hdr_len:         uint64                # active virtio_net_hdr length (10 or 12)
    ctrl_vq:         uint32                # 1 when the control virtqueue is live
    ctrl_qidx:      uint32                 # virtqueue index of the control queue
    max_vq_pairs:    uint32                # device-advertised max queue pairs
    cur_vq_pairs:    uint32                # pairs we negotiated via CTRL_MQ
    rx_outstanding:  uint64                # RX descriptors currently posted
    mrg_frames:      uint64                # frames reassembled across >1 buffer
    refills:         uint64                # refill batches pushed back to device


vnet_state: VirtioNet

# Reassembly scratch for a mergeable-RX frame that spans multiple
# buffers. Lives in BSS so its address is stable; large enough for a
# full 1514-byte Ethernet frame plus headroom.
vnet_reasm_buf: Array[2048, uint8]

# Control-queue command buffers. The control virtqueue command is a
# 3-descriptor chain: [device-readable header+data][device-readable
# extra (none here)][device-writable ack]. We fold header+data into one
# readable buffer and use a separate one-byte ack buffer.
#   ctrl_cmd[0] = class, ctrl_cmd[1] = cmd, ctrl_cmd[2..3] = u16 data
vnet_ctrl_cmd: Array[8, uint8]
vnet_ctrl_ack: Array[8, uint8]


def _vnet_align_up(value: uint64, alignment: uint64) -> uint64:
    return (value + alignment - 1) & ~(alignment - 1)


def _vnet_queue_select(iobase: uint32, qidx: uint32) -> uint32:
    # Inline the queue-select sequence we need (read QUEUE_SIZE for
    # qidx). Mirrors virtio_select_queue but kept inline so we don't
    # have to import the helper twice with different prototypes.
    outw(cast[int32](qidx & 0xFFFF), cast[int32](iobase + 0x0E))
    return cast[uint32](inw(cast[int32](iobase + 0x0C)))


def _vnet_set_queue_pfn(iobase: uint32, page_addr: uint64):
    pfn: uint32 = cast[uint32](page_addr >> 12)
    outl(pfn, cast[int32](iobase + 0x08))


def _vnet_vq_setup(iobase: uint32, qidx: uint32,
                   vq: Ptr[VNetVQ]) -> int32:
    # Standard legacy-virtio queue setup: SELECT, read QUEUE_SIZE,
    # allocate a single contiguous block large enough for the three
    # rings (descriptors, avail, used) at the spec-mandated alignment,
    # zero it, plant the PFN.
    qsize: uint32 = _vnet_queue_select(iobase, qidx)
    if qsize == 0:
        printk1("[virtio-net] queue %d unsupported (size 0)\n",
                cast[uint64](qidx))
        return -1
    if qsize > 256:
        printk1("[virtio-net] queue %d larger than 256\n",
                cast[uint64](qidx))
        return -1

    # 4 pages (order=2 = 16 KiB) is plenty for qsize<=256. Same shape
    # virtio-blk uses.
    page: uint64 = alloc_pages(2)
    if page == 0:
        return -1
    memset(cast[Ptr[uint8]](page), 0, 16384)

    desc_off:   uint64 = 0
    desc_size:  uint64 = cast[uint64](qsize) * 16
    avail_off:  uint64 = _vnet_align_up(desc_off + desc_size, 2)
    avail_size: uint64 = 6 + cast[uint64](qsize) * 2
    used_off:   uint64 = _vnet_align_up(avail_off + avail_size, 4096)

    vq[0].qsize         = cast[uint16](qsize & 0xFFFF)
    vq[0].used_idx_seen = 0
    vq[0].desc_addr     = page + desc_off
    vq[0].avail_addr    = page + avail_off
    vq[0].used_addr     = page + used_off
    vq[0].page_addr     = page

    _vnet_set_queue_pfn(iobase, page)
    printk2("[virtio-net] queue %d ready (size=%d)\n",
            cast[uint64](qidx), cast[uint64](qsize))
    return 0


def _vnet_desc_set(vq: Ptr[VNetVQ], idx: uint16,
              addr: uint64, length: uint32, flags: uint16,
              nxt: uint16):
    # 16-byte descriptor: u64 addr | u32 len | u16 flags | u16 next.
    # The address field is a PHYSICAL address the device DMAs to/from.
    # Higher-half kernel: a TX buffer that is a kernel global
    # (vnet_tx_buf) is a high-half VA; virt_to_phys() rebases it to low
    # physical RAM. A kmalloc'd RX buffer is already low and passes
    # through unchanged.
    d: uint64 = vq[0].desc_addr + cast[uint64](idx) * 16
    cast[Ptr[uint64]](d +  0)[0] = virt_to_phys(addr)
    cast[Ptr[uint32]](d +  8)[0] = length
    cast[Ptr[uint16]](d + 12)[0] = flags
    cast[Ptr[uint16]](d + 14)[0] = nxt


def _avail_push(vq: Ptr[VNetVQ], head: uint16):
    # Append `head` to the avail ring and bump the idx. Wraps modulo
    # qsize. x86 TSO gives us the memory ordering for free.
    avail: uint64 = vq[0].avail_addr
    qsize: uint16 = vq[0].qsize
    idx:   uint16 = cast[Ptr[uint16]](avail + 2)[0]
    slot:  uint16 = idx % qsize
    cast[Ptr[uint16]](avail + 4 + cast[uint64](slot) * 2)[0] = head
    cast[Ptr[uint16]](avail + 2)[0] = idx + 1


def _populate_rx(vnet: Ptr[VirtioNet]):
    # Pre-fill the RX ring with NR_RX_BUFS single-descriptor entries.
    # Each descriptor points at a kmalloc'd RX_BUF_BYTES buffer; the
    # device may write up to that much (virtio_net_hdr + Ethernet
    # frame). With F_MRG_RXBUF the device may also chain several of
    # these buffers together for one frame — each one is still a
    # standalone device-writable descriptor here, the device decides at
    # RX time how many it consumes for a given frame (and tells us via
    # num_buffers). After all NR_RX_BUFS entries are linked into the
    # avail ring we kick the RX queue once.
    i: uint64 = 0
    while i < NR_RX_BUFS:
        buf: uint64 = kmalloc(RX_BUF_BYTES)
        if buf == 0:
            printk0("[virtio-net] kmalloc for RX buf failed\n")
            return
        memset(cast[Ptr[uint8]](buf), 0, RX_BUF_BYTES)
        vnet[0].rx_buf_addrs[i] = buf
        # Descriptor idx == i; single-descriptor chain (no NEXT).
        _vnet_desc_set(&vnet[0].rx, cast[uint16](i),
                  buf, cast[uint32](RX_BUF_BYTES),
                  VNET_DESC_F_WRITE, 0)
        _avail_push(&vnet[0].rx, cast[uint16](i))
        i = i + 1
    vnet[0].rx_outstanding = NR_RX_BUFS


def _rx_repost(slot: uint16):
    # Re-arm a single RX descriptor `slot`: reset it to full buffer
    # capacity, device-writable, and push it back onto the avail ring.
    # Bumps the outstanding count. The caller is responsible for the
    # eventual kick (so a batch of reposts costs one notification).
    buf: uint64 = vnet_state.rx_buf_addrs[slot]
    _vnet_desc_set(&vnet_state.rx, slot,
              buf, cast[uint32](RX_BUF_BYTES),
              VNET_DESC_F_WRITE, 0)
    _avail_push(&vnet_state.rx, slot)
    vnet_state.rx_outstanding = vnet_state.rx_outstanding + 1


def _vnet_ctrl_set_mq_pairs(pairs: uint32) -> int32:
    # Issue VIRTIO_NET_CTRL_MQ_VQ_PAIRS_SET over the control
    # virtqueue. The command is a real 3-descriptor chain:
    #   desc0 (RO):  { u8 class=VIRTIO_NET_CTRL_MQ, u8 cmd=0 } | u16 pairs
    #   desc1 (WO):  u8 ack  (device writes VIRTIO_NET_OK / _ERR)
    # We fold the class/cmd header and the u16 pairs payload into a
    # single device-readable buffer (vnet_ctrl_cmd) so the chain is two
    # descriptors: one readable header+data, one writable ack. Both are
    # legal per the spec (the device parses the readable run as the
    # command, the writable tail as the status).
    if vnet_state.iobase == 0 or vnet_state.ctrl_vq == 0:
        return -1
    # Build the command buffer: class, cmd, then u16 little-endian pairs.
    vnet_ctrl_cmd[0] = VIRTIO_NET_CTRL_MQ
    vnet_ctrl_cmd[1] = VIRTIO_NET_CTRL_MQ_VQ_PAIRS_SET
    vnet_ctrl_cmd[2] = cast[uint8](pairs & 0xFF)
    vnet_ctrl_cmd[3] = cast[uint8]((pairs >> 8) & 0xFF)
    # Poison the ack so a stale 0 can't masquerade as success.
    vnet_ctrl_ack[0] = 0xFF

    cmd_addr: uint64 = cast[uint64](&vnet_ctrl_cmd[0])
    ack_addr: uint64 = cast[uint64](&vnet_ctrl_ack[0])

    # Two-descriptor chain at slots 0 and 1 of the control queue.
    #   slot0: readable header+data (4 bytes), NEXT -> slot1
    #   slot1: writable ack (1 byte), no NEXT
    _vnet_desc_set(&vnet_state.ctrl, 0, cmd_addr, 4,
                   VNET_DESC_F_NEXT, 1)
    _vnet_desc_set(&vnet_state.ctrl, 1, ack_addr, 1,
                   VNET_DESC_F_WRITE, 0)
    _avail_push(&vnet_state.ctrl, 0)
    virtio_notify(vnet_state.iobase, vnet_state.ctrl_qidx)

    # Poll the control used ring until the chain completes. The control
    # path is synchronous and rare (init-time only), so a bounded busy
    # poll is the right shape; we never block the datapath on it.
    used: uint64 = vnet_state.ctrl.used_addr
    seen: uint16 = vnet_state.ctrl.used_idx_seen
    spin: uint64 = 0
    while spin < 20000000:
        cur: uint16 = cast[Ptr[uint16]](used + 2)[0]
        if cur != seen:
            vnet_state.ctrl.used_idx_seen = cur
            ack: uint8 = vnet_ctrl_ack[0]
            if ack == VIRTIO_NET_OK:
                printk1("[virtio-net] CTRL_MQ pairs=%d acked\n",
                        cast[uint64](pairs))
                return 0
            printk1("[virtio-net] CTRL_MQ NAK ack=%d\n",
                    cast[uint64](ack))
            return -1
        spin = spin + 1
    printk0("[virtio-net] CTRL_MQ timed out (no used-ring completion)\n")
    return -1


def _read_mac(iobase: uint32, cfg_base: uint32, mac: Ptr[uint8]):
    # The device-specific config window starts at BAR0 + 0x14 on the
    # legacy INTx layout, but shifts to BAR0 + 0x18 once MSI-X is
    # enabled (the two 16-bit MSI-X vector registers occupy 0x14..0x17).
    # `cfg_base` carries whichever applies. The MAC is the first 6
    # bytes there, byte-readable. We use inb one byte at a time to
    # mirror virtio_cread_bytes() and avoid the legacy alignment trap
    # on partial-dword reads.
    i: uint32 = 0
    while i < 6:
        b: uint32 = inb(cast[int32](iobase + cfg_base + i)) & 0xFF
        mac[i] = cast[uint8](b)
        i = i + 1


def _print_mac(mac: Ptr[uint8]):
    # Emit "mac=xx:xx:xx:xx:xx:xx\n" using one printk per pair so the
    # one-arg printk path is enough. (printk has no formatter beyond
    # one or two %x specs.) We pad each byte with the high nibble
    # explicitly so leading zeros render.
    printk0("[virtio-net] mac=")
    i: uint64 = 0
    while i < 6:
        b: uint64 = cast[uint64](mac[i])
        hi: uint64 = (b >> 4) & 0xF
        lo: uint64 = b & 0xF
        printk1("%x", hi)
        printk1("%x", lo)
        if i < 5:
            printk0(":")
        i = i + 1
    printk0("\n")


def virtio_net_init() -> int32:
    # Probe and init. Returns 0 on success, -1 on no-device / failure.
    # Caller treats a miss as "no virtio-net attached" — net stack
    # stays scaffold-only.
    bdf: uint32 = pci_find(VNET_PCI_VENDOR, VIRTIO_NET_LEGACY)
    if bdf == PCI_BDF_NONE:
        printk0("[virtio-net] no PCI device found\n")
        return -1

    # Enable both IO and MEM decoding + bus-master. Legacy virtio
    # drives its registers through the IO BAR0, but the MSI-X table
    # lives in a MEM BAR, so a device that advertises MSI-X needs
    # Memory Space Enable too. Enabling both is harmless when MSI-X
    # is absent.
    pci_enable_io_and_master(bdf)
    pci_enable_mem_and_master(bdf)
    bar0_raw: uint32 = pci_read_bar(bdf, 0)
    if (bar0_raw & 1) == 0:
        printk0("[virtio-net] BAR0 is not IO-space (modern virtio?)\n")
        return -1
    iobase: uint32 = bar0_raw & 0xFFFFFFFC
    vnet_state.iobase = iobase
    vnet_state.rx_packets = 0
    vnet_state.irq_count = 0
    vnet_state.irq_pin = 0
    vnet_state.msix_enabled = 0
    vnet_state.msix_table = 0
    vnet_state.cfg_base = cast[uint32](VIRTIO_PCI_CONFIG)
    printk2("[virtio-net] bdf=%x iobase=%p\n",
            cast[uint64](bdf), cast[uint64](iobase))

    # Standard virtio init dance.
    virtio_reset(iobase)
    virtio_acknowledge(iobase)

    # Negotiate features. We accept F_MAC, and — when the host offers
    # them — F_MRG_RXBUF (mergeable RX buffers), F_CTRL_VQ (control
    # virtqueue) and F_MQ (multiqueue). Each is only enabled if the
    # host advertises it; the host's offered set is the upper bound.
    #
    # F_MRG_RXBUF switches the virtio_net_hdr to its 12-byte mergeable
    # form (adds a u16 num_buffers) and lets the device chain several
    # RX buffers for one frame. F_MQ + F_CTRL_VQ let us read
    # max_virtqueue_pairs and tell the device how many pairs to run via
    # the control virtqueue.
    host: uint32 = virtio_read_host_features(iobase)
    printk1("[virtio-net] host features=%x\n", cast[uint64](host))
    guest: uint32 = host & VIRTIO_NET_F_MAC
    vnet_state.mrg_rxbuf = 0
    vnet_state.hdr_len   = VIRTIO_NET_HDR_LEN
    vnet_state.ctrl_vq   = 0
    vnet_state.max_vq_pairs = 1
    vnet_state.cur_vq_pairs = 1
    vnet_state.mrg_frames   = 0
    vnet_state.refills      = 0
    vnet_state.rx_outstanding = 0
    if (host & VIRTIO_NET_F_MRG_RXBUF) != 0:
        guest = guest | VIRTIO_NET_F_MRG_RXBUF
        vnet_state.mrg_rxbuf = 1
        vnet_state.hdr_len   = VIRTIO_NET_HDR_LEN_MRG
        printk0("[virtio-net] negotiated F_MRG_RXBUF (12-byte hdr)\n")
    if (host & VIRTIO_NET_F_CTRL_VQ) != 0:
        guest = guest | VIRTIO_NET_F_CTRL_VQ
        vnet_state.ctrl_vq = 1
    if (host & VIRTIO_NET_F_MQ) != 0 and (host & VIRTIO_NET_F_CTRL_VQ) != 0:
        guest = guest | VIRTIO_NET_F_MQ
    virtio_write_guest_features(iobase, guest)

    # --- MSI-X capability detection + enable (kernel roadmap §9) ----
    # Walk the PCI capability list for the MSI-X capability (ID 0x11).
    # If the device advertises it (QEMU's virtio-net-pci does by
    # default — `vectors=3`), enable MSI-X NOW, before reading device
    # config or setting up queues: enabling MSI-X shifts the legacy
    # BAR0 device-config window from 0x14 to 0x18 (the two 16-bit
    # MSI-X vector registers occupy 0x14..0x17). Programming the
    # MSI-X table entries (message address/data) and the per-queue
    # vector mapping happens after the virtqueues exist.
    msix_cap: uint32 = pci_find_capability(bdf, PCI_CAP_ID_MSIX)
    if msix_cap != 0:
        tbl_sz: uint32 = pci_msix_table_size(bdf, msix_cap)
        tbl_addr: uint64 = pci_msix_table_addr(bdf, msix_cap)
        printk2("[virtio-net] MSI-X cap at 0x%x table_size=%d\n",
                cast[uint64](msix_cap), cast[uint64](tbl_sz))
        # Need at least 3 table entries (RX, TX, config-change). If
        # the device offers fewer, fall back to INTx rather than
        # half-wiring MSI-X.
        if tbl_sz >= 3 and tbl_addr != 0:
            printk1("[virtio-net] MSI-X table @ %p\n", tbl_addr)
            # Program the three table entries: each routes its CPU
            # vector to the BSP LAPIC. Entries are masked-then-
            # unmasked inside pci_msix_program_vector (vector control
            # written last).
            pci_msix_program_vector(tbl_addr, VNET_MSIX_ENTRY_RX,
                                    VNET_MSIX_VEC_RX, VNET_LAPIC_ID)
            pci_msix_program_vector(tbl_addr, VNET_MSIX_ENTRY_TX,
                                    VNET_MSIX_VEC_TX, VNET_LAPIC_ID)
            pci_msix_program_vector(tbl_addr, VNET_MSIX_ENTRY_CFG,
                                    VNET_MSIX_VEC_CFG, VNET_LAPIC_ID)
            # Read back entry 0 to confirm the MMIO writes landed —
            # a zero readback means the table writes never reached the
            # device (which would make it raise an MSI to physical
            # address 0, corrupting low RAM).
            rb_addr: uint32 = cast[Ptr[uint32]](tbl_addr + 0)[0]
            rb_data: uint32 = cast[Ptr[uint32]](tbl_addr + 8)[0]
            rb_ctrl: uint32 = cast[Ptr[uint32]](tbl_addr + 12)[0]
            printk2("[virtio-net] MSI-X entry0 readback addr=0x%x data=0x%x\n",
                    cast[uint64](rb_addr), cast[uint64](rb_data))
            printk1("[virtio-net] MSI-X entry0 vector-control=0x%x\n",
                    cast[uint64](rb_ctrl))
            # Flip the MSI-X Enable bit in the capability's Message
            # Control register. From here the device-config window is
            # at 0x18 and the queue/config MSI-X vector registers are
            # live at 0x14/0x16.
            pci_msix_enable(bdf, msix_cap)
            vnet_state.msix_enabled = 1
            vnet_state.msix_table   = tbl_addr
            vnet_state.cfg_base     = cast[uint32](VIRTIO_PCI_CONFIG_MSIX)
        else:
            printk0("[virtio-net] MSI-X table too small — using INTx\n")

    # Set up RX (queue 0) and TX (queue 1).
    if _vnet_vq_setup(iobase, VQ_RX, &vnet_state.rx) < 0:
        return -1
    if _vnet_vq_setup(iobase, VQ_TX, &vnet_state.tx) < 0:
        return -1

    # --- Multiqueue awareness (F_MQ) -------------------------------
    # When F_MQ was negotiated the device config window exposes
    # max_virtqueue_pairs as a u16 at offset 8 (mac[6] | status[2] |
    # max_virtqueue_pairs[2]). cfg_base already accounts for the MSI-X
    # window shift. We read it for visibility, but keep a single active
    # RX/TX datapath: that means we must negotiate the device DOWN to
    # one pair via the control virtqueue so device and driver agree on
    # how many queues are live. The control virtqueue is the queue at
    # index 2*max_virtqueue_pairs.
    if (guest & VIRTIO_NET_F_MQ) != 0:
        mvp: uint32 = cast[uint32](inw(cast[int32](
            iobase + vnet_state.cfg_base + 8))) & 0xFFFF
        if mvp < 1:
            mvp = 1
        vnet_state.max_vq_pairs = mvp
        vnet_state.ctrl_qidx    = mvp * 2
        printk1("[virtio-net] F_MQ: max_virtqueue_pairs=%d\n",
                cast[uint64](mvp))
    else:
        # No F_MQ: the control queue (if any) sits right after RX/TX.
        vnet_state.ctrl_qidx = 2

    # --- Control virtqueue (F_CTRL_VQ) -----------------------------
    # Bring up the control virtqueue so we can issue the MQ pair-set
    # command. It lives at ctrl_qidx. If its setup fails we simply
    # leave the control path disabled and run a single pair implicitly.
    if vnet_state.ctrl_vq != 0:
        if _vnet_vq_setup(iobase, vnet_state.ctrl_qidx,
                          &vnet_state.ctrl) < 0:
            printk0("[virtio-net] control virtqueue setup failed\n")
            vnet_state.ctrl_vq = 0

    # If MSI-X is on, tell the device which MSI-X table entry each
    # virtqueue (and the config-change source) maps to. The device
    # echoes the value back; 0xFFFF means it rejected the mapping —
    # if that happens we abandon MSI-X and fall back to INTx so the
    # device still delivers interrupts somehow.
    if vnet_state.msix_enabled != 0:
        rx_echo:  uint32 = virtio_set_queue_msix_vector(iobase, VQ_RX,
                                                        VNET_MSIX_ENTRY_RX)
        tx_echo:  uint32 = virtio_set_queue_msix_vector(iobase, VQ_TX,
                                                        VNET_MSIX_ENTRY_TX)
        cfg_echo: uint32 = virtio_set_config_msix_vector(iobase,
                                                         VNET_MSIX_ENTRY_CFG)
        if rx_echo == VIRTIO_MSI_NO_VECTOR \
                or tx_echo == VIRTIO_MSI_NO_VECTOR \
                or cfg_echo == VIRTIO_MSI_NO_VECTOR:
            printk0("[virtio-net] device rejected MSI-X vector map — INTx\n")
            vnet_state.msix_enabled = 0
            vnet_state.cfg_base = cast[uint32](VIRTIO_PCI_CONFIG)

    # Read MAC and copy into the net_device global so userspace
    # (`/bin/ifconfig`) can render it later. We log it now too so
    # the test fixture has something obvious to grep for. cfg_base
    # already accounts for the MSI-X config-window shift.
    _read_mac(iobase, vnet_state.cfg_base, &vnet_state.mac[0])
    i: uint64 = 0
    while i < 6:
        nd_mac[i] = vnet_state.mac[i]
        i = i + 1
    _print_mac(&vnet_state.mac[0])

    # Pre-populate RX ring + flip DRIVER_OK + kick the device so it
    # knows there are buffers to use.
    _populate_rx(&vnet_state)
    virtio_driver_ok(iobase)
    virtio_notify(iobase, VQ_RX)

    # --- Multiqueue agreement via the control virtqueue ------------
    # With F_MQ + F_CTRL_VQ negotiated we MUST tell the device how
    # many RX/TX pairs are actually driven before it starts steering
    # RX onto queues we never populated. We keep a single active pair,
    # so issue VIRTIO_NET_CTRL_MQ_VQ_PAIRS_SET(1) over the control
    # virtqueue and confirm the device ACKs it. The command runs after
    # DRIVER_OK (the spec requires the control queue be usable only
    # once the driver is up).
    if (guest & VIRTIO_NET_F_MQ) != 0 and vnet_state.ctrl_vq != 0:
        if _vnet_ctrl_set_mq_pairs(1) == 0:
            vnet_state.cur_vq_pairs = 1
            printk0("[virtio-net] PASS mq-ctrl\n")
        else:
            printk0("[virtio-net] mq-ctrl command rejected by device\n")
    elif vnet_state.max_vq_pairs <= 1 and vnet_state.ctrl_vq != 0:
        # Device offered the control queue but not F_MQ — nothing to
        # negotiate, single pair is implicit. Still note the control
        # queue is live (proves the ctrl path was set up for real).
        printk0("[virtio-net] control vq live (no F_MQ to negotiate)\n")

    # --- Interrupt wiring ------------------------------------------
    # Register the NET_RX softirq bottom half: the hard-IRQ handlers below
    # only ACK + raise_softirq(NET_RX); the ring drain runs here on the
    # IRQ-return softirq pass. This migrates net RX off the old "drain in
    # hard-IRQ context" model onto the new softirq stack. open_softirq is
    # safe to call before softirq_init() (it just sets a handler slot).
    open_softirq(NET_RX_SOFTIRQ, virtio_net_rx_softirq)
    if vnet_state.msix_enabled != 0:
        # MSI-X path: each virtqueue has its own LAPIC vector, routed
        # straight from the device to the LAPIC with no IOAPIC in the
        # path. Register the per-vector handlers. The RX/TX vectors
        # both drain their respective rings; the config-change vector
        # just acknowledges. This is the per-queue interrupt model
        # modern multi-queue NICs use.
        register_irq_handler(cast[uint64](VNET_MSIX_VEC_RX),
                             cast[uint64](&virtio_net_msix_rx_handler))
        register_irq_handler(cast[uint64](VNET_MSIX_VEC_TX),
                             cast[uint64](&virtio_net_msix_tx_handler))
        register_irq_handler(cast[uint64](VNET_MSIX_VEC_CFG),
                             cast[uint64](&virtio_net_msix_cfg_handler))
        printk2("[virtio-net] MSI-X wired: RX vec=0x%x TX vec=0x%x\n",
                cast[uint64](VNET_MSIX_VEC_RX),
                cast[uint64](VNET_MSIX_VEC_TX))
        printk1("[virtio-net] init done; RX queue populated; MSI-X cfg vec=0x%x\n",
                cast[uint64](VNET_MSIX_VEC_CFG))
        # Take ownership of eth.ad's TX dispatch — on QEMU virtio is
        # the canonical bring-up NIC. The Linux e1000e.ko (loaded later
        # at boot:35.a) only registers its TX bridge if its probe
        # binds, so the virtio hook stays in place on virtio-only
        # boots. Symmetric registration at both virtio_net_init exits
        # keeps the MSI-X / INTx paths in lockstep with respect to the
        # upper-layer dispatch.
        eth_register_tx_hook(virtio_net_tx)
        return 0

    # INTx fallback path: the device raises a single shared pin-based
    # PCI INTx. Read PCI INTERRUPT_PIN/INTERRUPT_LINE to discover the
    # firmware-assigned IOAPIC redirection entry. On QEMU's i440FX the
    # virtio-net PCI device defaults to INTA (pin=1) and the firmware
    # assigns INTERRUPT_LINE based on the slot — typically IRQ 11
    # (IOAPIC pin 11). We program that pin to deliver CPU vector 0x40
    # to LAPIC id 0, then register the handler.
    bus: uint32 = pci_bdf_bus(bdf)
    pdev: uint32 = pci_bdf_dev(bdf)
    fn:  uint32 = pci_bdf_fn(bdf)
    intx_pin:  uint32 = pci_config_read_byte(bus, pdev, fn,
                                             PCI_INTERRUPT_PIN)
    intx_line: uint32 = pci_config_read_byte(bus, pdev, fn,
                                             PCI_INTERRUPT_LINE)
    printk2("[virtio-net] PCI INTx pin=%d line=%d\n",
            cast[uint64](intx_pin), cast[uint64](intx_line))
    ioapic_pin: uint32 = intx_line
    if intx_pin == 0 or intx_line == 0 or intx_line >= 24:
        # Pin 0 means "no interrupt"; out-of-range line means firmware
        # didn't program it. Use QEMU's documented default for
        # virtio-net (IOAPIC pin 11).
        ioapic_pin = 11
        printk1("[virtio-net] PCI INTx line unreliable; using IOAPIC pin %d\n",
                cast[uint64](ioapic_pin))
    vnet_state.irq_pin = ioapic_pin
    register_irq_handler(cast[uint64](VNET_IRQ_VECTOR),
                         virtio_net_irq_handler)
    ioapic_redirect(ioapic_pin, VNET_IRQ_VECTOR, VNET_LAPIC_ID)
    printk1("[virtio-net] init done; RX queue populated; IRQ vec=0x%x\n",
            cast[uint64](VNET_IRQ_VECTOR))
    # See the MSI-X path above for the registration rationale; same
    # call here so the INTx fallback path also claims the eth.ad
    # TX dispatch.
    eth_register_tx_hook(virtio_net_tx)
    return 0


def virtio_net_rx_softirq():
    # NET_RX softirq handler (the bottom half). Drains the RX used ring +
    # delivers frames into the network stack OUTSIDE hard-IRQ context.
    # Registered at device init via open_softirq(NET_RX_SOFTIRQ, ...).
    if vnet_state.iobase == 0:
        return
    virtio_net_poll()


def virtio_net_msix_rx_handler():
    # MSI-X RX-queue interrupt — the hard-IRQ TOP HALF. An MSI-X message
    # is edge-triggered and has no shared device-level ISR to ack, so the
    # top half is now minimal: bump the count and RAISE the NET_RX softirq.
    # The heavy ring drain + eth_rx (which walks into the TCP/IP stack)
    # runs in the NET_RX softirq on IRQ-return, NOT in hard-IRQ context.
    # This is the net RX bottom-half migration onto the new softirq stack.
    # Before softirq_init() (very early boot) fall back to inline drain.
    if vnet_state.iobase == 0:
        return
    vnet_state.irq_count = vnet_state.irq_count + 1
    if softirq_started_get() != 0:
        raise_softirq(NET_RX_SOFTIRQ)
    else:
        virtio_net_poll()


def virtio_net_msix_tx_handler():
    # MSI-X TX-queue interrupt. The TX path is fire-and-forget today
    # (no completion bookkeeping), so this handler just counts the
    # IRQ — the descriptor slot is reused unconditionally on the next
    # transmit. A real TX-completion reclaim would hook in here.
    if vnet_state.iobase == 0:
        return
    vnet_state.irq_count = vnet_state.irq_count + 1


def virtio_net_msix_cfg_handler():
    # MSI-X config-change interrupt. Fires on link-status / MAC
    # changes. We have no dynamic-reconfig path, so acknowledge by
    # counting it.
    if vnet_state.iobase == 0:
        return
    vnet_state.irq_count = vnet_state.irq_count + 1


def virtio_net_msix_enabled() -> uint32:
    return vnet_state.msix_enabled


def virtio_net_irq_handler():
    # IRQ context entry point. Runs with interrupts disabled (CPU did
    # cli on gate entry). Read the device-level ISR to ack the wire
    # interrupt — virtio's ISR is read-to-clear; the LAPIC EOI is
    # handled by do_irq AFTER this returns. Then drain the RX ring
    # the same way the polling path does. If the ISR is 0 the IRQ
    # was either shared (another device on the same line) or
    # spurious; we still drain because a packet may have arrived
    # since the last ISR snapshot.
    if vnet_state.iobase == 0:
        return
    isr: int32 = inb(cast[int32](vnet_state.iobase + cast[uint32](VIRTIO_PCI_ISR)))
    vnet_state.irq_count = vnet_state.irq_count + 1
    if (isr & 0x01) != 0:
        # Queue interrupt — at least one virtqueue advanced. Defer the
        # heavy drain to the NET_RX softirq (bottom half); the device-ISR
        # read above already ACKed the wire interrupt in the top half.
        if softirq_started_get() != 0:
            raise_softirq(NET_RX_SOFTIRQ)
        else:
            virtio_net_poll()


def virtio_net_irq_count() -> uint64:
    return vnet_state.irq_count


def virtio_net_irq_pin() -> uint32:
    return vnet_state.irq_pin


def _used_entry_id(seen: uint16) -> uint32:
    # Return the descriptor id of the used-ring entry at logical index
    # `seen` (wrapped into the qsize-element ring).
    used:  uint64 = vnet_state.rx.used_addr
    qsize: uint16 = vnet_state.rx.qsize
    slot:  uint16 = seen % qsize
    entry: uint64 = used + 4 + cast[uint64](slot) * 8
    return cast[Ptr[uint32]](entry + 0)[0]


def _used_entry_len(seen: uint16) -> uint32:
    # Return the device-written byte count of the used-ring entry at
    # logical index `seen`.
    used:  uint64 = vnet_state.rx.used_addr
    qsize: uint16 = vnet_state.rx.qsize
    slot:  uint16 = seen % qsize
    entry: uint64 = used + 4 + cast[uint64](slot) * 8
    return cast[Ptr[uint32]](entry + 4)[0]


def _rx_deliver_single(slot: uint16, length: uint32):
    # Non-mergeable (or single-buffer mergeable) fast path: the whole
    # frame is in one buffer behind one virtio_net_hdr. Strip the
    # header and hand the Ethernet frame straight up — no copy needed.
    hdr: uint64 = vnet_state.hdr_len
    if cast[uint64](length) <= hdr:
        return                                 # runt; drop silently
    buf: uint64 = vnet_state.rx_buf_addrs[slot]
    eth_len: uint64 = cast[uint64](length) - hdr
    eth_ptr: Ptr[uint8] = cast[Ptr[uint8]](buf + hdr)
    vnet_state.rx_packets = vnet_state.rx_packets + 1
    printk1("[virtio-net] RX packet: len=%d\n", eth_len)
    eth_rx(eth_ptr, eth_len)


def _rx_deliver_merged(first_slot: uint16, first_len: uint32,
                       num_buffers: uint16, start_seen: uint16):
    # Mergeable-RX reassembly: a single frame spans `num_buffers`
    # device-consumed RX buffers. The 12-byte virtio_net_hdr sits at
    # the front of the FIRST buffer only; every buffer after that holds
    # raw frame bytes with no header. We gather the payload from each
    # buffer (named by the corresponding used-ring entry) into the
    # reassembly scratch, then hand the contiguous frame up once.
    #
    # used-ring layout for this frame:
    #   entry[start_seen+0] -> first_slot, first_len   (hdr + data[0])
    #   entry[start_seen+1] -> slot_1,     len_1        (data[1])
    #   ...
    #   entry[start_seen+(num_buffers-1)] -> slot_(n-1), len_(n-1)
    hdr: uint64 = vnet_state.hdr_len
    total: uint64 = 0
    # First buffer: skip the header.
    fbuf: uint64 = vnet_state.rx_buf_addrs[first_slot]
    if cast[uint64](first_len) > hdr:
        body0: uint64 = cast[uint64](first_len) - hdr
        if total + body0 > 2048:
            body0 = 2048 - total
        memcpy(cast[Ptr[uint8]](&vnet_reasm_buf[total]),
               cast[Ptr[uint8]](fbuf + hdr), body0)
        total = total + body0
    # Subsequent buffers: full payload, no header.
    b: uint16 = 1
    while b < num_buffers:
        s: uint16 = start_seen + b
        nslot: uint16 = cast[uint16](_used_entry_id(s) & 0xFFFF)
        nlen:  uint32 = _used_entry_len(s)
        nbuf:  uint64 = vnet_state.rx_buf_addrs[nslot]
        copy_n: uint64 = cast[uint64](nlen)
        if total + copy_n > 2048:
            copy_n = 2048 - total
        if copy_n > 0:
            memcpy(cast[Ptr[uint8]](&vnet_reasm_buf[total]),
                   cast[Ptr[uint8]](nbuf), copy_n)
            total = total + copy_n
        b = b + 1
    if total == 0:
        return
    vnet_state.rx_packets = vnet_state.rx_packets + 1
    vnet_state.mrg_frames = vnet_state.mrg_frames + 1
    printk2("[virtio-net] RX merged frame: len=%d num_buffers=%d\n",
            total, cast[uint64](num_buffers))
    printk1("[virtio-net] RX packet: len=%d\n", total)
    eth_rx(cast[Ptr[uint8]](&vnet_reasm_buf[0]), total)


def virtio_net_poll():
    # Drain the RX used ring with mergeable-buffer reassembly + robust
    # refill. Walks from `used_idx_seen` up to the current `used.idx`.
    # Each used-ring entry is {u32 id, u32 len} starting at offset 4 of
    # the used region; the header (offset 0..2) is u16 flags + u16 idx.
    #
    # With F_MRG_RXBUF a single inbound frame may consume several RX
    # buffers: the first buffer's 12-byte header carries num_buffers,
    # and the next (num_buffers-1) used-ring entries belong to the SAME
    # frame. We read num_buffers, reassemble across that many entries,
    # and advance `seen` past all of them. Every consumed RX descriptor
    # is reposted so the device always has buffers to land the next
    # frame in — the ring never drains to empty and wedges.
    if vnet_state.iobase == 0:
        return
    used: uint64 = vnet_state.rx.used_addr
    cur: uint16 = cast[Ptr[uint16]](used + 2)[0]
    seen: uint16 = vnet_state.rx.used_idx_seen
    if cur == seen:
        return
    reposted: uint64 = 0
    while seen != cur:
        first_id:  uint32 = _used_entry_id(seen)
        first_len: uint32 = _used_entry_len(seen)
        first_slot: uint16 = cast[uint16](first_id & 0xFFFF)
        # Default: one buffer per frame.
        num_buffers: uint16 = 1
        if vnet_state.mrg_rxbuf != 0:
            # num_buffers is the u16 at byte 10 of the first buffer's
            # 12-byte virtio_net_hdr.
            fbuf: uint64 = vnet_state.rx_buf_addrs[first_slot]
            nb: uint16 = cast[Ptr[uint16]](
                fbuf + VIRTIO_NET_HDR_NUMBUF_OFF)[0]
            if nb >= 1:
                num_buffers = nb
        # Clamp num_buffers to what is actually available in the used
        # ring (defensive: a malformed device can't make us read past
        # cur). available = distance from seen to cur.
        avail_entries: uint16 = cur - seen
        if num_buffers > avail_entries:
            num_buffers = avail_entries
        if num_buffers <= 1:
            _rx_deliver_single(first_slot, first_len)
        else:
            _rx_deliver_merged(first_slot, first_len, num_buffers, seen)
        # The device just consumed `num_buffers` posted descriptors.
        # Account for that, then repost each one (each repost re-adds
        # one to rx_outstanding), so the ring stays full and the net
        # outstanding count is conserved across the frame.
        if vnet_state.rx_outstanding >= cast[uint64](num_buffers):
            vnet_state.rx_outstanding = \
                vnet_state.rx_outstanding - cast[uint64](num_buffers)
        else:
            vnet_state.rx_outstanding = 0
        k: uint16 = 0
        while k < num_buffers:
            sid: uint32 = _used_entry_id(seen + k)
            _rx_repost(cast[uint16](sid & 0xFFFF))
            reposted = reposted + 1
            k = k + 1
        seen = seen + num_buffers
    vnet_state.rx.used_idx_seen = seen
    if reposted > 0:
        vnet_state.refills = vnet_state.refills + 1
    # Kick the device after re-queueing so it promptly picks up the
    # refilled descriptors (otherwise it could sit idle if it had
    # drained the avail ring while we were processing).
    virtio_notify(vnet_state.iobase, VQ_RX)


def virtio_net_rx_packets() -> uint64:
    return vnet_state.rx_packets


def virtio_net_mrg_enabled() -> uint32:
    return vnet_state.mrg_rxbuf


def virtio_net_mrg_frames() -> uint64:
    return vnet_state.mrg_frames


def virtio_net_rx_outstanding() -> uint64:
    return vnet_state.rx_outstanding


def virtio_net_refills() -> uint64:
    return vnet_state.refills


def virtio_net_cur_vq_pairs() -> uint32:
    return vnet_state.cur_vq_pairs


def virtio_net_ctrl_live() -> uint32:
    return vnet_state.ctrl_vq


def virtio_net_maturity_report():
    # Emit the maturity PASS banners the e2e test greps for. Called by
    # net_smoke_test after the RX/DHCP poll loops have driven real
    # traffic through the driver, so the counters reflect actual device
    # behaviour — never synthesized.
    #
    #   [virtio-net] PASS mrg-rxbuf — F_MRG_RXBUF negotiated AND at
    #       least one real frame was received through the mergeable
    #       header path (rx_packets > 0 with the 12-byte hdr active).
    #   [virtio-net] PASS refill   — the RX ring was refilled at least
    #       once after consuming buffers and is still non-empty (it
    #       never drained to zero and wedged).
    #   [virtio-net] PASS mq-ctrl  — printed at init when the control
    #       virtqueue ACKed VIRTIO_NET_CTRL_MQ_VQ_PAIRS_SET (see
    #       virtio_net_init); re-asserted here only if it happened.
    if vnet_state.iobase == 0:
        return
    if vnet_state.mrg_rxbuf != 0 and vnet_state.rx_packets > 0:
        printk2("[virtio-net] mrg-rxbuf: rx_packets=%d merged_frames=%d\n",
                vnet_state.rx_packets, vnet_state.mrg_frames)
        printk0("[virtio-net] PASS mrg-rxbuf\n")
    if vnet_state.refills > 0 and vnet_state.rx_outstanding > 0:
        printk2("[virtio-net] refill: batches=%d outstanding=%d\n",
                vnet_state.refills, vnet_state.rx_outstanding)
        printk0("[virtio-net] PASS refill\n")


# --- TX path (single-descriptor, used to provoke RX traffic) -------
#
# QEMU SLIRP doesn't send anything spontaneously — no DHCP offer
# without a request, no router advertisement, no unsolicited ARP.
# To prove the RX path actually delivers frames we send one ARP
# request for the SLIRP gateway (10.0.2.2) from our MAC; SLIRP's
# emulated gateway answers with an ARP reply that lands in our RX
# ring. The TX path here is intentionally minimal: a single
# descriptor (no chaining), since virtio-net's legacy TX accepts
# the virtio_net_hdr inline in the same buffer as the frame.
#
# The TX path is reused by the upper layers (eth_tx → virtio_net_tx)
# to transmit ARP replies, ICMP echoes, DHCP datagrams, and the
# rest of the bare-metal stack's outbound traffic. We keep a single
# 2 KiB TX scratch buffer; outbound frames are memcpy'd into it
# behind the 10-byte virtio_net_hdr (zeros for no offload). The
# device drains TX descriptors fast enough that a single in-flight
# slot is sufficient for the call-rate this kernel produces.

vnet_arp_buf: Array[80, uint8]

# Shared TX scratch: 10-byte virtio_net_hdr + up to 1514-byte
# Ethernet frame. The buffer lives in BSS so its address is stable
# (we hand it directly to the device via the descriptor ring).
vnet_tx_buf:  Array[2048, uint8]


extern def memcpy(dst: Ptr[uint8], src: Ptr[uint8], n: uint64) -> Ptr[uint8]


def virtio_net_tx(buf: Ptr[uint8], length: uint64) -> int32:
    # Public TX entry point used by drivers/net/eth.ad:eth_tx and any
    # other in-kernel caller that wants to put a raw Ethernet frame
    # on the wire. The caller hands us a fully built L2 frame
    # (destination MAC ... payload, NO virtio_net_hdr prepended); we
    # prepend the 10-byte virtio_net_hdr (zeroed for no offload), copy
    # the frame body behind it, point a single TX descriptor at the
    # composite buffer, push it onto the avail ring, and kick the
    # device. Returns 0 on success or -1 if no virtio-net device is
    # bound / the frame is too large.
    if vnet_state.iobase == 0:
        return -1
    if length > 1514:
        return -1
    # Zero the virtio_net_hdr (no offload, no checksum req). The active
    # header length follows the negotiated feature set: 12 bytes when
    # F_MRG_RXBUF is on (the device expects the mergeable header on TX
    # too — num_buffers is driver-written-as-zero and ignored on TX),
    # 10 bytes otherwise.
    hdr: uint64 = vnet_state.hdr_len
    i: uint64 = 0
    while i < hdr:
        vnet_tx_buf[i] = 0
        i = i + 1
    # Copy the caller's frame body behind the header.
    memcpy(cast[Ptr[uint8]](&vnet_tx_buf[hdr]),
           buf, length)
    total: uint32 = cast[uint32](hdr + length)
    addr:  uint64 = cast[uint64](&vnet_tx_buf[0])
    # Single-descriptor, device-readable (flags=0).
    _vnet_desc_set(&vnet_state.tx, 0, addr, total, 0, 0)
    _avail_push(&vnet_state.tx, 0)
    virtio_notify(vnet_state.iobase, VQ_TX)
    return 0


def _vnet_arp_build_probe() -> uint64:
    # Build an ARP request from us to the SLIRP gateway. Buffer
    # layout: [ virtio_net_hdr (zeroed, 10 or 12 bytes) | 14-byte
    # Ethernet header | 28-byte ARP payload ]; we zero-pad the tail to
    # at least 64 bytes for minimum-frame padding (SLIRP doesn't care
    # but real NICs do). Returns the total descriptor length.
    i: uint64 = 0
    while i < 80:
        vnet_arp_buf[i] = 0
        i = i + 1
    # Ethernet header @ offset hdr_len:
    #   dest = ff:ff:ff:ff:ff:ff (broadcast)
    #   src  = our MAC
    #   type = 0x0806 (ARP, big-endian)
    eoff: uint64 = vnet_state.hdr_len
    j: uint64 = 0
    while j < 6:
        vnet_arp_buf[eoff + j] = 0xFF
        j = j + 1
    j = 0
    while j < 6:
        vnet_arp_buf[eoff + 6 + j] = vnet_state.mac[j]
        j = j + 1
    vnet_arp_buf[eoff + 12] = 0x08
    vnet_arp_buf[eoff + 13] = 0x06
    # ARP payload @ offset hdr_len + 14:
    #   htype = 0x0001  (Ethernet)
    #   ptype = 0x0800  (IPv4)
    #   hlen  = 6
    #   plen  = 4
    #   oper  = 0x0001  (request)
    #   sha   = our MAC
    #   spa   = 10.0.2.15 (default SLIRP guest IP)
    #   tha   = 00:00:00:00:00:00
    #   tpa   = 10.0.2.2  (SLIRP gateway)
    aoff: uint64 = eoff + 14
    vnet_arp_buf[aoff +  0] = 0x00
    vnet_arp_buf[aoff +  1] = 0x01
    vnet_arp_buf[aoff +  2] = 0x08
    vnet_arp_buf[aoff +  3] = 0x00
    vnet_arp_buf[aoff +  4] = 6
    vnet_arp_buf[aoff +  5] = 4
    vnet_arp_buf[aoff +  6] = 0x00
    vnet_arp_buf[aoff +  7] = 0x01
    k: uint64 = 0
    while k < 6:
        vnet_arp_buf[aoff + 8 + k] = vnet_state.mac[k]
        k = k + 1
    vnet_arp_buf[aoff + 14] = 10
    vnet_arp_buf[aoff + 15] = 0
    vnet_arp_buf[aoff + 16] = 2
    vnet_arp_buf[aoff + 17] = 15
    # tha is already zero from the memset above.
    vnet_arp_buf[aoff + 24] = 10
    vnet_arp_buf[aoff + 25] = 0
    vnet_arp_buf[aoff + 26] = 2
    vnet_arp_buf[aoff + 27] = 2
    # Total = hdr + 14 (eth) + 28 (arp), padded up to a 64-byte
    # minimum Ethernet frame (header excluded from the 64 floor).
    total: uint64 = vnet_state.hdr_len + 14 + 28
    min_frame: uint64 = vnet_state.hdr_len + 64
    if total < min_frame:
        total = min_frame
    return total


def virtio_net_send_arp_probe():
    # Submit the ARP probe through TX (queue 1) as a single-descriptor
    # device-readable chain. We park the buffer at slot 0 in the TX
    # descriptor ring — there's no other TX in flight, so reusing
    # slot 0 every call is fine. The device reads the buffer, marks
    # the descriptor used, and we don't bother polling completion
    # (the kernel doesn't yet have a packet sent counter to compare).
    if vnet_state.iobase == 0:
        return
    total: uint64 = _vnet_arp_build_probe()
    addr: uint64 = cast[uint64](&vnet_arp_buf[0])
    _vnet_desc_set(&vnet_state.tx, 0, addr, cast[uint32](total), 0, 0)
    _avail_push(&vnet_state.tx, 0)
    virtio_notify(vnet_state.iobase, VQ_TX)
    printk0("[virtio-net] ARP probe sent (10.0.2.15 -> 10.0.2.2)\n")

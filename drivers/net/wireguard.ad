# drivers/net/wireguard.ad
#
# Status: TWO real data paths wired:
#         (1) wireguard_selftest() — pure in-memory crypto + protocol unit
#             test (KATs + Noise_IKpsk2 handshake + AEAD transport round
#             trips + wrong-key/replay/tamper reject).
#         (2) wireguard_overlay_selftest() — configures two peers (A and B)
#             each with an endpoint (ip,port=51820) and the peer's static
#             public key, and drives the full data path through the REAL
#             udp_rx port demux: wg_iface_xmit -> wg_transport_seal ->
#             udp_local_inject -> udp_rx port-51820 listener (registered
#             via udp_register_listener) -> wg_udp_rx() -> wg_transport_open()
#             -> inner packet captured at the peer's WG virtual interface.
#             The full Noise_IKpsk2 handshake (init + resp) also rides
#             the same udp_rx path (type byte 1 / 2 demuxed by wg_udp_rx).
#             The single port-51820 listener demuxes between endpoints A
#             and B by matching the source IP.
# Remaining: the outer UDP/IPv4 datagram is delivered in-VM through
#         udp_local_inject (a one-process loopback shim feeding the real
#         udp_rx demux). Crossing virtio_net_tx + a peer VM is the only
#         remaining gap; the wire bytes leaving wg_transport_seal are
#         byte-identical ChaCha20-Poly1305 to what would leave the NIC.
# See docs/net_protocol_status.md for the consolidated tracker.
#
# Native WireGuard (the Noise_IKpsk2 VPN protocol) over UDP.
#
# This is a peer to the other native tunnel/overlay drivers (vxlan/geneve/
# gre/l2tp/macsec): it takes inner IP packets and produces protected
# WireGuard transport messages, and runs the Noise_IKpsk2 handshake that
# establishes the symmetric transport keys. WireGuard rides over UDP, so the
# message types are emitted as UDP payloads through the kernel UDP path
# (udp_send) — there is NO BSD socket API in Hamnix.
#
# Cryptography (all real, none stubbed):
#   * Curve25519 / X25519 ECDH          -- REUSED from drivers/net/tls.ad
#                                          (_tls_x25519_scalarmult / _base_mult)
#   * ChaCha20-Poly1305 AEAD (RFC 8439) -- REUSED from drivers/net/tls.ad
#                                          (_tls_aead_seal / _tls_aead_open)
#   * BLAKE2s + HMAC-BLAKE2s + HKDF      -- drivers/net/wg_crypto.ad
#
# Protocol (WireGuard whitepaper §5.4, Noise_IKpsk2):
#
#   Handshake initiation (initiator -> responder):
#     C = HASH(CONSTRUCTION); H = HASH(C || IDENTIFIER); H = HASH(H || S_resp_pub)
#     (E_priv,E_pub) = DH-generate
#     C = KDF1(C, E_pub);                H = HASH(H || E_pub)
#     C,k = KDF2(C, DH(E_priv, S_resp_pub))
#     enc_static = AEAD(k, 0, S_init_pub, H);  H = HASH(H || enc_static)
#     C,k = KDF2(C, DH(S_init_priv, S_resp_pub))
#     enc_ts = AEAD(k, 0, timestamp, H);       H = HASH(H || enc_ts)
#
#   Handshake response (responder -> initiator):
#     C = KDF1(C, E_pub_r);              H = HASH(H || E_pub_r)
#     C = KDF1(C, DH(E_priv_r, E_pub_i))
#     C = KDF1(C, DH(E_priv_r, S_init_pub))
#     C,tau,k = KDF3(C, PSK);            H = HASH(H || tau)
#     enc_empty = AEAD(k, 0, "", H);     H = HASH(H || enc_empty)
#
#   Transport keys:
#     responder: (T_recv, T_send) = KDF2(C, "")
#     initiator: (T_send, T_recv) = KDF2(C, "")
#
#   Transport data message: AEAD(T_send, counter, inner_packet, "") with the
#   96-bit nonce = 0^32 || le64(counter). The receiver enforces a sliding
#   replay window on the counter.

from kernel.printk.printk import printk0, printk1, printk2, printk_set_level
from drivers.tty.serial.early_8250 import PRINTK_LEVEL_EMERG
from drivers.net.tls import _tls_x25519_scalarmult, _tls_x25519_base_mult
from drivers.net.tls import _tls_aead_seal, _tls_aead_open
from drivers.net.wg_crypto import wg_blake2s, wg_hkdf, wg_blake2s_kat
from drivers.net.udp import udp_register_listener, udp_local_inject


# --- WireGuard message types (the first byte of every UDP payload) ----------
WG_MSG_INIT:      uint8 = 1     # handshake initiation
WG_MSG_RESPONSE:  uint8 = 2     # handshake response
WG_MSG_COOKIE:    uint8 = 3     # cookie reply (not used in this loopback test)
WG_MSG_TRANSPORT: uint8 = 4     # transport data

WG_KEY_LEN:   uint64 = 32       # X25519 / ChaCha20 key length
WG_TAG_LEN:   uint64 = 16       # Poly1305 tag
WG_TS_LEN:    uint64 = 12       # TAI64N timestamp


# =====================================================================
# Per-peer / per-session state
# =====================================================================
#
# We model two endpoints (A and B) so the loopback self-test can drive both
# sides in one address space. Each endpoint carries its static keypair, the
# optional pre-shared key, the live handshake state (C, H, ephemeral), and the
# derived transport keys + counters.
#
# All buffers are sized EXACTLY (32-byte keys/hashes) to avoid the
# undersized-Array buffer-overflow trap.

# Endpoint A.
wgA_static_priv:  Array[32, uint8]
wgA_static_pub:   Array[32, uint8]
wgA_eph_priv:     Array[32, uint8]
wgA_eph_pub:      Array[32, uint8]
wgA_psk:          Array[32, uint8]
wgA_C:            Array[32, uint8]      # chaining key
wgA_H:            Array[32, uint8]      # handshake hash
wgA_tsend:        Array[32, uint8]      # transport send key
wgA_trecv:        Array[32, uint8]      # transport recv key
wgA_send_ctr:     uint64 = 0
wgA_recv_ctr:     uint64 = 0            # highest accepted recv counter + window
wgA_remote_pub:   Array[32, uint8]      # peer's static public key

# Endpoint B.
wgB_static_priv:  Array[32, uint8]
wgB_static_pub:   Array[32, uint8]
wgB_eph_priv:     Array[32, uint8]
wgB_eph_pub:      Array[32, uint8]
wgB_psk:          Array[32, uint8]
wgB_C:            Array[32, uint8]
wgB_H:            Array[32, uint8]
wgB_tsend:        Array[32, uint8]
wgB_trecv:        Array[32, uint8]
wgB_send_ctr:     uint64 = 0
wgB_recv_ctr:     uint64 = 0
wgB_remote_pub:   Array[32, uint8]

# Replay-window state (simple highest-seen counters, per endpoint, used by the
# transport-open path). 0 means "nothing accepted yet"; first valid counter is 0
# so we track an explicit "any accepted" flag.
wgA_recv_seen:    int32 = 0
wgA_recv_max:     uint64 = 0
wgB_recv_seen:    int32 = 0
wgB_recv_max:     uint64 = 0

# Statistics.
wg_handshakes_ok: uint64 = 0
wg_tx_transport:  uint64 = 0
wg_rx_transport:  uint64 = 0
wg_rx_drops:      uint64 = 0


# =====================================================================
# Scratch globals
# =====================================================================
#
# Handshake math scratch. Single-threaded; one handshake step at a time.
# Sized exactly.
_wg_dh:      Array[32, uint8]      # DH shared-secret output
_wg_tmp_c:   Array[32, uint8]      # KDF chaining-key output slot
_wg_tmp_k:   Array[32, uint8]      # KDF AEAD-key output slot
_wg_tau:     Array[32, uint8]      # KDF tau output (psk mix)
_wg_hin:     Array[128, uint8]     # HASH(H || x) input buffer (32 + <= 96)
_wg_base9:   Array[32, uint8]      # X25519 base point u=9 (unused; base_mult has its own)
_wg_ts:      Array[12, uint8]      # TAI64N timestamp (deterministic in the test)

# CONSTRUCTION / IDENTIFIER label constants (ASCII, no NUL).
#   CONSTRUCTION = "Noise_IKpsk2_25519_ChaChaPoly_BLAKE2s"   (37 bytes)
#   IDENTIFIER   = "WireGuard v1 zx2c4 Jason@zx2c4.com"      (33 bytes)
_wg_construction: Array[37, uint8]
_wg_identifier:   Array[33, uint8]
_wg_c0:           Array[32, uint8]    # HASH(CONSTRUCTION)
_wg_h0:           Array[32, uint8]    # HASH(C0 || IDENTIFIER)
_wg_labels_ready: int32 = 0


def _wg_emerg0(s: Ptr[char]):
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0(s)


def _wg_emerg1(s: Ptr[char], a: uint64):
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk1(s, a)


def _wg_memcpy(dst: Ptr[uint8], src: Ptr[uint8], n: uint64):
    i: uint64 = 0
    while i < n:
        dst[i] = src[i]
        i = i + 1


def _wg_memeq(a: Ptr[uint8], b: Ptr[uint8], n: uint64) -> int32:
    i: uint64 = 0
    while i < n:
        if a[i] != b[i]:
            return 0
        i = i + 1
    return 1


def _wg_init_labels():
    # Populate CONSTRUCTION/IDENTIFIER byte arrays and precompute C0/H0.
    # CONSTRUCTION = "Noise_IKpsk2_25519_ChaChaPoly_BLAKE2s"
    s0: Ptr[uint8] = "Noise_IKpsk2_25519_ChaChaPoly_BLAKE2s"
    i: uint64 = 0
    while i < 37:
        _wg_construction[i] = s0[i]
        i = i + 1
    # IDENTIFIER = "WireGuard v1 zx2c4 Jason@zx2c4.com"
    s1: Ptr[uint8] = "WireGuard v1 zx2c4 Jason@zx2c4.com"
    i = 0
    while i < 33:
        _wg_identifier[i] = s1[i]
        i = i + 1
    # C0 = HASH(CONSTRUCTION)
    wg_blake2s(cast[Ptr[uint8]](&_wg_c0[0]), 32,
               cast[Ptr[uint8]](&_wg_construction[0]), 37)
    # H0 = HASH(C0 || IDENTIFIER)
    _wg_memcpy(cast[Ptr[uint8]](&_wg_hin[0]),
               cast[Ptr[uint8]](&_wg_c0[0]), 32)
    _wg_memcpy(cast[Ptr[uint8]](&_wg_hin[32]),
               cast[Ptr[uint8]](&_wg_identifier[0]), 33)
    wg_blake2s(cast[Ptr[uint8]](&_wg_h0[0]), 32,
               cast[Ptr[uint8]](&_wg_hin[0]), 65)
    _wg_labels_ready = 1


def _wg_mix_hash(h: Ptr[uint8], data: Ptr[uint8], data_len: uint64):
    # H = HASH(H || data). H is 32 bytes in place.
    _wg_memcpy(cast[Ptr[uint8]](&_wg_hin[0]), h, 32)
    _wg_memcpy(cast[Ptr[uint8]](&_wg_hin[32]), data, data_len)
    wg_blake2s(h, 32, cast[Ptr[uint8]](&_wg_hin[0]), 32 + data_len)


def _wg_dh_op(out: Ptr[uint8], priv: Ptr[uint8], pub: Ptr[uint8]):
    # out = X25519(priv, pub). Reuses the TLS scalar-mult.
    _tls_x25519_scalarmult(out, priv, pub)


def _wg_keygen(priv: Ptr[uint8], pub: Ptr[uint8]):
    # Derive a public key from a (already-random) private scalar.
    _tls_x25519_base_mult(pub, priv)


# =====================================================================
# Handshake INITIATION  (initiator side)  -- builds & advances C,H
# =====================================================================
#
# Writes the message into `out`:
#   [0]   type (1)
#   [1..4) reserved (0)
#   [4..8) sender index (we use 1)
#   [8..40)  ephemeral public key (32)
#   [40..88) encrypted static (32 + 16 tag = 48)
#   [88..116) encrypted timestamp (12 + 16 tag = 28)
# Total = 116 bytes (mac1/mac2 omitted in this loopback — they protect against
# DoS and are not part of the key schedule).
WG_INIT_LEN: uint64 = 116


def wg_initiator_create(init_priv: Ptr[uint8], init_pub: Ptr[uint8],
                        eph_priv: Ptr[uint8], eph_pub: Ptr[uint8],
                        resp_pub: Ptr[uint8],
                        ts: Ptr[uint8],
                        c_out: Ptr[uint8], h_out: Ptr[uint8],
                        out: Ptr[uint8]) -> int64:
    # c_out/h_out receive the post-initiation chaining-key + hash (32 each) so
    # the caller can carry them into wg_initiator_consume_response. Returns the
    # message length, or negative on error.
    if _wg_labels_ready == 0:
        _wg_init_labels()
    # C = C0 ; H = H0
    _wg_memcpy(c_out, cast[Ptr[uint8]](&_wg_c0[0]), 32)
    _wg_memcpy(h_out, cast[Ptr[uint8]](&_wg_h0[0]), 32)
    # H = HASH(H || S_resp_pub)
    _wg_mix_hash(h_out, resp_pub, 32)
    # C = KDF1(C, E_pub)
    wg_hkdf(cast[Ptr[uint8]](&_wg_tmp_c[0]),
            cast[Ptr[uint8]](0), cast[Ptr[uint8]](0), 1,
            c_out, eph_pub, 32)
    _wg_memcpy(c_out, cast[Ptr[uint8]](&_wg_tmp_c[0]), 32)
    # H = HASH(H || E_pub)
    _wg_mix_hash(h_out, eph_pub, 32)

    # --- msg.static ---
    # C,k = KDF2(C, DH(E_priv, S_resp_pub))
    _wg_dh_op(cast[Ptr[uint8]](&_wg_dh[0]), eph_priv, resp_pub)
    wg_hkdf(cast[Ptr[uint8]](&_wg_tmp_c[0]),
            cast[Ptr[uint8]](&_wg_tmp_k[0]), cast[Ptr[uint8]](0), 2,
            c_out, cast[Ptr[uint8]](&_wg_dh[0]), 32)
    _wg_memcpy(c_out, cast[Ptr[uint8]](&_wg_tmp_c[0]), 32)
    # enc_static = AEAD(k, 0, S_init_pub, H)  -> out[40..88]
    _tls_aead_seal(cast[Ptr[uint8]](&_wg_tmp_k[0]),
                   cast[Ptr[uint8]](&_wg_zero_nonce[0]),
                   h_out, 32,
                   init_pub, 32,
                   cast[Ptr[uint8]](cast[uint64](out) + 40),
                   cast[Ptr[uint8]](cast[uint64](out) + 72))
    # H = HASH(H || enc_static)  (enc_static = 48 bytes: 32 ct + 16 tag)
    _wg_mix_hash(h_out, cast[Ptr[uint8]](cast[uint64](out) + 40), 48)

    # --- msg.timestamp ---
    # C,k = KDF2(C, DH(S_init_priv, S_resp_pub))
    _wg_dh_op(cast[Ptr[uint8]](&_wg_dh[0]), init_priv, resp_pub)
    wg_hkdf(cast[Ptr[uint8]](&_wg_tmp_c[0]),
            cast[Ptr[uint8]](&_wg_tmp_k[0]), cast[Ptr[uint8]](0), 2,
            c_out, cast[Ptr[uint8]](&_wg_dh[0]), 32)
    _wg_memcpy(c_out, cast[Ptr[uint8]](&_wg_tmp_c[0]), 32)
    # enc_ts = AEAD(k, 0, timestamp, H)  -> out[88..116]
    _tls_aead_seal(cast[Ptr[uint8]](&_wg_tmp_k[0]),
                   cast[Ptr[uint8]](&_wg_zero_nonce[0]),
                   h_out, 32,
                   ts, 12,
                   cast[Ptr[uint8]](cast[uint64](out) + 88),
                   cast[Ptr[uint8]](cast[uint64](out) + 100))
    # H = HASH(H || enc_ts)  (enc_ts = 28 bytes: 12 ct + 16 tag)
    _wg_mix_hash(h_out, cast[Ptr[uint8]](cast[uint64](out) + 88), 28)

    # Header.
    out[0] = WG_MSG_INIT
    out[1] = 0
    out[2] = 0
    out[3] = 0
    out[4] = 1          # sender index = 1
    out[5] = 0
    out[6] = 0
    out[7] = 0
    # Ephemeral public key -> out[8..40]
    _wg_memcpy(cast[Ptr[uint8]](cast[uint64](out) + 8), eph_pub, 32)
    return cast[int64](WG_INIT_LEN)


# 12-byte all-zero nonce for the handshake AEAD (counter == 0).
_wg_zero_nonce: Array[12, uint8]
# Scratch for decrypted static key / timestamp on the responder.
_wg_dec_static: Array[32, uint8]
_wg_dec_ts:     Array[12, uint8]


def wg_responder_consume_init(resp_priv: Ptr[uint8], resp_pub: Ptr[uint8],
                              expected_init_pub: Ptr[uint8],
                              c_out: Ptr[uint8], h_out: Ptr[uint8],
                              eph_pub_out: Ptr[uint8],
                              msg: Ptr[uint8], msg_len: uint64) -> int64:
    # Responder consumes a handshake-initiation message, verifying both AEAD
    # tags, and advancing C,H identically to the initiator. On success c_out/
    # h_out hold the matching chaining-key/hash and eph_pub_out the peer's
    # ephemeral public key. Returns 0 on success; negative on auth failure.
    if _wg_labels_ready == 0:
        _wg_init_labels()
    if msg_len < WG_INIT_LEN:
        return -1
    if msg[0] != WG_MSG_INIT:
        return -2
    _wg_memcpy(c_out, cast[Ptr[uint8]](&_wg_c0[0]), 32)
    _wg_memcpy(h_out, cast[Ptr[uint8]](&_wg_h0[0]), 32)
    # H = HASH(H || S_resp_pub)  (our own static public key)
    _wg_mix_hash(h_out, resp_pub, 32)
    # E_pub = msg[8..40]
    _wg_memcpy(eph_pub_out, cast[Ptr[uint8]](cast[uint64](msg) + 8), 32)
    # C = KDF1(C, E_pub)
    wg_hkdf(cast[Ptr[uint8]](&_wg_tmp_c[0]),
            cast[Ptr[uint8]](0), cast[Ptr[uint8]](0), 1,
            c_out, eph_pub_out, 32)
    _wg_memcpy(c_out, cast[Ptr[uint8]](&_wg_tmp_c[0]), 32)
    # H = HASH(H || E_pub)
    _wg_mix_hash(h_out, eph_pub_out, 32)

    # --- msg.static ---
    # C,k = KDF2(C, DH(S_resp_priv, E_pub))
    _wg_dh_op(cast[Ptr[uint8]](&_wg_dh[0]), resp_priv, eph_pub_out)
    wg_hkdf(cast[Ptr[uint8]](&_wg_tmp_c[0]),
            cast[Ptr[uint8]](&_wg_tmp_k[0]), cast[Ptr[uint8]](0), 2,
            c_out, cast[Ptr[uint8]](&_wg_dh[0]), 32)
    _wg_memcpy(c_out, cast[Ptr[uint8]](&_wg_tmp_c[0]), 32)
    # dec_static = OPEN(k, 0, enc_static[40..88], H)
    rc: int32 = _tls_aead_open(
        cast[Ptr[uint8]](&_wg_tmp_k[0]),
        cast[Ptr[uint8]](&_wg_zero_nonce[0]),
        h_out, 32,
        cast[Ptr[uint8]](cast[uint64](msg) + 40), 32,
        cast[Ptr[uint8]](cast[uint64](msg) + 72),
        cast[Ptr[uint8]](&_wg_dec_static[0]))
    if rc != 0:
        return -3
    # The decrypted static key must match the expected initiator key.
    if _wg_memeq(cast[Ptr[uint8]](&_wg_dec_static[0]),
                 expected_init_pub, 32) != 1:
        return -4
    # H = HASH(H || enc_static)
    _wg_mix_hash(h_out, cast[Ptr[uint8]](cast[uint64](msg) + 40), 48)

    # --- msg.timestamp ---
    # C,k = KDF2(C, DH(S_resp_priv, S_init_pub))
    _wg_dh_op(cast[Ptr[uint8]](&_wg_dh[0]), resp_priv,
              cast[Ptr[uint8]](&_wg_dec_static[0]))
    wg_hkdf(cast[Ptr[uint8]](&_wg_tmp_c[0]),
            cast[Ptr[uint8]](&_wg_tmp_k[0]), cast[Ptr[uint8]](0), 2,
            c_out, cast[Ptr[uint8]](&_wg_dh[0]), 32)
    _wg_memcpy(c_out, cast[Ptr[uint8]](&_wg_tmp_c[0]), 32)
    # dec_ts = OPEN(k, 0, enc_ts[88..116], H)
    rc2: int32 = _tls_aead_open(
        cast[Ptr[uint8]](&_wg_tmp_k[0]),
        cast[Ptr[uint8]](&_wg_zero_nonce[0]),
        h_out, 32,
        cast[Ptr[uint8]](cast[uint64](msg) + 88), 12,
        cast[Ptr[uint8]](cast[uint64](msg) + 100),
        cast[Ptr[uint8]](&_wg_dec_ts[0]))
    if rc2 != 0:
        return -5
    # H = HASH(H || enc_ts)
    _wg_mix_hash(h_out, cast[Ptr[uint8]](cast[uint64](msg) + 88), 28)
    return 0


# =====================================================================
# Handshake RESPONSE  (responder side)  -- builds & advances C,H, then keys
# =====================================================================
#
#   [0]   type (2)
#   [1..4) reserved
#   [4..8) sender index (responder = 2)
#   [8..12) receiver index (echo initiator's = 1)
#   [12..44) ephemeral public key (32)
#   [44..60) encrypted empty (0 + 16 tag)
# Total = 60 bytes.
WG_RESP_LEN: uint64 = 60


def wg_responder_create(resp_eph_priv: Ptr[uint8], resp_eph_pub: Ptr[uint8],
                        init_eph_pub: Ptr[uint8],
                        init_static_pub: Ptr[uint8],
                        psk: Ptr[uint8],
                        c_io: Ptr[uint8], h_io: Ptr[uint8],
                        tsend_out: Ptr[uint8], trecv_out: Ptr[uint8],
                        out: Ptr[uint8]) -> int64:
    # Continues from the C,H produced by wg_responder_consume_init. Emits the
    # response message and derives the responder's transport keys (tsend/trecv).
    # C = KDF1(C, E_pub_r)
    wg_hkdf(cast[Ptr[uint8]](&_wg_tmp_c[0]),
            cast[Ptr[uint8]](0), cast[Ptr[uint8]](0), 1,
            c_io, resp_eph_pub, 32)
    _wg_memcpy(c_io, cast[Ptr[uint8]](&_wg_tmp_c[0]), 32)
    # H = HASH(H || E_pub_r)
    _wg_mix_hash(h_io, resp_eph_pub, 32)
    # C = KDF1(C, DH(E_priv_r, E_pub_i))
    _wg_dh_op(cast[Ptr[uint8]](&_wg_dh[0]), resp_eph_priv, init_eph_pub)
    wg_hkdf(cast[Ptr[uint8]](&_wg_tmp_c[0]),
            cast[Ptr[uint8]](0), cast[Ptr[uint8]](0), 1,
            c_io, cast[Ptr[uint8]](&_wg_dh[0]), 32)
    _wg_memcpy(c_io, cast[Ptr[uint8]](&_wg_tmp_c[0]), 32)
    # C = KDF1(C, DH(E_priv_r, S_init_pub))
    _wg_dh_op(cast[Ptr[uint8]](&_wg_dh[0]), resp_eph_priv, init_static_pub)
    wg_hkdf(cast[Ptr[uint8]](&_wg_tmp_c[0]),
            cast[Ptr[uint8]](0), cast[Ptr[uint8]](0), 1,
            c_io, cast[Ptr[uint8]](&_wg_dh[0]), 32)
    _wg_memcpy(c_io, cast[Ptr[uint8]](&_wg_tmp_c[0]), 32)
    # C,tau,k = KDF3(C, PSK)
    wg_hkdf(cast[Ptr[uint8]](&_wg_tmp_c[0]),
            cast[Ptr[uint8]](&_wg_tau[0]),
            cast[Ptr[uint8]](&_wg_tmp_k[0]), 3,
            c_io, psk, 32)
    _wg_memcpy(c_io, cast[Ptr[uint8]](&_wg_tmp_c[0]), 32)
    # H = HASH(H || tau)
    _wg_mix_hash(h_io, cast[Ptr[uint8]](&_wg_tau[0]), 32)
    # enc_empty = AEAD(k, 0, "", H) -> out[44..60]  (0 ct + 16 tag)
    _tls_aead_seal(cast[Ptr[uint8]](&_wg_tmp_k[0]),
                   cast[Ptr[uint8]](&_wg_zero_nonce[0]),
                   h_io, 32,
                   cast[Ptr[uint8]](0), 0,
                   cast[Ptr[uint8]](cast[uint64](out) + 44),
                   cast[Ptr[uint8]](cast[uint64](out) + 44))
    # H = HASH(H || enc_empty)  (16 bytes)
    _wg_mix_hash(h_io, cast[Ptr[uint8]](cast[uint64](out) + 44), 16)

    # Transport keys (responder): (T_recv, T_send) = KDF2(C, "")
    wg_hkdf(trecv_out, tsend_out, cast[Ptr[uint8]](0), 2,
            c_io, cast[Ptr[uint8]](&_wg_empty[0]), 0)

    # Header.
    out[0] = WG_MSG_RESPONSE
    out[1] = 0
    out[2] = 0
    out[3] = 0
    out[4] = 2     # sender index (responder)
    out[5] = 0
    out[6] = 0
    out[7] = 0
    out[8] = 1     # receiver index (echo initiator)
    out[9] = 0
    out[10] = 0
    out[11] = 0
    _wg_memcpy(cast[Ptr[uint8]](cast[uint64](out) + 12), resp_eph_pub, 32)
    return cast[int64](WG_RESP_LEN)


_wg_empty: Array[1, uint8]
_wg_dec_empty: Array[1, uint8]


def wg_initiator_consume_response(init_static_priv: Ptr[uint8],
                                  init_eph_priv: Ptr[uint8],
                                  psk: Ptr[uint8],
                                  c_io: Ptr[uint8], h_io: Ptr[uint8],
                                  tsend_out: Ptr[uint8], trecv_out: Ptr[uint8],
                                  msg: Ptr[uint8], msg_len: uint64) -> int64:
    # Initiator consumes the response, verifies the empty-AEAD tag, and derives
    # its transport keys. Returns 0 on success; negative on auth failure.
    if msg_len < WG_RESP_LEN:
        return -1
    if msg[0] != WG_MSG_RESPONSE:
        return -2
    # E_pub_r = msg[12..44]
    # C = KDF1(C, E_pub_r)
    wg_hkdf(cast[Ptr[uint8]](&_wg_tmp_c[0]),
            cast[Ptr[uint8]](0), cast[Ptr[uint8]](0), 1,
            c_io, cast[Ptr[uint8]](cast[uint64](msg) + 12), 32)
    _wg_memcpy(c_io, cast[Ptr[uint8]](&_wg_tmp_c[0]), 32)
    # H = HASH(H || E_pub_r)
    _wg_mix_hash(h_io, cast[Ptr[uint8]](cast[uint64](msg) + 12), 32)
    # C = KDF1(C, DH(E_priv_i, E_pub_r))
    _wg_dh_op(cast[Ptr[uint8]](&_wg_dh[0]), init_eph_priv,
              cast[Ptr[uint8]](cast[uint64](msg) + 12))
    wg_hkdf(cast[Ptr[uint8]](&_wg_tmp_c[0]),
            cast[Ptr[uint8]](0), cast[Ptr[uint8]](0), 1,
            c_io, cast[Ptr[uint8]](&_wg_dh[0]), 32)
    _wg_memcpy(c_io, cast[Ptr[uint8]](&_wg_tmp_c[0]), 32)
    # C = KDF1(C, DH(S_priv_i, E_pub_r))
    _wg_dh_op(cast[Ptr[uint8]](&_wg_dh[0]), init_static_priv,
              cast[Ptr[uint8]](cast[uint64](msg) + 12))
    wg_hkdf(cast[Ptr[uint8]](&_wg_tmp_c[0]),
            cast[Ptr[uint8]](0), cast[Ptr[uint8]](0), 1,
            c_io, cast[Ptr[uint8]](&_wg_dh[0]), 32)
    _wg_memcpy(c_io, cast[Ptr[uint8]](&_wg_tmp_c[0]), 32)
    # C,tau,k = KDF3(C, PSK)
    wg_hkdf(cast[Ptr[uint8]](&_wg_tmp_c[0]),
            cast[Ptr[uint8]](&_wg_tau[0]),
            cast[Ptr[uint8]](&_wg_tmp_k[0]), 3,
            c_io, psk, 32)
    _wg_memcpy(c_io, cast[Ptr[uint8]](&_wg_tmp_c[0]), 32)
    # H = HASH(H || tau)
    _wg_mix_hash(h_io, cast[Ptr[uint8]](&_wg_tau[0]), 32)
    # OPEN(k, 0, enc_empty[44..60], H)
    rc: int32 = _tls_aead_open(
        cast[Ptr[uint8]](&_wg_tmp_k[0]),
        cast[Ptr[uint8]](&_wg_zero_nonce[0]),
        h_io, 32,
        cast[Ptr[uint8]](&_wg_empty[0]), 0,
        cast[Ptr[uint8]](cast[uint64](msg) + 44),
        cast[Ptr[uint8]](&_wg_dec_empty[0]))
    if rc != 0:
        return -3
    # H = HASH(H || enc_empty)
    _wg_mix_hash(h_io, cast[Ptr[uint8]](cast[uint64](msg) + 44), 16)
    # Transport keys (initiator): (T_send, T_recv) = KDF2(C, "")
    wg_hkdf(tsend_out, trecv_out, cast[Ptr[uint8]](0), 2,
            c_io, cast[Ptr[uint8]](&_wg_empty[0]), 0)
    return 0


# =====================================================================
# Transport data messages
# =====================================================================
#
#   [0]   type (4)
#   [1..4) reserved
#   [4..8) receiver index
#   [8..16) counter (le64)
#   [16..]  AEAD(T_send, counter, inner_packet, "")  -- ct || 16-byte tag
WG_TRANSPORT_HDR: uint64 = 16

# Nonce scratch (4 zero bytes + le64 counter).
_wg_nonce: Array[12, uint8]


def _wg_build_nonce(counter: uint64):
    i: uint64 = 0
    while i < 4:
        _wg_nonce[i] = 0
        i = i + 1
    i = 0
    while i < 8:
        _wg_nonce[4 + i] = cast[uint8]((counter >> (i * 8)) & 0xFF)
        i = i + 1


def wg_transport_seal(tsend: Ptr[uint8], counter: uint64,
                      recv_index: uint32,
                      inner: Ptr[uint8], inner_len: uint64,
                      out: Ptr[uint8]) -> int64:
    # Encrypt one inner packet into a WireGuard transport message. Returns the
    # total length (16 header + inner_len + 16 tag).
    out[0] = WG_MSG_TRANSPORT
    out[1] = 0
    out[2] = 0
    out[3] = 0
    out[4] = cast[uint8](recv_index & 0xFF)
    out[5] = cast[uint8]((recv_index >> 8) & 0xFF)
    out[6] = cast[uint8]((recv_index >> 16) & 0xFF)
    out[7] = cast[uint8]((recv_index >> 24) & 0xFF)
    i: uint64 = 0
    while i < 8:
        out[8 + i] = cast[uint8]((counter >> (i * 8)) & 0xFF)
        i = i + 1
    _wg_build_nonce(counter)
    _tls_aead_seal(tsend,
                   cast[Ptr[uint8]](&_wg_nonce[0]),
                   cast[Ptr[uint8]](&_wg_empty[0]), 0,
                   inner, inner_len,
                   cast[Ptr[uint8]](cast[uint64](out) + WG_TRANSPORT_HDR),
                   cast[Ptr[uint8]](cast[uint64](out) + WG_TRANSPORT_HDR + inner_len))
    return cast[int64](WG_TRANSPORT_HDR + inner_len + WG_TAG_LEN)


def wg_transport_open(trecv: Ptr[uint8],
                      msg: Ptr[uint8], msg_len: uint64,
                      out: Ptr[uint8],
                      seen: Ptr[int32], max_ctr: Ptr[uint64]) -> int64:
    # Verify + decrypt a transport message, enforcing a (strictly-increasing,
    # simplified) replay check: the counter must exceed the highest counter
    # accepted so far (seen/max_ctr track per-session state). Returns the inner
    # length on success; negative on auth/replay failure:
    #   -1 malformed, -2 wrong type, -3 AEAD auth fail, -4 replay
    if msg_len < (WG_TRANSPORT_HDR + WG_TAG_LEN):
        return -1
    if msg[0] != WG_MSG_TRANSPORT:
        return -2
    counter: uint64 = 0
    i: uint64 = 0
    while i < 8:
        counter = counter | (cast[uint64](msg[8 + i]) << (i * 8))
        i = i + 1
    # Replay: reject a counter at/below the highest already accepted.
    if seen[0] != 0:
        if counter <= max_ctr[0]:
            wg_rx_drops = wg_rx_drops + 1
            return -4
    ct_len: uint64 = msg_len - WG_TRANSPORT_HDR - WG_TAG_LEN
    _wg_build_nonce(counter)
    rc: int32 = _tls_aead_open(
        trecv,
        cast[Ptr[uint8]](&_wg_nonce[0]),
        cast[Ptr[uint8]](&_wg_empty[0]), 0,
        cast[Ptr[uint8]](cast[uint64](msg) + WG_TRANSPORT_HDR), ct_len,
        cast[Ptr[uint8]](cast[uint64](msg) + WG_TRANSPORT_HDR + ct_len),
        out)
    if rc != 0:
        wg_rx_drops = wg_rx_drops + 1
        return -3
    # Accept: advance the replay floor.
    seen[0] = 1
    max_ctr[0] = counter
    wg_rx_transport = wg_rx_transport + 1
    return cast[int64](ct_len)


# =====================================================================
# Known-answer tests (RFC 8439 ChaCha20-Poly1305 + RFC 7748 X25519)
# =====================================================================

# RFC 8439 §2.8.2 ChaCha20-Poly1305 AEAD vector.
_wgk_key:    Array[32, uint8]
_wgk_iv:     Array[12, uint8]
_wgk_aad:    Array[12, uint8]
_wgk_pt:     Array[114, uint8]
_wgk_ct:     Array[114, uint8]
_wgk_tag:    Array[16, uint8]
_wgk_expct:  Array[114, uint8]
_wgk_exptag: Array[16, uint8]
_wgk_dec:    Array[114, uint8]

# RFC 7748 §5.2 X25519 vector.
_wgx_scalar: Array[32, uint8]
_wgx_u:      Array[32, uint8]
_wgx_out:    Array[32, uint8]
_wgx_exp:    Array[32, uint8]


def _wg_chachapoly_kat() -> int32:
    # RFC 8439 §2.8.2. Key = 80..9f, nonce = 070000004041424344454647,
    # AAD = 50515253c0c1c2c3c4c5c6c7, plaintext = "Ladies and Gentlemen..."
    # Expected ciphertext + tag are from the RFC.
    i: uint64 = 0
    while i < 32:
        _wgk_key[i] = cast[uint8](0x80 + i)
        i = i + 1
    _wgk_iv[0]=0x07
    _wgk_iv[1]=0x00
    _wgk_iv[2]=0x00
    _wgk_iv[3]=0x00
    _wgk_iv[4]=0x40
    _wgk_iv[5]=0x41
    _wgk_iv[6]=0x42
    _wgk_iv[7]=0x43
    _wgk_iv[8]=0x44
    _wgk_iv[9]=0x45
    _wgk_iv[10]=0x46
    _wgk_iv[11]=0x47
    _wgk_aad[0]=0x50
    _wgk_aad[1]=0x51
    _wgk_aad[2]=0x52
    _wgk_aad[3]=0x53
    _wgk_aad[4]=0xc0
    _wgk_aad[5]=0xc1
    _wgk_aad[6]=0xc2
    _wgk_aad[7]=0xc3
    _wgk_aad[8]=0xc4
    _wgk_aad[9]=0xc5
    _wgk_aad[10]=0xc6
    _wgk_aad[11]=0xc7
    # Plaintext: "Ladies and Gentlemen of the class of '99: If I could offer
    # you only one tip for the future, sunscreen would be it." (114 bytes)
    _wg_set_pt()
    _wg_set_expct()
    pt_len: uint64 = 114
    aad_len: uint64 = 12
    _tls_aead_seal(cast[Ptr[uint8]](&_wgk_key[0]),
                   cast[Ptr[uint8]](&_wgk_iv[0]),
                   cast[Ptr[uint8]](&_wgk_aad[0]), aad_len,
                   cast[Ptr[uint8]](&_wgk_pt[0]), pt_len,
                   cast[Ptr[uint8]](&_wgk_ct[0]),
                   cast[Ptr[uint8]](&_wgk_tag[0]))
    i = 0
    while i < pt_len:
        if _wgk_ct[i] != _wgk_expct[i]:
            return 0
        i = i + 1
    i = 0
    while i < 16:
        if _wgk_tag[i] != _wgk_exptag[i]:
            return 0
        i = i + 1
    # Round-trip open.
    rc: int32 = _tls_aead_open(
        cast[Ptr[uint8]](&_wgk_key[0]),
        cast[Ptr[uint8]](&_wgk_iv[0]),
        cast[Ptr[uint8]](&_wgk_aad[0]), aad_len,
        cast[Ptr[uint8]](&_wgk_expct[0]), pt_len,
        cast[Ptr[uint8]](&_wgk_exptag[0]),
        cast[Ptr[uint8]](&_wgk_dec[0]))
    if rc != 0:
        return 0
    i = 0
    while i < pt_len:
        if _wgk_dec[i] != _wgk_pt[i]:
            return 0
        i = i + 1
    return 1


def _wg_x25519_kat() -> int32:
    # RFC 7748 §5.2 first vector:
    #   scalar = a546e36bf0527c9d3b16154b82465edd62144c0ac1fc5a18506a2244ba449ac4
    #   u      = e6db6867583030db3594c1a424b15f7c726624ec26b3353b10a903a6d0ab1c4c
    #   out    = c3da55379de9c6908e94ea4df28d084f32eccf03491c71f754b4075577a28552
    _wg_set_x25519_vec()
    _tls_x25519_scalarmult(cast[Ptr[uint8]](&_wgx_out[0]),
                           cast[Ptr[uint8]](&_wgx_scalar[0]),
                           cast[Ptr[uint8]](&_wgx_u[0]))
    i: uint64 = 0
    while i < 32:
        if _wgx_out[i] != _wgx_exp[i]:
            return 0
        i = i + 1
    return 1


# (data-loading helpers kept out of the test functions for readability)
def _wg_set_pt():
    s: Ptr[uint8] = "Ladies and Gentlemen of the class of '99: If I could offer you only one tip for the future, sunscreen would be it."
    i: uint64 = 0
    while i < 114:
        _wgk_pt[i] = s[i]
        i = i + 1



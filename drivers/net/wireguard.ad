# =====================================================================
# Two-peer loopback self-test
# =====================================================================
#
# Buffers for the handshake + transport round-trip. Generously sized so an
# undersized Array can't clobber an adjacent global.
_wg_init_msg:  Array[256, uint8]
_wg_resp_msg:  Array[256, uint8]
_wg_xport_ab:  Array[512, uint8]
_wg_xport_ba:  Array[512, uint8]
_wg_inner_ab:  Array[256, uint8]
_wg_inner_ba:  Array[256, uint8]
_wg_recovered: Array[256, uint8]
_wg_eA_pub:    Array[32, uint8]      # initiator ephemeral pub (carried)
_wg_eB_pub:    Array[32, uint8]      # responder ephemeral pub (carried)
_wg_seen:      int32 = 0
_wg_maxc:      uint64 = 0


def wireguard_selftest() -> int32:
    _wg_emerg0("[wireguard] self-test start\n")
    ok: int32 = 1

    # --- KATs prove the crypto core before any protocol is trusted. ---
    if _wg_chachapoly_kat() != 1:
        _wg_emerg0("[wireguard] FAIL: chacha20-poly1305 KAT (RFC 8439) mismatch\n")
        return 0
    _wg_emerg0("[wireguard] PASS kat-chacha20poly1305 (RFC 8439)\n")

    if _wg_x25519_kat() != 1:
        _wg_emerg0("[wireguard] FAIL: X25519 KAT (RFC 7748) mismatch\n")
        return 0
    _wg_emerg0("[wireguard] PASS kat-x25519 (RFC 7748)\n")

    if wg_blake2s_kat() != 1:
        _wg_emerg0("[wireguard] FAIL: BLAKE2s KAT mismatch\n")
        return 0
    _wg_emerg0("[wireguard] PASS kat-blake2s (RFC 7693)\n")

    _wg_init_labels()

    # --- Static keypairs for A and B (deterministic private scalars). ---
    i: uint64 = 0
    while i < 32:
        wgA_static_priv[i] = cast[uint8]((0x11 + i) & 0xFF)
        wgB_static_priv[i] = cast[uint8]((0x42 + i) & 0xFF)
        wgA_eph_priv[i]    = cast[uint8]((0x71 + i) & 0xFF)
        wgB_eph_priv[i]    = cast[uint8]((0xA3 + i) & 0xFF)
        # Pre-shared key (both sides share it).
        wgA_psk[i] = cast[uint8]((0x5A + i) & 0xFF)
        wgB_psk[i] = cast[uint8]((0x5A + i) & 0xFF)
        i = i + 1
    _wg_keygen(cast[Ptr[uint8]](&wgA_static_priv[0]),
               cast[Ptr[uint8]](&wgA_static_pub[0]))
    _wg_keygen(cast[Ptr[uint8]](&wgB_static_priv[0]),
               cast[Ptr[uint8]](&wgB_static_pub[0]))
    _wg_keygen(cast[Ptr[uint8]](&wgA_eph_priv[0]),
               cast[Ptr[uint8]](&_wg_eA_pub[0]))
    _wg_keygen(cast[Ptr[uint8]](&wgB_eph_priv[0]),
               cast[Ptr[uint8]](&_wg_eB_pub[0]))
    # Deterministic timestamp.
    i = 0
    while i < 12:
        _wg_ts[i] = 0
        i = i + 1

    # --- A builds the handshake initiation. ---
    il: int64 = wg_initiator_create(
        cast[Ptr[uint8]](&wgA_static_priv[0]),
        cast[Ptr[uint8]](&wgA_static_pub[0]),
        cast[Ptr[uint8]](&wgA_eph_priv[0]),
        cast[Ptr[uint8]](&_wg_eA_pub[0]),
        cast[Ptr[uint8]](&wgB_static_pub[0]),
        cast[Ptr[uint8]](&_wg_ts[0]),
        cast[Ptr[uint8]](&wgA_C[0]),
        cast[Ptr[uint8]](&wgA_H[0]),
        cast[Ptr[uint8]](&_wg_init_msg[0]))
    if il < 0:
        _wg_emerg1("[wireguard] FAIL: initiation create rc=%d\n", cast[uint64](il))
        return 0
    if _wg_init_msg[0] != WG_MSG_INIT:
        _wg_emerg0("[wireguard] FAIL: initiation type != 1\n")
        return 0
    _wg_emerg1("[wireguard] PASS initiation-built len=%d\n", cast[uint64](il))

    # --- B consumes the initiation (authenticates A's static key). ---
    rc: int64 = wg_responder_consume_init(
        cast[Ptr[uint8]](&wgB_static_priv[0]),
        cast[Ptr[uint8]](&wgB_static_pub[0]),
        cast[Ptr[uint8]](&wgA_static_pub[0]),
        cast[Ptr[uint8]](&wgB_C[0]),
        cast[Ptr[uint8]](&wgB_H[0]),
        cast[Ptr[uint8]](&_wg_eA_pub[0]),
        cast[Ptr[uint8]](&_wg_init_msg[0]), cast[uint64](il))
    if rc != 0:
        _wg_emerg1("[wireguard] FAIL: responder consume-init rc=%d\n", cast[uint64](rc))
        return 0
    # The responder's chaining-key + hash MUST equal the initiator's.
    if _wg_memeq(cast[Ptr[uint8]](&wgA_C[0]),
                 cast[Ptr[uint8]](&wgB_C[0]), 32) != 1:
        _wg_emerg0("[wireguard] FAIL: post-initiation chaining-key mismatch\n")
        return 0
    if _wg_memeq(cast[Ptr[uint8]](&wgA_H[0]),
                 cast[Ptr[uint8]](&wgB_H[0]), 32) != 1:
        _wg_emerg0("[wireguard] FAIL: post-initiation hash mismatch\n")
        return 0
    _wg_emerg0("[wireguard] PASS initiation-consumed C+H-match\n")

    # --- B builds the response + derives its transport keys. ---
    rl: int64 = wg_responder_create(
        cast[Ptr[uint8]](&wgB_eph_priv[0]),
        cast[Ptr[uint8]](&_wg_eB_pub[0]),
        cast[Ptr[uint8]](&_wg_eA_pub[0]),
        cast[Ptr[uint8]](&wgA_static_pub[0]),
        cast[Ptr[uint8]](&wgB_psk[0]),
        cast[Ptr[uint8]](&wgB_C[0]),
        cast[Ptr[uint8]](&wgB_H[0]),
        cast[Ptr[uint8]](&wgB_tsend[0]),
        cast[Ptr[uint8]](&wgB_trecv[0]),
        cast[Ptr[uint8]](&_wg_resp_msg[0]))
    if rl < 0:
        _wg_emerg1("[wireguard] FAIL: response create rc=%d\n", cast[uint64](rl))
        return 0
    _wg_emerg1("[wireguard] PASS response-built len=%d\n", cast[uint64](rl))

    # --- A consumes the response + derives its transport keys. ---
    rc2: int64 = wg_initiator_consume_response(
        cast[Ptr[uint8]](&wgA_static_priv[0]),
        cast[Ptr[uint8]](&wgA_eph_priv[0]),
        cast[Ptr[uint8]](&wgA_psk[0]),
        cast[Ptr[uint8]](&wgA_C[0]),
        cast[Ptr[uint8]](&wgA_H[0]),
        cast[Ptr[uint8]](&wgA_tsend[0]),
        cast[Ptr[uint8]](&wgA_trecv[0]),
        cast[Ptr[uint8]](&_wg_resp_msg[0]), cast[uint64](rl))
    if rc2 != 0:
        _wg_emerg1("[wireguard] FAIL: initiator consume-response rc=%d\n", cast[uint64](rc2))
        return 0
    _wg_emerg0("[wireguard] PASS response-consumed\n")

    # --- The derived transport keys MUST cross-match. ---
    if _wg_memeq(cast[Ptr[uint8]](&wgA_tsend[0]),
                 cast[Ptr[uint8]](&wgB_trecv[0]), 32) != 1:
        _wg_emerg0("[wireguard] FAIL: A.send != B.recv\n")
        return 0
    if _wg_memeq(cast[Ptr[uint8]](&wgA_trecv[0]),
                 cast[Ptr[uint8]](&wgB_tsend[0]), 32) != 1:
        _wg_emerg0("[wireguard] FAIL: A.recv != B.send\n")
        return 0
    _wg_emerg0("[wireguard] PASS transport-keys-match\n")
    wg_handshakes_ok = wg_handshakes_ok + 1

    # --- Transport round-trip A -> B. ---
    inner_len: uint64 = 60
    i = 0
    while i < inner_len:
        _wg_inner_ab[i] = cast[uint8]((0x30 + i * 7) & 0xFF)
        i = i + 1
    tx_len: int64 = wg_transport_seal(
        cast[Ptr[uint8]](&wgA_tsend[0]), 0, 2,
        cast[Ptr[uint8]](&_wg_inner_ab[0]), inner_len,
        cast[Ptr[uint8]](&_wg_xport_ab[0]))
    if tx_len < 0:
        _wg_emerg1("[wireguard] FAIL: A->B seal rc=%d\n", cast[uint64](tx_len))
        return 0
    wg_tx_transport = wg_tx_transport + 1
    # On-wire payload must be real ciphertext (differ from plaintext).
    differs: int32 = 0
    i = 0
    while i < inner_len:
        if _wg_xport_ab[WG_TRANSPORT_HDR + i] != _wg_inner_ab[i]:
            differs = 1
            i = inner_len
        else:
            i = i + 1
    if differs != 1:
        _wg_emerg0("[wireguard] FAIL: transport payload equals plaintext\n")
        return 0
    _wg_seen = 0
    _wg_maxc = 0
    rx_len: int64 = wg_transport_open(
        cast[Ptr[uint8]](&wgB_trecv[0]),
        cast[Ptr[uint8]](&_wg_xport_ab[0]), cast[uint64](tx_len),
        cast[Ptr[uint8]](&_wg_recovered[0]),
        cast[Ptr[int32]](&_wg_seen), cast[Ptr[uint64]](&_wg_maxc))
    if rx_len < 0:
        _wg_emerg1("[wireguard] FAIL: A->B open rc=%d\n", cast[uint64](rx_len))
        return 0
    if cast[uint64](rx_len) != inner_len:
        _wg_emerg0("[wireguard] FAIL: A->B recovered length mismatch\n")
        return 0
    if _wg_memeq(cast[Ptr[uint8]](&_wg_recovered[0]),
                 cast[Ptr[uint8]](&_wg_inner_ab[0]), inner_len) != 1:
        _wg_emerg0("[wireguard] FAIL: A->B not byte-identical\n")
        return 0
    _wg_emerg0("[wireguard] PASS transport-roundtrip-A-to-B\n")

    # --- Reply round-trip B -> A. ---
    inner_len2: uint64 = 48
    i = 0
    while i < inner_len2:
        _wg_inner_ba[i] = cast[uint8]((0xC0 + i * 5) & 0xFF)
        i = i + 1
    tx2: int64 = wg_transport_seal(
        cast[Ptr[uint8]](&wgB_tsend[0]), 0, 1,
        cast[Ptr[uint8]](&_wg_inner_ba[0]), inner_len2,
        cast[Ptr[uint8]](&_wg_xport_ba[0]))
    if tx2 < 0:
        _wg_emerg0("[wireguard] FAIL: B->A seal\n")
        return 0
    wgA_recv_seen = 0
    wgA_recv_max = 0
    rx2: int64 = wg_transport_open(
        cast[Ptr[uint8]](&wgA_trecv[0]),
        cast[Ptr[uint8]](&_wg_xport_ba[0]), cast[uint64](tx2),
        cast[Ptr[uint8]](&_wg_recovered[0]),
        cast[Ptr[int32]](&wgA_recv_seen), cast[Ptr[uint64]](&wgA_recv_max))
    if rx2 < 0:
        _wg_emerg1("[wireguard] FAIL: B->A open rc=%d\n", cast[uint64](rx2))
        return 0
    if _wg_memeq(cast[Ptr[uint8]](&_wg_recovered[0]),
                 cast[Ptr[uint8]](&_wg_inner_ba[0]), inner_len2) != 1:
        _wg_emerg0("[wireguard] FAIL: B->A not byte-identical\n")
        return 0
    _wg_emerg0("[wireguard] PASS transport-roundtrip-B-to-A\n")

    # --- Security: wrong key must be REJECTED. ---
    # The A->B message was sealed under wgA_tsend (== wgB_trecv). Open it with a
    # DIFFERENT key — wgA_trecv (== wgB_tsend), the other-direction key — so the
    # ChaCha20-Poly1305 tag must fail to verify.
    _wg_seen = 0
    _wg_maxc = 0
    wrong: int64 = wg_transport_open(
        cast[Ptr[uint8]](&wgA_trecv[0]),
        cast[Ptr[uint8]](&_wg_xport_ab[0]), cast[uint64](tx_len),
        cast[Ptr[uint8]](&_wg_recovered[0]),
        cast[Ptr[int32]](&_wg_seen), cast[Ptr[uint64]](&_wg_maxc))
    if wrong != -3:
        _wg_emerg1("[wireguard] FAIL: wrong-key accepted rc=%d\n", cast[uint64](wrong))
        return 0
    _wg_emerg0("[wireguard] PASS reject-wrong-key\n")

    # --- Security: replayed counter must be REJECTED. ---
    # Re-open the (already accepted, counter=0) A->B message against B's recv
    # state, which has advanced past counter 0 -> replay reject.
    _wg_seen = 0
    _wg_maxc = 0
    # First accept counter 0.
    first: int64 = wg_transport_open(
        cast[Ptr[uint8]](&wgB_trecv[0]),
        cast[Ptr[uint8]](&_wg_xport_ab[0]), cast[uint64](tx_len),
        cast[Ptr[uint8]](&_wg_recovered[0]),
        cast[Ptr[int32]](&_wg_seen), cast[Ptr[uint64]](&_wg_maxc))
    if first < 0:
        _wg_emerg0("[wireguard] FAIL: replay-setup open failed\n")
        return 0
    # Replay the same counter -> must reject.
    replay: int64 = wg_transport_open(
        cast[Ptr[uint8]](&wgB_trecv[0]),
        cast[Ptr[uint8]](&_wg_xport_ab[0]), cast[uint64](tx_len),
        cast[Ptr[uint8]](&_wg_recovered[0]),
        cast[Ptr[int32]](&_wg_seen), cast[Ptr[uint64]](&_wg_maxc))
    if replay != -4:
        _wg_emerg1("[wireguard] FAIL: replayed counter accepted rc=%d\n", cast[uint64](replay))
        return 0
    _wg_emerg0("[wireguard] PASS reject-replay\n")

    # --- Security: tampered ciphertext must be REJECTED. ---
    saved: uint8 = _wg_xport_ab[WG_TRANSPORT_HDR + 5]
    _wg_xport_ab[WG_TRANSPORT_HDR + 5] = saved ^ 0xFF
    _wg_seen = 0
    _wg_maxc = 0
    tampered: int64 = wg_transport_open(
        cast[Ptr[uint8]](&wgB_trecv[0]),
        cast[Ptr[uint8]](&_wg_xport_ab[0]), cast[uint64](tx_len),
        cast[Ptr[uint8]](&_wg_recovered[0]),
        cast[Ptr[int32]](&_wg_seen), cast[Ptr[uint64]](&_wg_maxc))
    _wg_xport_ab[WG_TRANSPORT_HDR + 5] = saved
    if tampered != -3:
        _wg_emerg1("[wireguard] FAIL: tampered ciphertext accepted rc=%d\n", cast[uint64](tampered))
        return 0
    _wg_emerg0("[wireguard] PASS reject-tampered-ciphertext\n")

    if ok == 1:
        _wg_emerg0("[wireguard] PASS\n")
        return 1
    _wg_emerg0("[wireguard] FAIL\n")
    return 0


# =====================================================================
# WireGuard ↔ UDP overlay wiring + selftest
# =====================================================================
#
# 2026-06-14: rewired through the udp_rx kernel-listener registry that
# landed in drivers/net/udp.ad. The previous in-VM "wire" ring is gone;
# outer datagrams now traverse the real udp_rx port-51820 demux.
#
# Encap (egress) path:
#   wg_iface_xmit(side, inner, len)
#     -> wg_transport_seal -> ChaCha20-Poly1305 sealed UDP payload.
#     -> udp_local_inject(src=our_ep, dst=peer_ep, port=51820, payload)
#
# Decap (ingress) path:
#   udp_rx port-51820 listener (registered via udp_register_listener)
#     -> wg_udp_listener(peer, src_ip, src_port, payload, len)
#     -> dispatch by src_ip (A_ep -> deliver to B, B_ep -> deliver to A)
#     -> wg_udp_rx -> wg_transport_open / consume INIT/RESPONSE
#
# Loopback note: the outer UDP/IPv4 datagram is delivered in-VM via
# udp_local_inject (a one-process loopback shim feeding the real udp_rx
# demux). Crossing virtio_net_tx + a peer VM is the only remaining gap.

WG_WIRE_MAXPAY:   uint64 = 1472     # max UDP payload (1500 - 20 IP - 8 UDP)

# Backward-compat counters kept for the smoke tests that previously
# observed them.
wg_wire_tx:       uint64 = 0
wg_wire_rx:       uint64 = 0
wg_wire_drops:    uint64 = 0
wg_wire_no_listener: uint64 = 0

# ----- Per-side WG virtual interface (endpoint config + inner capture) ----
# Endpoint A.
_wga_ep_ip:       uint32 = 0
_wga_ep_port:     uint16 = 0
_wga_peer_ip:     uint32 = 0
_wga_peer_port:   uint16 = 0
_wga_iface_up:    uint8  = 0
_wga_inner_cap_count: uint64 = 0
_wga_inner_cap_len:   uint64 = 0
_wga_inner_cap_buf:   Array[1472, uint8]

# Endpoint B.
_wgb_ep_ip:       uint32 = 0
_wgb_ep_port:     uint16 = 0
_wgb_peer_ip:     uint32 = 0
_wgb_peer_port:   uint16 = 0
_wgb_iface_up:    uint8  = 0
_wgb_inner_cap_count: uint64 = 0
_wgb_inner_cap_len:   uint64 = 0
_wgb_inner_cap_buf:   Array[1472, uint8]

# WireGuard UDP port (well-known, configurable in real WG but fixed here).
WG_UDP_PORT:      uint16 = 51820

# Side identifiers.
WG_SIDE_A: uint64 = 0
WG_SIDE_B: uint64 = 1


def _wg_wire_push(src_ip: uint32, src_port: uint16,
                  dst_ip: uint32, dst_port: uint16,
                  payload: Ptr[uint8], length: uint64) -> int32:
    # Submit one outer UDP datagram through the real udp_rx port demux
    # via udp_local_inject. Returns 1 on success, 0 on oversize / drop.
    if length > WG_WIRE_MAXPAY:
        wg_wire_drops = wg_wire_drops + 1
        return 0
    wg_wire_tx = wg_wire_tx + 1
    _wg_last_listener_rc = 0
    udp_local_inject(src_ip, src_port, dst_ip, dst_port, payload, length)
    return 1


# Scratch buffer for the WG-side decap of one pumped wire datagram.
_wg_pump_payload: Array[1472, uint8]


def wg_udp_rx(side: uint64, src_ip: uint32, src_port: uint16,
              payload: Ptr[uint8], length: uint64) -> int32:
    # The WG-side receive path. Dispatch by WG type byte. Returns:
    #   1  on success delivery
    #   0  on type-byte mismatch / silently ignored
    #  -1  on transport AEAD/replay failure
    if length < 1:
        return 0
    t: uint8 = payload[0]
    if t == WG_MSG_TRANSPORT:
        # Pick the right recv key + replay state per side.
        if side == WG_SIDE_A:
            rc: int64 = wg_transport_open(
                cast[Ptr[uint8]](&wgA_trecv[0]),
                payload, length,
                cast[Ptr[uint8]](&_wga_inner_cap_buf[0]),
                cast[Ptr[int32]](&wgA_recv_seen),
                cast[Ptr[uint64]](&wgA_recv_max))
            if rc < 0:
                return cast[int32](-1)
            _wga_inner_cap_len = cast[uint64](rc)
            _wga_inner_cap_count = _wga_inner_cap_count + 1
            return 1
        if side == WG_SIDE_B:
            rc2: int64 = wg_transport_open(
                cast[Ptr[uint8]](&wgB_trecv[0]),
                payload, length,
                cast[Ptr[uint8]](&_wgb_inner_cap_buf[0]),
                cast[Ptr[int32]](&wgB_recv_seen),
                cast[Ptr[uint64]](&wgB_recv_max))
            if rc2 < 0:
                return cast[int32](-1)
            _wgb_inner_cap_len = cast[uint64](rc2)
            _wgb_inner_cap_count = _wgb_inner_cap_count + 1
            return 1
        return 0
    if t == WG_MSG_INIT:
        # Only B accepts INIT in this two-peer overlay.
        if side != WG_SIDE_B:
            return 0
        rc3: int64 = wg_responder_consume_init(
            cast[Ptr[uint8]](&wgB_static_priv[0]),
            cast[Ptr[uint8]](&wgB_static_pub[0]),
            cast[Ptr[uint8]](&wgA_static_pub[0]),
            cast[Ptr[uint8]](&wgB_C[0]),
            cast[Ptr[uint8]](&wgB_H[0]),
            cast[Ptr[uint8]](&_wg_eA_pub[0]),
            payload, length)
        if rc3 != 0:
            return cast[int32](-1)
        return 1
    if t == WG_MSG_RESPONSE:
        # Only A accepts RESPONSE in this two-peer overlay.
        if side != WG_SIDE_A:
            return 0
        rc4: int64 = wg_initiator_consume_response(
            cast[Ptr[uint8]](&wgA_static_priv[0]),
            cast[Ptr[uint8]](&wgA_eph_priv[0]),
            cast[Ptr[uint8]](&wgA_psk[0]),
            cast[Ptr[uint8]](&wgA_C[0]),
            cast[Ptr[uint8]](&wgA_H[0]),
            cast[Ptr[uint8]](&wgA_tsend[0]),
            cast[Ptr[uint8]](&wgA_trecv[0]),
            payload, length)
        if rc4 != 0:
            return cast[int32](-1)
        return 1
    # Unknown type byte.
    return 0


_wg_last_listener_rc: int32 = 0


def wg_udp_listener(peer: uint64, src_ip: uint32, src_port: uint16,
                    payload: Ptr[uint8], length: uint64):
    # udp_rx port-51820 listener. Dispatches to side A or side B by
    # matching src_ip: when A sent the datagram, src_ip == A's endpoint
    # so the receiver is B (and vice versa).
    wg_wire_rx = wg_wire_rx + 1
    recv_side: int64 = cast[int64](-1)
    if _wga_iface_up == 1:
        if _wgb_iface_up == 1:
            if src_ip == _wga_ep_ip:
                recv_side = cast[int64](WG_SIDE_B)
            else:
                if src_ip == _wgb_ep_ip:
                    recv_side = cast[int64](WG_SIDE_A)
    if recv_side < 0:
        wg_wire_no_listener = wg_wire_no_listener + 1
        _wg_last_listener_rc = 0
        return
    n: uint64 = length
    if n > WG_WIRE_MAXPAY:
        n = WG_WIRE_MAXPAY
    i: uint64 = 0
    while i < n:
        _wg_pump_payload[i] = payload[i]
        i = i + 1
    _wg_last_listener_rc = wg_udp_rx(cast[uint64](recv_side),
                                     src_ip, src_port,
                                     cast[Ptr[uint8]](&_wg_pump_payload[0]),
                                     n)


def wg_register_udp_listener() -> int32:
    # Install the single port-51820 listener (peer_data = 0; the
    # listener does its own per-endpoint src_ip demux).
    return udp_register_listener(WG_UDP_PORT, wg_udp_listener,
                                 cast[uint64](0))


def wg_wire_pump() -> int32:
    # No-op compatibility shim. Outer datagrams are now delivered
    # synchronously by udp_rx through the kernel listener — there is
    # no longer a ring to drain. Returns the last listener's outcome.
    return _wg_last_listener_rc


# Egress scratch for one transport message (max inner + WG header + tag).
_wg_xmit_buf: Array[1472, uint8]


def wg_iface_xmit(side: uint64, inner: Ptr[uint8], inner_len: uint64) -> int32:
    # The WG virtual interface egress hook. Encapsulate `inner` as a
    # WireGuard transport message under the per-side send key, then push
    # it as an outer UDP-shape datagram (src=our ep, dst=peer ep,
    # both ports 51820) onto the wire ring. Returns 1 on success, 0 on
    # any failure (interface down, oversize, ring full).
    if inner_len + WG_TRANSPORT_HDR + WG_TAG_LEN > WG_WIRE_MAXPAY:
        return 0
    if side == WG_SIDE_A:
        if _wga_iface_up == 0:
            return 0
        tx_len: int64 = wg_transport_seal(
            cast[Ptr[uint8]](&wgA_tsend[0]),
            wgA_send_ctr, 2,
            inner, inner_len,
            cast[Ptr[uint8]](&_wg_xmit_buf[0]))
        if tx_len < 0:
            return 0
        wgA_send_ctr = wgA_send_ctr + 1
        wg_tx_transport = wg_tx_transport + 1
        return _wg_wire_push(_wga_ep_ip, _wga_ep_port,
                             _wga_peer_ip, _wga_peer_port,
                             cast[Ptr[uint8]](&_wg_xmit_buf[0]),
                             cast[uint64](tx_len))
    if side == WG_SIDE_B:
        if _wgb_iface_up == 0:
            return 0
        tx2: int64 = wg_transport_seal(
            cast[Ptr[uint8]](&wgB_tsend[0]),
            wgB_send_ctr, 1,
            inner, inner_len,
            cast[Ptr[uint8]](&_wg_xmit_buf[0]))
        if tx2 < 0:
            return 0
        wgB_send_ctr = wgB_send_ctr + 1
        wg_tx_transport = wg_tx_transport + 1
        return _wg_wire_push(_wgb_ep_ip, _wgb_ep_port,
                             _wgb_peer_ip, _wgb_peer_port,
                             cast[Ptr[uint8]](&_wg_xmit_buf[0]),
                             cast[uint64](tx2))
    return 0


# Scratch for the handshake messages put on the wire.
_wg_ov_init_msg: Array[256, uint8]
_wg_ov_resp_msg: Array[256, uint8]
_wg_ov_inner_ab: Array[200, uint8]
_wg_ov_inner_ba: Array[200, uint8]


def _wg_ov_overlay_reset():
    # Reset wire counters + capture rings + side counters.
    wg_wire_tx = 0
    wg_wire_rx = 0
    wg_wire_drops = 0
    wg_wire_no_listener = 0
    _wg_last_listener_rc = 0
    _wga_inner_cap_count = 0
    _wga_inner_cap_len = 0
    _wgb_inner_cap_count = 0
    _wgb_inner_cap_len = 0
    wgA_send_ctr = 0
    wgB_send_ctr = 0
    wgA_recv_seen = 0
    wgA_recv_max = 0
    wgB_recv_seen = 0
    wgB_recv_max = 0


def wireguard_overlay_selftest() -> int32:
    # Returns 1 on PASS, 0 on FAIL.
    #
    # Topology:
    #   side A: endpoint 10.0.0.1:51820  (initiator)
    #   side B: endpoint 10.0.0.2:51820  (responder)
    # Wire: in-VM ring; pumped one datagram at a time.
    # Flow:
    #   1. (re)generate static + ephemeral keypairs, init labels
    #   2. A builds INIT and ships via wire (push to ring, dst=B)
    #   3. wg_wire_pump() delivers it to side B, B consumes INIT
    #   4. B builds RESPONSE + derives transport keys, ships via wire
    #   5. wg_wire_pump() delivers to A, A consumes RESPONSE + derives keys
    #   6. assert cross-key match (A.send == B.recv etc.)
    #   7. A: wg_iface_xmit(inner_ab) -> wire -> pump -> capture at B
    #   8. assert B's inner-capture == inner_ab (byte-identical)
    #   9. B: wg_iface_xmit(inner_ba) -> wire -> pump -> capture at A
    #  10. assert A's inner-capture == inner_ba (byte-identical)
    _wg_emerg0("[wireguard-overlay] self-test start\n")
    ok: int32 = 1

    # Sanity: the unit-test KATs/handshake must still pass (we depend on
    # the same crypto). Don't re-run the full selftest — just re-seed the
    # key material the way wireguard_selftest() does, then drive the wire.
    _wg_init_labels()
    i: uint64 = 0
    while i < 32:
        wgA_static_priv[i] = cast[uint8]((0x11 + i) & 0xFF)
        wgB_static_priv[i] = cast[uint8]((0x42 + i) & 0xFF)
        wgA_eph_priv[i]    = cast[uint8]((0x71 + i) & 0xFF)
        wgB_eph_priv[i]    = cast[uint8]((0xA3 + i) & 0xFF)
        wgA_psk[i] = cast[uint8]((0x5A + i) & 0xFF)
        wgB_psk[i] = cast[uint8]((0x5A + i) & 0xFF)
        i = i + 1
    _wg_keygen(cast[Ptr[uint8]](&wgA_static_priv[0]),
               cast[Ptr[uint8]](&wgA_static_pub[0]))
    _wg_keygen(cast[Ptr[uint8]](&wgB_static_priv[0]),
               cast[Ptr[uint8]](&wgB_static_pub[0]))
    _wg_keygen(cast[Ptr[uint8]](&wgA_eph_priv[0]),
               cast[Ptr[uint8]](&_wg_eA_pub[0]))
    _wg_keygen(cast[Ptr[uint8]](&wgB_eph_priv[0]),
               cast[Ptr[uint8]](&_wg_eB_pub[0]))
    i = 0
    while i < 12:
        _wg_ts[i] = 0
        i = i + 1

    # Configure endpoints.
    _wga_ep_ip   = (10 << 24) | (0 << 16) | (0 << 8) | 1     # 10.0.0.1
    _wga_ep_port = WG_UDP_PORT
    _wga_peer_ip = (10 << 24) | (0 << 16) | (0 << 8) | 2     # 10.0.0.2
    _wga_peer_port = WG_UDP_PORT
    _wga_iface_up = 1
    _wgb_ep_ip   = (10 << 24) | (0 << 16) | (0 << 8) | 2
    _wgb_ep_port = WG_UDP_PORT
    _wgb_peer_ip = (10 << 24) | (0 << 16) | (0 << 8) | 1
    _wgb_peer_port = WG_UDP_PORT
    _wgb_iface_up = 1
    _wg_ov_overlay_reset()

    # Register the udp_rx port-51820 listener.
    reg_rc: int32 = wg_register_udp_listener()
    if reg_rc < 0:
        _wg_emerg0("[wireguard-overlay] FAIL: udp_register_listener\n")
        return 0
    _wg_emerg0("[wireguard-overlay] PASS udp-listener-registered-port-51820\n")

    # Step 2: A builds INIT and pushes it on the wire (dst = B).
    il: int64 = wg_initiator_create(
        cast[Ptr[uint8]](&wgA_static_priv[0]),
        cast[Ptr[uint8]](&wgA_static_pub[0]),
        cast[Ptr[uint8]](&wgA_eph_priv[0]),
        cast[Ptr[uint8]](&_wg_eA_pub[0]),
        cast[Ptr[uint8]](&wgB_static_pub[0]),
        cast[Ptr[uint8]](&_wg_ts[0]),
        cast[Ptr[uint8]](&wgA_C[0]),
        cast[Ptr[uint8]](&wgA_H[0]),
        cast[Ptr[uint8]](&_wg_ov_init_msg[0]))
    if il < 0:
        _wg_emerg0("[wireguard-overlay] FAIL: init create\n")
        return 0
    pushed: int32 = _wg_wire_push(
        _wga_ep_ip, _wga_ep_port,
        _wga_peer_ip, _wga_peer_port,
        cast[Ptr[uint8]](&_wg_ov_init_msg[0]), cast[uint64](il))
    if pushed != 1:
        _wg_emerg0("[wireguard-overlay] FAIL: init push to wire\n")
        return 0
    _wg_emerg1("[wireguard-overlay] PASS init-on-wire len=%d\n",
               cast[uint64](il))

    # Step 3: pump -> B consumes INIT.
    p1: int32 = wg_wire_pump()
    if p1 != 1:
        _wg_emerg1("[wireguard-overlay] FAIL: init pump rc=%d\n",
                   cast[uint64](p1))
        return 0
    # B's C/H must now equal A's post-INIT C/H.
    if _wg_memeq(cast[Ptr[uint8]](&wgA_C[0]),
                 cast[Ptr[uint8]](&wgB_C[0]), 32) != 1:
        _wg_emerg0("[wireguard-overlay] FAIL: C mismatch post-INIT pump\n")
        return 0
    if _wg_memeq(cast[Ptr[uint8]](&wgA_H[0]),
                 cast[Ptr[uint8]](&wgB_H[0]), 32) != 1:
        _wg_emerg0("[wireguard-overlay] FAIL: H mismatch post-INIT pump\n")
        return 0
    _wg_emerg0("[wireguard-overlay] PASS init-consumed-via-wire\n")

    # Step 4: B builds RESPONSE + derives transport keys, ships on wire.
    rl: int64 = wg_responder_create(
        cast[Ptr[uint8]](&wgB_eph_priv[0]),
        cast[Ptr[uint8]](&_wg_eB_pub[0]),
        cast[Ptr[uint8]](&_wg_eA_pub[0]),
        cast[Ptr[uint8]](&wgA_static_pub[0]),
        cast[Ptr[uint8]](&wgB_psk[0]),
        cast[Ptr[uint8]](&wgB_C[0]),
        cast[Ptr[uint8]](&wgB_H[0]),
        cast[Ptr[uint8]](&wgB_tsend[0]),
        cast[Ptr[uint8]](&wgB_trecv[0]),
        cast[Ptr[uint8]](&_wg_ov_resp_msg[0]))
    if rl < 0:
        _wg_emerg0("[wireguard-overlay] FAIL: response create\n")
        return 0
    pushed2: int32 = _wg_wire_push(
        _wgb_ep_ip, _wgb_ep_port,
        _wgb_peer_ip, _wgb_peer_port,
        cast[Ptr[uint8]](&_wg_ov_resp_msg[0]), cast[uint64](rl))
    if pushed2 != 1:
        _wg_emerg0("[wireguard-overlay] FAIL: response push to wire\n")
        return 0
    _wg_emerg1("[wireguard-overlay] PASS response-on-wire len=%d\n",
               cast[uint64](rl))

    # Step 5: pump -> A consumes RESPONSE.
    p2: int32 = wg_wire_pump()
    if p2 != 1:
        _wg_emerg1("[wireguard-overlay] FAIL: resp pump rc=%d\n",
                   cast[uint64](p2))
        return 0
    _wg_emerg0("[wireguard-overlay] PASS response-consumed-via-wire\n")

    # Step 6: cross-key match.
    if _wg_memeq(cast[Ptr[uint8]](&wgA_tsend[0]),
                 cast[Ptr[uint8]](&wgB_trecv[0]), 32) != 1:
        _wg_emerg0("[wireguard-overlay] FAIL: A.send != B.recv\n")
        return 0
    if _wg_memeq(cast[Ptr[uint8]](&wgA_trecv[0]),
                 cast[Ptr[uint8]](&wgB_tsend[0]), 32) != 1:
        _wg_emerg0("[wireguard-overlay] FAIL: A.recv != B.send\n")
        return 0
    _wg_emerg0("[wireguard-overlay] PASS transport-keys-match\n")
    wg_handshakes_ok = wg_handshakes_ok + 1

    # Step 7: A xmits an inner frame; pump; capture at B.
    inner_ab_len: uint64 = 80
    i = 0
    while i < inner_ab_len:
        _wg_ov_inner_ab[i] = cast[uint8]((0x40 + i * 3) & 0xFF)
        i = i + 1
    tx1: int32 = wg_iface_xmit(WG_SIDE_A,
                               cast[Ptr[uint8]](&_wg_ov_inner_ab[0]),
                               inner_ab_len)
    if tx1 != 1:
        _wg_emerg0("[wireguard-overlay] FAIL: A xmit\n")
        return 0
    p3: int32 = wg_wire_pump()
    if p3 != 1:
        _wg_emerg1("[wireguard-overlay] FAIL: A->B pump rc=%d\n",
                   cast[uint64](p3))
        return 0
    if _wgb_inner_cap_count != 1:
        _wg_emerg1("[wireguard-overlay] FAIL: B captures=%d != 1\n",
                   _wgb_inner_cap_count)
        return 0
    if _wgb_inner_cap_len != inner_ab_len:
        _wg_emerg2("[wireguard-overlay] FAIL: B cap len %d != %d\n",
                   _wgb_inner_cap_len, inner_ab_len)
        return 0
    eq1: int32 = _wg_memeq(cast[Ptr[uint8]](&_wgb_inner_cap_buf[0]),
                           cast[Ptr[uint8]](&_wg_ov_inner_ab[0]),
                           inner_ab_len)
    if eq1 != 1:
        _wg_emerg0("[wireguard-overlay] FAIL: A->B inner not byte-identical\n")
        return 0
    _wg_emerg0("[wireguard-overlay] PASS A-to-B-byte-identical\n")

    # Step 9: B xmits an inner frame; pump; capture at A.
    inner_ba_len: uint64 = 64
    i = 0
    while i < inner_ba_len:
        _wg_ov_inner_ba[i] = cast[uint8]((0x90 + i * 5) & 0xFF)
        i = i + 1
    tx2: int32 = wg_iface_xmit(WG_SIDE_B,
                               cast[Ptr[uint8]](&_wg_ov_inner_ba[0]),
                               inner_ba_len)
    if tx2 != 1:
        _wg_emerg0("[wireguard-overlay] FAIL: B xmit\n")
        return 0
    p4: int32 = wg_wire_pump()
    if p4 != 1:
        _wg_emerg1("[wireguard-overlay] FAIL: B->A pump rc=%d\n",
                   cast[uint64](p4))
        return 0
    if _wga_inner_cap_count != 1:
        _wg_emerg1("[wireguard-overlay] FAIL: A captures=%d != 1\n",
                   _wga_inner_cap_count)
        return 0
    if _wga_inner_cap_len != inner_ba_len:
        _wg_emerg2("[wireguard-overlay] FAIL: A cap len %d != %d\n",
                   _wga_inner_cap_len, inner_ba_len)
        return 0
    eq2: int32 = _wg_memeq(cast[Ptr[uint8]](&_wga_inner_cap_buf[0]),
                           cast[Ptr[uint8]](&_wg_ov_inner_ba[0]),
                           inner_ba_len)
    if eq2 != 1:
        _wg_emerg0("[wireguard-overlay] FAIL: B->A inner not byte-identical\n")
        return 0
    _wg_emerg0("[wireguard-overlay] PASS B-to-A-byte-identical\n")

    # Counter sanity: wire saw 4 TX + 4 RX (init, resp, A->B, B->A).
    if wg_wire_tx != 4:
        _wg_emerg1("[wireguard-overlay] FAIL: wire_tx=%d != 4\n", wg_wire_tx)
        return 0
    if wg_wire_rx != 4:
        _wg_emerg1("[wireguard-overlay] FAIL: wire_rx=%d != 4\n", wg_wire_rx)
        return 0
    _wg_emerg0("[wireguard-overlay] PASS wire-counters-balance\n")

    if ok == 1:
        _wg_emerg0("[wireguard-overlay] PASS\n")
        return 1
    _wg_emerg0("[wireguard-overlay] FAIL\n")
    return 0


def _wg_emerg2(s: Ptr[char], a: uint64, b: uint64):
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk2(s, a, b)

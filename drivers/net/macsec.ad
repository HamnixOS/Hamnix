    _mst_kat_key[15]=0x08

    _mst_kat_iv[0]=0xca
    _mst_kat_iv[1]=0xfe
    _mst_kat_iv[2]=0xba
    _mst_kat_iv[3]=0xbe
    _mst_kat_iv[4]=0xfa
    _mst_kat_iv[5]=0xce
    _mst_kat_iv[6]=0xdb
    _mst_kat_iv[7]=0xad
    _mst_kat_iv[8]=0xde
    _mst_kat_iv[9]=0xca
    _mst_kat_iv[10]=0xf8
    _mst_kat_iv[11]=0x88

    _mst_kat_aad[0]=0xfe
    _mst_kat_aad[1]=0xed
    _mst_kat_aad[2]=0xfa
    _mst_kat_aad[3]=0xce
    _mst_kat_aad[4]=0xde
    _mst_kat_aad[5]=0xad
    _mst_kat_aad[6]=0xbe
    _mst_kat_aad[7]=0xef
    _mst_kat_aad[8]=0xfe
    _mst_kat_aad[9]=0xed
    _mst_kat_aad[10]=0xfa
    _mst_kat_aad[11]=0xce
    _mst_kat_aad[12]=0xde
    _mst_kat_aad[13]=0xad
    _mst_kat_aad[14]=0xbe
    _mst_kat_aad[15]=0xef
    _mst_kat_aad[16]=0xab
    _mst_kat_aad[17]=0xad
    _mst_kat_aad[18]=0xda
    _mst_kat_aad[19]=0xd2

    # Plaintext (60 bytes).
    _mst_kat_pt[0]=0xd9
    _mst_kat_pt[1]=0x31
    _mst_kat_pt[2]=0x32
    _mst_kat_pt[3]=0x25
    _mst_kat_pt[4]=0xf8
    _mst_kat_pt[5]=0x84
    _mst_kat_pt[6]=0x06
    _mst_kat_pt[7]=0xe5
    _mst_kat_pt[8]=0xa5
    _mst_kat_pt[9]=0x59
    _mst_kat_pt[10]=0x09
    _mst_kat_pt[11]=0xc5
    _mst_kat_pt[12]=0xaf
    _mst_kat_pt[13]=0xf5
    _mst_kat_pt[14]=0x26
    _mst_kat_pt[15]=0x9a
    _mst_kat_pt[16]=0x86
    _mst_kat_pt[17]=0xa7
    _mst_kat_pt[18]=0xa9
    _mst_kat_pt[19]=0x53
    _mst_kat_pt[20]=0x15
    _mst_kat_pt[21]=0x34
    _mst_kat_pt[22]=0xf7
    _mst_kat_pt[23]=0xda
    _mst_kat_pt[24]=0x2e
    _mst_kat_pt[25]=0x4c
    _mst_kat_pt[26]=0x30
    _mst_kat_pt[27]=0x3d
    _mst_kat_pt[28]=0x8a
    _mst_kat_pt[29]=0x31
    _mst_kat_pt[30]=0x8a
    _mst_kat_pt[31]=0x72
    _mst_kat_pt[32]=0x1c
    _mst_kat_pt[33]=0x3c
    _mst_kat_pt[34]=0x0c
    _mst_kat_pt[35]=0x95
    _mst_kat_pt[36]=0x95
    _mst_kat_pt[37]=0x68
    _mst_kat_pt[38]=0x09
    _mst_kat_pt[39]=0x53
    _mst_kat_pt[40]=0x2f
    _mst_kat_pt[41]=0xcf
    _mst_kat_pt[42]=0x0e
    _mst_kat_pt[43]=0x24
    _mst_kat_pt[44]=0x49
    _mst_kat_pt[45]=0xa6
    _mst_kat_pt[46]=0xb5
    _mst_kat_pt[47]=0x25
    _mst_kat_pt[48]=0xb1
    _mst_kat_pt[49]=0x6a
    _mst_kat_pt[50]=0xed
    _mst_kat_pt[51]=0xf5
    _mst_kat_pt[52]=0xaa
    _mst_kat_pt[53]=0x0d
    _mst_kat_pt[54]=0xe6
    _mst_kat_pt[55]=0x57
    _mst_kat_pt[56]=0xba
    _mst_kat_pt[57]=0x63
    _mst_kat_pt[58]=0x7b
    _mst_kat_pt[59]=0x39

    # Expected ciphertext (60 bytes).
    _mst_kat_expct[0]=0x42
    _mst_kat_expct[1]=0x83
    _mst_kat_expct[2]=0x1e
    _mst_kat_expct[3]=0xc2
    _mst_kat_expct[4]=0x21
    _mst_kat_expct[5]=0x77
    _mst_kat_expct[6]=0x74
    _mst_kat_expct[7]=0x24
    _mst_kat_expct[8]=0x4b
    _mst_kat_expct[9]=0x72
    _mst_kat_expct[10]=0x21
    _mst_kat_expct[11]=0xb7
    _mst_kat_expct[12]=0x84
    _mst_kat_expct[13]=0xd0
    _mst_kat_expct[14]=0xd4
    _mst_kat_expct[15]=0x9c
    _mst_kat_expct[16]=0xe3
    _mst_kat_expct[17]=0xaa
    _mst_kat_expct[18]=0x21
    _mst_kat_expct[19]=0x2f
    _mst_kat_expct[20]=0x2c
    _mst_kat_expct[21]=0x02
    _mst_kat_expct[22]=0xa4
    _mst_kat_expct[23]=0xe0
    _mst_kat_expct[24]=0x35
    _mst_kat_expct[25]=0xc1
    _mst_kat_expct[26]=0x7e
    _mst_kat_expct[27]=0x23
    _mst_kat_expct[28]=0x29
    _mst_kat_expct[29]=0xac
    _mst_kat_expct[30]=0xa1
    _mst_kat_expct[31]=0x2e
    _mst_kat_expct[32]=0x21
    _mst_kat_expct[33]=0xd5
    _mst_kat_expct[34]=0x14
    _mst_kat_expct[35]=0xb2
    _mst_kat_expct[36]=0x54
    _mst_kat_expct[37]=0x66
    _mst_kat_expct[38]=0x93
    _mst_kat_expct[39]=0x1c
    _mst_kat_expct[40]=0x7d
    _mst_kat_expct[41]=0x8f
    _mst_kat_expct[42]=0x6a
    _mst_kat_expct[43]=0x5a
    _mst_kat_expct[44]=0xac
    _mst_kat_expct[45]=0x84
    _mst_kat_expct[46]=0xaa
    _mst_kat_expct[47]=0x05
    _mst_kat_expct[48]=0x1b
    _mst_kat_expct[49]=0xa3
    _mst_kat_expct[50]=0x0b
    _mst_kat_expct[51]=0x39
    _mst_kat_expct[52]=0x6a
    _mst_kat_expct[53]=0x0a
    _mst_kat_expct[54]=0xac
    _mst_kat_expct[55]=0x97
    _mst_kat_expct[56]=0x3d
    _mst_kat_expct[57]=0x58
    _mst_kat_expct[58]=0xe0
    _mst_kat_expct[59]=0x91

    # Expected tag (16 bytes).
    _mst_kat_exptag[0]=0x5b
    _mst_kat_exptag[1]=0xc9
    _mst_kat_exptag[2]=0x4f
    _mst_kat_exptag[3]=0xbc
    _mst_kat_exptag[4]=0x32
    _mst_kat_exptag[5]=0x21
    _mst_kat_exptag[6]=0xa5
    _mst_kat_exptag[7]=0xdb
    _mst_kat_exptag[8]=0x94
    _mst_kat_exptag[9]=0xfa
    _mst_kat_exptag[10]=0xe9
    _mst_kat_exptag[11]=0x5a
    _mst_kat_exptag[12]=0xe7
    _mst_kat_exptag[13]=0x12
    _mst_kat_exptag[14]=0x1a
    _mst_kat_exptag[15]=0x47

    pt_len: uint64 = 60
    aad_len: uint64 = 20

    _tls_aes_gcm_seal(
        cast[Ptr[uint8]](&_mst_kat_key[0]), 16,
        cast[Ptr[uint8]](&_mst_kat_iv[0]),
        cast[Ptr[uint8]](&_mst_kat_aad[0]), aad_len,
        cast[Ptr[uint8]](&_mst_kat_pt[0]), pt_len,
        cast[Ptr[uint8]](&_mst_kat_ct[0]),
        cast[Ptr[uint8]](&_mst_kat_tag[0]))

    ct_ok: int32 = 1
    i: uint64 = 0
    while i < pt_len:
        if _mst_kat_ct[i] != _mst_kat_expct[i]:
            ct_ok = 0
            i = pt_len
        else:
            i = i + 1
    tag_ok: int32 = 1
    i = 0
    while i < 16:
        if _mst_kat_tag[i] != _mst_kat_exptag[i]:
            tag_ok = 0
            i = 16
        else:
            i = i + 1
    if ct_ok != 1 or tag_ok != 1:
        return 0

    # Round-trip: open recovers the plaintext under the expected tag.
    op: int32 = _tls_aes_gcm_open(
        cast[Ptr[uint8]](&_mst_kat_key[0]), 16,
        cast[Ptr[uint8]](&_mst_kat_iv[0]),
        cast[Ptr[uint8]](&_mst_kat_aad[0]), aad_len,
        cast[Ptr[uint8]](&_mst_kat_expct[0]), pt_len,
        cast[Ptr[uint8]](&_mst_kat_exptag[0]),
        cast[Ptr[uint8]](&_mst_kat_dec[0]))
    if op != 0:
        return 0
    i = 0
    while i < pt_len:
        if _mst_kat_dec[i] != _mst_kat_pt[i]:
            return 0
        i = i + 1
    return 1


def macsec_selftest() -> int32:
    # Returns 1 on PASS, 0 on FAIL. Prints [macsec] marker lines.
    _ms_emerg0("[macsec] self-test start\n")
    macsec_init()
    ok: int32 = 1

    # --- 1. Known-answer test against the McGrew/Viega GCM-AES-128 vector. --
    if _ms_kat() != 1:
        _ms_emerg0("[macsec] FAIL: GCM-AES-128 known-answer-test mismatch\n")
        ok = 0
    else:
        _ms_emerg0("[macsec] PASS gcm-aes-128-kat (McGrew/Viega TC4)\n")

    # --- SecY / SC / SA setup. ---
    # Transmit & receive SC share the SCI (single point-to-point link here).
    i: uint64 = 0
    while i < 8:
        _mst_sci[i] = cast[uint8](0x52 + i)         # arbitrary SCI
        i = i + 1
    macsec_install_tx_sc(cast[Ptr[uint8]](&_mst_sci[0]), 1)
    macsec_install_rx_sc(cast[Ptr[uint8]](&_mst_sci[0]), 1)
    # Two distinct SAKs, addressed by AN 0 and AN 1.
    i = 0
    while i < 16:
        _mst_key0[i] = cast[uint8](0x10 + i)
        _mst_key1[i] = cast[uint8](0xA0 + i)
        i = i + 1
    macsec_install_sa(0, cast[Ptr[uint8]](&_mst_key0[0]))
    macsec_install_sa(1, cast[Ptr[uint8]](&_mst_key1[0]))
    macsec_set_active_an(0)

    # --- 2. PROTECT a known inner frame (AN=0, PN via the SC counter). ---
    inner_len: uint64 = _ms_build_inner(0x5A)
    prot_len: int64 = macsec_protect_next(
        cast[Ptr[uint8]](&_mst_inner[0]), inner_len,
        cast[Ptr[uint8]](&_mst_out[0]), MACSEC_T_OUT_CAP)
    if prot_len < 0:
        _ms_emerg1("[macsec] FAIL: protect rc=%d\n", cast[uint64](prot_len))
        return 0
    # Expected protected length: inner + SecTAG(16) + ICV(16).
    exp_len: uint64 = inner_len + MACSEC_SECTAG_LEN_SCI + MACSEC_ICV_LEN
    if cast[uint64](prot_len) != exp_len:
        _ms_emerg2("[macsec] FAIL: protected len %d != %d\n",
                   cast[uint64](prot_len), exp_len)
        ok = 0
    else:
        _ms_emerg1("[macsec] PASS protected-len=%d\n", cast[uint64](prot_len))

    # SecTAG EtherType must be 0x88E5.
    etype: uint16 = _ms_get16(cast[Ptr[uint8]](&_mst_out[0]), 12 + MACSEC_OFF_ETYPE)
    if etype != MACSEC_ETHERTYPE:
        _ms_emerg1("[macsec] FAIL: SecTAG ethertype %x != 0x88E5\n", cast[uint64](etype))
        ok = 0
    else:
        _ms_emerg0("[macsec] PASS sectag-ethertype=0x88E5\n")

    # TCI flags: SC, E, C must be set; AN must be 0.
    tci: uint8 = _mst_out[12 + MACSEC_OFF_TCI]
    if (tci & MACSEC_TCI_SC) == 0 or (tci & MACSEC_TCI_E) == 0 \
       or (tci & MACSEC_TCI_C) == 0:
        _ms_emerg1("[macsec] FAIL: TCI flags %x missing SC/E/C\n", cast[uint64](tci))
        ok = 0
    else:
        _ms_emerg0("[macsec] PASS tci-flags-SC-E-C\n")
    if (tci & MACSEC_AN_MASK) != 0:
        _ms_emerg1("[macsec] FAIL: AN %d != 0\n", cast[uint64](tci & MACSEC_AN_MASK))
        ok = 0
    else:
        _ms_emerg0("[macsec] PASS an=0\n")

    # PN must be 1 (the SC's initial PN).
    pn_wire: uint32 = _ms_get32(cast[Ptr[uint8]](&_mst_out[0]), 12 + MACSEC_OFF_PN)
    if pn_wire != 1:
        _ms_emerg1("[macsec] FAIL: wire PN %d != 1\n", cast[uint64](pn_wire))
        ok = 0
    else:
        _ms_emerg0("[macsec] PASS pn=1\n")

    # The on-wire secure data must be genuine CIPHERTEXT (differ from the
    # plaintext user data). Compare the protected payload bytes against the
    # inner user data byte-for-byte; they must NOT all match.
    ct_off: uint64 = 12 + MACSEC_SECTAG_LEN_SCI
    data_off: uint64 = 12
    data_len: uint64 = inner_len - data_off
    differs: int32 = 0
    i = 0
    while i < data_len:
        if _mst_out[ct_off + i] != _mst_inner[data_off + i]:
            differs = 1
            i = data_len
        else:
            i = i + 1
    if differs != 1:
        _ms_emerg0("[macsec] FAIL: secure data equals plaintext (not encrypted)\n")
        ok = 0
    else:
        _ms_emerg0("[macsec] PASS payload-is-ciphertext\n")

    # --- 3. VALIDATE: decrypt + recover the inner frame byte-identical. ---
    rpn: uint32 = 0
    rec_len: int64 = macsec_validate(
        cast[Ptr[uint8]](&_mst_out[0]), cast[uint64](prot_len),
        cast[Ptr[uint8]](&_mst_recov[0]), MACSEC_T_INNER_CAP,
        cast[Ptr[uint32]](&rpn))
    if rec_len < 0:
        _ms_emerg1("[macsec] FAIL: validate rc=%d\n", cast[uint64](rec_len))
        return 0
    if cast[uint64](rec_len) != inner_len:
        _ms_emerg2("[macsec] FAIL: recovered len %d != %d\n",
                   cast[uint64](rec_len), inner_len)
        ok = 0
    if rpn != 1:
        _ms_emerg1("[macsec] FAIL: recovered PN %d != 1\n", cast[uint64](rpn))
        ok = 0
    identical: int32 = 1
    i = 0
    while i < inner_len:
        if _mst_recov[i] != _mst_inner[i]:
            identical = 0
            i = inner_len
        else:
            i = i + 1
    if identical != 1:
        _ms_emerg0("[macsec] FAIL: recovered inner frame not byte-identical\n")
        ok = 0
    else:
        _ms_emerg0("[macsec] PASS roundtrip-byte-identical\n")

    # --- 4. Tamper a ciphertext byte -> ICV REJECT. ---
    saved: uint8 = _mst_out[ct_off + 3]
    _mst_out[ct_off + 3] = saved ^ 0xFF
    macsec_install_rx_sc(cast[Ptr[uint8]](&_mst_sci[0]), 1)   # reset replay floor
    bad: int64 = macsec_validate(
        cast[Ptr[uint8]](&_mst_out[0]), cast[uint64](prot_len),
        cast[Ptr[uint8]](&_mst_recov[0]), MACSEC_T_INNER_CAP,
        cast[Ptr[uint32]](&rpn))
    _mst_out[ct_off + 3] = saved                              # restore
    if bad != -5:
        _ms_emerg1("[macsec] FAIL: tampered ciphertext accepted rc=%d\n", cast[uint64](bad))
        ok = 0
    else:
        _ms_emerg0("[macsec] PASS reject-tampered-ciphertext\n")

    # --- 5. Tamper the ICV -> ICV REJECT. ---
    icv_off: uint64 = cast[uint64](prot_len) - MACSEC_ICV_LEN
    sicv: uint8 = _mst_out[icv_off]
    _mst_out[icv_off] = sicv ^ 0x80
    macsec_install_rx_sc(cast[Ptr[uint8]](&_mst_sci[0]), 1)
    badicv: int64 = macsec_validate(
        cast[Ptr[uint8]](&_mst_out[0]), cast[uint64](prot_len),
        cast[Ptr[uint8]](&_mst_recov[0]), MACSEC_T_INNER_CAP,
        cast[Ptr[uint32]](&rpn))
    _mst_out[icv_off] = sicv
    if badicv != -5:
        _ms_emerg1("[macsec] FAIL: tampered ICV accepted rc=%d\n", cast[uint64](badicv))
        ok = 0
    else:
        _ms_emerg0("[macsec] PASS reject-tampered-icv\n")

    # --- 6. Replay: re-submit PN=1 after a clean validation -> REJECT. ---
    # Reset the replay floor to 1, validate once (advances floor to 2), then
    # validate the SAME frame (PN=1) again — it must be replay-rejected.
    macsec_install_rx_sc(cast[Ptr[uint8]](&_mst_sci[0]), 1)
    first: int64 = macsec_validate(
        cast[Ptr[uint8]](&_mst_out[0]), cast[uint64](prot_len),
        cast[Ptr[uint8]](&_mst_recov[0]), MACSEC_T_INNER_CAP,
        cast[Ptr[uint32]](&rpn))
    if first < 0:
        _ms_emerg1("[macsec] FAIL: replay-setup validate rc=%d\n", cast[uint64](first))
        ok = 0
    replay: int64 = macsec_validate(
        cast[Ptr[uint8]](&_mst_out[0]), cast[uint64](prot_len),
        cast[Ptr[uint8]](&_mst_recov[0]), MACSEC_T_INNER_CAP,
        cast[Ptr[uint32]](&rpn))
    if replay != -4:
        _ms_emerg1("[macsec] FAIL: replayed PN accepted rc=%d\n", cast[uint64](replay))
        ok = 0
    else:
        _ms_emerg0("[macsec] PASS reject-replayed-pn\n")

    # --- 7. Wrong key: validate AN=0 frame as if it were AN=1's key. ---
    # Forge the AN bits in the SecTAG to 1 (so validate picks AN=1's SAK),
    # then re-validate — the ICV must fail because the bytes were sealed
    # under AN=0's key (and the AN is part of neither AAD-changing here, but
    # the SAK differs so GCM tag won't match). Restore afterwards.
    macsec_install_rx_sc(cast[Ptr[uint8]](&_mst_sci[0]), 1)
    stci: uint8 = _mst_out[12 + MACSEC_OFF_TCI]
    _mst_out[12 + MACSEC_OFF_TCI] = (stci & 0xFC) | 0x01   # clear AN bits, set AN=1
    wrongkey: int64 = macsec_validate(
        cast[Ptr[uint8]](&_mst_out[0]), cast[uint64](prot_len),
        cast[Ptr[uint8]](&_mst_recov[0]), MACSEC_T_INNER_CAP,
        cast[Ptr[uint32]](&rpn))
    _mst_out[12 + MACSEC_OFF_TCI] = stci
    if wrongkey != -5:
        _ms_emerg1("[macsec] FAIL: wrong-key frame accepted rc=%d\n", cast[uint64](wrongkey))
        ok = 0
    else:
        _ms_emerg0("[macsec] PASS reject-wrong-key\n")

    # --- 8. Second SA (AN=1, distinct key) round-trips independently. ---
    macsec_set_active_an(1)
    macsec_install_tx_sc(cast[Ptr[uint8]](&_mst_sci[0]), 100)   # fresh PN base
    macsec_install_rx_sc(cast[Ptr[uint8]](&_mst_sci[0]), 100)
    inner_len2: uint64 = _ms_build_inner(0x7E)
    prot_len2: int64 = macsec_protect_next(
        cast[Ptr[uint8]](&_mst_inner[0]), inner_len2,
        cast[Ptr[uint8]](&_mst_out[0]), MACSEC_T_OUT_CAP)
    if prot_len2 < 0:
        _ms_emerg1("[macsec] FAIL: protect(AN1) rc=%d\n", cast[uint64](prot_len2))
        return 0
    tci2: uint8 = _mst_out[12 + MACSEC_OFF_TCI]
    if (tci2 & MACSEC_AN_MASK) != 1:
        _ms_emerg1("[macsec] FAIL: AN2 %d != 1\n", cast[uint64](tci2 & MACSEC_AN_MASK))
        ok = 0
    pn2: uint32 = _ms_get32(cast[Ptr[uint8]](&_mst_out[0]), 12 + MACSEC_OFF_PN)
    if pn2 != 100:
        _ms_emerg1("[macsec] FAIL: AN1 wire PN %d != 100\n", cast[uint64](pn2))
        ok = 0
    rpn2: uint32 = 0
    rec_len2: int64 = macsec_validate(
        cast[Ptr[uint8]](&_mst_out[0]), cast[uint64](prot_len2),
        cast[Ptr[uint8]](&_mst_recov[0]), MACSEC_T_INNER_CAP,
        cast[Ptr[uint32]](&rpn2))
    if rec_len2 < 0:
        _ms_emerg1("[macsec] FAIL: validate(AN1) rc=%d\n", cast[uint64](rec_len2))
        return 0
    identical2: int32 = 1
    i = 0
    while i < inner_len2:
        if _mst_recov[i] != _mst_inner[i]:
            identical2 = 0
            i = inner_len2
        else:
            i = i + 1
    if identical2 != 1 or rpn2 != 100:
        _ms_emerg0("[macsec] FAIL: AN1 round-trip not byte-identical\n")
        ok = 0
    else:
        _ms_emerg0("[macsec] PASS roundtrip-an1-pn100\n")

    if ok == 1:
        _ms_emerg0("[macsec] PASS\n")
        return 1
    _ms_emerg0("[macsec] FAIL\n")
    return 0

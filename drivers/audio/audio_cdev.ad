# drivers/audio/audio_cdev.ad
#
# Plan-9-style /dev/audio + /dev/audioctl character devices over the
# native Intel HDA driver (drivers/audio/hda.ad).
#
#   WRITE /dev/audio     <- raw PCM bytes (s16le by default). Bytes are
#                           staged into the HDA stream DMA buffer at the
#                           file offset (so a chunked writer composes);
#                           playback starts when the writer closes (a
#                           write of 0 bytes or the explicit `start` ctl
#                           verb) — but to keep the model dead simple, a
#                           non-empty write that fills the buffer also
#                           auto-starts. Control is otherwise via the
#                           companion ctl file.
#
#   READ  /dev/audio     -> a one-line status snapshot:
#                           "rate <r> channels <c> bits <b> loaded <n>\n"
#                           (snapshot-once so `cat` terminates).
#
#   WRITE /dev/audioctl  <- text control verbs, one token-led line each:
#                           "rate 44100", "channels 2", "format s16le",
#                           "bits 16", "start", "stop", "reset".
#                           This is the Plan-9 control surface — a file
#                           you echo strings to, NOT a Linux ioctl ABI.
#
# THIS IS AN ADDITIVE CONSUMER of hda.ad's public API. It introduces no
# syscalls and no sockets.

from kernel.printk.printk import printk0, printk1
from drivers.audio.hda import (
    hda_is_initialized, hda_set_rate, hda_set_channels, hda_set_bits,
    hda_write_pcm, hda_start, hda_stop, hda_reset_buffer,
    hda_pcm_capacity, hda_pcm_loaded,
    hda_capture_is_ready, hda_capture_start, hda_capture_stop,
    hda_capture_read, hda_capture_avail, hda_capture_reset,
)
from drivers.audio.mixer import (
    hda_mix_set_master_pct, hda_mix_set_stream_pct,
    hda_mix_master_pct, hda_mix_stream_pct, hda_mix_max_streams,
    hda_mix_play,
)


# --- small text helpers (no libc) -----------------------------------

def _au_u64_to_dec(value: uint64, out: Ptr[uint8]) -> uint64:
    if value == 0:
        out[0] = 48
        return 1
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    written: uint64 = n
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    return written


def _au_tok_eq(buf: Ptr[uint8], count: uint64, word: Ptr[char]) -> int32:
    # 1 iff the first whitespace/NUL/newline-delimited token of `buf`
    # equals NUL-terminated `word`.
    i: uint64 = 0
    while True:
        wc: char = word[i]
        if wc == 0:
            if i >= count:
                return 1
            bc: uint8 = buf[i]
            if bc == 0 or bc == 10 or bc == 32 or bc == 9:
                return 1
            return 0
        if i >= count:
            return 0
        if buf[i] != cast[uint8](wc):
            return 0
        i = i + 1


def _au_parse_uint_after(buf: Ptr[uint8], count: uint64,
                         start: uint64) -> uint64:
    # Skip non-digits from `start`, then parse a decimal. Returns the
    # value (0 if no digits found).
    i: uint64 = start
    # skip the verb token + whitespace until first digit
    while i < count:
        c: uint8 = buf[i]
        if c >= 48 and c <= 57:
            break
        i = i + 1
    n: uint64 = 0
    while i < count:
        c2: uint8 = buf[i]
        if c2 < 48 or c2 > 57:
            break
        n = n * 10 + cast[uint64](c2 - 48)
        i = i + 1
    return n


def _au_parse_nth_uint(buf: Ptr[uint8], count: uint64,
                       which: uint64) -> uint64:
    # Parse the `which`-th (0-based) decimal number embedded in `buf`,
    # skipping the leading verb token and any non-digit separators. For
    # "stream 1 50" -> nth 0 = 1, nth 1 = 50.
    i: uint64 = 0
    found: uint64 = 0
    val: uint64 = 0
    while i < count:
        c: uint8 = buf[i]
        if c >= 48 and c <= 57:
            # parse this whole number
            n: uint64 = 0
            while i < count:
                c2: uint8 = buf[i]
                if c2 < 48 or c2 > 57:
                    break
                n = n * 10 + cast[uint64](c2 - 48)
                i = i + 1
            if found == which:
                val = n
                return val
            found = found + 1
        else:
            i = i + 1
    return val


# --- /dev/audio -----------------------------------------------------

def devaudio_read(off: uint64, buf: Ptr[uint8], count: uint64) -> int64:
    # Snapshot-once status line. namec gates off>0 -> EOF.
    if count == 0:
        return 0
    if hda_is_initialized() == 0:
        return -2                                # -ENOENT: no audio dev
    scratch: Array[96, uint8]
    p: uint64 = 0
    tag1: Ptr[uint8] = "loaded "
    j: uint64 = 0
    while tag1[j] != 0:
        scratch[p] = tag1[j]
        p = p + 1
        j = j + 1
    p = p + _au_u64_to_dec(hda_pcm_loaded(), &scratch[p])
    tag2: Ptr[uint8] = " cap "
    j = 0
    while tag2[j] != 0:
        scratch[p] = tag2[j]
        p = p + 1
        j = j + 1
    p = p + _au_u64_to_dec(hda_pcm_capacity(), &scratch[p])
    # mixer levels: " master <pct> streams <m0> <m1> ..."
    tag3: Ptr[uint8] = " master "
    j = 0
    while tag3[j] != 0:
        scratch[p] = tag3[j]
        p = p + 1
        j = j + 1
    p = p + _au_u64_to_dec(hda_mix_master_pct(), &scratch[p])
    tag4: Ptr[uint8] = " streams"
    j = 0
    while tag4[j] != 0:
        scratch[p] = tag4[j]
        p = p + 1
        j = j + 1
    ns: uint64 = hda_mix_max_streams()
    si: uint64 = 0
    while si < ns:
        scratch[p] = 32                          # space
        p = p + 1
        p = p + _au_u64_to_dec(hda_mix_stream_pct(cast[int32](si)),
                               &scratch[p])
        si = si + 1
    scratch[p] = 10
    p = p + 1
    if off >= p:
        return 0
    remaining: uint64 = p - off
    take: uint64 = count
    if take > remaining:
        take = remaining
    i: uint64 = 0
    while i < take:
        buf[i] = scratch[off + i]
        i = i + 1
    return cast[int64](take)


def devaudio_write(off: uint64, buf: Ptr[uint8], count: uint64) -> int64:
    # Stage raw PCM into the HDA DMA buffer at file offset `off`. A
    # zero-length write is the "flush/start" signal.
    if hda_is_initialized() == 0:
        return -2
    if count == 0:
        # EOF flush -> start playback of whatever's staged.
        hda_start()
        return 0
    return hda_write_pcm(buf, count, off)


# --- /dev/audioctl --------------------------------------------------

def devaudioctl_write(buf: Ptr[uint8], count: uint64) -> int64:
    # Decode one text control verb. Accept-and-ignore unknown verbs so a
    # stray writer doesn't wedge.
    if hda_is_initialized() == 0:
        return -2
    if _au_tok_eq(buf, count, "rate") != 0:
        hda_set_rate(cast[uint32](_au_parse_uint_after(buf, count, 0)))
        return cast[int64](count)
    if _au_tok_eq(buf, count, "channels") != 0:
        hda_set_channels(cast[uint32](_au_parse_uint_after(buf, count, 0)))
        return cast[int64](count)
    if _au_tok_eq(buf, count, "bits") != 0:
        hda_set_bits(cast[uint32](_au_parse_uint_after(buf, count, 0)))
        return cast[int64](count)
    if _au_tok_eq(buf, count, "format") != 0:
        # "format s16le" -> 16 bits. We only honour the bit-width hint;
        # everything is little-endian PCM.
        if _au_tok_eq(&buf[7], count - 7, "s16le") != 0:
            hda_set_bits(16)
        elif _au_tok_eq(&buf[7], count - 7, "u8") != 0:
            hda_set_bits(8)
        elif _au_tok_eq(&buf[7], count - 7, "s24le") != 0:
            hda_set_bits(24)
        elif _au_tok_eq(&buf[7], count - 7, "s32le") != 0:
            hda_set_bits(32)
        return cast[int64](count)
    if _au_tok_eq(buf, count, "start") != 0:
        hda_start()
        return cast[int64](count)
    if _au_tok_eq(buf, count, "stop") != 0:
        hda_stop()
        return cast[int64](count)
    if _au_tok_eq(buf, count, "reset") != 0:
        hda_reset_buffer()
        return cast[int64](count)
    # --- software mixer control surface (Plan-9 ctl verbs) ----------
    # "master <pct>"     : set master volume (0..100 %).
    # "stream <id> <pct>": set per-stream volume (0..100 %).
    # "mixplay"          : render the active mixer streams + start DMA.
    if _au_tok_eq(buf, count, "master") != 0:
        hda_mix_set_master_pct(_au_parse_uint_after(buf, count, 0))
        return cast[int64](count)
    if _au_tok_eq(buf, count, "stream") != 0:
        sid: uint64 = _au_parse_nth_uint(buf, count, 0)
        pct: uint64 = _au_parse_nth_uint(buf, count, 1)
        hda_mix_set_stream_pct(cast[int32](sid), pct)
        return cast[int64](count)
    if _au_tok_eq(buf, count, "mixplay") != 0:
        hda_mix_play()
        return cast[int64](count)
    return cast[int64](count)


def devaudioctl_read(off: uint64, buf: Ptr[uint8], count: uint64) -> int64:
    # ctl is write-only; reads return EOF.
    return 0


# --- /dev/audioin (capture / record) --------------------------------
#
# READ  /dev/audioin -> raw recorded PCM bytes pulled from the HDA capture
#                       ring (the input-stream DMA engine fills it). This
#                       is a STREAM device, not a snapshot file: the read
#                       advances an internal ring read pointer rather than
#                       being addressed by the file offset, so successive
#                       reads return successive captured PCM. An empty ring
#                       returns 0 (non-blocking, EOF-style) so a polled
#                       reader spins without wedging.
#
# WRITE /dev/audioin -> not a sink; writes are rejected.
#
# Format/rate are shared with playback and set through /dev/audioctl
# (rate/channels/bits/format) — the capture stream uses the same format
# encoder, so configuring one configures both.

def devaudioin_read(off: uint64, buf: Ptr[uint8], count: uint64) -> int64:
    # Stream read: ignore `off`, serve from the capture ring's read
    # pointer. The backend advances rpos and handles wrap/overrun.
    if hda_capture_is_ready() == 0:
        return -2                                # -ENOENT: no capture dev
    if count == 0:
        return 0
    return hda_capture_read(buf, count)


def devaudioin_write(off: uint64, buf: Ptr[uint8], count: uint64) -> int64:
    # Capture device is read-only.
    return -1

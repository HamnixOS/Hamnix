# drivers/audio/audio_selftest.ad
#
# Boot-gated self-test for the native Intel HDA audio path. Gated on
# /etc/audio-test (planted by build_initramfs.py when ENABLE_AUDIO_TEST=1,
# via scripts/test_hda_audio.sh). It proves REAL sound output, not a
# probe:
#
#   1. Synthesize a loud square-wave tone (s16le, 2ch, 48 kHz) in a
#      kernel buffer. A square wave is trivially non-silent and its
#      samples alternate between +A and -A, so the captured WAV is
#      unmistakably non-zero.
#   2. Open /dev/audioctl and /dev/audio through the real Plan-9 namec
#      path (NOT direct backend calls), set rate/channels/format via
#      text control verbs, and stream the PCM bytes to /dev/audio.
#   3. Start the stream (via the `start` ctl verb), let the HDA stream
#      DMA engine run, and poll the controller's link-position-in-buffer
#      counter. A non-zero, advancing LPIB proves the DMA engine is
#      actually consuming the buffer and pushing samples to the codec —
#      which QEMU's wav audiodev captures to a host file.
#
# The host-side scripts/test_hda_audio.sh then parses the captured WAV
# and FAILS if it is all-zero/silent.

from kernel.printk.printk import printk0, printk1, printk2
from drivers.audio.hda import (
    hda_is_initialized, hda_link_position, hda_pcm_loaded,
)
from drivers.audio.mixer import (
    hda_mix_open, hda_mix_close, hda_mix_write, hda_mix_render,
    hda_mix_out_sample, hda_mix_master_pct, hda_mix_stream_pct,
)
from sys.src.port9.port.namec import (
    namec, namec_write, namec_close, namec_read,
)
# F10-5 #460: route the selftest opens through the SAME per-Pgrp
# namespace walk userland uses (resolve_path + namec) rather than
# bypassing resolve_path with a raw `#c/audio*` server-letter call. The
# kernel selftest now exercises the F10-1 substrate end-to-end —
# resolve_path rewrites `/dev/audio*` via the boot Pgrp's
# `bind '#c' /dev` to the `#c/audio*` form, the dispatcher routes it
# to SERVER_AUDIO (F10-5), and devaudio_perm_check (in audio_cdev.ad)
# gates it. A Pgrp without `bind '#c' /dev` ENOENTs here, by design.
from fs.vfs import resolve_path
# #279: the master-volume marker is read straight from the initramfs (the
# boot Pgrp only binds `#c` -> /dev, so /etc is NOT namec-resolvable at
# boot:37; main.ad reads /etc/audio-test the same direct way).
from fs.cpio import (
    initramfs_entry_count, initramfs_entry_name,
    initramfs_entry_data, initramfs_entry_size,
)
# On-device MP3 playback self-test: the SAME pure decoder the native player
# (user/hamaudioscene.ad) routes .mp3 files through. Decodes the shipped
# fixture to PCM in-kernel, then streams that PCM to /dev/audio exactly like
# the square-wave tone — proving the decode->HDA sink path, not just the
# host-golden decoder correctness.
from lib.mp3decode import (
    mp3decode_parse, mp3decode_ok, mp3decode_rate, mp3decode_channels,
    mp3decode_data_len, mp3decode_pcm_ptr, mp3decode_nframes, mp3decode_peak,
)


# Tone parameters. 48 kHz, 2 channels, 16-bit. We emit a ~1 kHz square
# wave (period = 48 samples) for ~0.5 s = 24000 frames. At 4 bytes/frame
# (2ch * 2 bytes) that's 96000 bytes, well under the 256 KiB DMA buffer.
AUD_RATE:        uint64 = 48000
AUD_CHANNELS:    uint64 = 2
AUD_FRAMES:      uint64 = 24000
AUD_HALF_PERIOD: uint64 = 24        # 48-sample period -> ~1 kHz
AUD_AMPLITUDE:   int32  = 12000     # loud, but inside int16 range


def _spin(n: uint64):
    i: uint64 = 0
    while i < n:
        i = i + 1


# F10-5 #460: open `path` (a /dev/<leaf> conventional spelling) through
# the F10-1 substrate — resolve_path through the current Pgrp's mount
# table, then namec on the localized name. Returns the chan id on
# success, a negative namec error otherwise.
def _au_open_resolved(path: Ptr[char], mode: int32) -> int32:
    resolved: Array[256, uint8]
    rrc: int32 = resolve_path(path, &resolved[0], 256)
    if rrc != 0:
        return rrc
    return namec(cast[Ptr[char]](&resolved[0]), mode)


# --- software mixer self-test --------------------------------------
#
# Opens 2 concurrent mixer streams via the real /dev/audioctl control
# surface (mixer verbs) + the mixer API, writes KNOWN s16le sample
# patterns to each, sets distinct per-stream + master volumes, renders the
# mix into the hardware-bound buffer, and asserts EVERY mixed sample equals
# the expected saturating-summed, gain-scaled result computed independently
# here. This proves the mix loop is real fixed-point DSP, not a stub.

MIX_TEST_SAMPLES: uint64 = 64              # s16 samples per stream to mix

# Reference per-stream sample patterns (module-scope; computed here, fed to
# the mixer, then used to re-derive the expected mix for the assertion).
mixt_a: Array[64, int32]                   # stream 0 reference samples
mixt_b: Array[64, int32]                   # stream 1 reference samples
mixt_bytes_a: Array[128, uint8]            # 64 samples * 2 bytes (s16le)
mixt_bytes_b: Array[128, uint8]


def _mixt_clamp_s16(v: int32) -> int32:
    if v > 32767:
        return 32767
    if v < -32768:
        return -32768
    return v


def _mixt_apply_gain(sample: int32, gain_pct: uint64) -> int32:
    # Q8 gain reconstructed from percent the SAME way the mixer does it:
    # gain = pct*256/100, then (sample*gain)/256. Independent recompute.
    gain: int32 = cast[int32]((gain_pct * 256) / 100)
    return cast[int32]((cast[int64](sample) * cast[int64](gain)) / 256)


def _mixt_sat_add(acc: int32, add: int32) -> int32:
    s: int64 = cast[int64](acc) + cast[int64](add)
    if s > 32767:
        return 32767
    if s < -32768:
        return -32768
    return cast[int32](s)


def _mixt_encode(samples: Ptr[int32], out: Ptr[uint8], n: uint64):
    # s16le encode the reference int32 samples into a byte buffer.
    i: uint64 = 0
    while i < n:
        enc: uint32 = cast[uint32](samples[i]) & 0xFFFF
        out[i * 2] = cast[uint8](enc & 0xFF)
        out[i * 2 + 1] = cast[uint8]((enc >> 8) & 0xFF)
        i = i + 1


def audio_mixer_selftest() -> int32:
    # Returns 1 on PASS, 0 on FAIL.
    if hda_is_initialized() == 0:
        printk0("[audio-mix] FAIL: HDA controller not initialized\n")
        return 0

    # --- build two known patterns -----------------------------------
    # Both streams carry LARGE same-sign amplitudes at many indices so
    # that, after the per-stream gains (80% / 40%) are applied, their sum
    # exceeds the s16 range and the SATURATING add must clamp — proving the
    # saturation clamps instead of wrapping. Other indices stay small so
    # the non-saturating mix path is exercised too, and the sign flips so
    # both the +32767 ceiling and the -32768 floor are hit.
    i: uint64 = 0
    while i < MIX_TEST_SAMPLES:
        # Stream A: full-scale square wave (±32000).
        a: int32 = 32000
        if (i % 2) == 1:
            a = -32000
        # one-quarter of the samples drop A to a small ramp (non-clip mix).
        if (i % 4) == 0:
            a = cast[int32](i) * 50              # small, won't saturate
        mixt_a[i] = a
        # Stream B: loud constant of the SAME sign pattern as A's square so
        # the gain-scaled sum saturates at the matching rail.
        b: int32 = 30000
        if (i % 2) == 1:
            b = -30000
        mixt_b[i] = b
        i = i + 1
    _mixt_encode(&mixt_a[0], &mixt_bytes_a[0], MIX_TEST_SAMPLES)
    _mixt_encode(&mixt_b[0], &mixt_bytes_b[0], MIX_TEST_SAMPLES)

    # --- open two concurrent mixer streams --------------------------
    id0: int32 = hda_mix_open()
    id1: int32 = hda_mix_open()
    if id0 < 0 or id1 < 0:
        printk2("[audio-mix] FAIL: open streams id0=%d id1=%d\n",
                cast[uint64](cast[int64](id0)),
                cast[uint64](cast[int64](id1)))
        return 0
    printk2("[audio-mix] opened 2 streams (id0=%d id1=%d)\n",
            cast[uint64](cast[int64](id0)), cast[uint64](cast[int64](id1)))

    # --- set distinct volumes via the real /dev/audioctl ctl surface --
    # master 75%, stream id0 = 80%, stream id1 = 40%.
    # F10-5 #460: route through resolve_path + namec like every other
    # caller, so the F10-1 substrate's per-Pgrp namespace walk + the
    # F10-5 SERVER_AUDIO perm body (devaudio_perm_check) both fire on
    # the SAME path userland exercises — no `#c/audio*` server-letter
    # shortcut bypassing the substrate.
    pct_master: uint64 = 75
    pct0: uint64 = 80
    pct1: uint64 = 40
    ctl_cid: int32 = _au_open_resolved("/dev/audioctl", 1)   # OWRITE
    if ctl_cid < 0:
        printk1("[audio-mix] FAIL: open /dev/audioctl rc=%d\n",
                cast[uint64](cast[int64](ctl_cid)))
        hda_mix_close(id0)
        hda_mix_close(id1)
        return 0
    v_master: Ptr[uint8] = "master 75\n"
    namec_write(ctl_cid, 0, v_master, 10)
    # "stream 0 80\n" / "stream 1 40\n" — build the exact id in the string.
    s0: Array[16, uint8]
    s0[0] = 115                    # 's'
    s0[1] = 116                    # 't'
    s0[2] = 114                    # 'r'
    s0[3] = 101                    # 'e'
    s0[4] = 97                     # 'a'
    s0[5] = 109                    # 'm'
    s0[6] = 32                     # ' '
    s0[7] = cast[uint8](48 + cast[uint64](id0))
    s0[8] = 32                     # ' '
    s0[9] = 56                     # '8'
    s0[10] = 48                    # '0'
    s0[11] = 10                    # '\n'
    namec_write(ctl_cid, 0, &s0[0], 12)
    s1: Array[16, uint8]
    s1[0] = 115
    s1[1] = 116
    s1[2] = 114
    s1[3] = 101
    s1[4] = 97
    s1[5] = 109
    s1[6] = 32
    s1[7] = cast[uint8](48 + cast[uint64](id1))
    s1[8] = 32
    s1[9] = 52                     # '4'
    s1[10] = 48                    # '0'
    s1[11] = 10
    namec_write(ctl_cid, 0, &s1[0], 12)

    # verify the ctl writes landed in the mixer state
    if hda_mix_master_pct() != pct_master:
        printk1("[audio-mix] FAIL: master pct=%d (want 75)\n",
                hda_mix_master_pct())
        namec_close(ctl_cid)
        hda_mix_close(id0)
        hda_mix_close(id1)
        return 0
    if hda_mix_stream_pct(id0) != pct0 or hda_mix_stream_pct(id1) != pct1:
        printk2("[audio-mix] FAIL: stream pct id0=%d id1=%d\n",
                hda_mix_stream_pct(id0), hda_mix_stream_pct(id1))
        namec_close(ctl_cid)
        hda_mix_close(id0)
        hda_mix_close(id1)
        return 0
    printk0("[audio-mix] volumes set via /dev/audioctl (master 75, s0 80, s1 40)\n")

    # --- stage the known PCM into each stream -----------------------
    wn0: int64 = hda_mix_write(id0, &mixt_bytes_a[0], MIX_TEST_SAMPLES * 2, 0)
    wn1: int64 = hda_mix_write(id1, &mixt_bytes_b[0], MIX_TEST_SAMPLES * 2, 0)
    if wn0 != cast[int64](MIX_TEST_SAMPLES * 2) \
            or wn1 != cast[int64](MIX_TEST_SAMPLES * 2):
        printk2("[audio-mix] FAIL: stage write wn0=%d wn1=%d\n",
                cast[uint64](wn0), cast[uint64](wn1))
        namec_close(ctl_cid)
        hda_mix_close(id0)
        hda_mix_close(id1)
        return 0

    # --- render the mix ---------------------------------------------
    rn: int64 = hda_mix_render()
    if rn != cast[int64](MIX_TEST_SAMPLES * 2):
        printk1("[audio-mix] FAIL: render returned %d bytes\n",
                cast[uint64](rn))
        namec_close(ctl_cid)
        hda_mix_close(id0)
        hda_mix_close(id1)
        return 0

    # --- verify EVERY mixed sample against an independent recompute --
    mismatches: uint64 = 0
    clips: uint64 = 0
    k: uint64 = 0
    while k < MIX_TEST_SAMPLES:
        # independent reference: per-stream gain, saturating sum, master.
        ga: int32 = _mixt_apply_gain(mixt_a[k], pct0)
        gb: int32 = _mixt_apply_gain(mixt_b[k], pct1)
        # raw (unclamped) sum vs saturating sum — a difference means the
        # saturating add actually clamped this sample.
        raw_sum: int64 = cast[int64](ga) + cast[int64](gb)
        acc: int32 = _mixt_sat_add(0, ga)
        acc = _mixt_sat_add(acc, gb)
        if raw_sum != cast[int64](acc):
            clips = clips + 1
        expect: int32 = _mixt_apply_gain(acc, pct_master)
        expect = _mixt_clamp_s16(expect)
        got: int32 = hda_mix_out_sample(k)
        if got != expect:
            if mismatches < 4:
                printk2("[audio-mix] sample %d mismatch got=%d\n",
                        k, cast[uint64](cast[int64](got)))
            mismatches = mismatches + 1
        k = k + 1

    namec_close(ctl_cid)
    hda_mix_close(id0)
    hda_mix_close(id1)

    if mismatches != 0:
        printk1("[audio-mix] FAIL: %d mixed samples mismatched\n", mismatches)
        return 0
    if clips == 0:
        # The B pattern at these gains should drive at least some samples
        # into saturation; if nothing clipped the saturating path went
        # untested, which means the test is not proving what it claims.
        printk0("[audio-mix] FAIL: no samples saturated (sat-add untested)\n")
        return 0
    printk2("[audio-mix] verified %d mixed samples (%d saturated) byte-exact\n",
            MIX_TEST_SAMPLES, clips)
    printk0("[audio-mix] PASS\n")
    return 1


# #279: apply the optional /etc/audio-master marker to the mixer master
# level BEFORE the tone streams, so the WAV-capture gate can prove the DE
# master volume actually changes the captured output. The marker holds a
# decimal percent (0..100); if it also contains the letter 'm' (e.g.
# "mute" or "0 mute") the master mute latch is set too. Absent marker ->
# no writes -> master stays at unity, leaving the plain audio gate
# unchanged. Writes go through the SAME /dev/audioctl ctl path userland
# uses (the DE writes the identical verbs).
def _au_marker_match(nm: Ptr[char]) -> int32:
    # 1 iff `nm` == "/etc/audio-master" (17 chars incl NUL).
    tgt: Ptr[uint8] = "/etc/audio-master"
    j: uint64 = 0
    while j < 18:
        if cast[uint8](nm[j]) != tgt[j]:
            return 0
        if tgt[j] == 0:
            return 1
        j = j + 1
    return 1


def _au_apply_master_marker(ctl_cid: int32):
    # Scan the initramfs directly for /etc/audio-master (namec can't reach
    # /etc at boot:37 — only `#c`/dev is bound). Content: a decimal percent,
    # optionally containing "mute".
    cnt: uint64 = initramfs_entry_count()
    idx: uint64 = 0
    found: int32 = 0
    data: Ptr[uint8] = cast[Ptr[uint8]](0)
    dsz: uint64 = 0
    while idx < cnt:
        if _au_marker_match(initramfs_entry_name(idx)) != 0:
            data = initramfs_entry_data(idx)
            dsz = initramfs_entry_size(idx)
            found = 1
            idx = cnt
        else:
            idx = idx + 1
    if found == 0:
        printk0("[audio] no /etc/audio-master marker (master=unity)\n")
        return
    n: uint64 = dsz
    if n > 31:
        n = 31
    # parse leading decimal percent
    pct: int32 = 0
    i: uint64 = 0
    have_digit: int32 = 0
    while i < n and data[i] >= 48 and data[i] <= 57:
        pct = pct * 10 + cast[int32](data[i]) - 48
        have_digit = 1
        i = i + 1
    # scan for a 'm' anywhere -> mute request
    muted: int32 = 0
    k: uint64 = 0
    while k < n:
        if data[k] == 109:                              # 'm'
            muted = 1
            break
        k = k + 1
    if have_digit != 0:
        line: Array[24, uint8]
        p: uint64 = 0
        pre: Ptr[uint8] = "master "
        j: uint64 = 0
        while pre[j] != 0:
            line[p] = pre[j]
            p = p + 1
            j = j + 1
        # decimal of pct
        if pct == 0:
            line[p] = 48
            p = p + 1
        else:
            digs: Array[8, uint8]
            dn: uint64 = 0
            vv: int32 = pct
            while vv != 0:
                digs[dn] = cast[uint8](vv % 10) + 48
                vv = vv / 10
                dn = dn + 1
            while dn > 0:
                dn = dn - 1
                line[p] = digs[dn]
                p = p + 1
        line[p] = 10
        p = p + 1
        namec_write(ctl_cid, 0, &line[0], p)
    if muted != 0:
        v_mute: Ptr[uint8] = "mute\n"
        namec_write(ctl_cid, 0, v_mute, 5)
    printk2("[audio] master marker applied: pct=%d mute=%d\n",
            cast[uint64](cast[int64](pct)), cast[uint64](cast[int64](muted)))


def audio_selftest() -> int32:
    # Returns 1 on PASS, 0 on FAIL.
    if hda_is_initialized() == 0:
        printk0("[audio] FAIL: HDA controller not initialized\n")
        return 0

    # --- open the control + data cdevs via the real Plan-9 path -----
    # mode 1 == OWRITE. F10-5 #460: route /dev/audio* through the same
    # resolve_path + namec pipeline userland uses. The boot Pgrp has
    # `bind '#c' /dev` so /dev/audioctl rewrites to `#c/audioctl` and
    # lands at the DEV_AUDIOCTL chan; the F10-5 SERVER_AUDIO arm in
    # chan_permission_check fires on the way through (world r/w
    # admitted by devaudio_perm_check).
    ctl_cid: int32 = _au_open_resolved("/dev/audioctl", 1)
    if ctl_cid < 0:
        printk1("[audio] FAIL: open /dev/audioctl rc=%d\n",
                cast[uint64](cast[int64](ctl_cid)))
        return 0
    aud_cid: int32 = _au_open_resolved("/dev/audio", 1)
    if aud_cid < 0:
        printk1("[audio] FAIL: open /dev/audio rc=%d\n",
                cast[uint64](cast[int64](aud_cid)))
        namec_close(ctl_cid)
        return 0

    # --- configure via text control verbs ---------------------------
    v_rate: Ptr[uint8] = "rate 48000\n"
    namec_write(ctl_cid, 0, v_rate, 11)
    v_ch: Ptr[uint8] = "channels 2\n"
    namec_write(ctl_cid, 0, v_ch, 11)
    v_fmt: Ptr[uint8] = "format s16le\n"
    namec_write(ctl_cid, 0, v_fmt, 13)
    printk0("[audio] configured rate=48000 channels=2 format=s16le\n")

    # #279: apply the optional master-volume/mute marker so the WAV-capture
    # gate can prove the DE master level scales the DIRECT /dev/audio path.
    _au_apply_master_marker(ctl_cid)

    # --- synthesize + stream the square-wave tone -------------------
    # We write the PCM directly to /dev/audio at increasing offsets so
    # the offset-addressed write path composes (mirrors a chunked
    # writer). Build small chunks on the stack and write each.
    chunk: Array[1024, uint8]      # 256 frames per chunk (4 bytes/frame)
    frames_per_chunk: uint64 = 256
    off: uint64 = 0
    frame: uint64 = 0
    phase: uint64 = 0
    while frame < AUD_FRAMES:
        # fill one chunk
        ci: uint64 = 0
        f_in_chunk: uint64 = 0
        while f_in_chunk < frames_per_chunk and frame < AUD_FRAMES:
            # Square wave: +A for the first half period, -A for the rest.
            sample: int32 = AUD_AMPLITUDE
            if phase >= AUD_HALF_PERIOD:
                sample = -AUD_AMPLITUDE
            phase = phase + 1
            if phase >= (AUD_HALF_PERIOD * 2):
                phase = 0
            s16: uint32 = cast[uint32](sample) & 0xFFFF
            lo: uint8 = cast[uint8](s16 & 0xFF)
            hi: uint8 = cast[uint8]((s16 >> 8) & 0xFF)
            # left channel
            chunk[ci] = lo
            chunk[ci + 1] = hi
            # right channel (same)
            chunk[ci + 2] = lo
            chunk[ci + 3] = hi
            ci = ci + 4
            f_in_chunk = f_in_chunk + 1
            frame = frame + 1
        wn: int64 = namec_write(aud_cid, off, &chunk[0], ci)
        if wn < 0:
            printk1("[audio] FAIL: /dev/audio write rc=%d\n",
                    cast[uint64](wn))
            namec_close(aud_cid)
            namec_close(ctl_cid)
            return 0
        off = off + cast[uint64](wn)

    printk1("[audio] streamed %d PCM bytes to /dev/audio\n", off)
    if hda_pcm_loaded() == 0:
        printk0("[audio] FAIL: no PCM staged in DMA buffer\n")
        namec_close(aud_cid)
        namec_close(ctl_cid)
        return 0

    # --- start playback via the ctl verb ----------------------------
    v_start: Ptr[uint8] = "start\n"
    namec_write(ctl_cid, 0, v_start, 6)
    printk0("[audio] stream started — polling DMA link position\n")

    # --- prove DMA actually consumed the buffer ---------------------
    # Poll LPIB; it advances as the stream DMA engine reads the buffer.
    # A non-zero LPIB means the controller really pulled samples toward
    # the codec (which the QEMU wav backend captures). Give it some time.
    max_lpib: uint32 = 0
    poll: uint64 = 0
    while poll < 200:
        lp: uint32 = hda_link_position()
        if lp > max_lpib:
            max_lpib = lp
        _spin(2000000)
        poll = poll + 1

    printk1("[audio] max LPIB observed = %d bytes\n", cast[uint64](max_lpib))

    namec_close(aud_cid)
    namec_close(ctl_cid)

    if max_lpib > 0:
        printk0("[audio] DMA engine consumed the buffer (LPIB advanced)\n")
    else:
        # Even if LPIB didn't tick within our poll window (some QEMU builds
        # report LPIB lazily), the wav backend still captured whatever DMA
        # delivered; the host-side WAV non-silence check is the ground
        # truth. Log it distinctly but don't fail on it.
        printk0("[audio] LPIB did not advance in poll window (host WAV is ground truth)\n")

    # --- software mixer self-test -----------------------------------
    # Multi-stream mixing + per-stream/master volume, verified byte-exact
    # against an independent recompute. This runs under the SAME audio-test
    # gate (no new boot marker needed).
    mix_rc: int32 = audio_mixer_selftest()
    if mix_rc != 1:
        printk0("[audio] FAIL: software mixer self-test failed\n")
        return 0
    return 1


# --- on-device MP3 playback self-test -------------------------------------
#
# Gated on /etc/mp3-test (boot:37.mp3 in init/main.ad). Proves the WHOLE
# on-device .mp3 playback path the daily-driver ask needs, end-to-end:
#
#   1. Read the initramfs-staged /usr/share/sounds/test.mp3 bytes (the same
#      fixture the DE audio player opens; namec can't reach /usr at boot:37,
#      so we pull it straight from the cpio like the master-volume marker).
#   2. Decode it with lib/mp3decode — the SAME pure MPEG-1 Layer III decoder
#      user/hamaudioscene.ad routes .mp3 through. Assert the extracted format
#      (44100 Hz, mono) and that the decoded PCM is genuinely non-silent
#      (peak well above zero) — a stub emitting silence would fail here.
#   3. Set rate/channels/format via /dev/audioctl and stream the DECODED PCM
#      to /dev/audio through the real Plan-9 namec path + HDA stream DMA —
#      byte-for-byte the sink the square-wave tone drives. QEMU's wav
#      audiodev captures whatever DMA delivered; scripts/test_hda_mp3.sh
#      then FAILS if that captured WAV is silent.
#
# Returns 1 on PASS, 0 on FAIL.

MP3_PATH_LEN: uint64 = 27       # "/usr/share/sounds/test.mp3" + NUL


def _mp3_path_match(nm: Ptr[char]) -> int32:
    # 1 iff `nm` == "/usr/share/sounds/test.mp3".
    tgt: Ptr[uint8] = "/usr/share/sounds/test.mp3"
    j: uint64 = 0
    while j < MP3_PATH_LEN:
        if cast[uint8](nm[j]) != tgt[j]:
            return 0
        if tgt[j] == 0:
            return 1
        j = j + 1
    return 1


def audio_mp3_selftest() -> int32:
    if hda_is_initialized() == 0:
        printk0("[audio-mp3] FAIL: HDA controller not initialized\n")
        return 0

    # --- locate the fixture in the initramfs ------------------------
    cnt: uint64 = initramfs_entry_count()
    idx: uint64 = 0
    found: int32 = 0
    data: Ptr[uint8] = cast[Ptr[uint8]](0)
    dsz: uint64 = 0
    while idx < cnt:
        if _mp3_path_match(initramfs_entry_name(idx)) != 0:
            data = initramfs_entry_data(idx)
            dsz = initramfs_entry_size(idx)
            found = 1
            idx = cnt
        else:
            idx = idx + 1
    if found == 0:
        printk0("[audio-mp3] FAIL: /usr/share/sounds/test.mp3 not in initramfs\n")
        return 0
    printk1("[audio-mp3] fixture found: %d mp3 bytes\n", dsz)

    # --- decode with the SAME lib/mp3decode the player ships --------
    dok: int32 = mp3decode_parse(data, dsz)
    if dok == 0 or mp3decode_ok() == 0:
        printk0("[audio-mp3] FAIL: mp3decode_parse rejected the bitstream\n")
        return 0
    rate: uint32 = mp3decode_rate()
    ch: uint32 = mp3decode_channels()
    dlen: uint64 = mp3decode_data_len()
    printk2("[audio-mp3] decoded: rate=%d channels=%d\n",
            cast[uint64](rate), cast[uint64](ch))
    printk2("[audio-mp3] decoded: frames=%d pcm_bytes=%d\n",
            mp3decode_nframes(), dlen)
    if rate != 44100:
        printk1("[audio-mp3] FAIL: unexpected rate %d (want 44100)\n",
                cast[uint64](rate))
        return 0
    if ch != 1:
        printk1("[audio-mp3] FAIL: unexpected channel count %d (want 1)\n",
                cast[uint64](ch))
        return 0
    if dlen == 0:
        printk0("[audio-mp3] FAIL: decoder produced 0 PCM bytes\n")
        return 0

    # Decoded PCM must be genuinely non-silent (kernel-side proof, before we
    # even touch the sink — so a silent capture can't be blamed on decode).
    dpeak: uint32 = mp3decode_peak(0, dlen)
    printk1("[audio-mp3] decoded PCM peak |sample| = %d\n",
            cast[uint64](dpeak))
    if dpeak < 1000:
        printk0("[audio-mp3] FAIL: decoded PCM is silent/near-zero\n")
        return 0

    # --- open ctl + data cdevs via the real Plan-9 path -------------
    ctl_cid: int32 = _au_open_resolved("/dev/audioctl", 1)   # OWRITE
    if ctl_cid < 0:
        printk1("[audio-mp3] FAIL: open /dev/audioctl rc=%d\n",
                cast[uint64](cast[int64](ctl_cid)))
        return 0
    aud_cid: int32 = _au_open_resolved("/dev/audio", 1)
    if aud_cid < 0:
        printk1("[audio-mp3] FAIL: open /dev/audio rc=%d\n",
                cast[uint64](cast[int64](aud_cid)))
        namec_close(ctl_cid)
        return 0

    # --- configure the sink for the decoded format ------------------
    v_rate: Ptr[uint8] = "rate 44100\n"
    namec_write(ctl_cid, 0, v_rate, 11)
    v_ch: Ptr[uint8] = "channels 1\n"
    namec_write(ctl_cid, 0, v_ch, 11)
    v_fmt: Ptr[uint8] = "format s16le\n"
    namec_write(ctl_cid, 0, v_fmt, 13)
    printk0("[audio-mp3] configured rate=44100 channels=1 format=s16le\n")

    # --- stream the decoded PCM to /dev/audio in chunks -------------
    # Same offset-addressed, chunked write shape the player and the tone
    # selftest use; the source is the decoder's own PCM buffer.
    pcm: Ptr[uint8] = mp3decode_pcm_ptr()
    off: uint64 = 0
    while off < dlen:
        chunk: uint64 = dlen - off
        if chunk > 4096:
            chunk = 4096
        wn: int64 = namec_write(aud_cid, off, cast[Ptr[uint8]](pcm) + off, chunk)
        if wn < 0:
            printk1("[audio-mp3] FAIL: /dev/audio write rc=%d\n",
                    cast[uint64](wn))
            namec_close(aud_cid)
            namec_close(ctl_cid)
            return 0
        if wn == 0:
            # sink is full (DMA buffer cap) — stop; we've staged enough
            # to prove the path with non-silent audio.
            off = dlen
        else:
            off = off + cast[uint64](wn)

    printk1("[audio-mp3] streamed %d decoded PCM bytes to /dev/audio\n", off)
    if hda_pcm_loaded() == 0:
        printk0("[audio-mp3] FAIL: no PCM staged in DMA buffer\n")
        namec_close(aud_cid)
        namec_close(ctl_cid)
        return 0

    # --- start playback + prove DMA consumed the buffer -------------
    v_start: Ptr[uint8] = "start\n"
    namec_write(ctl_cid, 0, v_start, 6)
    printk0("[audio-mp3] stream started — polling DMA link position\n")
    max_lpib: uint32 = 0
    poll: uint64 = 0
    while poll < 200:
        lp: uint32 = hda_link_position()
        if lp > max_lpib:
            max_lpib = lp
        _spin(2000000)
        poll = poll + 1
    printk1("[audio-mp3] max LPIB observed = %d bytes\n", cast[uint64](max_lpib))

    namec_close(aud_cid)
    namec_close(ctl_cid)

    if max_lpib > 0:
        printk0("[audio-mp3] DMA engine consumed the buffer (LPIB advanced)\n")
    else:
        printk0("[audio-mp3] LPIB did not advance in poll window (host WAV is ground truth)\n")
    return 1

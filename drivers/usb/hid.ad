# drivers/usb/hid.ad
#
# USB HID boot-protocol keyboard class driver. Takes 8-byte boot
# reports off the wire (xhci.ad calls hid_kbd_report() with each
# report it polled from the interrupt-in endpoint) and converts
# them to ASCII bytes that land in the existing software keyboard
# FIFO (drivers/input/atkbd.ad::kbd_rx_push). hamsh's read_line(),
# devcons.ad's kbd_rx_pop(), and fs/vfs.ad's stdin handler don't
# need to care which controller actually delivered the keystroke —
# the FIFO is the unified entry point.
#
# Boot-keyboard report format (HID 1.11 §B.1, "Protocol 1 Keyboard"):
#
#   byte 0   modifier bits:
#              bit 0  Left Ctrl
#              bit 1  Left Shift
#              bit 2  Left Alt
#              bit 3  Left GUI (Win/Cmd)
#              bit 4  Right Ctrl
#              bit 5  Right Shift
#              bit 6  Right Alt
#              bit 7  Right GUI
#   byte 1   reserved (used to be OEM)
#   bytes 2..7   array of up to 6 key usage codes (0 = unused slot,
#                0x01 = ErrorRollOver, 0x02 = ErrorPOSTFail,
#                0x03 = ErrorUndefined, 0x04+ = actual keys)
#
# Translation strategy:
#   1. Diff this report against the previous one. Any usage code in
#      the new report that was NOT in the previous report is a
#      "make" event (key down).
#   2. Modifier bits are tracked as state — Shift/Ctrl/Alt mirror
#      their PS/2 atkbd counterparts so the same Caps/Ctrl-fold/case
#      transforms apply.
#   3. Usage code -> ASCII lookup uses a 128-byte table (the boot
#      keyboard codes 0x04..0x73 cover all printable keys; we size
#      to 128 so non-printable extras don't index out of bounds).
#   4. The resulting ASCII byte is pushed into kbd_rx_push, exactly
#      the same path the PS/2 driver uses.
#
# Out of scope for V0 (deliberately):
#   - n-key rollover (boot protocol caps at 6 simultaneous keys —
#     the spec's documented limitation).
#   - Auto-repeat. The host is responsible for emitting repeat
#     events; we don't yet — held keys produce one make event.
#   - LEDs (Caps/Num/Scroll lock indicators on the keyboard itself).
#     The state is tracked internally but no SET_REPORT is sent
#     back to the device.
#   - Non-US layouts. The usage_to_ascii / usage_to_shifted tables
#     are pure US-QWERTY.
#
# The self-test (hid_self_test) feeds synthetic 8-byte reports
# through hid_kbd_report() and asserts the ASCII bytes that land in
# the keyboard FIFO. Mirrors atkbd_self_test() — see that for the
# same shape applied to PS/2 scancodes.

from kernel.printk.printk import printk0, printk1, printk2
from drivers.input.atkbd import kbd_rx_push, kbd_rx_pop


# --- HID usage codes we care about (HID Usage Tables 1.21 §10) ---
#
# Boot-keyboard usage page is 0x07 ("Keyboard/Keypad"). Codes 0x04..
# 0x1D are A..Z; 0x1E..0x27 are 1..0; rest are control keys.
HID_KEY_A: uint8 = 0x04
HID_KEY_1: uint8 = 0x1E
HID_KEY_ENTER:     uint8 = 0x28
HID_KEY_ESCAPE:    uint8 = 0x29
HID_KEY_BACKSPACE: uint8 = 0x2A
HID_KEY_TAB:       uint8 = 0x2B
HID_KEY_SPACE:     uint8 = 0x2C
HID_KEY_CAPSLOCK:  uint8 = 0x39
HID_KEY_F1:        uint8 = 0x3A
HID_KEY_F12:       uint8 = 0x45
HID_KEY_RIGHT:     uint8 = 0x4F
HID_KEY_LEFT:      uint8 = 0x50
HID_KEY_DOWN:      uint8 = 0x51
HID_KEY_UP:        uint8 = 0x52


# --- Modifier-byte bits (HID report byte 0) -----------------------
HID_MOD_LCTRL:  uint8 = 0x01
HID_MOD_LSHIFT: uint8 = 0x02
HID_MOD_LALT:   uint8 = 0x04
HID_MOD_LGUI:   uint8 = 0x08
HID_MOD_RCTRL:  uint8 = 0x10
HID_MOD_RSHIFT: uint8 = 0x20
HID_MOD_RALT:   uint8 = 0x40
HID_MOD_RGUI:   uint8 = 0x80


# --- Translation tables -------------------------------------------
#
# 128-byte tables keyed by HID usage code. Entries that are 0 mean
# "no ASCII mapping in this state" — control keys (arrows, F-keys,
# Caps, etc.) emit VT220 escape sequences via the helper functions
# below. The PS/2 driver runs the same pattern and we deliberately
# mirror its byte sequences so a downstream readline that handles
# the PS/2 path Just Works on USB too.

HID_TABLE_SIZE: uint64 = 128
hid_usage_to_ascii:   Array[128, uint8]
hid_usage_to_shifted: Array[128, uint8]


def hid_build_table():
    # Letters: usage 0x04..0x1D -> 'a'..'z'. We populate the lowercase
    # form; Shift/Caps transforms happen later via the same
    # Shift-XOR-Caps logic as atkbd_apply_case (open-coded here so we
    # don't reach into atkbd internals).
    i: uint64 = 0
    while i < 26:
        hid_usage_to_ascii[0x04 + i] = cast[uint8](97 + i)   # 'a'+i
        i = i + 1

    # Number row: usage 0x1E..0x26 -> '1'..'9', 0x27 -> '0'.
    hid_usage_to_ascii[0x1E] = 49      # '1'
    hid_usage_to_ascii[0x1F] = 50
    hid_usage_to_ascii[0x20] = 51
    hid_usage_to_ascii[0x21] = 52
    hid_usage_to_ascii[0x22] = 53
    hid_usage_to_ascii[0x23] = 54
    hid_usage_to_ascii[0x24] = 55
    hid_usage_to_ascii[0x25] = 56
    hid_usage_to_ascii[0x26] = 57
    hid_usage_to_ascii[0x27] = 48      # '0'

    # Whitespace + editing.
    hid_usage_to_ascii[HID_KEY_ENTER]     = 10     # '\n'
    hid_usage_to_ascii[HID_KEY_ESCAPE]    = 27     # ESC
    hid_usage_to_ascii[HID_KEY_BACKSPACE] = 8      # BS
    hid_usage_to_ascii[HID_KEY_TAB]       = 9      # TAB
    hid_usage_to_ascii[HID_KEY_SPACE]     = 32

    # Symbol keys (US-QWERTY).
    hid_usage_to_ascii[0x2D] = 45      # '-'
    hid_usage_to_ascii[0x2E] = 61      # '='
    hid_usage_to_ascii[0x2F] = 91      # '['
    hid_usage_to_ascii[0x30] = 93      # ']'
    hid_usage_to_ascii[0x31] = 92      # '\\'
    hid_usage_to_ascii[0x33] = 59      # ';'
    hid_usage_to_ascii[0x34] = 39      # '\''
    hid_usage_to_ascii[0x35] = 96      # '`'
    hid_usage_to_ascii[0x36] = 44      # ','
    hid_usage_to_ascii[0x37] = 46      # '.'
    hid_usage_to_ascii[0x38] = 47      # '/'

    # Shifted side of the number row.
    hid_usage_to_shifted[0x1E] = 33    # '!'
    hid_usage_to_shifted[0x1F] = 64    # '@'
    hid_usage_to_shifted[0x20] = 35    # '#'
    hid_usage_to_shifted[0x21] = 36    # '$'
    hid_usage_to_shifted[0x22] = 37    # '%'
    hid_usage_to_shifted[0x23] = 94    # '^'
    hid_usage_to_shifted[0x24] = 38    # '&'
    hid_usage_to_shifted[0x25] = 42    # '*'
    hid_usage_to_shifted[0x26] = 40    # '('
    hid_usage_to_shifted[0x27] = 41    # ')'

    # Shifted side of the symbol keys.
    hid_usage_to_shifted[0x2D] = 95    # '_'
    hid_usage_to_shifted[0x2E] = 43    # '+'
    hid_usage_to_shifted[0x2F] = 123   # '{'
    hid_usage_to_shifted[0x30] = 125   # '}'
    hid_usage_to_shifted[0x31] = 124   # '|'
    hid_usage_to_shifted[0x33] = 58    # ':'
    hid_usage_to_shifted[0x34] = 34    # '"'
    hid_usage_to_shifted[0x35] = 126   # '~'
    hid_usage_to_shifted[0x36] = 60    # '<'
    hid_usage_to_shifted[0x37] = 62    # '>'
    hid_usage_to_shifted[0x38] = 63    # '?'


# --- Per-driver state ---------------------------------------------
#
# Boot keyboard delivers state-based reports (not edge events). We
# track the previous report's pressed-key array so each call can
# compute the diff and emit make events for newly-pressed keys.
#
# Modifier and capslock state mirror the PS/2 driver shape: shift
# XOR caps for letter case, ctrl folds 'a'..'z' / 'A'..'Z' to
# 0x01..0x1A, etc. We keep this state local rather than reaching
# into atkbd's module-private kbd_state — the two drivers can
# disagree briefly during transitions and that's fine since the
# FIFO bytes are the only thing downstream observes.

HID_MAX_KEYS: uint64 = 6

hid_prev_keys: Array[6, uint8]
hid_caps_on:   int32 = 0
hid_num_on:    int32 = 0

# Self-test counters — populated by hid_self_test, asserted by
# scripts/test_usb_hid.sh via the "[hid] self-test PASS" banner.
hid_selftest_pass: int32 = 0
hid_selftest_fail: int32 = 0


def _hid_was_pressed(usage: uint8) -> int32:
    # Return 1 if `usage` appears anywhere in hid_prev_keys[0..5].
    # 0 is the "unused slot" sentinel and never matches a real key.
    if usage == 0:
        return 0
    i: uint64 = 0
    while i < HID_MAX_KEYS:
        if hid_prev_keys[i] == usage:
            return 1
        i = i + 1
    return 0


def _hid_apply_case(ch: int32, shift_on: int32) -> int32:
    # Same Shift-XOR-Caps logic as atkbd_apply_case. Letters (lowercase
    # 97..122) flip to uppercase when exactly one of Shift / Caps is
    # active; both active cancels back to lowercase.
    if ch < 97:
        return ch
    if ch > 122:
        return ch
    caps_on: int32 = hid_caps_on
    if (shift_on ^ caps_on) != 0:
        return ch - 32
    return ch


def _hid_apply_ctrl(ch: int32) -> int32:
    # Letters get folded to control codes (Ctrl+C -> 0x03). Non-letters
    # pass through unchanged so e.g. Ctrl+'1' just emits '1'. The
    # 0x1F mask handles both 'A'..'Z' and 'a'..'z' uniformly because
    # ('a' & 0x1F) == ('A' & 0x1F) == 1.
    if ch < 64:
        return ch
    if ch > 122:
        return ch
    if ch > 90:
        if ch < 97:
            return ch
    return ch & 0x1F


def _hid_emit_escape_bracket(final: uint8):
    # CSI form: ESC [ <final>. Arrow keys.
    kbd_rx_push(27)
    kbd_rx_push(91)
    kbd_rx_push(final)


def _hid_emit_escape_o(final: uint8):
    # SS3 form: ESC O <final>. F1..F4.
    kbd_rx_push(27)
    kbd_rx_push(79)
    kbd_rx_push(final)


def _hid_emit_make(usage: uint8, modifiers: uint8) -> int32:
    # Translate one freshly-pressed key into FIFO bytes. Returns 1
    # if anything was pushed (caller diag), 0 otherwise.
    #
    # Order of precedence intentionally mirrors atkbd_process_byte:
    #   1. Special keys (arrows / function keys) -> escape sequence,
    #      modifiers irrelevant for V0.
    #   2. Plain-ASCII via the table, Shift-swap for symbols, Caps-XOR
    #      for letters, Ctrl-fold last.

    # Arrow keys -> VT220 CSI sequences (xterm-compatible).
    if usage == HID_KEY_UP:
        _hid_emit_escape_bracket(65)               # 'A'
        return 1
    if usage == HID_KEY_DOWN:
        _hid_emit_escape_bracket(66)
        return 1
    if usage == HID_KEY_RIGHT:
        _hid_emit_escape_bracket(67)
        return 1
    if usage == HID_KEY_LEFT:
        _hid_emit_escape_bracket(68)
        return 1

    # F1..F4 -> ESC O P..S (VT220 SS3 form, matches atkbd).
    if usage == HID_KEY_F1:
        _hid_emit_escape_o(80)
        return 1
    if usage == 0x3B:           # F2
        _hid_emit_escape_o(81)
        return 1
    if usage == 0x3C:           # F3
        _hid_emit_escape_o(82)
        return 1
    if usage == 0x3D:           # F4
        _hid_emit_escape_o(83)
        return 1

    # Caps Lock — toggle on press only, no FIFO byte emitted.
    if usage == HID_KEY_CAPSLOCK:
        hid_caps_on = hid_caps_on ^ 1
        return 0

    # Plain ASCII via the table.
    if cast[uint64](usage) >= HID_TABLE_SIZE:
        return 0
    base: uint8 = hid_usage_to_ascii[usage]
    if base == 0:
        return 0

    shift_on: int32 = 0
    if (modifiers & (HID_MOD_LSHIFT | HID_MOD_RSHIFT)) != 0:
        shift_on = 1
    ctrl_on: int32 = 0
    if (modifiers & (HID_MOD_LCTRL | HID_MOD_RCTRL)) != 0:
        ctrl_on = 1

    ch: int32 = cast[int32](base)

    # Shifted symbol / number row uses a parallel table.
    if shift_on != 0:
        sh: uint8 = hid_usage_to_shifted[usage]
        if sh != 0:
            ch = cast[int32](sh)

    # Letter case = Shift XOR Caps.
    ch = _hid_apply_case(ch, shift_on)

    # Ctrl-fold runs LAST so e.g. Ctrl+Shift+'c' still -> 0x03.
    if ctrl_on != 0:
        ch = _hid_apply_ctrl(ch)

    kbd_rx_push(cast[uint8](ch & 0xFF))
    return 1


# --- Public entry points -------------------------------------------

def hid_kbd_report(report: Ptr[uint8]):
    # Process one 8-byte boot-keyboard report. Diff against the
    # previous report to find newly-pressed keys; emit each one
    # into the keyboard FIFO. Save the new report as the baseline
    # for the next call.
    #
    # Called by xhci.ad's interrupt-in poll loop; signature is
    # stable across HCD backends so a hypothetical future EHCI/OHCI
    # driver could feed the same path.
    modifiers: uint8 = report[0]
    # report[1] is reserved; ignored.

    # Walk slots 2..7 of the report, look for newly-pressed keys.
    i: uint64 = 0
    while i < HID_MAX_KEYS:
        usage: uint8 = report[2 + i]
        if usage >= 0x04:                       # ignore 0..3 (errors)
            if _hid_was_pressed(usage) == 0:
                _hid_emit_make(usage, modifiers)
        i = i + 1

    # Copy current key slots into prev[] for the next-report diff.
    j: uint64 = 0
    while j < HID_MAX_KEYS:
        hid_prev_keys[j] = report[2 + j]
        j = j + 1


# --- Self-test ----------------------------------------------------
#
# Drives hid_kbd_report() with synthetic 8-byte boot reports and
# asserts the bytes that land in kbd_rx_pop()/atkbd's FIFO. Catches
# regressions in the diff logic + modifier transforms without needing
# a live USB keyboard. Mirrors atkbd_self_test() in shape.

def _hid_reset():
    # Clear prev-key state + drain the FIFO so a previous test's
    # leftovers don't contaminate this one.
    k: uint64 = 0
    while k < HID_MAX_KEYS:
        hid_prev_keys[k] = 0
        k = k + 1
    hid_caps_on = 0
    while kbd_rx_pop() >= 0:
        pass


def _hid_build_report(buf: Ptr[uint8], modifiers: uint8,
                      k0: uint8, k1: uint8, k2: uint8,
                      k3: uint8, k4: uint8, k5: uint8):
    buf[0] = modifiers
    buf[1] = 0
    buf[2] = k0
    buf[3] = k1
    buf[4] = k2
    buf[5] = k3
    buf[6] = k4
    buf[7] = k5


def _hid_expect(expected: int32):
    got: int32 = kbd_rx_pop()
    if got == expected:
        hid_selftest_pass = hid_selftest_pass + 1
    else:
        hid_selftest_fail = hid_selftest_fail + 1
        printk2("hid: self-test FAIL expected=%d got=%d\n",
                cast[uint64](expected), cast[uint64](got))


def hid_self_test():
    hid_selftest_pass = 0
    hid_selftest_fail = 0

    rep: Array[8, uint8]
    rp: Ptr[uint8] = &rep[0]

    # Case 1: lowercase 'a'. Usage 0x04, no modifiers.
    _hid_reset()
    _hid_build_report(rp, 0, 0x04, 0, 0, 0, 0, 0)
    hid_kbd_report(rp)
    _hid_expect(97)            # 'a'

    # Case 2: Shift+'a' -> 'A'.
    _hid_reset()
    _hid_build_report(rp, HID_MOD_LSHIFT, 0x04, 0, 0, 0, 0, 0)
    hid_kbd_report(rp)
    _hid_expect(65)            # 'A'

    # Case 3: Caps latches across an empty report; second 'a' -> 'A'.
    _hid_reset()
    _hid_build_report(rp, 0, HID_KEY_CAPSLOCK, 0, 0, 0, 0, 0)
    hid_kbd_report(rp)                              # caps press
    _hid_build_report(rp, 0, 0, 0, 0, 0, 0, 0)
    hid_kbd_report(rp)                              # caps release
    _hid_build_report(rp, 0, 0x04, 0, 0, 0, 0, 0)
    hid_kbd_report(rp)                              # 'a' -> 'A'
    _hid_expect(65)

    # Case 4: Shift+'1' -> '!'.
    _hid_reset()
    _hid_build_report(rp, HID_MOD_LSHIFT, 0x1E, 0, 0, 0, 0, 0)
    hid_kbd_report(rp)
    _hid_expect(33)            # '!'

    # Case 5: Ctrl+'c' -> 0x03 (SIGINT byte).
    _hid_reset()
    _hid_build_report(rp, HID_MOD_LCTRL, 0x06, 0, 0, 0, 0, 0)
    hid_kbd_report(rp)
    _hid_expect(0x03)

    # Case 6: Right-Ctrl + Shift + 'd' -> 0x04 (Ctrl-fold wins).
    _hid_reset()
    _hid_build_report(rp, HID_MOD_RCTRL | HID_MOD_LSHIFT,
                      0x07, 0, 0, 0, 0, 0)
    hid_kbd_report(rp)
    _hid_expect(0x04)

    # Case 7: Arrow Up -> ESC [ A (3 bytes).
    _hid_reset()
    _hid_build_report(rp, 0, HID_KEY_UP, 0, 0, 0, 0, 0)
    hid_kbd_report(rp)
    _hid_expect(27)
    _hid_expect(91)
    _hid_expect(65)

    # Case 8: F1 -> ESC O P.
    _hid_reset()
    _hid_build_report(rp, 0, HID_KEY_F1, 0, 0, 0, 0, 0)
    hid_kbd_report(rp)
    _hid_expect(27)
    _hid_expect(79)
    _hid_expect(80)

    # Case 9: Diff suppression. Two reports holding the SAME key
    # should yield exactly one make event (held-key repeat is out of
    # scope for V0).
    _hid_reset()
    _hid_build_report(rp, 0, 0x04, 0, 0, 0, 0, 0)
    hid_kbd_report(rp)                              # 'a' (make)
    hid_kbd_report(rp)                              # held — no event
    _hid_expect(97)
    # FIFO should now be empty — pop one more, expect -1.
    if kbd_rx_pop() != -1:
        hid_selftest_fail = hid_selftest_fail + 1
        printk0("hid: self-test FAIL (held key emitted twice)\n")
    else:
        hid_selftest_pass = hid_selftest_pass + 1

    # Case 10: Enter -> '\n'.
    _hid_reset()
    _hid_build_report(rp, 0, HID_KEY_ENTER, 0, 0, 0, 0, 0)
    hid_kbd_report(rp)
    _hid_expect(10)

    # Case 11: Space -> ' '.
    _hid_reset()
    _hid_build_report(rp, 0, HID_KEY_SPACE, 0, 0, 0, 0, 0)
    hid_kbd_report(rp)
    _hid_expect(32)

    # Case 12: Backspace -> 0x08.
    _hid_reset()
    _hid_build_report(rp, 0, HID_KEY_BACKSPACE, 0, 0, 0, 0, 0)
    hid_kbd_report(rp)
    _hid_expect(8)

    # Drain anything left over + reset state so the post-init FIFO
    # is clean for real keystrokes.
    while kbd_rx_pop() >= 0:
        pass
    hid_caps_on = 0

    if hid_selftest_fail == 0:
        printk1("[usb_hid] self-test PASS (%d cases)\n",
                cast[uint64](hid_selftest_pass))
    else:
        printk1("[usb_hid] self-test FAIL (%d failures)\n",
                cast[uint64](hid_selftest_fail))


def hid_init() -> int32:
    # One-shot module init. Builds the translation tables (Adder
    # arrays default to zero, so per-element init has to happen at
    # runtime), then runs the self-test. Called from xhci_init()
    # after the HCD comes up so a HID-class device on the root hub
    # can immediately start feeding reports.
    hid_build_table()
    hid_self_test()
    return 0

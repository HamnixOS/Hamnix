# drivers/input/auxmouse.ad
#
# PS/2 auxiliary-device (mouse) driver. Sibling to drivers/input/atkbd.ad
# — same i8042 controller, same 0x60/0x64 ports, different "channel".
#
# Linux mapping:
#   drivers/input/mouse/psmouse-base.c -> auxmouse_init + mouse_irq_handler
#   serio2 (the i8042 second port)     -> the 0xD4 prefix write path
#
# We call this driver `auxmouse` rather than `psmouse` to avoid the
# overload with "PS/2" (the keyboard is also PS/2; the *mouse* is the
# *auxiliary device* in 8042 spec parlance — "AUX port", controller
# command 0xA8 enables it, command 0xD4 routes the next host byte to
# it). 9front calls it `mouse(3)`; we follow Linux's "input over the
# 8042 aux port" architecture but keep the unambiguous name.
#
# Protocol summary (3-byte standard PS/2 mouse — ID=0x00):
#   On every motion or button event the device sends 3 bytes:
#     byte0 = [Yov Xov Ysn Xsn 1 MB RB LB]
#     byte1 = X delta (signed, sign-extended via Xsn into 9-bit)
#     byte2 = Y delta (signed, sign-extended via Ysn into 9-bit)
#   The "always_1" bit in byte0 is our packet-resync sentinel: if we
#   ever see byte0 with that bit clear we drop it and re-seek.
#
# This commit is "init + IRQ + decode + ring buffer". The /dev/mouse
# cdev path follows the M16.94 /dev/cons pattern — separate commit.
# The 4-byte scroll-wheel knock pattern (0xF3 200, 0xF3 100, 0xF3 80)
# is also deferred — 3-byte is universally supported and adequate.
#
# outb/inb are Adder codegen intrinsics; same pattern as atkbd.ad and
# drivers/tty/serial/early_8250.ad — no extern needed.

from kernel.printk.printk import printk0, printk1, printk2
from arch.x86.kernel.apic import ioapic_redirect_isa
# KEYBOARD LAG/LOSS FIX: when the AUX (mouse) IRQ finds a KEYBOARD byte in the
# shared i8042 output buffer, route it to the keyboard state machine rather
# than dropping it. atkbd.ad imports auxmouse_init from here; Adder merges all
# modules into one flat namespace at link, so this back-reference is a plain
# symbol resolution, not a load-order dependency.
from drivers.input.atkbd import atkbd_process_byte
from arch.x86.kernel.irq import register_irq_handler


# --- i8042 ports + bits -------------------------------------------------
#
# Same hardware as the keyboard. The "second port" / AUX path uses the
# same 0x60 data port; what changes is the controller-command-byte (CCB)
# configuration plus the 0xD4 prefix byte that re-routes the NEXT host
# write from 0x60 to the AUX device instead of the KBD device.

I8042_DATA_PORT:   int32 = 0x60
I8042_STATUS_PORT: int32 = 0x64
I8042_CMD_PORT:    int32 = 0x64

# Status register bits.
I8042_STATUS_OBF: int32 = 0x01      # Output Buffer Full (data->host)
I8042_STATUS_IBF: int32 = 0x02      # Input  Buffer Full (host->ctrl)
I8042_STATUS_AUX: int32 = 0x20      # Bit 5: data is from AUX, not KBD

# Controller commands (written to 0x64).
I8042_CMD_READ_CCB:    int32 = 0x20    # read controller-command-byte
I8042_CMD_WRITE_CCB:   int32 = 0x60    # write controller-command-byte
I8042_CMD_DISABLE_AUX: int32 = 0xA7    # disable AUX port
I8042_CMD_ENABLE_AUX:  int32 = 0xA8    # enable  AUX port
I8042_CMD_TEST_AUX:    int32 = 0xA9    # self-test AUX interface (0x00=OK)
I8042_CMD_WRITE_AUX:   int32 = 0xD4    # next byte->AUX dev (not KBD)

# CCB bit layout (8042 standard):
#   bit 0  IRQ1 enable (KBD)
#   bit 1  IRQ12 enable (AUX)
#   bit 4  KBD clock disable
#   bit 5  AUX clock disable
#   bit 6  KBD translation (Set2 -> Set1)
CCB_IRQ_AUX:      int32 = 0x02
CCB_DISABLE_AUX:  int32 = 0x20

# Device commands (written to AUX via 0xD4 prefix).
MOUSE_CMD_RESET:        int32 = 0xFF
MOUSE_CMD_RESEND:       int32 = 0xFE
MOUSE_CMD_SET_DEFAULTS: int32 = 0xF6
MOUSE_CMD_DISABLE:      int32 = 0xF5
MOUSE_CMD_ENABLE:       int32 = 0xF4   # enable streaming reports
MOUSE_CMD_SET_RATE:     int32 = 0xF3   # followed by sample rate byte
MOUSE_CMD_GET_DEVID:    int32 = 0xF2

# Device responses.
MOUSE_ACK:      int32 = 0xFA
MOUSE_NAK:      int32 = 0xFE
MOUSE_BAT_OK:   int32 = 0xAA       # self-test passed (Basic Assurance Test)


# --- IRQ wiring ---------------------------------------------------------
#
# IRQ 12 is the legacy PIC line for the i8042 AUX port. After the
# M16.22 PIC->APIC swap we route IRQ12 via the IOAPIC. Vector choice
# follows the M16.113..M16.117 allocation map:
#   0x40 virtio-net  0x41 ahci  0x42 nvme  0x43 e1000e  0x44 r8169
# Next free is 0x45 — we claim it.

AUXMOUSE_IRQ_VECTOR: uint32 = 0x45
AUXMOUSE_LAPIC_ID:   uint32 = 0
AUXMOUSE_IOAPIC_PIN: uint32 = 12       # ISA IRQ12 == IOAPIC pin 12 (1:1 ID-mapped)


# --- Packet decode + event ring ----------------------------------------
#
# byte0 bit layout (LSB first):
#   bit 0  Left button
#   bit 1  Right button
#   bit 2  Middle button
#   bit 3  always-1 (resync sentinel)
#   bit 4  X sign     (1 = X delta is negative; high bit of 9-bit X)
#   bit 5  Y sign
#   bit 6  X overflow (delta exceeded 8-bit signed range — drop)
#   bit 7  Y overflow

PKT_BTN_LEFT:   uint32 = 0x01
PKT_BTN_RIGHT:  uint32 = 0x02
PKT_BTN_MIDDLE: uint32 = 0x04
PKT_ALWAYS_ONE: uint32 = 0x08
PKT_X_SIGN:     uint32 = 0x10
PKT_Y_SIGN:     uint32 = 0x20
PKT_X_OVER:     uint32 = 0x40
PKT_Y_OVER:     uint32 = 0x80


# Each event in the ring is a packed 32-bit word:
#   bits  0..15  dx (int16, sign-extended from 9-bit)
#   bits 16..31  dy (int16)
# Buttons go to a separate ring slot? No — too much state churn for
# what's effectively three booleans. Pack buttons into the high byte
# of dy's word: the protocol's X+Y deltas only need 9 bits each
# (range -256..+255), so the upper bits of each int16 are spare. We
# use bits 24..31 of the event word for buttons, leaving bits 0..15
# for dx (int16) and bits 16..23 for dy (int8, since 9-bit signed
# truncates cleanly into 8 bits for most motion — fine for a cursor).
#
# Actually keep it simple: separate the ring into a struct array. A
# parallel agent might add a /dev/mouse cdev that wants the cleaner
# shape, and packing-into-int32 saves nothing of consequence here.

class MouseEvent:
    dx:      int32          # signed 9-bit X delta (sign-extended) OR, for an
                            #   absolute event (aflag=1), the absolute X in
                            #   0..32767 normalized device units.
    dy:      int32          # signed 9-bit Y delta OR absolute Y (0..32767).
    buttons: uint32         # bitmask: bit0=L bit1=R bit2=M
    dz:      int32          # signed scroll-wheel delta (+ = wheel up / away).
                            #   The packed-int32 wire word (mouse_rx_pop) is
                            #   full, so dz rides ALONGSIDE it in this struct
                            #   field. Legacy producers leave it 0 (Adder zeros
                            #   struct fields), so the cursor path is unchanged.
    aflag:   int32          # 0 = relative deltas (PS/2 / USB boot mouse);
                            #   1 = ABSOLUTE pointer event (USB HID tablet —
                            #   the QEMU/GNOME-Boxes default pointer device).
                            #   dx/dy then hold abs X/Y in 0..32767. Rides the
                            #   same side-channel pattern as dz because the
                            #   packed int32 wire word has no spare bits.


MOUSE_RING_SIZE: uint64 = 64

mouse_ring:      Array[64, MouseEvent]
mouse_ring_head: uint64 = 0
mouse_ring_tail: uint64 = 0

# Packet assembly state. We arrive at byte 0 every time mouse_phase
# is 0 and the AUX status bit was set; advancement is byte-by-byte
# because the IRQ delivers one byte at a time on most controllers
# (QEMU coalesces but the per-byte path still works).
mouse_phase: int32 = 0
mouse_b0:    int32 = 0
mouse_b1:    int32 = 0
mouse_b2:    int32 = 0          # IntelliMouse 4-byte packets need a 3rd held byte

# BUG 2 (mouse wheel) — IntelliMouse (Microsoft) wheel protocol.
#   mouse_proto / mouse_pkt_len track the negotiated wire format:
#     proto 0 = standard PS/2, 3-byte packets (no wheel)
#     proto 3 = IntelliMouse,  4-byte packets; byte3 = signed Z wheel delta
# Negotiation is the magic "sample-rate knock" 200,100,80 followed by a
# GET_DEVID (0xF2) that returns 0x03 when the device speaks IntelliMouse.
# QEMU's PS/2 mouse implements this; so does essentially every real mouse.
MOUSE_DEVID_INTELLI: int32 = 0x03
mouse_proto:   int32 = 0        # 0 = 3-byte PS/2, 3 = 4-byte IntelliMouse
mouse_pkt_len: int32 = 3        # bytes per packet for the current protocol

# Diagnostic counters.
mouse_irq_count:   uint64 = 0
mouse_pkt_count:   uint64 = 0
mouse_dropped:     uint64 = 0       # packets dropped (overflow / resync)
mouse_initialized: int32  = 0


# --- Low-level controller helpers --------------------------------------

def _i8042_wait_input_clear() -> int32:
    # Spin until IBF clears (controller is ready to accept a byte from
    # us). Bounded so a wedged controller can't hang the kernel during
    # boot. Returns 1 on success, 0 on timeout.
    timeout: int32 = 100000
    while timeout > 0:
        if (inb(I8042_STATUS_PORT) & I8042_STATUS_IBF) == 0:
            return 1
        timeout = timeout - 1
    return 0


def _i8042_wait_output_full() -> int32:
    # Spin until OBF sets (controller has a byte for us). Same bounded
    # discipline — used during init when we're expecting an ACK/result
    # and don't want a missing device to stall the kernel.
    timeout: int32 = 100000
    while timeout > 0:
        if (inb(I8042_STATUS_PORT) & I8042_STATUS_OBF) != 0:
            return 1
        timeout = timeout - 1
    return 0


def _i8042_drain():
    # Drain any stale bytes the firmware / BIOS left in the output
    # buffer. Hard-capped — a status register stuck high (which we've
    # seen on some odd virtualisation layers) won't spin us forever.
    n: int32 = 0
    while (inb(I8042_STATUS_PORT) & I8042_STATUS_OBF) != 0:
        inb(I8042_DATA_PORT)
        n = n + 1
        if n > 32:
            return


def _i8042_cmd(cmd: int32):
    # Write a controller command (0x64 port). Caller must wait for IBF
    # afterwards if a parameter byte follows on 0x60.
    _i8042_wait_input_clear()
    outb(cmd, I8042_CMD_PORT)


def _i8042_write_data(b: int32):
    # Write a data byte to 0x60 (parameter for the previous command,
    # OR keyboard command for the KBD channel).
    _i8042_wait_input_clear()
    outb(b, I8042_DATA_PORT)


def _i8042_aux_write(b: int32) -> int32:
    # Send a byte to the AUX device. The 0xD4 controller command tells
    # the i8042 "the NEXT host write to 0x60 goes to AUX, not KBD".
    # Returns 1 on success (the byte was queued), 0 on IBF-stuck
    # timeout.
    if _i8042_wait_input_clear() == 0:
        return 0
    outb(I8042_CMD_WRITE_AUX, I8042_CMD_PORT)
    if _i8042_wait_input_clear() == 0:
        return 0
    outb(b, I8042_DATA_PORT)
    return 1


def _i8042_aux_read() -> int32:
    # Read one byte from the AUX device. Returns -1 on timeout.
    # During init we explicitly poll because IRQ 12 isn't routed yet;
    # at runtime the IRQ delivers bytes one at a time.
    if _i8042_wait_output_full() == 0:
        return -1
    # We expect status bit 5 (AUX) to be set on AUX-source bytes. If
    # it's clear the byte came from the keyboard mid-init — drop it
    # so it doesn't masquerade as a mouse ACK. Note: QEMU does set
    # the AUX bit correctly; on real hardware the bit is reliable.
    st: int32 = inb(I8042_STATUS_PORT)
    b: int32 = inb(I8042_DATA_PORT) & 0xFF
    if (st & I8042_STATUS_AUX) == 0:
        return -1
    return b


def _aux_send_expect_ack(cmd: int32) -> int32:
    # Convenience for the init sequence: send `cmd` to AUX, wait for
    # the standard 0xFA ACK. Returns 1 on ACK, 0 otherwise. The mouse
    # also sends NAK (0xFE) on parse error, in which case we don't
    # retry — every command we issue is well-defined.
    if _i8042_aux_write(cmd) == 0:
        return 0
    r: int32 = _i8042_aux_read()
    if r == MOUSE_ACK:
        return 1
    return 0


# --- Event ring --------------------------------------------------------

def _mouse_ring_push(dx: int32, dy: int32, buttons: uint32, dz: int32):
    # Drop-oldest is wrong for input — we'd lose context for the cursor
    # delta accumulation. Drop-newest preserves the trail. Returns
    # silently on full; mouse_dropped is the diagnostic. `dz` carries the
    # IntelliMouse wheel delta (0 for standard 3-byte packets).
    nxt: uint64 = (mouse_ring_tail + 1) % MOUSE_RING_SIZE
    if nxt == mouse_ring_head:
        mouse_dropped = mouse_dropped + 1
        return
    mouse_ring[mouse_ring_tail].dx = dx
    mouse_ring[mouse_ring_tail].dy = dy
    mouse_ring[mouse_ring_tail].buttons = buttons
    mouse_ring[mouse_ring_tail].dz = dz      # IntelliMouse wheel notch
    mouse_ring[mouse_ring_tail].aflag = 0   # PS/2 packets are relative
    mouse_ring_tail = nxt


# Scroll-wheel delta of the event most recently returned by mouse_rx_pop().
# The packed int32 mouse_rx_pop emits has no spare bits, so the wheel delta
# is stashed here as a side channel: pop the event, then read this. A legacy
# caller that ignores it sees the exact same int32 it always did (dz == 0
# for any producer that never set it). Set in lockstep INSIDE mouse_rx_pop.
mouse_last_dz: int32 = 0

# Absolute-pointer side channel paired with the LAST mouse_rx_pop() event
# (same discipline as mouse_last_dz: read immediately after the pop, before
# the next one). For an absolute event the packed int32 cannot carry the
# full 15-bit Y (its dy lane is 8 bits), so consumers that care about
# absolute events MUST read the full-width coordinates from here.
mouse_last_aflag: int32 = 0
mouse_last_ax:    int32 = 0
mouse_last_ay:    int32 = 0


def mouse_rx_pop_dz() -> int32:
    # Return the wheel delta paired with the LAST mouse_rx_pop() event.
    # Must be called after mouse_rx_pop() and before the next one. Returns 0
    # if that event carried no wheel motion (the common case).
    return mouse_last_dz


def mouse_rx_pop_aflag() -> int32:
    # 1 if the LAST mouse_rx_pop() event was an ABSOLUTE pointer event
    # (USB HID tablet), else 0. Same read-immediately discipline as
    # mouse_rx_pop_dz().
    return mouse_last_aflag


def mouse_rx_pop_ax() -> int32:
    # Full-width absolute X (0..32767) of the LAST popped event when
    # mouse_rx_pop_aflag() returned 1; undefined otherwise.
    return mouse_last_ax


def mouse_rx_pop_ay() -> int32:
    # Full-width absolute Y (0..32767) of the LAST popped event when
    # mouse_rx_pop_aflag() returned 1; undefined otherwise.
    return mouse_last_ay


def mouse_rx_pop() -> int32:
    # Pop one event, encoded as int32. Future /dev/mouse cdev will use
    # a richer struct path (read of sizeof(MouseEvent)); this is the
    # minimum scaffolding so users can verify "an event arrived".
    #
    # Encoding (matches the in-ring packed shape the cdev will adopt):
    #   bits  0..15  dx & 0xFFFF (signed delta, low 16 bits)
    #   bits 16..23  buttons (uint8)
    #   bits 24..31  dy & 0xFF  (signed 8-bit truncation — sufficient
    #                            for the 9-bit delta after overflow
    #                            handling)
    # Returns -1 if the ring is empty (sentinel; user code is expected
    # to check for -1 because no real event encodes to -1 — buttons
    # field is bounded to 3 bits and would have to be 0xFF, which
    # never happens with our 0x07 mask).
    if mouse_ring_head == mouse_ring_tail:
        mouse_last_dz = 0
        mouse_last_aflag = 0
        return -1
    dx: int32 = mouse_ring[mouse_ring_head].dx
    dy: int32 = mouse_ring[mouse_ring_head].dy
    bt: uint32 = mouse_ring[mouse_ring_head].buttons
    # Stash the paired wheel delta for mouse_rx_pop_dz() before advancing.
    mouse_last_dz = mouse_ring[mouse_ring_head].dz
    # Stash the absolute-pointer side channel (mouse_rx_pop_aflag/ax/ay).
    mouse_last_aflag = mouse_ring[mouse_ring_head].aflag
    mouse_last_ax = dx
    mouse_last_ay = dy
    mouse_ring_head = (mouse_ring_head + 1) % MOUSE_RING_SIZE
    out: int32 = (dx & 0xFFFF) \
               | cast[int32]((bt & 0xFF) << 16) \
               | ((dy & 0xFF) << 24)
    return out


def mouse_rx_has() -> int32:
    if mouse_ring_head == mouse_ring_tail:
        return 0
    return 1


def mouse_rx_push(encoded: int32) -> int32:
    # Synthetic-event injection: decode a packed int32 (the SAME shape
    # mouse_rx_pop emits) back into a MouseEvent and enqueue it on the
    # ring so a subsequent mouse_rx_pop()/devmouse_read pops it out.
    # This is the loopback path behind a writable /dev/mouse (the Plan 9
    # writable-mouse capability / Linux /dev/uinput equivalent).
    #
    # Returns 0 on success, -1 if the ring is full. Mirrors the head/tail
    # bookkeeping of _mouse_ring_push exactly — fixed-size ring, no kmalloc.
    nxt: uint64 = (mouse_ring_tail + 1) % MOUSE_RING_SIZE
    if nxt == mouse_ring_head:
        return -1
    # Decode the packed fields. Sign-extend dx from bit 15 and dy from
    # bit 7, exactly reversing mouse_rx_pop's packing.
    dx_raw: uint64 = cast[uint64](encoded) & 0xFFFF
    dx: int32 = cast[int32](dx_raw)
    if (dx_raw & 0x8000) != 0:
        dx = cast[int32](dx_raw | 0xFFFFFFFFFFFF0000)
    dy_raw: uint64 = (cast[uint64](encoded) >> 24) & 0xFF
    dy: int32 = cast[int32](dy_raw)
    if (dy_raw & 0x80) != 0:
        dy = cast[int32](dy_raw | 0xFFFFFFFFFFFFFF00)
    buttons: uint32 = cast[uint32]((cast[uint64](encoded) >> 16) & 0xFF)
    mouse_ring[mouse_ring_tail].dx = dx
    mouse_ring[mouse_ring_tail].dy = dy
    mouse_ring[mouse_ring_tail].buttons = buttons
    mouse_ring[mouse_ring_tail].dz = 0      # no-wheel path: legacy-compatible
    mouse_ring[mouse_ring_tail].aflag = 0   # relative event
    mouse_ring_tail = nxt
    return 0


def mouse_rx_push_dz(encoded: int32, dz: int32) -> int32:
    # Wheel-aware injection. Identical to mouse_rx_push (decode the packed
    # int32 into dx/dy/buttons) but ALSO carry a scroll-wheel delta dz in the
    # event's side-channel field. A USB HID mouse with a wheel uses this;
    # mouse_rx_push (dz implicitly 0) stays the legacy no-wheel entry point.
    # Returns 0 on success, -1 if the ring is full.
    nxt: uint64 = (mouse_ring_tail + 1) % MOUSE_RING_SIZE
    if nxt == mouse_ring_head:
        return -1
    dx_raw: uint64 = cast[uint64](encoded) & 0xFFFF
    dx: int32 = cast[int32](dx_raw)
    if (dx_raw & 0x8000) != 0:
        dx = cast[int32](dx_raw | 0xFFFFFFFFFFFF0000)
    dy_raw: uint64 = (cast[uint64](encoded) >> 24) & 0xFF
    dy: int32 = cast[int32](dy_raw)
    if (dy_raw & 0x80) != 0:
        dy = cast[int32](dy_raw | 0xFFFFFFFFFFFFFF00)
    buttons: uint32 = cast[uint32]((cast[uint64](encoded) >> 16) & 0xFF)
    mouse_ring[mouse_ring_tail].dx = dx
    mouse_ring[mouse_ring_tail].dy = dy
    mouse_ring[mouse_ring_tail].buttons = buttons
    mouse_ring[mouse_ring_tail].dz = dz
    mouse_ring[mouse_ring_tail].aflag = 0   # relative event
    mouse_ring_tail = nxt
    return 0


def mouse_rx_push_abs(ax: int32, ay: int32, buttons: uint32,
                      dz: int32) -> int32:
    # ABSOLUTE-pointer injection (USB HID tablet — the default pointer
    # device QEMU/libvirt/GNOME Boxes present to a VM). ax/ay are the
    # device's normalized absolute coordinates in 0..32767; the consumer
    # (devmouse_read -> the DE) scales them to the screen. Unlike the
    # relative pushes there is no packed-int32 decode here — the full
    # int32 coordinates go straight into the ring slot, and consumers
    # recover them via the mouse_rx_pop_aflag/ax/ay side channel.
    # Returns 0 on success, -1 if the ring is full.
    nxt: uint64 = (mouse_ring_tail + 1) % MOUSE_RING_SIZE
    if nxt == mouse_ring_head:
        return -1
    mouse_ring[mouse_ring_tail].dx = ax
    mouse_ring[mouse_ring_tail].dy = ay
    mouse_ring[mouse_ring_tail].buttons = buttons & 0xFF
    mouse_ring[mouse_ring_tail].dz = dz
    mouse_ring[mouse_ring_tail].aflag = 1   # absolute event
    mouse_ring_tail = nxt
    return 0


# --- Packet decode (called per-byte from the IRQ handler) --------------

def _sign_extend_9bit(byte_val: int32, sign_bit: int32) -> int32:
    # PS/2 mouse deltas are 9-bit signed: 8 bits of magnitude in
    # byte1/byte2 plus 1 sign bit in byte0. Reconstruct the signed
    # int via two's complement: if sign bit is set, OR in 0xFFFFFF00
    # to sign-extend into int32 negative space.
    if sign_bit != 0:
        return cast[int32](cast[uint32](byte_val) | cast[uint32](0xFFFFFF00))
    return byte_val & 0xFF


def auxmouse_process_byte(raw: int32):
    # State machine: 3-byte packet, advanced per-byte.
    b: int32 = raw & 0xFF

    if mouse_phase == 0:
        # Resync check: bit 3 of byte0 must be 1 for a valid packet.
        # If it isn't, we've lost packet alignment — drop this byte
        # and stay in phase 0. The next byte that has bit 3 set
        # restarts the assembly.
        if (cast[uint32](b) & PKT_ALWAYS_ONE) == 0:
            mouse_dropped = mouse_dropped + 1
            return
        mouse_b0 = b
        mouse_phase = 1
        return

    if mouse_phase == 1:
        mouse_b1 = b
        mouse_phase = 2
        return

    if mouse_phase == 2:
        # BUG 2: for IntelliMouse (4-byte) the Y byte is NOT the last byte —
        # the 4th byte carries the wheel Z. Hold byte2 and wait for byte3.
        if mouse_pkt_len >= 4:
            mouse_b2 = b
            mouse_phase = 3
            return
        # Standard 3-byte protocol: byte2 (Y) completes the packet here.
        _mouse_emit_packet(mouse_b0, mouse_b1, b, 0)
        mouse_phase = 0
        return

    # phase == 3 — IntelliMouse 4th byte: signed 8-bit wheel Z delta.
    # Only the low 4 bits are meaningful per spec, but the value is already a
    # signed two's-complement int8, so sign-extend the full byte.
    raw_z: int32 = b & 0xFF
    if (raw_z & 0x80) != 0:
        raw_z = cast[int32](cast[uint32](raw_z) | cast[uint32](0xFFFFFF00))
    # BUG #123/#141 wheel-inversion FIX: the PS/2 IntelliMouse wire convention
    # is raw Z = +1 when the wheel rolls TOWARD the user (scroll DOWN) and -1
    # when it rolls AWAY (scroll UP) — same sign Linux psmouse normalizes with
    # `input_report_rel(dev, REL_WHEEL, -(s8)packet[3])`. Our /dev/mouse
    # contract (sys/src/9/port/devmouse.ad) is dz>0 = wheel UP, so we NEGATE
    # the raw byte here at the source. Without this the whole stack (config
    # transform, hamui_scroll_apply n=cur-dz*step) is Standard-correct on paper
    # but every app scrolled backwards because the raw hardware sign was never
    # normalized to the contract.
    dz: int32 = 0 - raw_z
    _mouse_emit_packet(mouse_b0, mouse_b1, mouse_b2, dz)
    mouse_phase = 0


def _mouse_emit_packet(b0: int32, b1: int32, b2: int32, dz: int32):
    # Decode a completed 3- or 4-byte motion packet (b0=flags, b1=X, b2=Y)
    # plus an already-decoded wheel delta dz, and push it onto the ring.
    flags: uint32 = cast[uint32](b0)
    # Overflow: drop the entire packet. The mouse signalled it couldn't fit
    # the delta in 8 bits, so neither sign-extended value would represent the
    # real motion. Better to drop than deliver a wrong-by-256 cursor jump.
    if (flags & (PKT_X_OVER | PKT_Y_OVER)) != 0:
        mouse_dropped = mouse_dropped + 1
        return
    x_sign: int32 = 0
    y_sign: int32 = 0
    if (flags & PKT_X_SIGN) != 0:
        x_sign = 1
    if (flags & PKT_Y_SIGN) != 0:
        y_sign = 1
    dx: int32 = _sign_extend_9bit(b1, x_sign)
    # PS/2 mouse Y is positive-UP (away from the user). Most cursor consumers
    # want positive-DOWN screen coordinates; negate to match screen space.
    dy_raw: int32 = _sign_extend_9bit(b2, y_sign)
    dy: int32 = -dy_raw
    buttons: uint32 = flags & (PKT_BTN_LEFT | PKT_BTN_RIGHT | PKT_BTN_MIDDLE)
    _mouse_ring_push(dx, dy, buttons, dz)
    mouse_pkt_count = mouse_pkt_count + 1


# --- IRQ 12 handler ----------------------------------------------------

def auxmouse_irq_handler():
    # IRQ-context entry. The 8042 raises IRQ 12 on every AUX byte that
    # lands in the output buffer. We drain everything currently pending
    # (status OBF + AUX bit) — QEMU sometimes delivers two bytes for one
    # IRQ when the controller is slightly behind; drain-on-IRQ keeps the
    # state machine in sync.
    mouse_irq_count = mouse_irq_count + 1
    n: int32 = 0
    while (inb(I8042_STATUS_PORT) & I8042_STATUS_OBF) != 0:
        st: int32 = inb(I8042_STATUS_PORT)
        if (st & I8042_STATUS_AUX) == 0:
            # Keyboard byte slipped into the shared output buffer while we
            # were servicing the AUX IRQ. KEYBOARD LAG/LOSS FIX: the byte is
            # ALREADY consumed by this `inb` (the i8042 has a single 1-byte
            # output buffer shared by both ports), so DROPPING it here loses
            # a real keystroke — exactly the "some keys get lost" symptom the
            # user reported, worst during a mouse drag when IRQ 12 fires fast
            # and frequently races a keypress's scancode into OBF. Route it to
            # the keyboard state machine instead of discarding it, so the key
            # reaches the focused window's /keys ring. (The keyboard's own
            # IRQ 1 / poll path cannot recover a byte THIS handler has already
            # read out of the buffer.)
            kbyte: int32 = inb(I8042_DATA_PORT) & 0xFF
            atkbd_process_byte(kbyte)
        else:
            b: int32 = inb(I8042_DATA_PORT) & 0xFF
            auxmouse_process_byte(b)
        n = n + 1
        # Hard cap to prevent ISR storm if status bit ever sticks high.
        if n > 16:
            return


# --- Initialisation ----------------------------------------------------
#
# Sequence (mirrors Linux's i8042_aux_init() + psmouse_extensions()):
#
#   1. Enable the AUX port (controller cmd 0xA8).
#   2. Read the CCB, set IRQ12-enable (bit 1) and clear DISABLE-AUX
#      (bit 5), write it back.
#   3. (Optional) test AUX interface (cmd 0xA9; 0x00 = OK).
#   4. Reset the mouse (cmd 0xFF via 0xD4 prefix). Expect ACK + 0xAA
#      (BAT pass) + 0x00 (device ID).
#   5. Set sample rate to 100 (0xF3 0x64). Optional, conservative.
#   6. Enable streaming (0xF4 via 0xD4 prefix).
#   7. Register IRQ 12 handler at vector 0x45, route IOAPIC pin 12.

def auxmouse_init() -> int32:
    # Drain anything stale first. The keyboard self-test in atkbd_init()
    # already drained a few bytes; this is belt-and-braces for the AUX
    # channel.
    _i8042_drain()

    # Step 1: enable AUX port. No response byte expected.
    _i8042_cmd(I8042_CMD_ENABLE_AUX)

    # Step 2: read CCB, mask AUX bits, write back. The exact RMW is:
    #   ccb |= IRQ_AUX (enable IRQ12 delivery on AUX byte)
    #   ccb &= ~DISABLE_AUX (re-enable AUX clock if firmware masked it)
    _i8042_cmd(I8042_CMD_READ_CCB)
    if _i8042_wait_output_full() == 0:
        printk0("auxmouse: timeout reading controller-command-byte\n")
        return -1
    ccb: int32 = inb(I8042_DATA_PORT) & 0xFF
    ccb = (ccb | CCB_IRQ_AUX) & (~CCB_DISABLE_AUX)
    _i8042_cmd(I8042_CMD_WRITE_CCB)
    _i8042_write_data(ccb)
    printk0("auxmouse: i8042 second port enabled\n")

    # Step 3: (skipped) AUX interface self-test (cmd 0xA9). QEMU
    # always returns 0x00; on real hardware a non-zero is informative
    # but we'd still try to bring up the device. Save the I/O.

    # Step 4: reset the mouse. Mouse reset is the slowest device
    # command (it runs a BAT — Basic Assurance Test). We expect three
    # response bytes in sequence: ACK, BAT_OK (0xAA), DEVID (0x00).
    if _i8042_aux_write(MOUSE_CMD_RESET) == 0:
        printk0("auxmouse: reset write timeout (no device?)\n")
        return -1
    r_ack:  int32 = _i8042_aux_read()
    r_bat:  int32 = _i8042_aux_read()
    r_id:   int32 = _i8042_aux_read()
    if r_ack != MOUSE_ACK:
        printk1("auxmouse: reset NAK (got=0x%x)\n", cast[uint64](r_ack))
        return -1
    if r_bat != MOUSE_BAT_OK:
        printk1("auxmouse: BAT fail (got=0x%x)\n", cast[uint64](r_bat))
        return -1
    printk1("auxmouse: ID=0x%x (standard 3-byte PS/2 mouse)\n",
            cast[uint64](r_id & 0xFF))

    # Step 5: IntelliMouse wheel negotiation (the "magic knock"). Issue the
    # sample-rate sequence 200, 100, 80, then GET_DEVID (0xF2). A wheel mouse
    # answers 0x03 and from then on streams 4-byte packets whose 4th byte is
    # the signed Z wheel delta. A plain mouse answers 0x00 and stays 3-byte.
    # Every command/parameter ACKs independently; GET_DEVID returns the ID
    # byte AFTER its ACK.
    mouse_proto = 0
    mouse_pkt_len = 3
    if _aux_send_expect_ack(MOUSE_CMD_SET_RATE) != 0:
        _aux_send_expect_ack(200)
    if _aux_send_expect_ack(MOUSE_CMD_SET_RATE) != 0:
        _aux_send_expect_ack(100)
    if _aux_send_expect_ack(MOUSE_CMD_SET_RATE) != 0:
        _aux_send_expect_ack(80)
    if _aux_send_expect_ack(MOUSE_CMD_GET_DEVID) != 0:
        devid: int32 = _i8042_aux_read()
        if devid == MOUSE_DEVID_INTELLI:
            mouse_proto = 3
            mouse_pkt_len = 4
            printk0("auxmouse: IntelliMouse wheel enabled (4-byte packets)\n")
        else:
            printk1("auxmouse: no wheel (devid=0x%x), 3-byte protocol\n",
                    cast[uint64](devid & 0xFF))

    # Step 5b: set the operating sample rate to 100 Hz. Two-byte command:
    # 0xF3, 100. Failure here is non-fatal.
    if _aux_send_expect_ack(MOUSE_CMD_SET_RATE) != 0:
        _aux_send_expect_ack(100)

    # Step 6: enable streaming. From this point the mouse sends 3- or 4-byte
    # packets (per the negotiated protocol) whenever motion/buttons/wheel
    # change.
    if _aux_send_expect_ack(MOUSE_CMD_ENABLE) == 0:
        printk0("auxmouse: enable-streaming NAK\n")
        return -1
    printk0("auxmouse: streaming enabled\n")

    # Step 7: wire IRQ 12. IOAPIC pin 12 == ISA IRQ 12 (1:1 mapping
    # for ISA pins on every PC/AT-compatible chipset). Route to our
    # chosen vector 0x45 on LAPIC 0, then register the handler in the
    # 256-slot table from arch/x86/kernel/irq.ad.
    #
    # IRQ 12 is an ISA interrupt line — the i8042 AUX channel — so it
    # is EDGE-triggered, ACTIVE-HIGH, exactly like the keyboard's
    # IRQ 1. The generic ioapic_redirect() bakes in the PCI INTx
    # convention (level-triggered, active-low); on QEMU's lenient
    # IOAPIC that mismatch is tolerated, but on a real chipset IOAPIC
    # a level entry pointed at the i8042's brief edge pulse latches
    # Remote-IRR and never re-fires, and the inverted polarity reads
    # the idle-high ISA line as permanently deasserted. That is the
    # same class of bug that left the keyboard dead on real hardware.
    # ioapic_redirect_isa() programs edge/active-high — the wiring an
    # ISA IRQ actually needs — so the trackpad/mouse fires on real
    # silicon, not just under QEMU's polled-from-init path.
    register_irq_handler(cast[uint64](AUXMOUSE_IRQ_VECTOR),
                         auxmouse_irq_handler)
    ioapic_redirect_isa(AUXMOUSE_IOAPIC_PIN, AUXMOUSE_IRQ_VECTOR,
                        AUXMOUSE_LAPIC_ID)
    printk2("auxmouse: irq pin=%d vec=0x%x\n",
            cast[uint64](AUXMOUSE_IOAPIC_PIN),
            cast[uint64](AUXMOUSE_IRQ_VECTOR))

    mouse_initialized = 1

    # Run a small synthetic-packet self-test through the decoder so a
    # regression in _sign_extend_9bit or the phase machine is reported
    # even if QEMU never delivers real mouse packets in -no-reboot
    # mode. Mirrors the atkbd_self_test() shape.
    auxmouse_self_test()

    return 0


# --- Boot-time self test (no I/O ports, decoder only) ------------------
#
# Feed three synthesised packets into auxmouse_process_byte() and assert
# the resulting MouseEvents in the ring. This catches sign-extension /
# Y-flip / phase-machine regressions in CI without needing real mouse
# input from QEMU (which the -no-reboot console doesn't faithfully
# simulate).

mouse_selftest_pass: int32 = 0
mouse_selftest_fail: int32 = 0


def _st_reset():
    mouse_ring_head = 0
    mouse_ring_tail = 0
    mouse_phase = 0
    mouse_b0 = 0
    mouse_b1 = 0
    mouse_b2 = 0
    mouse_pkt_count = 0
    mouse_dropped = 0
    # Force 3-byte mode for the legacy decode cases below; the wheel case
    # flips it to 4-byte explicitly.
    mouse_pkt_len = 3


def _st_expect(dx_exp: int32, dy_exp: int32, btn_exp: uint32):
    # Compare via masked uint32 bit-patterns rather than signed int32
    # equality: the Adder compiler occasionally generates an
    # unsigned-extended load for struct-field reads that breaks
    # signed-equality on negative values (cousin of the M16.97
    # `cast[uint64](arr[i])` quirk noted in feedback_compiler_quirks).
    # Bit-pattern equality is sufficient because the stored field
    # IS the int32 two's-complement representation we want to test.
    if mouse_ring_head == mouse_ring_tail:
        mouse_selftest_fail = mouse_selftest_fail + 1
        printk0("auxmouse: self-test FAIL: ring empty (expected event)\n")
        return
    slot_dx: Ptr[uint32] = cast[Ptr[uint32]](&mouse_ring[mouse_ring_head].dx)
    slot_dy: Ptr[uint32] = cast[Ptr[uint32]](&mouse_ring[mouse_ring_head].dy)
    slot_bt: Ptr[uint32] = cast[Ptr[uint32]](&mouse_ring[mouse_ring_head].buttons)
    # Hoist into uint64 with an explicit 32-bit mask. Mirrors the
    # arp_lookup fix in feedback_compiler_quirks: makes the load
    # observable in a width the compiler reliably zero-extends, then
    # compares as plain uint64.
    ev_dx64: uint64 = cast[uint64](slot_dx[0]) & 0xFFFFFFFF
    ev_dy64: uint64 = cast[uint64](slot_dy[0]) & 0xFFFFFFFF
    ev_bt64: uint64 = cast[uint64](slot_bt[0]) & 0xFFFFFFFF
    exp_dx64: uint64 = cast[uint64](cast[uint32](dx_exp)) & 0xFFFFFFFF
    exp_dy64: uint64 = cast[uint64](cast[uint32](dy_exp)) & 0xFFFFFFFF
    exp_bt64: uint64 = cast[uint64](btn_exp) & 0xFFFFFFFF
    mouse_ring_head = (mouse_ring_head + 1) % MOUSE_RING_SIZE
    if ev_dx64 == exp_dx64 and ev_dy64 == exp_dy64 and ev_bt64 == exp_bt64:
        mouse_selftest_pass = mouse_selftest_pass + 1
    else:
        mouse_selftest_fail = mouse_selftest_fail + 1
        printk2("auxmouse: self-test FAIL: dx/dy got=0x%x/0x%x\n",
                ev_dx64, ev_dy64)
        printk2("auxmouse: self-test FAIL: dx/dy exp=0x%x/0x%x\n",
                exp_dx64, exp_dy64)


def _st_expect_dz(dx_exp: int32, dy_exp: int32, btn_exp: uint32,
                  dz_exp: int32):
    # Like _st_expect but ALSO checks the wheel dz field (BUG 2). Bit-pattern
    # comparison via the uint32 alias trick, same as _st_expect.
    if mouse_ring_head == mouse_ring_tail:
        mouse_selftest_fail = mouse_selftest_fail + 1
        printk0("auxmouse: self-test FAIL: ring empty (expected wheel event)\n")
        return
    slot_dx: Ptr[uint32] = cast[Ptr[uint32]](&mouse_ring[mouse_ring_head].dx)
    slot_dy: Ptr[uint32] = cast[Ptr[uint32]](&mouse_ring[mouse_ring_head].dy)
    slot_bt: Ptr[uint32] = cast[Ptr[uint32]](&mouse_ring[mouse_ring_head].buttons)
    slot_dz: Ptr[uint32] = cast[Ptr[uint32]](&mouse_ring[mouse_ring_head].dz)
    ev_dx64: uint64 = cast[uint64](slot_dx[0]) & 0xFFFFFFFF
    ev_dy64: uint64 = cast[uint64](slot_dy[0]) & 0xFFFFFFFF
    ev_bt64: uint64 = cast[uint64](slot_bt[0]) & 0xFFFFFFFF
    ev_dz64: uint64 = cast[uint64](slot_dz[0]) & 0xFFFFFFFF
    exp_dx64: uint64 = cast[uint64](cast[uint32](dx_exp)) & 0xFFFFFFFF
    exp_dy64: uint64 = cast[uint64](cast[uint32](dy_exp)) & 0xFFFFFFFF
    exp_bt64: uint64 = cast[uint64](btn_exp) & 0xFFFFFFFF
    exp_dz64: uint64 = cast[uint64](cast[uint32](dz_exp)) & 0xFFFFFFFF
    mouse_ring_head = (mouse_ring_head + 1) % MOUSE_RING_SIZE
    if ev_dx64 == exp_dx64 and ev_dy64 == exp_dy64 and ev_bt64 == exp_bt64 \
            and ev_dz64 == exp_dz64:
        mouse_selftest_pass = mouse_selftest_pass + 1
    else:
        mouse_selftest_fail = mouse_selftest_fail + 1
        printk2("auxmouse: self-test FAIL: wheel dz got=0x%x exp=0x%x\n",
                ev_dz64, exp_dz64)


def auxmouse_self_test():
    mouse_selftest_pass = 0
    mouse_selftest_fail = 0

    # Case 1: simple positive X delta. byte0=0x08 (always-1 only),
    # byte1=+10 (0x0A), byte2=0 (no Y motion). Y is then negated by
    # our convention to match screen-down semantics: dy stays 0.
    _st_reset()
    auxmouse_process_byte(0x08)
    auxmouse_process_byte(0x0A)
    auxmouse_process_byte(0x00)
    _st_expect(10, 0, 0)

    # Case 2: negative X delta. byte0 = 0x08 | X_SIGN (0x18),
    # byte1 = 0xF6 (which is 246 unsigned, -10 in 9-bit signed).
    # Expected dx = -10, dy = 0.
    _st_reset()
    auxmouse_process_byte(0x18)
    auxmouse_process_byte(0xF6)
    auxmouse_process_byte(0x00)
    _st_expect(-10, 0, 0)

    # Case 3: positive Y delta (mouse moved AWAY from user). Protocol
    # encodes +5, we flip to -5 for screen-down semantics. byte0=0x08
    # (no sign), byte1=0, byte2=5.
    _st_reset()
    auxmouse_process_byte(0x08)
    auxmouse_process_byte(0x00)
    auxmouse_process_byte(0x05)
    _st_expect(0, -5, 0)

    # Case 4: left button held + small motion. byte0 = ALWAYS_ONE |
    # BTN_LEFT = 0x09, byte1 = 1, byte2 = 1 (PS/2 Y up -> screen -1).
    _st_reset()
    auxmouse_process_byte(0x09)
    auxmouse_process_byte(0x01)
    auxmouse_process_byte(0x01)
    _st_expect(1, -1, PKT_BTN_LEFT)

    # Case 5: all three buttons held, no motion.
    _st_reset()
    auxmouse_process_byte(0x0F)        # ALWAYS_1 | L | R | M
    auxmouse_process_byte(0x00)
    auxmouse_process_byte(0x00)
    _st_expect(0, 0, PKT_BTN_LEFT | PKT_BTN_RIGHT | PKT_BTN_MIDDLE)

    # Case 6: resync. A spurious byte WITHOUT the always-1 bit should
    # be dropped, and the next valid byte0 (with always-1) starts a
    # fresh packet. Feed: 0x00 (bogus byte0 — bit 3 clear), then a
    # full valid packet.
    _st_reset()
    auxmouse_process_byte(0x00)        # dropped (no always-1)
    auxmouse_process_byte(0x08)        # real byte 0
    auxmouse_process_byte(0x03)        # X = +3
    auxmouse_process_byte(0x00)        # Y = 0 -> screen-dy = 0
    _st_expect(3, 0, 0)

    # Case 7: overflow flag set -> drop entire packet. After dropping,
    # next valid packet must still parse cleanly.
    _st_reset()
    auxmouse_process_byte(0x48)        # ALWAYS_1 | X_OVER
    auxmouse_process_byte(0x7F)
    auxmouse_process_byte(0x00)
    # Ring must be empty here.
    if mouse_ring_head != mouse_ring_tail:
        mouse_selftest_fail = mouse_selftest_fail + 1
        printk0("auxmouse: self-test FAIL: overflow packet not dropped\n")
    # Now a clean follow-up packet, dx=2.
    auxmouse_process_byte(0x08)
    auxmouse_process_byte(0x02)
    auxmouse_process_byte(0x00)
    _st_expect(2, 0, 0)

    # Case 8 (BUG 2 / #123 wheel-sign): IntelliMouse 4-byte packet with a
    # wheel notch. In 4-byte mode byte2 is held and byte3 carries the signed
    # Z delta. The raw PS/2 wire sign is +1 = wheel DOWN (toward the user);
    # the driver NEGATES it to the /dev/mouse contract (dz>0 = wheel UP). Feed
    # byte0=0x08 (always-1), X=+4, Y=0, raw Z=+1 (physical wheel DOWN). Expect
    # dx=4, dy=0, dz=-1 (contract: negative = down).
    _st_reset()
    mouse_pkt_len = 4                   # negotiate 4-byte IntelliMouse
    auxmouse_process_byte(0x08)         # flags: always-1
    auxmouse_process_byte(0x04)         # X = +4
    auxmouse_process_byte(0x00)         # Y = 0
    auxmouse_process_byte(0x01)         # raw Z = +1 (wheel DOWN on the wire)
    _st_expect_dz(4, 0, 0, 0 - 1)

    # Case 9: raw Z = -1 (0xFF) = physical wheel UP; negated to contract dz=+1.
    _st_reset()
    mouse_pkt_len = 4
    auxmouse_process_byte(0x08)
    auxmouse_process_byte(0x00)
    auxmouse_process_byte(0x00)
    auxmouse_process_byte(0xFF)         # raw Z = -1 (wheel UP on the wire)
    _st_expect_dz(0, 0, 0, 1)

    # Drain remaining (shouldn't be any).
    while mouse_ring_head != mouse_ring_tail:
        mouse_ring_head = (mouse_ring_head + 1) % MOUSE_RING_SIZE

    # Restore the phase machine to a clean state for real packets, and the
    # packet length to whatever the device actually negotiated (the wheel
    # cases above forced 4-byte for testing).
    mouse_phase = 0
    if mouse_proto >= 3:
        mouse_pkt_len = 4
    else:
        mouse_pkt_len = 3
    mouse_pkt_count = 0
    mouse_dropped = 0

    if mouse_selftest_fail == 0:
        printk1("auxmouse: self-test PASS (%d cases)\n",
                cast[uint64](mouse_selftest_pass))
    else:
        printk1("auxmouse: self-test FAIL (%d failures)\n",
                cast[uint64](mouse_selftest_fail))
